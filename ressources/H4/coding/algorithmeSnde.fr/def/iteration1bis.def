choicecnt=0
conditioncnt=0
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!record 1 of langage

val6=$(tmp0)
tmp0=!randitem 2,3,4

val7=$[rint($(tmp0))]
tmp0=!record $val7 of langage

tmp=!trim $(tmp0)
val8=!translate internal $	\
$ to ;; in $tmp
tmp0=!item 5 of $val8

val9=$(tmp0)
tmp0=!item 7 of $val8

val10=$(tmp0)
tmp0=!item 8 of $val8

val11=$(tmp0)
tmp0=!item 9 of $val8

val12=$(tmp0)
tmp0=!item 10 of $val8

val13=$(tmp0)
tmp0=!item 11 of $val8

val14=$(tmp0)
tmp0=!item 12 of $val8

val15=$(tmp0)
val16=&larr;
val17=&rarr;
val18=&le;
tmp0=!randint 1, 4

val19=$[rint($(tmp0))]
tmp0=!item $val19 of X,A,U,P

val20=$(tmp0)
tmp0=!item $val19 of Y,B,V,Q

val21=$(tmp0)
tmp=!nonempty items N,I,J

tmp0=!randitem $tmp
val22=$(tmp0)
tmp0=!randint -10, 10

val23=$[rint($(tmp0))]
tmp0=!randint 2, 8

val24=$[rint($(tmp0))]
tmp0=!randitem 0,1

val25=$[rint($(tmp0))]
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
tmp1=!randint 1, 4

val26=$[rint($(tmp0)*$(tmp1))]
tmp=!trim $val23 $val17 $val20, $val26 $val17 $val21, $val10 $val22 $val11 $val25 $val12 $val24, $val22 + 1 $val17 $val22, $val20 + $val21 $val17 $val20, $val13, $val9 $val20	$val23 $val17 $val20, $val26 $val17 $val21, $val25 $val17 $val22, $val14 $val22 $val18 $val24, $val20 + $val21 $val17 $val20, $val22 + 1 $val17 $val22, $val15, $val9 $val20	$val23 $val17 $val20, $val26 $val17 $val21, $val25 $val17 $val22, $val14 $val22 $val18 $val24, $val20 + $val21 $val17 $val20, $val22 + 1 $val17 $val22, $val15, $val9 $val21	$val23 $val17 $val20, $val26 $val17 $val21, $val25 $val17 $val22, $val14 $val22 $val18 $val24, $val20 + $val21 $val17 $val20, $val22 + 1 $val17 $val22, $val15, $val9 $val22	$val23 $val17 $val20, $val26 $val17 $val21, $val10 $val22 $val11 $val25 $val12 $val24, $val22 + 2 $val17 $val22, $val20 + $val21 $val17 $val20, $val13, $val9 $val20	$val23 $val17 $val20, $val26 $val17 $val21, $val10 $val22 $val11 $val25 $val12 $val24, $val22 + 2 $val17 $val22, $val20 + $val21 $val17 $val20, $val13, $val9 $val22	
val27=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val27

tmp0=!rowcnt $tmp
val28=$[rint($(tmp0))]
tmp0=!randint $val28

val29=$[rint($(tmp0))]
tmp=!translate internal $	$ to ; in $val27

tmp=!row $val29 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val30=$(tmp0)
tmp0=!replace internal , by </td></tr><tr><td> in $val30

val31=$(tmp0)

!ifval $val29>4
t_=!replace internal \( by ( in 1+floor(($val24-$val25)/2)
tmp0=!exec pari $t_

val32=$[rint($(tmp0))]
!else
val32=$[rint($val24-$val25+1)]
!endif

!ifval $val29>4
val33=$[rint( $val25+2*$val32)]
!else
val33=$[rint( $val24+1)]
!endif
val34=$[rint($val23+($val32*$val26))]

!ifval $val29<3 or $val29==5
val35=$[rint($val34)]
!endif

!ifval $val29==3
val35=$[rint($val26)]
!endif

!ifval $val29==4 or $val29==6
val35=$[rint($val33)]
!endif
replytype1=numeric
replyname1=
replygood1=$[$val35]
question=__EXECUTED_1692754_EXERCISE__
help=!nosubst $val6


!goto stat

!exit

:question
$()	On exÈcute l'algorithme suivant :	<div class="wimscenter">	<table style="text-align:left; background-color:lightblue;" cellpadding=5><tr><td>	$val31	</td></tr></table>	</div>	Quand cet algorithme a terminÈ, il affiche la valeur :  
