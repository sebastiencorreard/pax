!set title=Echanger deux variables
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Sébastien, Dumortier
email=sdumortier@ac-limoges.fr
language=fr
computeanswer=no
precision=10000
leftrange=1.000000
rightrange=100.000000

ansorder=r,r,r
varcnt=12
prevarcnt=11
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!record 1 of langage

val6=$(tmp0)
val7=A,X,couleur1,nb1,abscisse,Pierre,Taille,déficit,NbFilles
val8=B,Y,couleur2,nb2,ordonnée,Paul,Poids,recette,NbGarçons
tmp0=!shuffle C,D,E,F,G,H,I,J,K,L,M,N,P,Q,R,S,T,U,V,W,Z

val9=$(tmp0)
tmp0=!randint 1, 9

val10=$[rint($(tmp0))]
tmp0=!item $val10 of $val7

val11=$(tmp0)
tmp0=!item $val10 of $val8

val12=$(tmp0)
tmp0=!shuffle $val11,$val12

val13=$(tmp0)
tmp0=!item 1 of $val13

val14=$(tmp0)
tmp0=!item 2 of $val13

val15=$(tmp0)
tmp0=!item 1 of $val9

val16=$(tmp0)
replytype1=dragfill
replyname1=
replygood1=$val16 = $val11;$val11 = $val12+$val16;Afficher $val11
replytype2=dragfill
replyname2=
replygood2=$val11 = $val12;$val16 = $val11+$val12;Afficher $val12
replytype3=dragfill
replyname3=
replygood3=$val12 = $val16;$val12 = $val11+$val16;Afficher $val16
question=__EXECUTED_1692754_EXERCISE__
help=!nosubst $val6

solution=!nosubst  L'échange de deux variables nécessite l'utilisation d'une troisième variable. On commence par y stocker l'une des variables à échanger. Cette dernière peut alors prendre la valeur de l'autre, qui pourra enfin prendre la valeur de la variable d'échange.


!goto stat

!exit

:question
$()	<p>Quelle série de trois instructions faut-il écrire	pour échanger les contenus des variables $val14 et $val15 ?	</p>		 
!read oef/embed.phtml r1,150x50x1 
$()	 
!read oef/embed.phtml r2,150x50x1 
$()	 
!read oef/embed.phtml r3,150x50x1 
$()	
$()
!exit

:hint
$()
$()
!exit

:help
$()$val6
$()
!exit

:solution
$() L'échange de deux variables nécessite l'utilisation d'une troisième variable. On commence par y stocker l'une des variables à échanger. Cette dernière peut alors prendre la valeur de l'autre, qui pourra enfin prendre la valeur de la variable d'échange.
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,14,15
embedcnt=3
