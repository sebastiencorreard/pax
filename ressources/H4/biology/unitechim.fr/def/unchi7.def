val20=$[rint($(tmp0))]

!ifval $val20 >1 
tmp=!nonempty items $val17

tmp0=!randitem $tmp
val17= $(tmp0)
!endif
val18=$val17,$(val18[1..$val7-1])
tmp0=!shuffle $val18

val18=$(tmp0)
!endif
