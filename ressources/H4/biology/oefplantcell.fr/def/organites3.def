!set title=Eléments d'une cellule végétale 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=F.,Paris; Sophie,Lemaire
email=sophie.lemaire@math.u-psud.fr
oefcss=<style> .navy {color:#000080} </style>

ansorder=r
varcnt=7
prevarcnt=6
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=les chloroplastes,le cytoplasme,la membrane plasmique,les mitochondries,le noyau,la paroi cellulosique,les vacuoles
tmp=!trim organites responsables de la photosynthèse	est constitué d'un milieu plus ou moins homogène dans lequel baignent les organites	enveloppe qui délimite le compartiment intracellulaire	siège de la respiration cellulaire permettant la production d’énergie utilisable pour le métabolisme	contient la majeure partie de l'ADN organisé en chromosomes	structure de soutien des cellules végétales	poches incluses dans le cytoplasme limitées par une membrane et remplies de liquide (eau, diverses substances dissoutes et parfois des pigments)	
val7=!translate internal $	\
$ to ;; in $tmp
tmp0=!itemcnt $val6

val8=$[rint($(tmp0))]
tmp0=!randint 1, $val8

val9=$(tmp0)
val10=$(val7[$val9;1])
val11=$val9
replytype1=radio
replyoption1=noanalyzeprint 
replyname1=
replygood1=$val11;$val6
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Lequel de ces composants d'une cellule végétale correspond à la définition suivante ?	<div class="wimscenter bold navy">$val10</div>	<ul> 
!for m_i=1 to $val8 
$()	<li> 
!read oef/embed.phtml reply1,\i 
$()</li> 
!next
$()</ul>	
$()
!exit

