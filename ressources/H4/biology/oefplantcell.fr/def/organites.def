!set title=Eléments d'une cellule végétale 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=F.,Paris;Sophie,Lemaire
email=sophie.lemaire@math.u-psud.fr
oefcss=<style> .navy {color:#000080} </style>

ansorder=r
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!trim au noyau,4,1,3,5,6	à une mitochondrie,3,1,4,5,6	à une vacuole,6,1,2,3,4	à un chloroplaste,1,4,5,6	à la paroi cellulosique,5,1,2,3	à la membrane plasmique,2,1,3,5	
val6=!translate internal $	\
$ to ;; in $tmp
tmp=!trim siège de la photosynthèse	enveloppe qui délimite le compartiment intracellulaire	siège de la respiration cellulaire permettant la production d’énergie utilisable pour le métabolisme	contient la majeure partie de l'ADN organisé en chromosomes	structure de soutien des cellules végétales	poche incluse dans le cytoplasme limitée par une membrane et remplie de liquide	(eau, diverses substances dissoutes et parfois des pigments)	
val7=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val6

tmp0=!rowcnt $tmp
val8=$[rint($(tmp0))]
tmp0=!randint 1, $val8

val9=$(tmp0)
val10=$(val6[$val9;1])
val11=$(val7[$(val6[$val9;2..-1]);1])
tmp0=!itemcnt $(val6[$val9;2..-1])

val12=$[rint($(tmp0))]
replytype1=radio
replyoption1=shuffle noanalyzeprint 
replyname1=
replygood1=1;$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Parmi les assertions suivantes sélectionner celle qui correspond	<span class="bold navy">$val10</span> :	<ul> 
!for m_i=1 to $val12 
$()	<li> 
!read oef/embed.phtml reply1,\i 
$()</li> 
!next
$()	</ul>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=10,12
embedcnt=1
