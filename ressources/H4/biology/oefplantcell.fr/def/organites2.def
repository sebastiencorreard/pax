!set title=Spécificités d'une cellule végétale
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=F.,Paris;Sophie,Lemaire
email=sophie.lemaire@math.u-psud.fr
oefcss=<style type="text/css"> .navy {color:#000080} </style>

ansorder=r
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=les chloroplastes,le cytoplasme,la membrane plasmique,les mitochondries,le noyau,la paroi cellulosique,une grande vacuole
tmp0=!randint 1, 2

val7=$(tmp0)
!if $val7=1 
val8=spécifiques à une cellule chlorophyllienne
val9=1,6,7
!else
val8=qui existent aussi bien dans les cellules végétales que dans les cellules animales
val9=2,3,4,5
!endif
val10=$(val6[$val7;2])
replytype1=checkbox
replyoption1=shuffle noanalyzeprint 
replyname1=
replygood1=$val9;$val6
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Dans la liste suivante sélectionner les éléments	<span class="bold navy">$val8</span> ?	<ul> 
!for m_i=1 to 7 
$()	<li> 
!read oef/embed.phtml reply1,\i 
$()</li> 
!next
$()</ul>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=8
embedcnt=1
