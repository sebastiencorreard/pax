!set title=Fraction, décimal, pourcentage
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille,Douriez
email=cyrille.douriez@ac-amiens.fr
keywords=skill_calculate,percents
oefdescription=Cet exercice peut ętre résolu sans utiliser la calculatrice.
oefobservation=Conseillé sans calculatrice
precision=10000000

ansorder=r,r
varcnt=4
prevarcnt=3
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 15

tmp1=!randint 1, 20

tmp=!nonempty items 5*$(tmp0),4*$(tmp1)

tmp2=!randitem $tmp
val6=$[rint($(tmp2))]
t_=!rawmath $val6/100
val7=!exec pari print($t_)
val8=$[$val7]
replyoption1=comma absolute 
replyname1=
replygood1=$val8
replyoption2=comma absolute 
replyname2=
replygood2=$val6
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<p>Écrire sous forme décimale, puis sous forme d'un pourcentage	  le nombre rationnel 
!insmath $val7 
$():</p>	<div>
!insmath $val7
$()= 
!read oef/embed.phtml r1,2 
$()= 
!read oef/embed.phtml r2,2 
$()&#8239;%.</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7
embedcnt=2
