!set title=Valeur absolue : distance et intervalle 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez;Bruno, Mifsud
email=cyrille.douriez@ac-amiens.fr;communaute.mutuwims@laposte.net
keywords=absolute_value,order,inequalities,intervals
language=fr

ansorder=r
varcnt=9
prevarcnt=8
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint -10, 20

val6=$[rint($(tmp0))]
tmp0=!randint 1, 20

val7=$[rint($(tmp0))]
val8=$[rint($val6-$val7)]
val9=$[rint($val6+$val7)]
val10=!rawmath x-$val6
val11=&#91;,&#93;,$val8,$val9,$val7,$val6
val12=&#91;,$val8,&#59;,$val9,&#93;

!ifval $val8>0
val13=$val8
!else
val13=($val8)
!endif
replytype1=clickfill
replyname1=
replygood1=$val12;$val11
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()
!insmath |$val10| \le $val7
$() Èquivaut ‡ 
!insmath x \in 
$() 
!read oef/embed.phtml r1 
$().	<div class="wims_instruction">Faire glisser les Ètiquettes pour Ècrire le bon intervalle.</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$() <p>Par dÈfinition, on a : 
!insmath  | x-m | \le 6 \Leftrightarrow  x \in \lbrack m-6 ; m+6 \rbrack
$().</p>	<p>Ici : 
!insmath m=$val6
$() ainsi : 
!insmath  | $val10 | \le $val7 \Leftrightarrow  x \in \lbrack $val6-$val7 ; $val6+$val7 \rbrack = \lbrack $val8 ; $val9 \rbrack 
$()</p>
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,10
embedcnt=1
