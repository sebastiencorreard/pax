!set title=Rationnels : fractionnaire -> dťcimal
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
keywords=skill_calculate,rational_number,fraction
oefdescription=Cet exercice peut Ítre rťsolu sans utiliser la calculatrice.
oefobservation=Conseillť sans calculatrice
precision=10000000

ansorder=r
varcnt=7
prevarcnt=6
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!trim 4,2,1,3	5,4,1,2,3,4	8,4,1,3,5,7	10,5,1,3,5,7,9	20,8,1,3,7,9,11,13,17,19	40,15,1,7,9,11,13,17,19,21,23,27,29,31,33,37,39
val6=!translate internal $	\
$ to ;; in $tmp
tmp0=!randint 1, 6

val7=$[rint($(tmp0))]
val8=$[rint($(val6[$val7;1]))]
tmp0=!randint 3, (2+$(val6[$val7;2]))

val9=$[rint($(tmp0))]
tmp0=!randitem -1,1

tmp1=!randint -3, 9

val10=$[rint($(val6[$val7;$val9])*$(tmp0)+$(tmp1)*$val8)]
val11=$[$val10/$val8]
replytype1=raw
replyoption1=comma absolute 
replyname1=\(\frac{$val10}{$val8})
replygood1=$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Donner l'ťcriture dťcimale de 
!insmath \frac{$val10}{$val8}
$().
$()
!exit

