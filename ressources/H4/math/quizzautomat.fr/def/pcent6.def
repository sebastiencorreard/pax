!set title=Pourcentages : proportion de proportion
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
keywords=skill_calculate,percents
oefdescription=Cet exercice peut ętre résolu sans utiliser la calculatrice.
oefobservation=Conseillé sans calculatrice
precision=1000

ansorder=r
varcnt=6
prevarcnt=5
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 9

val6=$[rint(10*$(tmp0))]
tmp0=!randint 1, 9

val7=$[rint(10*$(tmp0))]
val8=$[rint($val6*$val7)]
val9=$[rint($val8/100)]
val10=$[$val8/10000]
replytype1=numeric
replyname1=
replygood1=$[$val9]
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()$val6&#8239;% de $val7&#8239;% font  
!read oef/embed.phtml r1,4 
$()&#8239;%.
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()$val6&#8239;% de $val7&#8239;% font 
!insmath \frac{$val6}{100}\times \frac{$val7}{100}=\frac{$val8}{10000}=$val10=$val9&#8239; \%
$().
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,10
embedcnt=1
