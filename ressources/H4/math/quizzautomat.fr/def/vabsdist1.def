!set title=Valeur absolue : distance et intervalle 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez;Bruno, Mifsud
email=cyrille.douriez@ac-amiens.fr;communaute.mutuwims@laposte.net
keywords=absolute_value,order,inequalities,intervals
language=fr
computeanswer=yes
precision=1000

ansorder=r
varcnt=7
prevarcnt=6
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint -10, 20

val6=$[rint($(tmp0))]
tmp0=!randint 1, 30

val7=$[rint($(tmp0))]
val8=$[rint($val6-$val7)]
val9=$[rint($val6+$val7)]
val10=!rawmath x-$val6

!ifval $val8>=0
val11=$val8
!else
val11=($val8)
!endif
replytype1=numeric
replyname1=
replygood1=$[$val7]
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()
!insmath  x \in\lbrack $val8 ; $val9 \rbrack
$() Èquivaut ý :   
!read oef/special.phtml mathmlinput [| $val10 | \le \reply1],5,noanswer	 reply 1	  
$()
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$() <p>Par dÈfinition, on a : 
!insmath  x \in \lbrack a ; b \rbrack \Leftrightarrow | x-m | \le \frac{b-a}{2} 
$(), o˘ 
!insmath m
$() est la moyenne de 
!insmath a
$() et de 
!insmath b
$().</p>	<p>Ici :
!insmath  x \in\lbrack $val8 ; $val9 \rbrack
$() Èquivaut ý :  
!insmath | $val10 | \le \frac{$val9- $val11}{2}=$val7
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,8,9,10,11
embedcnt=1
