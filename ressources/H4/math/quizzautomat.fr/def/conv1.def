!set title=Conversion litre-cube
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
keywords=conversion,volume
oefdescription=Cet exercice peut Ítre rťsolu sans utiliser la calculatrice.
oefobservation=Conseillť sans calculatrice

ansorder=r,r
varcnt=13
prevarcnt=12
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 6

val6=$[rint($(tmp0))]
tmp0=!randint 1, 4

val7=$[rint($(tmp0))]
val8=mL,cL,dL,L,daL,hL
val9=mm,cm,dm,m
tmp0=!randint 2, 1200

val10=$[rint($(tmp0))]
val11=$[$val10*10^($val6-4)]
val12=$[$val11*10^(3*(3-$val7))]
tmp0=!randint 1, 6

val13=$[rint($(tmp0))]
tmp0=!randint 1, 4

val14=$[rint($(tmp0))]
tmp0=!randint 2, 999

val15=$[rint($(tmp0))]
val16=$[$val15*10^(3*($val14-3))]
val17=$[$val16*10^(4-$val13)]
replytype1=formal
replyname1=
replygood1=$val12
replytype2=formal
replyname2=
replygood2=$val17
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Convertir : $val10 $(val8[$val6]) =  
