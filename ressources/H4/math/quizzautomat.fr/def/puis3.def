!set title=Millions et milliards
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
keywords=skill_calculate,number
oefdescription=Cet exercice peut ętre résolu sans utiliser la calculatrice.
oefobservation=Conseillé sans calculatrice

ansorder=r
varcnt=5
prevarcnt=4
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items 0,1

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!randint 2, 95

val7=$[rint($(tmp0)*10)]

!ifval ($val6=0)
tmp0=!randint 5, 9

val8=$[rint( $(tmp0))]
!else
tmp1=!randint 8, 12

val8=$[rint($(tmp1))]
!endif

!ifval ($val6=0)
val9=$[rint( $val7*10^($val8-6))]
!else
val9=$[rint($val7*10^($val8-9))]
!endif
replytype1=formal
replyname1=
replygood1=$val9
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Compléter : 
!insmath $val7 \times 10^$val8=
$() 
!read oef/embed.phtml r1,4 
$()
!if $val6=0 
$()millions 
!else
$() milliards 
!endif
$().
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8
embedcnt=1
