!set title=Conversions d'unités
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
keywords=conversion,volume,length
language=fr
computeanswer=no
oefdescription=Cet exercice peut ętre résolu sans utiliser la calculatrice.
oefobservation=Conseillé sans calculatrice
precision=100000

ansorder=r
varcnt=25
prevarcnt=24
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=mm, cm, dm, m, dam, hm, km 
val7=mL, cL, dL, L, daL, hL, m<sup>3</sup> 
val8=cm<sup>3</sup>, cL, dL, dm<sup>3</sup>, daL, hL, m<sup>3</sup> 
tmp0=!randitem 1,2,3

val9=$[rint($(tmp0))]
tmp0=!randitem 1,2

val10=$[rint($(tmp0))]
tmp0=!randitem 1,1,1,1,2,3

val11=$[rint($(tmp0))]
!if $val11 = 1 
!if $val10 = 1 
tmp0=!randint 10, 300

tmp1=!randitem 1, 0.1, 0.01, 0.001

val12=$[$(tmp0)*$(tmp1)]
tmp0=!randint 4, 7

val13=$[rint($(tmp0))]
tmp0=!randint 1, (4-$val9)

val14=$[rint($val13 -$(tmp0))]
!else
tmp0=!randint 10, 300

tmp1=!randitem 1, 0.1, 0.01

val12=$[$(tmp0)*$(tmp1)]
tmp0=!randint 1, 4

val13=$[rint($(tmp0))]
tmp0=!randint 1, (4-$val9)

val14=$[rint($val13 +$(tmp0))]
!endif

!ifval $val9=1
val15=$(val6[$val13])
!else
val15=$(val6[$val13])<sup>$val9</sup>
!endif

!ifval $val9=1
val16=$(val6[$val14])
!else
val16=$(val6[$val14])<sup>$val9</sup>
!endif
val17=$[10^(($val13-$val14)*$val9)]
!endif
!if $val11 >= 2 
!if $val10 = 1 
tmp0=!randint 10, 300

tmp1=!randitem 1, 0.1, 0.01, 0.001

val12=$[$(tmp0)*$(tmp1)]
tmp0=!randint 4, 7

val13=$[rint($(tmp0))]
tmp0=!randint 1, 3

val14=$[rint($val13 -$(tmp0))]
!else
tmp0=!randint 10, 300

tmp1=!randitem 1, 0.1, 0.01

val12=$[$(tmp0)*$(tmp1)]
tmp0=!randint 1, 4

val13=$[rint($(tmp0))]
tmp0=!randint 1, 3

val14=$[rint($val13 +$(tmp0))]
!endif

!ifval ($val11=2)
val15= $(val7[$val13])
!else
val15=$(val8[$val13])
!endif

!ifval ($val11=2)
val16= $(val7[$val14])
!else
val16=$(val8[$val14])
!endif
val17=$[10^($val13-$val14)]
!endif
replytype1=numeric
replyoption1=comma 
replyname1=
replygood1=$[$val12*$val17]
question=__EXECUTED_1692754_EXERCISE__
solution=!nosubst  


!goto stat

!exit

:question
$()	Convertir : <div>	 $val12 $val15 =  
!read oef/embed.phtml r1,5 
$() $val16	 </div>	
$()
!exit

