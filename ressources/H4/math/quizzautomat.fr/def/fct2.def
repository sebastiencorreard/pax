!set title=Appartenance à une courbe
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
language=fr
computeanswer=yes
precision=1000
computeanswer=yes

ansorder=r
varcnt=17
prevarcnt=16
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 10

tmp1=!randitem -1,1

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -10, 10

val7=$[rint($(tmp0))]
tmp0=!randint -10, 10

val8=$[rint($(tmp0))]

!ifval ($val8<0)
tmp0=!randint -15, -1

val9=$[rint( $(tmp0))]
!else
tmp1=!randint 1, 15

val9=$[rint($(tmp1))]
!endif
t_=!replace internal \( by ( in $val6*x+$val9
tmp0=!exec maxima $t_

val10=!rawmath $(tmp0)
t_=!replace internal \( by ( in $val6*x^2+$val7*x+$val9
tmp0=!exec maxima $t_

val11=!rawmath $(tmp0)
t_=!replace internal \( by ( in $val6*x^3+$val7*x^2+$val8*x+$val9
tmp0=!exec maxima $t_

val12=!rawmath $(tmp0)
t_=!replace internal \( by ( in ($val6*x+$val7)/($val8*x^2+$val9)
tmp0=!exec maxima $t_

val13=!rawmath $(tmp0)
val14=$val10,$val11,$val12,$val13
tmp0=!randint 1, 4

val15=$[rint($(tmp0))]
tmp0=!texmath $(val14[$val15])

val16=$(tmp0)
tmp0=!randint -10, 10

val17=$[rint($(tmp0))]
evaltmp=$(val14[$val15])

evaltmp=!mathsubst x=($val17) in $evaltmp
tmp0=($evaltmp)
t_=!rawmath $(tmp0)
val18=!exec pari print($t_)
tmp0=!randitem 1,2

val19=$[rint($(tmp0))]

!ifval ($val19=1)
t_=!rawmath  $val18
val20=!exec pari print($t_)
!else
tmp0=!randitem -2,-1,1,2

t_=!rawmath $val18+$(tmp0)
val20=!exec pari print($t_)
!endif
!readproc slib/utilities/mathcalc 
tmp0=$slib_out
val21=$(tmp0)
replytype1=menu
replyname1=
replygood1=$val19;appartient,n'appartient pas,aucune idée
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Soit 
!insmath f
$() la fonction définie pour tout réel x par : 	<div class="wimscenter">
!insmath f(x)=$val16
$()</div>	Le point A($val17 ; $val20)  
!read oef/embed.phtml r1,8 
$() à la courbe représentative de 
!insmath f
$().<br/>	Calculatrice disponible en cliquant sur l'image : $val21
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()En remplaçant 
!insmath x
$() par 
!insmath $val17
$() dans l'expression de 
!insmath f
$() :	
!insmath f(x_A)=f($val17)=$val18
$()
!if $val19=1 
$()
!insmath =y_A
$() 
!else
$() 
!insmath \neq y_A
$() 
!endif
$() donc A 
!if $val19=1 
$()appartient 
!else
$() n'appartient pas 
!endif
$() à la courbe représentative de 
!insmath f
$().
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

