!set title=Pourcentages : coefficient multiplicateur
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
keywords=skill_calculate,percents
precision=10000000
oefdescription=Cet exercice peut être résolu sans utiliser la calculatrice.
oefobservation=Conseillé sans calculatrice

ansorder=r,r
varcnt=7
prevarcnt=6
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 99

val6=$[rint($(tmp0))]
tmp0=!randint 1, 99

val7=$[rint($(tmp0))]
val8=$[1+$val6/100]
val9=$[1-$val7/100]
tmp0=!randitem 1,2

val10=$[rint($(tmp0))]
tmp=!trim $val8,$val9	$val9,$val8
val11=!translate internal $	\
$ to ;; in $tmp
replytype1=numeric
replyoption1=comma absolute 
replyname1=
replygood1=$[$(val11[$val10;1])]
replytype2=numeric
replyoption2=comma absolute 
replyname2=
replygood2=$[$(val11[$val10;2])]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()
!if $val10=1 
$()<ol><li>Augmenter une valeur de $val6&#8239;% revient à la multiplier par  
!read oef/embed.phtml r1,3 
$().	</li><li>Diminuer une valeur de $val7&#8239;% revient à la multiplier par  
!read oef/embed.phtml r2,3 
$().</li></ol> 
!else
$()	 <ol><li>Diminuer une valeur de $val7&#8239;% revient à la multiplier par  
!read oef/embed.phtml r1,3 
$().	</li><li>Augmenter une valeur de $val6&#8239;% revient à la multiplier par  
!read oef/embed.phtml r2,3 
$().</li></ol> 
!endif
$()	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,10
embedcnt=4
