!set title=Signe graphiquement
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=Cyrille.douriez@ac-amiens.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100
oefcss= <style> .scroll{overflow-x:auto;} </style> 

ansorder=r,r,r,r,r
varcnt=14
prevarcnt=13
postvarcnt=0
replycnt=5
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items 1,1,2

tmp0=!randitem $tmp
val6=$[rint($(tmp0))]
tmp0=!randint -8, 0

val7=$[$(tmp0)]
tmp0=!randint 4, 8

val8=$[$val7+$(tmp0)]

!ifval ($val6=1)
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
tmp1=!randint 2, 20

val9=$[ $(tmp0)* $(tmp1)/($val8-$val7)^2]
!else
tmp=!nonempty items -1,1

tmp2=!randitem $tmp
tmp3=!randint 10, 54

val9=$[$(tmp2)* $(tmp3)/($val8-$val7)^3]
!endif

!ifval ($val6=1)
t_=!replace internal \( by ( in $val9*(x-$val7)*(x-$val8)
tmp0=!exec maxima $t_

val10=!rawmath  $(tmp0)
!else
t_=!replace internal \( by ( in $val9*(x-$val7)^2*(x-$val8)
tmp1=!exec maxima $t_

val10=!rawmath $(tmp1)
!endif
!readproc slib/function/tabsignes [[x, $val10],[-Inf,+Inf,$val7,$val8;]],reply=[[1,4;1,6;2,3;2,5;2,7],[1]] text=[Signe de \(f(x)),replace,2] 
tmp0=$slib_out
val11=$(tmp0)
tmp0=!item 1 of $val11

val12=$(tmp0)
!readproc slib/function/tabsignes [[x, $val10],[-Inf,+Inf,$val7,$val8;]],text=[Signe de \(f(x)),replace,2]  
tmp0=$slib_out
val13=$(tmp0)
tmp0=!item 2 of $val11

tmp=!trim $(tmp0)
val14=!translate internal $	\
$ to ;; in $tmp
tmp0=!declosing $val14

tmp=!trim $(tmp0)
val14=!translate internal $	\
$ to ;; in $tmp

!ifval ($(val14[3]) issametext +)
val15=$[rint( 2)]
!else
val15=$[rint(1)]
!endif

!ifval ($(val14[4]) issametext +)
val16=$[rint( 2)]
!else
val16=$[rint(1)]
!endif

!ifval ($(val14[5]) issametext +)
val17=$[rint( 2)]
!else
val17=$[rint(1)]
!endif
replytype1=numeric
replyname1=
replygood1=$[$(val14[1])]
replytype2=numeric
replyname2=
replygood2=$[$(val14[2])]
replytype3=menu
replyname3=
replygood3=$val15;-,+
replytype4=menu
replyname4=
replygood4=$val16;-,+
replytype5=menu
replyname5=
replygood5=$val17;-,+
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Ci-dessous est tracée la courbe représentative d'une fonction 
!insmath f
$() définie sur 
!insmath \mathbb{R}
$().	<div >	 
!read oef/draw.phtml 300,300 \
	xrange -10,10	yrange -10,10	parallel -10,-10,-10,10,1,0, 20, grey	parallel -10,-10,10,-10,0,1, 20, grey	hline 0,0,black	vline 0,0,black	segment 1,-0.3,1,0.3, black	segment -0.3,1,0.3,1, black	text black , -0.5,-0.2,small , O	text black , 1,-0.3,small , I	text black , -0.5,1,small , J	linewidth 1.5	plot blue,$val10 
$()</div> 	Lire graphiquement le signe de 
!insmath f(x)
$() :	<div class="scroll"> 
!read oef/special.phtml codeinput [$val12],1,div	reply1	reply2	reply3	reply4	reply5 
$()</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()La courbe de 
!insmath f
$() coupe l'axe des abscisses aux points d'abscisses 
!insmath $val7
$() et 
!insmath $val8
$().<br/>	
!if $val6=1 
$()	La courbe de 
!insmath f
$() est 
!if $val9>0 
$()au-dessus 
!else
$() en-dessous 
!endif
$() de l'axe des abscisses sur l'intervalle &#93;
!insmath -\infty ; $val7
$()&#93;.<br/>	La courbe de 
!insmath f
$() est 
!if $val9<0 
$()au-dessus 
!else
$() en-dessous 
!endif
$() de l'axe des abscisses sur l'intervalle &#91;
!insmath $val7 ; $val8
$()&#93;.<br/>	La courbe de 
!insmath f
$() est 
!if $val9>0 
$()au-dessus 
!else
$() en-dessous 
!endif
$() de l'axe des abscisses sur l'intervalle &#91;
!insmath $val8; +\infty 
$()&#91;.<br/>	 
!else
$() 	La courbe de 
!insmath f
$() est 
!if $val9>0 
$()en-dessous 
!else
$() au-dessus 
!endif
$() de l'axe des abscisses sur l'intervalle &#93;
!insmath -\infty ; $val7
$()&#93;.<br/>	La courbe de 
!insmath f
$() est 
!if $val9>0 
$()en-dessous 
!else
$() au-dessus 
!endif
$() de l'axe des abscisses sur l'intervalle &#91;
!insmath $val7 ; $val8
$()&#93;.<br/>	La courbe de 
!insmath f
$() est 
!if $val9>0 
$()au-dessus 
!else
$() en-dessous 
!endif
$() de l'axe des abscisses sur l'intervalle &#91;
!insmath $val8; +\infty 
$()&#91;.<br/>	 
!endif
$()	Le signe de 
!insmath f(x)
$() est donc :<br/>	<div class="scroll"> $val13</div>
$()
!exit

