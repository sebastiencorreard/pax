!set title=Pourcentages : indice
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
keywords=skill_calculate,percents

ansorder=r
varcnt=14
prevarcnt=11
postvarcnt=2
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 100, 1500

val6=$[rint($(tmp0)*100)]
!readproc slib/numeration/ecriturenombre $val6 
tmp0=$slib_out
val7=$(tmp0)
tmp0=!randitem 1,2

val8=$[rint($(tmp0))]
tmp0=!randint 1, 15

val9=$[rint($(tmp0)*2)]

!ifval ($val8=1)
val10=$[rint( $val6*(1-$val9/100))]
!else
val10=$[rint($val6*(1+$val9/100))]
!endif
!readproc slib/numeration/ecriturenombre $val10 
tmp0=$slib_out
val11=$(tmp0)

!ifval ($val8=1)
val12=$[rint( 100-$val9)]
!else
val12=$[rint(100+$val9)]
!endif
!readproc slib/oef/env year 
tmp0=$slib_out
val13=$(tmp0)

!ifval $val13=\empty
val13= 2020
!endif
val14=$[rint($val13 - 1)]
val15=$[rint($val13 - 2)]
replyname1=Indice
replygood1=$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()En $val15, le chiffre d'affaires d'une entreprise est de $val7&#8239;€ et en $val14 il est de $val11&#8239;€.	Donner l'indice du chiffre d'affaires en $val14, base 100 en $val15.
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:postdef

!ifval ($val8=1)
val16=$[ (1-$val9/100)]
!else
val16=$[(1+$val9/100)]
!endif
val17=$[abs(1-$val16)]

!exit

:feedback
!ifval $m_sc_reply1=0
 <div class='oef_feedbacks'>$val10=$val6*c ssi c=$val10/$val6=$val16 donc l'indice est 100*$val16=$val12.
$()</div>
!endif

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,10,11,12,14,15
embedcnt=0
