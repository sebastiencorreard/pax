\title{Test automatismes}
\author{Cyrille, Douriez}
\computeanswer{no}
\precision{1000}

## Question type 1-2 : rationnels ##
\integer{q1e1=randint(2..9)}
\integer{q1d1=randitem(3,7,9,11)}
\integer{q1n1=randint(1..(\q1d1-1))}
\integer{q1d2=randitem(3,5,7,9,11)}
\integer{q1n2=randint(1..(\q1d2-1))}
\integer{q1d2=(\q1n1*\q1d2-\q1n2*\q1d1=0)? \q1d2+2:\q1d2}
\text{quest1=Calculer \(\frac{\q1n1}{\q1d1}+\frac{\q1n2}{\q1d2}) et donner le rÈsultat sous forme irrÈductible.,
Calculer \(\frac{\q1n1}{\q1d1}-\frac{\q1n2}{\q1d2}) et donner le rÈsultat sous forme irrÈductible.,
Calculer \(\q1e1+\frac{\q1n1}{\q1d1}) et donner le rÈsultat sous forme irrÈductible.,
Calculer \(\frac{\q1n1}{\q1d1}-\q1e1) et donner le rÈsultat sous forme irrÈductible.,
Calculer \(\left ( \frac{\q1n2}{\q1d2}\right ) ^2) et donner le rÈsultat sous forme irrÈductible.,
Calculer \(\q1e1 \times \left ( \frac{\q1n2}{\q1d2}\right ) ) et donner le rÈsultat sous forme irrÈductible.,
Calculer \(\frac{\q1n1}{\q1d1} \times \frac{\q1n2}{\q1d2}) et donner le rÈsultat sous forme irrÈductible.,
Calculer \(\frac{\q1n1 / \q1d1}{\q1n2 / \q1d2}) et donner le rÈsultat sous forme irrÈductible.,
Calculer \(\frac{\q1n1 / \q1d1}{\q1e1}) et donner le rÈsultat sous forme irrÈductible.}
\integer{q1den12=\q1d1*\q1d2}
\integer{q1num1=\q1n1*\q1d2+\q1n2*\q1d1}
\integer{q1num2=\q1n1*\q1d2-\q1n2*\q1d1}
\integer{q1den34=\q1d1}
\integer{q1num3=\q1e1*\q1d1+\q1n1}
\integer{q1num4=\q1n1-\q1e1*\q1d1}
\integer{q1num5=(\q1n2)*(\q1n2)}
\integer{q1den5=(\q1d2)*(\q1d2)}
\integer{q1num6=(\q1e1)*(\q1n2)}
\integer{q1pgcd6=maxima(gcd(\q1d2,\q1num6))}
\integer{q1num6=(\q1num6)/(\q1pgcd6)}
\integer{q1den6=(\q1d2)/(\q1pgcd6)}
\integer{q1num7=(\q1n1)*(\q1n2)}
\integer{q1pgcd7=maxima(gcd(\q1den12,\q1num7))}
\integer{q1num7=(\q1num7)/(\q1pgcd7)}
\integer{q1den7=(\q1den12)/(\q1pgcd7)}
\integer{q1num8=(\q1n1)*(\q1d2)}
\integer{q1den8=(\q1d1)*(\q1n2)}
\integer{q1pgcd8=maxima(gcd(\q1den8,\q1num8))}
\integer{q1num8=(\q1num8)/(\q1pgcd8)}
\integer{q1den8=(\q1den8)/(\q1pgcd8)}
\integer{q1den9=(\q1d1)*(\q1e1)}
\integer{q1pgcd9=maxima(gcd(\q1den9,\q1n1))}
\integer{q1num9=(\q1n1)/(\q1pgcd9)}
\integer{q1den9=(\q1den9)/(\q1pgcd9)}
\text{q1rq1=\q1num1/\q1den12}
\text{q1rq2=\q1num2/\q1den12}
\text{q1rq3=\q1num3/\q1den34}
\text{q1rq4=\q1num4/\q1den34}
\text{q1rq5=\q1num5/\q1den5}
\text{q1rq6=(\q1den6=1)? \q1num6:\q1num6/\q1den6}
\text{q1rq7=\q1num7/\q1den7}
\text{q1rq8=\q1num8/\q1den8}
\text{q1rq9=\q1num9/\q1den9}
\text{repq1=\q1rq1,\q1rq2,\q1rq3,\q1rq4,\q1rq5,\q1rq6,\q1rq7,\q1rq8,\q1rq9}
\integer{choixquest1=randint(1..4)}
\integer{choixquest2=randint(5..9)}

## Question type 3 : puissance ##
\integer{q3e=randitem(10,randint(2..9))}
\integer{q3p1=randint(2..15)}
\integer{q3p2=randitem(randint(3..15),randint(3..15),randint((-\q3p1-10)..(-\q3p1-1)))}
\integer{q3p3=randitem(randint((\q3p1+2)..(\q3p1+10)),randint((\q3p1+2)..(\q3p1+10)),randint(-15..-2))}
\integer{q3p4=(\q3p1+\q3p2<0)? randint(2..10):randitem(randint(-5..-2),randint(2..(\q3p1+\q3p2-1)))}
\text{quest3=Calculer \(\q3e^{\q3p1} \times \q3e^{\q3p2}) et donner le rÈsultat sous la forme d'une puissance de \(\q3e).,
Calculer \(\frac{\q3e^{\q3p1}}{\q3e^{\q3p3}}) et donner le rÈsultat sous la forme d'une puissance de \(\q3e).,
Calculer \(\left ( \q3e^{\q3p3} \right )^{\q3p1}) et donner le rÈsultat sous la forme d'une puissance de \(\q3e).,
Calculer \(\frac{\q3e^{\q3p1}\times \q3e^{\q3p2}}{\q3e^{\q3p4}}) et donner le rÈsultat sous la forme d'une puissance de \(\q3e).,
}
\integer{q3r1=\q3p1+\q3p2}
\integer{q3r2=\q3p1-\q3p3}
\integer{q3r3=\q3p1*\q3p3}
\integer{q3r4=\q3p1+\q3p2-\q3p4}
\text{repq3=\q3e^\q3r1,\q3e^\q3r2,\q3e^\q3r3,\q3e^\q3r4}
\integer{choixquest3=randitem(1,2,3,4,4)}

## Question type 4 : pourcentage ou fractionnaire <-> dÈcimal <-> pourcentage##
\matrix{q4composants=4,1,3,1,3,1,3,1,3
5,1,2,3,4,1,2,3,4
8,1,3,5,7,1,3,5,7
10,1,3,7,9,1,3,7,9
20,1,3,7,9,11,13,3,7
40,1,7,9,11,13,17,19,21}
\integer{q4choixdiviseur=randint(1..6)}
\integer{q4diviseur=\q4composants[\q4choixdiviseur;1]}
\integer{q4placedividende=randint(2..9)}
\integer{q4dividende=\q4composants[\q4choixdiviseur;\q4placedividende]*randint(-1,1)+randitem(0,randint(-3..3)*\q4diviseur)}
\real{q4fraction=\q4dividende/\q4diviseur}
\integer{q4numdeci=2^(randint(0..3))*3^randint(0..2)*5^(randint(0..2))*randint(3,7,11)}
\real{q4decimal=\q4numdeci/1000}
\integer{q4pgcddeci=maxima(gcd(\q4numdeci,1000))}
\integer{q4numdeci=\q4numdeci/\q4pgcddeci}
\integer{q4dendeci=1000/\q4pgcddeci}
\integer{q4taux1=randitem(10*randint(1..9),10*randint(1..9),25,75)}
\integer{q4valeur1=(\q4taux1<50)? 5*randint(3..40):10*randint(2..20)}
\integer{q4valeur1=(\q4taux1=25 or \q4taux1=75)? 4*randint(2..24):\q4valeur1}
\integer{q4taux2=10*randint(1..9)}
\real{q4valeur1f=\q4valeur1*\q4taux1/100}
\real{q4taux2f=\q4taux1*\q4taux2/10000}
\integer{q4taux1num=\q4taux1/(maxima(gcd(\q4taux1,100)))}
\integer{q4taux1den=100/(maxima(gcd(\q4taux1,100)))}
\rational{q4taux1fract=\q4taux1num/\q4taux1den}
\text{quest4=Donner l'Ècriture dÈcimale de \(\frac{ \q4dividende}{\q4diviseur}).,
Donner l'Ècriture fractionnaire irrÈductible de \(\q4decimal).,
\(\q4taux1 \%) de \(\q4valeur1) font,
\(\q4taux1 \%) de \(\q4taux2 \%) font,
La fraction irrÈductible Ègale ý \(\q4taux1 \%) est,
\(\frac{\q4taux1num}{\q4taux1den}) est Ègal ý un pourcentage de,
}
\text{repq4=\q4fraction,\q4numdeci/\q4dendeci,\q4valeur1f,\q4taux2f,\q4taux1fract,\q4taux1}
\integer{choixquest4=randint(1..6)}

## Question type 5 : dÈveloppement-factorisation##
\integer{q5a=randint(1..7)}
\integer{q5b=randint(1..9)*randint(-1,1)}
\integer{q5c=randint(1..5)*randitem(-1,1,1)}
\integer{q5d=(\q5b>0)?-randint(1..9):randint(1..9)*randint(-1,1)}
\function{q5f1=maxima((\q5a*x+\q5b)*(\q5c*x+\q5d))}
\function{q5f1dev=maxima(expand(\q5f1))}
\function{q5f1=texmath(\q5f1)}
\function{q5f2=maxima((\q5a*x+\q5b)^2)}
\function{q5f2dev=maxima(expand(\q5f2))}
\function{q5f2=texmath(\q5f2)}
\integer{q5e=(randint(1..9))}
\function{q5f3=maxima(\q5a^2*x^2-(\q5e)^2)}
\function{q5f3facto=maxima((\q5a*x+\q5e)*(\q5a*x-\q5e))}
\function{q5f3=texmath(\q5f3)}
\integer{q5f=randint(1,randint(1..5))}
\integer{q5g=randint(-1,-1,1)}
\function{q5f4=maxima(\q5f*(\q5a*x+\q5b)+\q5g*(\q5a*x+\q5b)*(\q5c*x+\q5d))}
\function{q5f4facto=maxima((\q5a*x+\q5b)*(\q5f+\q5g*(\q5c*x+\q5d)))}
\function{q5f4=texmath(\q5f4)}
\function{q5f5=maxima((\q5a*x+\q5b)^2+\q5g*(\q5a*x+\q5b)*(\q5d*x+\q5e))}
\function{q5f5facto=maxima((\q5a*x+\q5b)*((\q5a+\q5g*\q5d)*x+(\q5b+\q5g*\q5e)))}
\function{q5f5=texmath(\q5f5)}
\text{quest5=DÈvelopper \(\q5f1).,
DÈvelopper \(\q5f2).,
Factoriser \(\q5f3).,
Factoriser \(\q5f4),
Factoriser \(\q5f5)
}
\text{repq5=\q5f1dev,\q5f2dev,\q5f3facto,\q5f4facto,\q5f5facto}
\integer{choixquest5=randint(1..5)}

## Question type 6 : Èquation##
\integer{type6=randint(1,2)}
\integer{q6a=randint(1..15)*randitem(-1,1,1,1)}
\integer{q6b=randint(-20..20)}
\rational{q6sol=-\q6b/\q6a}
\if{\type6=1}{\text{repq6=\q6sol}}{\text{repq6=(\q6a>0)? sqrt(\q6a),-sqrt(\q6a):aucune}}
\function{q6f=(\type6=1)? maxima(\q6a*x+\q6b):maxima(x^2)}
\integer{q6membre2=(\type6=1)? 0:\q6a}
\text{q6f=texmath(\q6f)}
\text{quest6=RÈsoudre dans \(\mathbb{R}) l'Èquation \(\q6f=\q6membre2).}

## Question type 7 : pourcentage##
\integer{choixquest7=randitem(1,1,1,2,2,2,3,3,4,4,randitem(5,6))}
\integer{q7taux1=randint(5..40)}
\integer{q7taux2=10*randint(1..5)}
\integer{q7taux3=10*randint(2..8)}
\integer{q7n=randitem(10,20,30,40,50,200,300,500)}
\text{quest7=Appliquer une augmentation de \(\q7taux1 \%) revient ý multiplier par :,
Appliquer une rÈduction de \(\q7taux1 \%) revient ý multiplier par :,
\(\q7n) augmentÈ de \( \q7taux2 \%) est Ègal ý :,
\(\q7n) diminuÈ de \(\q7taux2 \%) est Ègal ý :,
Appliquer une baisse de \(\q7taux2 \%) puis une baisse de \(\q7taux3 \%) revient ý appliquer une baisse globale de :,
Pour annuler une baisse de \(\q7taux2 \%) on applique une hausse de : }
\real{q7r1=1+\q7taux1/100}
\real{q7r2=1-\q7taux1/100}
\real{q7r3=\q7n*(1+\q7taux2/100)}
\real{q7r4=\q7n*(1-\q7taux2/100)}
\real{q7r5=100*(1-(1-\q7taux2/100)*(1-\q7taux2/100))}
\real{q7r6=(1/(1-\q7taux2/100)-1)*100}
\text{repq7=\q7r1,\q7r2,\q7r3,\q7r4,\q7r5,\q7r6}

## Question type 8 : Ècriture scientifique - ordre de grandeur##
\integer{q8p=randitem(-3,-2,-1,1,2,3,4,5,6)}
\real{q8m=randint(101..990)/100}
\real{q8n=\q8m*10^\q8p}
\integer{q8o=(\q8m<=5)? \q8p-2: \q8p-1}
\integer{choixquest8=1}
\text{quest8=Donner l'Ècriture scientifique de \(\q8n).,
Donner un ordre de grandeur sous la forme d'une puissance de 10 de \(\q8n).}
\text{repq8=\q8m*10^\q8p,10^\q8o}

## Question type 9 : droite##
\integer{q9a=randint(1..4)*randint(-1,1)}
\integer{q9b=randint(-5..5)}
\function{q9f=maxima(\q9a*x+\q9b)}
\integer{q9xa=randint(-10..5)}
\integer{q9ya=\q9a*\q9xa+\q9b}
\integer{q9xb=\q9xa+randint(1..5)}
\integer{q9yb=\q9a*\q9xb+\q9b}
\text{q9fl=texmath(\q9f)}
\text{quest9=Calculer le coefficient directeur de la droite \((AB)) avec \(A(\q9xa; \q9ya)) et \(B(\q9xb; \q9yb)). ,
Le point \(A(\q9xa; y)) appartient ý la droite \(d) d'Èquation \(y=\q9fl). Que vaut \(y) ?,
Donner l'Èquation rÈduite de la droite \((AB)) avec \(A(\q9xa; \q9ya)) et \(B(\q9xb; \q9yb)).}
\integer{q9r2=\q9a*\q9xa+\q9b}
\text{repq9=\q9a,\q9r2,\q9f}
\integer{choixquest9=randint(1..3)}


## Question type 10 : conversiopn##
\integer{type10=randint(1..3)}
\text{q10unites=hm,dam,m,dm,cm,mm}
\text{q10choixunit=wims(shuffle 1,2,3,4,5,6)}
\text{q10unit1=\q10choixunit[1]}
\text{q10unit2=\q10choixunit[2]}
\integer{q10val=(\q10unit1-\q10unit2>2)? randint((10^(\type10*2))..(9*10^(\type10*2+1))):randint(11..990)}
\text{quest10=(\type10=1)? Combien \(\q10val) \(\q10unites[\q10unit1]) font en \(\q10unites[\q10unit2]) ?:Combien \(\q10val) \(\q10unites[\q10unit1]^\type10) font en \(\q10unites[\q10unit2]^\type10) ?   }
\real{q10r1=\q10val*10^(\type10*(\q10unit2-\q10unit1))}
\text{repq10=\q10r1}
\integer{choixquest10=1}

