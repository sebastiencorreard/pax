\title{Pourcentages : calcul simple}
\author{Cyrille, Douriez}
\email{cyrille.douriez@ac-amiens.fr}
\keywords{skill_calculate,percents}
\description{Cet exercice peut ętre résolu sans utiliser la calculatrice.}
\observation{Conseillé sans calculatrice}
\precision{1000}

\integer{x=randint(2..18)*5}
\integer{p=10*randint(1..9)}
\real{y=\x*\p/100}

\statement{\p&#8239;% de \x font \embed{r1,4}.}

\answer{Réponse}{\y}{type=numeric}
