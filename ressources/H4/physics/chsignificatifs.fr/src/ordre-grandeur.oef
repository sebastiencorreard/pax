\title{Ordre de grandeur}
\author{B.Markey}
\email{benoit.markey@ac-lille.fr}

\real{a=random(1..10)}
\integer{n1=randint(1..5)}
\integer{n2=randint(1..25)}
\real{s=random(1,-1)}

\real{nb=\a*10^(\s*\n2)}
\if{\a>=5}{\integer{n=\s*\n2+1}}{\integer{n=\s*\n2}}

\statement{
Soit le nombre \nb, donner son ordre de grandeur: \embed{reply 1,2}<sup>\embed{reply 2,2}</sup>
}


\answer{réponse1}{10}{type=numeric}
\answer{réponse2}{\n}{type=numeric}
