!set title=Réaction du support 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Benoit, Markey
keywords=force
precision=100
oefcss=<style> .jxgbox {margin-left:auto;margin-right:auto;} .jsxgraph_button {text-align:center;} </style>
oefcss=<style> .jxgbox {margin-left:auto;margin-right:auto;} .jsxgraph_button {text-align:center;} </style>

ansorder=r
varcnt=11
prevarcnt=10
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem 30,40,45,50,60,70

val6=$[rint($(tmp0))]
val7=$[$val6*3.141592/180]
tmp0=!randint 80, 100

val8=$[rint($(tmp0))]
val9=$[170-50*sin($val7)]
val10=$[360-(170-80)*tan($val7)-50*cos($val7)]
val11=$[170-200*sin($val7)]
val12=$[360-(170-80)*tan($val7)-200*cos($val7)]
val13=$[170]
val14=$[360-(170-80)*tan($val7)]
!readproc oef/draw.phtml 400,400 \
parallel 0,0,0,400,20,0,20,grey	parallel 0,0,400,0,0,20,20,grey		segment 80,360,260,360, green	segment 80,360,260,360-(260-80)*tan($val7), green		fcircle 170-50*sin($val7), 360-(170-80)*tan($val7)-50*cos($val7),100, skyblue	linewidth 5	point $val9,$val10 ,red	linewidth 1	text red,$val9,$val10,small,G	text purple,$val13,$val14,small,A	linewidth 3	point $val13,$val14, purple			arrow $val9,$val10,$val9,$val10+$val8,10,red	text red,$val9+10,$val10+$val8, medium, P	arrow $val9+5,$val10+$val8-3,$val9+20,$val10+$val8-3,7,red		 
tmp0=$ins_url
val15=$(tmp0)	
replytype1=jsxgraphcurve

replyname1=
replygood1=$val15;sline,$val13,$val14,$val11,$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$() On représente ci-dessous un objet M sur un plan incliné. On a représenté aussi son	vecteur poids 
!insmath \vec{P}
$().	<div class="wims_instruction">Il est recommandé d'utiliser votre rapporteur	ou tout autre instrument, en le posant directement sur l'écran. N'hésitez pas à utiliser les fonctions de zoom	 présentes au dessus du graphique.</div>	<div class="wims_question">Dessiner, <strong>à partir du point A</strong>, la demi-droite donnant le sens et la	direction de la réaction du support sur cet objet.	 
!read oef/embed.phtml r1,400x400 
$() </div>	
