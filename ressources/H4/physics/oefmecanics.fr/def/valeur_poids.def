parallel 0,0,0,400,20,0,20,grey	parallel 0,0,400,0,0,20,20,grey	filledrect 40,40,80,80, skyblue	point 60,60,red	text black,50,50,large,G		arrow 60,60,60,$val12,10,red	text red,70,$val12,medium,P	arrow 68,$val12,80,$val12,8,red		text red, 140,45, medium, échelle:	segment 150,60,150,100,red	text red,165,75,medium,$val11 N	 
