!set title=Tracé du vecteur poids
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Benoit, Markey
precision=100
oefcss=<style> .jxgbox {margin-left:auto;margin-right:auto;} .jsxgraph_button {text-align:center;} </style>

ansorder=r
varcnt=9
prevarcnt=8
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem 1,2,3,4

val6=$[rint($(tmp0))]
tmp0=!randitem 5,6,7,8

val7=$[rint($(tmp0))]
tmp0=!randitem $val6,$val7

val8=$[rint($(tmp0))]
!if $val8=$val6 
val9=$[rint(5)]
!endif
!if $val8=$val7 
val9=$[rint(10)]
!endif
val10=$[rint($val8*100)]
val11=$[$val9/10]
!readproc oef/draw.phtml 200,400 \
parallel 0,0,0,400,20,0,20,grey	parallel 0,0,400,0,0,20,20,grey	filledrect 40,40,80,80, skyblue	point 60,60,red	text black,50,50,large,G	segment 150,60,150,100,red	text red,165,75,medium,$val11 N	 
tmp0=$ins_url
val12=$(tmp0)	
replytype1=jsxgraphcurve

replyname1=
replygood1=$val12;vector,60,60,60,60+400*$val8/$val9
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$() On considère un objet de masse m=$val10 g, dont le centre de gravité	est représenté par le point G.	<div class="wims_question">Tracer le vecteur poids, 
!insmath \vec{P}
$() à partir du point G.	  
!read oef/embed.phtml r1,200x400 
$()</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=10
embedcnt=1
