!set title=Tension d'un fil
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
keywords=force
author=Benoit, Markey
precision=100
oefcss=<style> .jxgbox {margin-left:auto;margin-right:auto;} .jsxgraph_button {text-align:center;} </style>

ansorder=r
varcnt=14
prevarcnt=13
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 5, 15

val6=$[rint($(tmp0))]
val7=$[rint($val6*20)]
tmp0=!randint 8, 10

val8=$[rint($(tmp0))]
val9=$[rint(20+$val8*20)]
tmp0=!randint 4, 6

val10=$[rint($(tmp0))]
val11=$[rint($val10*50)]
!ifval $val7 == 200 
val12=$[rint($val11)]
!else
tmp0=!randint 4, 10

val13=$[rint($(tmp0))]
val12=$[rint($val13*50)]
!endif
val14=$[arctan(($val9-30)/(200.1-$val7))]
val15=$[$val7+2*$val12*cos($val14)*(sin($val14)/abs(sin($val14)))/5]
val16=$[$val9-2*$val12*abs(sin($val14))/5]
!readproc oef/draw.phtml 400,400 \
parallel 0,0,0,400,20,0,20,grey	parallel 0,0,400,0,0,20,20,grey	frect 20,20,380,40,darkgrey	linewidth 1	segment 200,30,$val7,$val9, brown		fcircle $val7,$val9,20, blue	linewidth 4	point $val7,$val9,skyblue	linewidth 1	arrow $val7,$val9,$val7,$val9+2*$val11/5,10,red	arrow $val7+8,$val9+2*$val11/5-5,$val7+20,$val9+2*$val11/5-5,7,red	text red,$val7+10,$val9+2*$val11/5,medium,P	 
tmp0=$ins_url
val17=$(tmp0)	
replytype1=jsxgraphcurve

replyname1=
replygood1=$val17;sline,$val7,$val9,$val15,$val16
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	On considère un solide accroché à un fil et dont le centre de gravité est	 représenté par le point G. On représente aussi le vecteur poids 
!insmath \vec{P}
$().	<div class="wims_question">Tracer, <strong>à partir du point G</strong>,	  la demi-droite donnant la direction de la tension du fil.	<div class="spacer">	  
!read oef/embed.phtml r1,400x400 
$()	 </div></div>	
$()
!exit

