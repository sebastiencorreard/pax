!set title=Calcul de force de gravitation
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
keywords=gravitation
author=Benoit, Markey ; Georges, Khaznadar
precision=100

ansorder=r
varcnt=11
prevarcnt=10
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=$[6.67e-11]
val7=$[5.97e24]
val8=$[6380]
tmp0=!randint 200, 36000

val9=$[rint($(tmp0))]
tmp0=!randint 100, 1000

val10=$[rint($(tmp0))]
val11=$[rint(500)]
val12=$[$val11 / ($val8+$val9)/ 2.2]
val13=$[$val6*$val7*$val10/(($val8+$val9)*1e3)^2]
!readproc slib/geo2D/jsxgraph jsxbox,$val11 x $val11,	  var brd = JXG.JSXGraph.initBoard(	    'jsxbox',	    {	      axis:true,	      originX: $val11 / 2,	      originY: $val11/ 2,	      unitX: $val12,	      unitY: $val12,	    }	   );	   p1 = brd.create('point', [0,0]).hideElement();	   p2 = brd.create('point', [0, $val8]).hideElement();	   p3 = brd.create('turtle', [($val8 + $val9)*Math.cos(0), ($val8 + $val9)*Math.sin(0)], {strokeOpacity:0.5, label: "satellite",});	   p3.setPenSize(3);	   p3.setAttribute({dotted: 3,});	   planete = brd.create('circle', [p1, p2], {strokeWidth: 1, strokeColor: 'blue', fillColor: '#00ffff50'});	   pl1 = brd.create('text',[100,200,"Planète"]);		    
tmp0=$slib_out
val14=$(tmp0)	
val15=<script>	   var temps=0;	   var animation= function() {	     temps+=0.01;	     p3.moveTo([($val8+$val9)*Math.cos(temps), ($val8+$val9)*Math.sin(temps)]);		     p3.lookTo([($val8+$val9)*Math.cos(temps)-Math.sin(temps), ($val8+$val9)*Math.sin(temps)+Math.cos(temps)]);		     setTimeout(animation, 40);	   };	   animation();	</script>	
replytype1=units
replyname1=réponse
replygood1=$val13 N 
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val14 $val15	<div class="wims_question">Quelle est est la force d'interaction gravitationnelle exercée entre la Terre	et un satellite S de masse m=$val10 kg et situé à une altitude h=$val9 km de la <i><strong>surface</strong></i>	de la terre.	<div> On donne :<ol><li>Masse de la Terre: M<sub>T</sub>=$val7 kg</li>	<li>Rayon de la Terre: R<sub>T</sub>=$val8 km</li>	<li>Constante de gravitation universelle: 
!insmath G=6.67\times10^{-11}
$()	  (unité du système international)</li></ol></div>	<div class="wimscenter"><label for="reply1">F=</label> 
!read oef/embed.phtml reply1,10 
$()</div></div>	<div class="wims_instruction">	<ul class="wims_nopuce">	<li>Le séparateur de décimales est le point (.).</li>	<li>On écrira les puissances de 
!insmath 10^x
$() sous la forme e+x. Par exemple 
!insmath 10^{3}
$() s'écrira e+3</li>	<li>Ne pas oublier l'unité</li></ul></div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,8,9,10,14,15
embedcnt=1
