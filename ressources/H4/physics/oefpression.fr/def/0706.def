 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
tmp=!trim surface du piston en	surface du piston en	pression exercée par le piston en pascal	pression exercée par le piston en bar
val7=!translate internal $	\
$ to ;; in $tmp
!if $val6=en 
tmp=!trim surface du piston en	surface du piston en	pression exercée par le piston en pascal	pression exercée par le piston en bar
val7=!translate internal $	\
$ to ;; in $tmp
!endif
tmp0=!randint 4, 12

val8=$[rint($(tmp0))]
tmp0=!randint 300, 400

val9=$[rint(10*$(tmp0))]
val10=$[pi*($val8/2)^2]
val11=$[$val10*10^(-4)]
val12=$[$val9*10/$val11]
val13=$[rint($val12/100000)]
val14=$val1/serie_700_transpalette.jpg
replytype1=sigunits
replyname1=$(val7[1;]) cm<sup>2</sup>
replygood1=$val10 #4
replytype2=sigunits
replyname2=$(val7[2;]) m<sup>2</sup>
replygood2=$val11 #4
replytype3=sigunits
replyname3=$(val7[3;])
replygood3=$val12 #4
replytype4=sigunits
replyname4=$(val7[4;])
replygood4=$val13 #4
