!set title=9 - Lac
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Eric, Guillet
email=eguillet@cfai.org
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100
