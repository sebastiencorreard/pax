\text{etoile1=randomrow(\etoile)}
\integer{an=wims(date +%Y)-\etoile1[2]} 
\integer{d=\etoile1[3]}

\statement{
L'étoile dénommée \etoile1[1] est située ŕ \d km de la Terre.<br>
<ol>
<li>A quelle distance, en <b><i>année de lumičre</i></b>, est située cette étoile de la Terre? \embed{reply1}
<li>En quelle année a été émise la lumičre de cette étoile que l'on observera ce soir?\embed{reply2}

</ol><br>
<i>On prendra 1 a.l= 9,46 &times; 10<sup>12</sup> km</i>
}

\answer{réponse 1}{\etoile1[2]}{type=numeric}

\answer{réponse 2}{\an}{type=numeric}
