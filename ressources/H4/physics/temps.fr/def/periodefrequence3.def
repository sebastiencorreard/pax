!set title=Période et fréquence 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Benoit Markey
email=benoit.markey@ac-lille.fr
author=Markey Benoît
leftrange=-5.000000
rightrange=5.000000
precision=100

ansorder=r,r
varcnt=20
prevarcnt=19
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 14

val6=$[rint($(tmp0))]
val7=$[1/$val6]
!if $val6>4 
val8=$[rint(4)]
!endif
!if $val6<5 
val8=$[rint(2)]
!endif
val9=$[3.141592]
val10=cos(x*2*$val9/$val6)
!for val11 =1 to 200 
val10=$val10+(((-1)^$val11)/(2*$val11+1))*cos((2*$val11+1)*x*2*$val9/$val6)
!next
val12=cos(x*2*$val9/$val6)
!for val11 =1 to 200 
val12=$val12+((-1)^$val11)/(2*$val11+1)*sin((2*$val11+1)*x*2*$val9/$val6)
!next
val13=cos(x*2*$val9/$val6)
!for val11 =1 to 200 
val13=$val13+((-1)^$val11)/((2*$val11+1)^2)*sin((2*$val11+1)*x*2*$val9/$val6)
!next
val14=cos(x*2*$val9/$val6)
tmp0=!randitem $val10,$val12,$val13,$val14

val15=$(tmp0)
!readproc slib/graphpaper/func_milli ,,0,4,$val8 t(s),0.5,,,,$val15 
tmp0=$slib_out
val16=$(tmp0)
!readproc oef/draw.phtml 300,300 \
$val16 
tmp0=$ins_url
val17=$(tmp0)
val18=<img src="$val17">
replytype1=units
replyname1=
replygood1=$val6 s
replytype2=units
replyname2=
replygood2=$val7 Hz
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Voici un signal périodique, déterminez sa période et sa fréquence.				$val18</div>				A l'aide de la courbe précédente déterminez: (on n'oubliera pas l'unité)	<ol>	<li>La période est T=  
!read oef/embed.phtml reply1,10 
$()</li>	<li>La fréquence est f=  
!read oef/embed.phtml reply2,10 
$()</li>		</ol>		
$()
!exit

