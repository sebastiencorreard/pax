!set title=Mouvements (1)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Markey Benoit
email=benoit.markey@ac-lille.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10

ansorder=r,r,c
varcnt=31
prevarcnt=30
postvarcnt=0
replycnt=2
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=$[-20]
val7=$[20]
val8=$[-3]
val9=$[3]
val10=$[($val9-$val8)/200*8]
tmp0=!randitem 40,50,60

val11=$[rint($(tmp0))]
tmp0=!randitem 0.5,1,2,2.5,3,4,5

val12=$[$(tmp0)]
val13=$[rint(800)]
val14=$[rint(600)]
tmp0=!randitem -1,1

val15=$[rint($(tmp0))]
val16=($val6+2.05)*$val15
val17=fcircle $val16,0,10,red	text red,$val16,1.1,small,A1
!for val18 =1 to 10 
!if $val15=1 
val19=$[rint($val18)]
!endif
!if $val15=-1 
val19=$[rint(11-$val18)]
!endif
val16=$val16,$val15*($val6+2+($val18*($val11/1000))^2*150)
val17=$val17	fcircle $(val16[$val18]),0,10,red	text red,$(val16[$val18]),1.3+0.2*(-1)^($val18),small,A$val19
!next
val20=($(val16[2])-($val6+2.05)*$val15)/($val11/1000)*$val12/100
!for val21 =2 to 9 
val20=$val20,($(val16[$val21+1])-$(val16[$val21]))/($val11/1000)*$val12/100
!next
tmp0=!randitem 2,3,4

val22=$[rint($(tmp0))]
tmp0=!randitem 5,6,7,8

val23=$[rint($(tmp0))]
val24=$[abs($(val20[$val22]))]
val25=$[abs($(val20[$val23]))]
!if $val15=1 
val26=accéléré
val27=ralenti
!endif
!if $val15=-1 
val26=ralenti
val27=accéléré
val24=$[abs($(val20[10-$val22]))]
val25=$[abs($(val20[10-$val23]))]
!endif
replytype1=units
replyname1=V<sub>$val22</sub>
replygood1=$val24 m/s
replytype2=units
replyname2=V<sub>$val23</sub>
replygood2=$val25 m/s
choiceweight1=0.5 
choicename1=Le mouvement est donc rectiligne et
choicegood1=$val26
choicebad1=$val27, uniforme
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div>On suit un mobile lors de son mouvement rectiligne. On obtient l'enregistrement 	suivant pour lequel l'intervalle de temps 
!insmath tau
$() entre 2 points est 
!insmath tau
$()=$val11 ms. <br>	<strong>On fera attention ŕ l'échelle indiquée sur le schéma.</strong><br>	<i> Il est conseillé d'utiliser <b>votre régle</b> ,directement sur l'écran, pour déterminer l'échelle.</i>	</div>		 
!read oef/draw.phtml 800,200 \
	xrange $val6,$val7	yrange $val8,$val9	$val17		dline -10,0,-10,-1.2,green	dline -9,0,-9,-1.2,green	parallel $val6,-$val10,$val6,$val10,1,0,$val7-$val6, blue	parallel $val6,-$val10/2,$val6,$val10/2,0.5,0,2*($val7-$val6), blue	text green,-10,-1.5,small,$val12 cm	hline black,0,0	rays green,-10,-1,-9,-1	arrow 5,-1.5,10,-1.5,20,grey	text grey,5.5,-2,small, sens du mouvement	  
$()					<br><br>				Déterminez la vitesse instantanée en m/s en A<sub>$val22</sub> et en A<sub>$val23</sub>. Caractérisez ensuite le mouvement.	 
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,10,11,12,17,22,23
embedcnt=0
