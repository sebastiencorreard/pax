# Variable declaration file.
#
# Only those variables with possible user inputs or requiring inter-request
# savings need to be declared in this file.
#
#Each non-comment line defines a variable. Format of the line:
#
#name	allow
#
#Or the condensed format
#
#allow: name name name ...
#
#name: name of the variable
#allow: when allow the user to override the defined value.
#       it maybe any, deny, init, config, reply.
#
#
#name	allow

status	deny
step deny

dernier_point deny

debug deny

incid[9] init
refra[9] init

sini[9]	reply
sinr[9]	reply

m1 init
m2 init
nm init

milieu init
indice init

milieu1 init
milieu2 init
indice1 init
indice2 init

c_sini[9] init
c_sinr[9] init

g_sini[9] deny
g_sinr[9] deny
g_dot[9]  deny

click_x reply
click_y reply
liste_points deny

correct_points deny
fini reply
annuler reply
rapport reply

score[3] deny
