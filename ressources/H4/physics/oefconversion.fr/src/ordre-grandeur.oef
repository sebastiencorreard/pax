\title{ordre de grandeur}

\real{a=random(1..10)}
\integer{n1=randint(1..5)}
\integer{n2=randint(1..25)}
\real{s=random(1,-1)}

\real{nb=\a*10^(\s*\n2)}
\if{\a>=5}{\integer{n=\s*\n2+1}}{integer{n=\s*\n2}}

\statement{
Soit le nombre \nb, donner son ordre de grandeur sous la forme 10 <sup>n</sup> avec n=\embed{reply 1}
}

\answer{réponse}{\n}{type=numeric}
