!set title=Conversion (3)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Markey Beno¯t
email=benoit.markey@ac-lille.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=15
prevarcnt=14
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 101, 9999

val6=$[$(tmp0)/100]
tmp=!trim nm,-9	mu m,-6	mm,-3	cm,-2	dm,-1	m,0	dam,1	hm,2	km,3
val7=!translate internal $	\
$ to ;; in $tmp
val8=$(val7[;1])
tmp0=!shuffle $val8

val9=$(tmp0)
tmp0=!item 1 of $val9

val10=$(tmp0)
tmp0=!positionof item $val10 in $val8

val11=$(tmp0)
tmp=!translate internal $	$ to ; in $val7

tmp=!row $val11 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val12=$(tmp0)
tmp0=!item 2 of $val12

val13=$(tmp0)
tmp0=!item 2 of $val9

val14=$(tmp0)
tmp0=!positionof item $val14 in $val8

val15=$(tmp0)
tmp=!translate internal $	$ to ; in $val7

tmp=!row $val15 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val16=$(tmp0)
tmp0=!item 2 of $val16

val17=$(tmp0)
val18=$[rint($val13-$val17)]
val19=$val6*10^($val18)
replytype1=numeric
replyname1=exposant
replygood1=$[$val18]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()		ComplÚter l'exposant afin de convertir  :
!insmath $val6   $val10
$()	en 
!insmath $val14
$() 	 <p> 
!insmath $val6  $val10
$()	= $val6 $m_times 10<sup><sup> 
!read oef/embed.phtml reply 1,4 
$() </sup></sup> 
!insmath  $val14
$()</p> 	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,10,14
embedcnt=1
