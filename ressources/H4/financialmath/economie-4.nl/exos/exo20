	!if $budgetresultaat < 0
	    nadelig1=nadelig
	    ans2=-1
	!else
	    ans2=1
	    nadelig1=voordelig
	!endif
	#
	prijsverschil=$[($prijs - $grondstof2/$kilo2)*$kilo2]
	ans3=$[abs($prijsverschil)]
	!if $prijsverschil < 0
	    nadelig2=nadelig
	    ans4=-1
	!else
	    nadelig2=voordelig
	    ans4=1
	!endif
	#
	effverschil=$[($kilo1*$stuks2 - $kilo2)*$prijs]
	ans5=$[abs($effverschil)]
	!if $effverschil < 0
	    nadelig3=nadelig
	    ans6=-1
	!else
	    nadelig3=voordelig
	    ans6=1
	!endif
	answer$n=$ans1,$ans2,$ans3,$ans4,$ans5,$ans6
	
	exotext=<table class="zebra_table_h2"><tr><td >Budgetresultaat = &euro;&nbsp;<input type="text" id="myinput0" size="5" class="schaersvoorde_input" value=""/></td><td> ... en dit is een <select  size="1" id="myinput1" class="schaersvoorde_input"><option value="-1">nadelig</option><option value="1">voordelig</option></select>&nbsp;budgetresultaat ?</td></tr><tr><td >Prijsverschil = &euro;&nbsp;<input type="text" id="myinput2" size="5" class="schaersvoorde_input" value=""/></td><td> ... en dit is een <select  size="1" id="myinput3" class="schaersvoorde_input"><option value="-1">nadelig</option><option value="1">voordelig</option></select>&nbsp;prijsverschil ?</td></tr><tr><td >Efficiencyverschil = &euro;&nbsp;<input type="text" id="myinput4" size="5" class="schaersvoorde_input" value=""/></td><td> ... en dit is een <select id="myinput5" size="1" class="schaersvoorde_input"><option value="-1">nadelig</option><option value="1">voordelig</option></select>&nbsp;eficiencyverschil ? </td></tr></table>
    
	description=Budgetresultaat,voordeel of nadeel,Prijsverschil,voordeel of nadeel,Efficiencyverschil,voordeel of nadeel
	textanswer$n=<ol><li><ul><li>Budgetresultaat = verwachte kosten <u>op basis van de werkelijke afzet</u> vergelijken met de werkenlijke kosten</li><li><b>Verwacht</b>  $kilo1 $kg &times; &euro; $prijs &times; $stuks2 stuks = &euro; $budgetresultaat_verwacht <br /><b>Werkelijk</b> : &euro; $grondstof2</li><li>$nadelig1 budgetresultaat : &euro; $ans1</li></ul></li><li><ul><li>Prijsverschil = (standaardprijs - werkelijke prijs) &times; werkelijke hoeveelheid</li><li>Prijsverschil = ( $prijs - $grondtof2 / $kilo2) &times; $kilo2 = &euro; $prijsverschil</li><li>$nadelig2 prijsverschil &euro; $ans3</li></ul></li><li><ul><li>Efficiencyverschil = (standaardhoeveelheid - werkelijke hoeveelheid) &times standaardprijs</li><li>Efficiencyverschil = ($kilo1 &times; $stuks2 - $kilo2) &times; $prijs = &euro; $effverschil</li><li>$nadelig3 efficiencyverschil &euro; $ans5</li></ul></li></ol><span style="color:red"><b>N.B. controle</b></span> : $prijsverschil + $effverschil = $budgetresultaat

    !else
	checkfile=exos/precheck2.proc
	var1=2,0
	var2=10,-1
	txt=Bereken het gerealiseerde bezettingsresultaat voor de maand januari.<br />Geef aan of het een voordelig of nadelig resultaat is.
	bezettingsresultaat=$[($stuks2 - $jaarafzet/12)*$kosten1]
	ans1=$[abs(round($bezettingsresultaat))]
	!if $bezettingsresultaat < 0
	    nadelig1=nadelig
	    ans2=-1
	!else
	    ans2=1
	    nadelig1=voordelig
	!endif
	answer$n=$ans1\
	$ans2
	
	exotext=<table class="zebra_table_h2"><tr><td >Bezettingsresultaat = &euro;&nbsp;<input type="text" id="myinput0" size="5" class="schaersvoorde_input" value=""/></td><td> ... en dit is een <select size="1" id="myinput1" class="schaersvoorde_input"><option value="-1">nadelig</option><option value="1">voordelig</option></select>&nbsp;bezettingsresultaat ?</td></tr></table>
	
	textanswer$n=<ul><li>Bezettingsresultaat is : (werkelijke productie &minus; normale productie) &times; constante kosten per stuk</li><li>Bezettingsresultaat is ($stuks2 &minus; $jaarafzet/12 ) &times; $kosten1 = $bezettingsresultaat &euro;&nbsp;</li><li>Dit is dus een $nadelig1 bezettingsresultaat van &euro; $[round($ans1)].</li></ul>
    !endif
!endif

roundingtext=Geef je eindantwoorden in hele &euro;&rsquo;s<br />en als <b>positieve getallen</b> !
