# lineaire hypotheek
n=$counter
!if $level=0
    R=$counter
!else
    R=$level
!endif
var1=yes
mathview=0
make_tr=1
inputs=-1
questiontype=0
checkfile=$checkdir/number.proc

num=!randitem 78,79

jaar=!randint 10,15
jaar=$[2*$jaar]
aflossing=!randint 5,9
aflossing=$[1000*$aflossing]
lening=$[$aflossing*$jaar]
perc1=!randint 40,80
perc1=$[$perc1/10]
perc2=!randint 10,17
perc2=$[2*$perc2]

namen=!record $num of $remarkdir/commonremarks.$taal
naam=!randitem $namen

interest=$[$lening*$perc1/100]
belastingvoordeel=$[$interest*$perc2/100]
nettomaandlast=!exec moneyprint $[($aflossing + $interest - $belastingvoordeel)/12]
answer$n=$aflossing,$interest,$belastingvoordeel,$nettomaandlast
c=0

var2=Aflossing,Interest,Belastingvoordeel,Netto maandlast
tabel=<table class="default_table"><tr><th>Schuld 1 januari</th><th>Aflossing</th><th>Interest $perc1 %</th><th>Belastingvoordeel</th><th>Netto maandlast</th></tr><tr><td>&euro; $lening</td>
ans_tabel=$tabel

!for p=1 to 4
    ans=!item $p of $(answer$n) 
    input = <input type="text" id="myinput$c" size="6" class="schaersvoorde_input" value=""/> 
    input_ans = <input type="text" id="myinput$c" size="6" class="schaersvoorde_input" value="&euro; $ans" readonly="readonly"/> 
    !increase c
    tabel=!append word <td>&euro; $input</td> to $tabel
    ans_tabel=!append word <td>$input_ans</td> to $ans_tabel
!next p
tabel=!append word </td></tr></table> to $tabel
ans_tabel=!append word </td></tr></table> to $ans_tabel
roundingtext=Rond je antwoord af op hele &euro;&rsquo;s
rounding=1

ss=$naam sluit een lineaire hypotheek af.<br />De lening bedraagt &euro; $lening .De looptijd is $jaar jaar.<br />De interest is vastgesteld op $perc1 %. Het belastingvoordeel is $perc2 %<br />Bereken de ontbrekende waarden (op jaarbasis) in de tabel.

question$n =<a onmouseover="return escape('$roundingtext')">$ss </a>
exotext=$tabel
helptext=
htext=<ul><li>De aflossing is : $lening &divide; $jaar = &euro; $aflossing</li><li>De interest is : $[$perc1/100] &times; $lening = &euro; $interest</li><li>Het belastingvoordeel is : $[$perc2/100] &times; $interest = &euro; $belastingvoordeel</li><li>De netto maandlast wordt : <b>(</b> $aflossing + $interest &minus; $belastingvoordeel <b>)</b>&divide; 12 = &euro; $nettomaandlast</li></ul>

textanswer$n=$ans_tabel<br />$htext

