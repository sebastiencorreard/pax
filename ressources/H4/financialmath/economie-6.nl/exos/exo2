# plaatje
n=$counter
!if $counter=1
    mathview=0
    image=0
    math=0
    cols=20
    rows=1
    !if $total_exos>8
	total_exos=8
    !endif
    questiontype=7
    javascript=js/exo2.js
    checkfile=exos/checkfile1.proc
    make_tr=1
    inputs=yes
    k=!randint 1,6
    markt=!item $k of aardappelmarkt,suikerbietenmarkt,voedermaismarkt,voederbietenmarkt,graanmarkt,koolzaadmarkt
    produkt=!item $k of aardappels,suikerbieten,mais,voederbieten,graan,koolzaad

    var5=!shuffle 1,2,3,4,5,7,8
    var6=Geef de oppervlakte van het consumentensurplus aan, uitgaande van vrije marktwerking.\
    Geef de oppervlakte van het producentensurplus aan, uitgaande van vrije marktwerking.\
    Geef de oppervlakte van de totale marktomzet aan, uitgaande van vrije marktwerking.\
    Geef de oppervlakte van het consumentensurplus aan, na instelling van de garantieprijs.\
    Geef de oppervlakte van het producentensurplus aan, na instelling van de garantieprijs.\
    Geef de oppervlakte aan van de afname van het totale surplus.\
    Geef de oppervlakte van de totale marktomzet aan, na instelling van de garantieprijs.\
    Geef de oppervlakte van de kosten voor de Europese Commissie van deze garantieprijs.
    
    var7=A B C\
    F G\
    F G H I\
    A\
    B C D F G\
    C G\
    B C D E F G H I J\
    C D E G I J
    var9=["A","B","C","D","E","F","G","H","I","J"]
    
    var8=<span class="schaersvoorde_link">Deze grafiek</span> hoort bij een vraag- &amp; aanbodfunctie voor de Europese $markt.<br />De Europese Commissie garandeert een minimumprijs : de horizontale lijn in de grafiek. 
    
    helptext=<img src=\'$module_dir/gifs/exo2.jpg\' alt=\'geen plaatje?\' />Geef met de corresponderende letters het gevraagde gebied aan<br />Bijvoorbeeld:<br />A , B en K

!endif

embed=1
display=1
formula$n=\text{De gebieden : }
v=!item $n of $var5
q=!line $v of $var6
answer$n=!line $v of $var7
answer$n=!singlespace $(answer$n)

question$n=<a onmouseover="return escape('<img src=\'$module_dir/gifs/exo2.jpg\' alt=\'geen plaatje?\' />')">$var8</a><p style="text-align:center" /><b>$q</b><br /><small><em>Bijvoorbeeld: A , B en K</em></small></p>
textanswer$n=<img src="$module_dir/gifs/ans2.$v.jpg" alt="mooi waardeloos"/><br />Dus de gebieden <b>$(answer$n)</b>



