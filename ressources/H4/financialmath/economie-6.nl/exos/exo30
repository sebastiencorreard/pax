    #arrow $[3*$q],$[5.5*$p],$[3*$q],$[4*$p+0.2*$p],0.15,red,180,2\
    string green,$[($a - $c)/($b1)],1.1*$c,MK\
    string blue,$[0.9*($a/($b1)-$xminor)],$[0.8*$yminor],GO\
    string red,$[$a/($b2)+0.5*$xminor],$yminor,MO \
    mouse blue,34
    
    answer$n=$[$euromax*$x1]
    #var1=$[$euromax*$x1 - $euromax*(x1-0.25*$xminor)]
    var1=$[$euromax*$x1 - ($euromax - 0.2*$yminor)*($x1-0.2*$xminor)]
    var2=1
    checkfile=$checkdir/new_number.proc
    
    ss=Van een monopolist zijn de volgende gegevens af te lezen in grafiek.<br />Bereken de omzet die hoort bij de maximale winst van de monopolist. 
    question$n=<a onmouseover="return escape('De muis geeft de co&ouml;rdinaten weer in de grafiek')">$ss</a
    textanswer$n=Af te lezen in de grafiek: <ul><li>Maximale winst bij MO = MK</li><li>x-as (aantal) = $x1 </li><li>y-as (&euro;) = $euromax &euro;</li><li>Omzet bij maximale winst is dan : $euromax &times; $x1 = $(answer$n) </li></ul>

 !exit
!endif


