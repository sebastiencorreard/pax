    size $xsize,$ysize\
    precision 1\
    xrange $xmin,$xmax\
    yrange $ymin,$ymax\
    fontsize 16\
    fontfamily bold italic 16px Ariel\
    axis\
    axisnumbering\
    xlabel aantal       \
    ylabel \u20AC \
    opacity 120,120\
    legend MK:GO:MO\
    legendcolors green:blue:red\
    grid $xmajor,$ymajor,black,4,4,10,blue\
    fontfamily bold 18px Ariel\
    linewidth 2\
    ftriangle 0,$euromax,$x1,$euromax,0,$a,lightgreen\
    ftriangle $x1,$c,$[($a-$c)/($b1)],$c,$x1,$euromax,pink\
    linewidth 3\
    dashtype 4,4\
    frect 0,$c,$x1,$euromax,yellow\
    opacity 255,120\
    segment 0,$a,$[$a/($b1)],0,blue\
    segment 0,$a,$[$a/($b2)],0,red\
    segment 0,$c,$[$a/($b1)],$c,green\
    dsegment $x1,0,$x1,$[$a-$b1*$x1],red\
    dsegment 0,$euromax,$x1,$euromax,red\
    point $x1,$c,black\
    #text $[7*$q],$p,ariel,14,MK = GTK = euro  $p,black\
