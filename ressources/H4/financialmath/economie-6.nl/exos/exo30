    b2=!randint 1,2
    c=!randint 1,3
    c=$[10*$c]
    a=$[$x1*$b2+$c]
    euromax=$[$a-($b1)*$x1]
    xmax=$[$a/($b1)]
    !if $xmax > 400
	xmajor=80
	xminor=20
	xmin=-80
	xmax=$[$xmax+15]
    !else
	!if $xmax > 250
	    xmajor=40
	    xminor=10
	    xmin=-40
	    xmax=$[$xmax+15]
	!else
	    !if $xmax > 150
		xmajor=20
		xminor=5
		xmin=-20
		xmax=$[$xmax+5]
	    !else
		xmajor=10
	        xminor=5
		xmin=-10
	        xmax=$[$xmax+5]
	    !endif
	!endif
    !endif
    !if $a < 60
	ymax=$[$a+7.5]
        ymajor=5
        yminor=2.5
