xsize=600
ysize=400
# vraag 1
description=Omzet bij prijsdiscriminatie
ex1=&euro;
m_rightarrow=&nbsp;=&nbsp;
object$n=!exec canvasdraw\
size $xsize,$ysize\
precision 1\
xrange $xmin,$xmax\
yrange $ymin,$ymax\
fontsize 16\
fontfamily bold italic 16px Ariel\
axis\
axisnumbering\
xlabel aantal       \
ylabel \u20AC \
opacity 120,120\
legend MK:GO:MO\
legendcolors green:blue:red\
grid $xmajor,$ymajor,black,4,4,6,blue\
fontfamily bold 18px Ariel\
linewidth 3\
dashtype 4,4\
ftriangle 0,$p1,$x1,$p1,0,$a,lightgreen\
ftriangle $x1,$p2,$x2,$p2,$x1,$p1,lightgreen\
ftriangle $x2,$c,$[($a-$c)/($b1)],$c,$x2,$p2,pink\
frect 0,$c,$x2,$p2,yellow\
frect 0,$p2,$x1,$p1,yellow\
opacity 200,120\
segment 0,$a,$[$a/($b1)],0,blue\
segment 0,$a,$[$a/($b2)],0,blue\
segment 0,$c,$[$a/($b1)],$c,blue\
dsegment $x1,$p1,$x1,0,red\
dsegment $x2,$p2,$x2,0,red\
dsegment 0,$p2,$x2,$p2,red\
dsegment 0,$p1,$x1,$p1,red\
point $[($a-$c)/$b2],$c,black\
string green,$[1.05*($a - $c)/($b1)],1.1*$c,MK\
string blue,$[0.95*($a/($b1)-$xminor)],$[0.5*$yminor],GO\
string red,$[($a-$c)/($b2)],$[1.2*$c],MO\
frect $xmin,$ymax,$[0.9*$xmajor],$[$ymax-0.8*$ymajor],white\
arrow 0,0.8*$p1,$x1,0.8*$p1,8,black\
arrow $x1,0.8*$p1,0,0.8*$p1,8,black\
arrow $x1,0.8*$p2,$x2,0.8*$p2,8,black\
arrow $x2,0.8*$p2,$x1,0.8*$p2,8,black\
string black,2*$xminor,0.9*$p1,groep 1\
string black,$[$x1+3*$xminor],0.9*$p2,groep 2\
mouse blue,34

answer$n=$[$x1*$p1 + ($x2 - $x1)*$p2]
ans1=$[($x1-0.2*$xminor)*$p1]
ans2=$[(($x2-0.2*$xminor) - ($x1-0.2*$xminor))*$p2]
ans=$[$ans1+$ans2]
var1=$[$(answer$n) - $ans]
var2=1
checkfile=$checkdir/new_number.proc

ss=Van een monopolist zijn de volgende gegevens af te lezen in grafiek.<br />Stel dat deze monopolist in staat is om prijsdiscriminatie toe te passen.<br />Voor <b>groep 1</b> kan zij een prijs vaststellen van &euro; $p1 <br />en voor <b>groep 2</b> een prijs van &euro; $p2.<br />Bereken in de situatie van prijsdiscriminatie de omzet van de monopolist.
question$n=<a onmouseover="return escape('De muis geeft de co&ouml;rdinaten weer in de grafiek')">$ss</a>
textanswer$n=Voorwaarden prijsdiscriminatie:<ul><li>Prijsdiscrimantie kan alleen bij een vorm van monopolie (prijszetter)</li><li>Er moet sprake zijn van verschillende deelmarkten en verschillende prijsafzetfuncties voor hetzelfde product (of dienst)Met andere woorden: vragers moeten gescheiden worden van een verschil in betalingsbereidheid</li><li>Af te lezen uit de grafiek:<ul><li>Groep 1: $x1 &times; &euro; $p1 = &euro; $[$x1*$p1 ]</li><li>Groep 2: ($x2 &minus; $x1) &times; &euro; $p2 = &euro; $[$p2*($x2 - $x1)] </li><li>Totaal : $[$x1*$p1 ] + $[$p2*($x2 - $x1)] = &euro; $(answer$n)</li></ul></li></ul>

!exit
