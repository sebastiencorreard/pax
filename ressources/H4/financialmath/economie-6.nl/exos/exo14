###### ACTIVA #########
gebouw=!randint 300,400
gebouw=$[1000*$gebouw]
inventaris=!randint 50,200
inventaris=$[1000*$inventaris]
voorraden=!randint 400,600
voorraden=$[1000*$voorraden]
debiteuren=!randint 100,300
debiteuren=$[1000*$debiteuren]
kasgelden=!randint 10,30
kasgelden=$[1000*$kasgelden]
banksaldo=!randint 30,70
banksaldo=$[1000*$banksaldo]
sum_links=$[$gebouw + $inventaris + $voorraden + $debiteuren + $kasgelden + $banksaldo]
 
##### PASSIVA #######
hypothecairelening=!randint 150,450
hypothecairelening=$[1000*$hypothecairelening]
rekeningcourant=!randint 75,150
rekeningcourant=$[1000*$rekeningcourant]
crediteuren=!randint 130,250
crediteuren=$[1000*$crediteuren]
# eigenvermogen wordt in eerste intstantie gebruikt voor kloppend maken
sum_rechts=$[$hypothecairelening + $crediteuren + $rekeningcourant]

### kloppend maken #####
diff=$[$sum_links - $sum_rechts]
!if $diff > 0
    eigenvermogen=$diff
!else
    # hmmm niet goed genoeg
    eigenvermogen=!randint 30,60
    eigenvermogen=$[$eigenvermogen*1000]
    sum_rechts=$[$hypothecairelening + $crediteuren + $rekeningcourant + $eigenvermogen]
    diff=$[$sum_links - $sum_rechts]
    !if $diff>0
	crediteuren=$diff
    !else
	rekeningcourant=$[$rekeningcourant + (-1*$diff)] 
    !endif
!endif
sum_rechts=$[$hypothecairelening + $crediteuren + $rekeningcourant + $eigenvermogen]


lijst=Voorraden,Gebouw,Debiteuren,Banksaldo,Kasgelden,Inventaris,Rekening-courant,Eigen vermogen,Hypothecaire lening,Crediteuren
