arrow 38,49,15,49,8,blue\
string blue,20,53,I = $I\
#overheid -> bedrijven\
segment 80,47,80,15,blue\
segment 80,15,3,15,blue\
arrow 3,15,3,46,8,blue\
inputstyle text-align:centercolor:blue;background-color:$k4;font-size:16px\
input 30,13,6,$true4,$intext4 

kringloop=!exec canvasdraw $plaatje
exotext=!append line $kringloop to $exotext
question$n=$ss<br />$ss1
math=0

