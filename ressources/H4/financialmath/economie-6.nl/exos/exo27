#####
p=$(var9[1])
q=$(var9[2])

xmin=$[-1*$q]
ymin=$[-1*$p]
xmax=$[10*$q]
ymax=$[10*$p]
xsize=600
ysize=400


!if $counter=1
# vraag 1
object1=!exec canvasdraw\
size $xsize,$ysize\
precision 1\
xrange $xmin,$xmax\
yrange $ymin,$[$ymax+0.5*$p]\
axis\
axisnumbering\
xlabel hoeveelheid\
ylabel prijs in \u20AC\
grid $q,$p,grey,4,4,6,blue\
linewidth 2\
fontfamily bold 14px Ariel\
ftriangle 0,$p,$[6*$q],$p,0,$[7*$p],lightgreen\
dashtype 2,2\
dsegment 0,$[7*$p],$[7*$q],0,blue\
dsegment 0,$p,$[7*$q],$p,blue\
dsegment 0,$[4*$p],$[3*$q],$[4*$p],red\
dsegment 0,$[3*$p],$[4*$q],$[3*$p],red\
dsegment $[3*$q],$[4*$p],$[3*$q],0,red\
dsegment $[4*$q],$[3*$p],$[4*$q],0,red\
dsegment $[6*$q],$p,$[6*$q],0,red\
points black,$[3*$q],$[4*$p],$[4*$q],$[3*$p],$[6*$q],$p\
stringup black,$[$q*0.3],$[7.1*$p],$[round(-180*(atan($ysize/$xsize))/pi)],Collectieve vraag\
string black,$[7*$q],$p,MK = GTK = \u20AC $p\
arrow $[6*$q],$[2.5*$p],$[6*$q],$[$p+0.2*$p],8,red\
arrow $[4*$q],$[4.5*$p],$[4*$q],$[3*$p+0.2*$p],8,red\
arrow $[3*$q],$[5.5*$p],$[3*$q],$[4*$p+0.2*$p],8,red\
string black,$[2.5*$q],$[6*$p],Monopolie P = \u20AC $[4*$p]\
string black,$[3.5*$q],$[5*$p],Oligopolie P = \u20AC $[3*$p]\
stirng black,$[5.5*$q],$[3*$p],Volkomen concurrentie P = \u20AC $p\
mouse red,28


ans1=$[18*$p*$q]
ans2=0
ans3=$ans1
ans4=0
answer1=$ans1,$ans2,$ans3,$ans4
var1=yes
checkfile=$checkdir/number.proc
exotext=<br /><table class="demospecial"><caption></caption><tr><td></td><td>Volkomen concurrentie</td></tr><tr><td>Consumentensurplus</td><th>&euro;&nbsp;<input type="text" size="$cols" class="schaersvoorde_input" id="myinput0" value="" /></th></tr><tr><td>Producentensurplus</td><th>&euro;&nbsp;<input type="text" size="$cols" class="schaersvoorde_input" id="myinput1" value="" /></th></tr><tr><td>Totale surplus</td><th>&euro;&nbsp;<input type="text" size="$cols" class="schaersvoorde_input" id="myinput2" value="" /></th></tr><tr><td>Welvaartsverlies <br />(Harberger-driehoek)</td><th>&euro;&nbsp;<input type="text" size="$cols" class="schaersvoorde_input" id="myinput3" value="" /></th></tr></table>
ss=Bestudeer <span class="schaersvoorde_link">deze figuur</span> en vul de gegevens <br />mbt volkomen concurrentie in de onderstaande tabel in.
question1=<a onmouseover="return escape('De muis geeft de co&ouml;rdinaten weer in de grafiek<br />maar ga uit van mooie getallen...')">$ss</a>
textanswer1=Het goede antwoord staat in de tabel bij het derde onderdeel.<br />Het oppervlakte van de gekleurde driehoek is het goede antwoord.<br />Het consumentensurplus is 0.5&times;$[6*$q]&times;($[7*$p] &minus; $p ) = &euro; $ans1
!exit

!endif

