varlist=q
embed=0
make_tr=1
questiontype=0
inputs=1.1
cols=20
rows=1

!if $rounding<1
    rounding=100
    !readproc $remarkdir/rounding.$taal
!endif

answer$n=!item $R of $var2
description=!item $R of $var4
!if $counter>1
    exotext=!append line <kbd><span style="color:blue">$questionnumber $[$counter-1]) $youranswer : $(reply$[$counter-1])</span></kbd><br /> to $exotext
!endif

!if $R=1
    checkfile=$checkdir/equation.proc
    arglist=!item $R of $var5
!else
    !if $R=2
	checkfile=$checkdir/equation.proc
        arglist=!item $R of $var5
    !else
	!if $R=3
	    checkfile=$checkdir/equation.proc
    	    arglist=!item $R of $var5
	!else
	    # een getal :het maximum
	    arglist=$empty
	    checkfile=$checkdir/number.proc
	!endif
    !endif
!endif
logotext=<img src=\'$module_dir/gifs/exo5.$R.jpg\' alt=\'plaatje\' />

question$n=<a onmouseover="return escape('$var8')">$var7 <br /> Stel uit deze gegevens $inputtext1 op.<br />$var3</a>
