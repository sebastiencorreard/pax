    R=$counter
!else
    R=$level
!endif
var5=1
var6=1000
sometext=q,TK_TO_TW,q,Euro (x $var6),Vergelijkingen,Break-evenpunt,Maximale winst,Kosten,Opbrengst,Winst
var7=!item 1 of $sometext
var8=!item 2 of $sometext
var8=!replace internal _ by , in $var8
# record 20 tot 30
# product,min_gs,max_gs,min_al,max_al,factor
# :tuinstoelen,15,55,15,25,20
# :ligstoelen,15,85,20,40,25
# :tafels,30,110,25,65,30
# :tafelkleden,10,40,15,25,20
# :tennisrackets,5,30,10,25,20
# :zwempakken,5,25,15,25,20
# :zonnebrillen,10,20,20,35,30
# :vloerkleden,50,100,20,30,40
# :linnenkasten,50,100,20,30,20
