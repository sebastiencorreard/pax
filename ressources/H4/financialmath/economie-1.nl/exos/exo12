	!if $counter=3
	    description=Belasting &amp; premies
	    ex1=&euro;
	    # new_number.proc
	    # range +/- 2
	    var1=2
	    # integer antwoorden
	    rounding=1
	    var2=1
	!else
	# new_number.proc
	# range: eerste antwoord
	    #var1=0.05,0.05
	    # rounding : eerste antwoord 1 decimaal , tweede antwoord  1 decimaal
	    #var2=10,10
	    
	    # 7.6.2013 eigenhandig verlaagd naar +/- 0.1% ivm andere sommen over %-rekenen
	    var1=0.1,0.1
	    var2=10,10
