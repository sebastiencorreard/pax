# leg alles vast tijdens de eerste vraag
# bewaar de gegevens die later nodig zijn in var1...var9
!if $counter=1
    make_tr=1
    questiontype=0
    mathview=0
    # 24/1/2012: new_number.proc 
    #checkfile=exos/precheck1.proc
    checkfile=$checkdir/new_number.proc
    inputs=1.1
    cols=10
    tarief11=!randint 500,680
    tarief11=$[$tarief11/20]
