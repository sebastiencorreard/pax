# Overheid II
make_tr=1
n=$counter
mathview=0
calculator=1
inputs=0
cols=8
checkfile=exos/precheck1.proc
math=0
questiontype=0
land=!randitem Waterland,Engerland,Duizelland,Fransland,Spaanderland,Welgi&euml;,Noorderrijk,Zweijtserland,Waldolahland

nu=!date +%Y
jaar1=$[$nu - 1]
jaar2=$[$nu - 2]
jaar3=$[$nu - 3]

Ninkomen2=!randint 800,990
tekort2=!randint 40,70
aflossing2=!randint 9,20
tekort1=$[$tekort2+$aflossing2]
d=!randint 200,350
f=!randint 15,40
schuld1=$[$Ninkomen2 - $d]
rente2=!randint 60,80
inkomen=$[$Ninkomen2+$f]
perc=$[round(1000*$tekort1/$inkomen)/10]
ss=Het Nationaal Inkomen van $land bedroeg in $jaar2 &euro; $Ninkomen2 miljard.<br />Het financieringstekort van dit land kwam uit op &euro; $tekort2 miljard in dat jaar.<br /><br />Voor $jaar1 is het financieringstekort &euro; $tekort1 miljard.<br />De staatsschuld van komt eind $jaar1 uit op &euro; $schuld1 miljard.<br />Uitgedrukt in een percentage van het <kbd>BBP</kbd> bedraagt het financieringstekort in $jaar1 $perc %.<br />Aan rente betaalde de overheid in $jaar2 &euro; $rente2 miljard en aan aflossingen &euro; $aflossing2 miljard.<br />Beantwoord de onderstaande vragen.

ans2=$[$schuld1 - $tekort1 - $tekort2]
Ninkomen1=$[($tekort1*100)/$perc]
ans3=$[(round(1000*$schuld1/($Ninkomen1)))/10]

answer$n=$tekort1,$ans2,$ans3
inputs=3
ex1=miljard &euro;
ex2=miljard &euro;
ex3=% (op &eacute;&eacute;n decimaal)
description=Bereken het begrotingstekort in $jaar2,Bereken de omvang van de staatsschuld<br />aan het eind van $jaar3,Bereken voor $jaar1 de <kbd>staatsschuldquote</kbd>

textanswer$n=<ol><li><kbd>Begrotingstekort = Financieringstekort + Aflossing</kbd><br />Begrotingstekort = $tekort2 + $aflossing2 = &euro; $tekort1 miljard.</li><li><kbd><kbd>Staatsschuld in $jaar3 = Staatsschuld $jaar1 &minus; Financieringstekort $jaar1 &minus; Financieringstekort $jaar2</kbd><br />Staatschuld in $jaar3 = $schuld1 &minus; $tekort1 &minus; $tekort2 = &euro; $ans2 miljard</li><li>Nationaal inkomen = $tekort1 &times; 100 <b>/</b> $perc = &euro; $Ninkomen1 miljard<br /><kbd>Staatsschuldquote = Staatsschuld <b>/</b> Nationaal inkomen &times; 100 %</kbd><br />Staatsschuldquote = $schuld1 / $Ninkomen1 &times; 100 % = $ans3 %</li></ol>

helptext=Alle bedragen zijn in miljarden euro&rsquo;s<br /><b>Geef je antwoorden ook in miljarden eur&rsquo;s</b>
#rounding=10
question$n=<a onmouseover="return escape('$helptext')">$ss</a><br />

var10=1,1,10
var1=yes
