# alleen een getal, geen tekst ; daarna $checkdir/number.proc
n=$counter

!if $(reply$n) = ? 
    !if $var9=0
	formula$n=$empty
    !endif
    remark$n=$NOK
    maxscore=0
    goback=0
    !exit
!endif
math=0
# volgorde belangrijk
orgineel=$(reply$n)
reply$n=!lower $(reply$n)
reply$n=!replace [a-z\~!@#$%_=:;"'<>{}] by $empty in $(reply$n)

!readproc $checkdir/new_number.proc

!exit
