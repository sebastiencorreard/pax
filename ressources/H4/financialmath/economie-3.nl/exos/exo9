	ex1=$empty
	rounding=100
	roundingtext=Rond de prijselasticiteit af op twee decimalen.<br />Maar reken wel met hele goederen !!
    !else
        rounding=1
        ex1=stuks
	roundingtext=Rond je antwoord af op hele goederen 
    !endif
!endif

helptext=$roundingtext


