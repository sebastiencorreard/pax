# Prijselasticiteit &amp; grafiek I 
# steps
n=$counter
!if $counter=1
    !if $total_exos>3
	total_exos=3
    !endif
    mathview=0
    checkfile=exos/precheck2.proc
    make_tr=1
    cols=5
    rows=1
    inputs=1.1
    embed=1
    bedrijven=rijwielhandelaar,computerwinkel
    produkten=fietsen,bromfietsen,fiets,bromfiets\
    laptops,netbooks,laptop,netbook
    
    k=!randint 1,2
    bedrijf=!item $k of $bedrijven
    produkt=!line $k of $produkten
    produkt1=!item 1 of $produkt
    produkt2=!item 2 of $produkt
    p1=!item 3 of $produkt
    p2=!item 4 of $produkt 
    aantal1=!randint 5,30
    prijs1=!randint 25,40
    prijs1=$[20*$prijs1]
    rc=!randint 5,9
    rc=$[-1*$rc/100]
    perc=!randint 8,15
    begin=$[$aantal1 - ($rc*$prijs1)]
    func=$[1/($rc)]*(x - $aantal1) + $prijs1
    prijs2=$[$prijs1*(100-$perc)/100]
    #aantal2=$[round($rc*$prijs2+$begin)]
    aantal2=$[$rc*$prijs2+$begin]
    tot=!exec moneyprint $prijs1,$prijs2
    prijs1=$(tot[1])
    prijs2=$(tot[2])
    deltaq=$[100*($aantal2-$aantal1)/$aantal1]
    aantal3=!randint 10,30
    kp=!randint 11,20
    kp=$[$kp/10]
    
    answer1=$prijs1
    textanswer1=Je kunt in de grafiek aflezen dat bij $aantal1 $produkt1 <br />een verwachte prijs  hoort van &euro; $prijs1
        
    answer2=$[$deltaq/(-1*($perc))]
    ans2=$[(round(100*$answer2))/100]
    texanswer2=\left[ \begin{array}{l} \textrm{De nieuwe prijs wordt : } \frac{100 - $perc}{100} \times $prijs1 = $[(100-$perc)/100] \times $prijs1 = $prijs2 \textrm{ euro} \\ \textrm{De nieuwe hoeveelheid wordt : } $rc \times $prijs2 + $begin = $[$rc*$prijs2+$begin] = $aantal2 \textrm{ $produkt1} \\ \Delta q = \frac{$aantal2 - $aantal1}{$aantal1} \times 100 \simeq $deltaq \% \\ E_{v} = \frac{\Delta q}{\Delta p} = \frac{$deltaq}{- $perc} \simeq $answer2 \simeq $ans2 \end{array} \right.
 
    perc3=$[$kp*(-1*$perc)]    
    answer3=$[$aantal3*(100+$perc3)/100]
    ans3=$[round($answer3)]
    texanswer3=\left[ \begin{array}{l} \textrm{De prijsafname van de $produkt1 is $perc \% } \\ E_{k} = $kp = \frac{\Delta q}{\Delta p} \rightarrow \Delta q = $kp \times \Delta p  \\ \Delta q = $kp \times - $perc = $perc3  \\ \textrm{De procentuele verandering van het aantal verkocht $produkt2 is :} $perc3 \% \\ \textrm{Er worden dan } \frac{100 $perc3}{100} \times $aantal3 \simeq $answer3 = $ans3 \;\textrm{ $produkt2} \end{array} \right.
    
    rounding=1
    roundingtext=Rond je antwoord af hele &euro;&rsquo;s
    myname=$wims_nowseconds.data
    !filewrite getfile/$myname $func
    myfile=$wims_ref_name?session=$session&cmd=getfile&special_parm=$myname
    xsize=480
    ysize=300
    ymax=$[100*(ceil(($prijs1 - (1/($rc))*$aantal1)/100))]
    ymin=100
    xmin=0
    xmax=$begin
    
    y1=!evalsubst x=0 in $func
    y2=!evalsubst x=$xmax in $func
    y3=!evalsubst x=$prijs in $func

    canvasimage=!exec canvasdraw\
    size 400,300\
    bgcolor $wims_bgcolor\
    xrange -8,$begin\
    yrange -80,$ymax\
    precision 1\
    axis\
    axisnumbering\
    xlabel aantal $produkt1\
    ylabel prijs in \u20AC\
    grid $[round($begin/10)],$[round($ymax/10)],grey,1,1,0,blue\
    linewidth 3\
    segment 0,$y1,$xmax,$y2,red\
    intooltip <img src='$gifdir/canvas.png' alt='plaatje' />\
    mouseprecision 10\
    mouse blue,32
    
    
    answerplaatje=!exec canvasdraw\
    size 400,300\
    bgcolor $wims_bgcolor\
    xrange -8,$begin\
    yrange -80,$ymax\
    precision 1\
    axis\
    axisnumbering\
    xlabel aantal $produkt1\
    ylabel prijs in \u20AC\
    grid $[round($begin/10)],$[round($ymax/10)],grey,1,1,0,blue\
    linewidth 3\
    segment 0,$y1,$xmax,$y2,red\
    linewidth 1\
    dashtype 3,3\
    dashed\
    vline $aantal1,0,blue\
    dashed\
    hline 0,$prijs1,blue\
    linewidth 3\
    point $aantal1,$prijs1,blue\
    string black,$aantal1,$prijs1,  bij $prijs1 \u20AC : $aantal1 $produkt1
    
    textanswer1=!append line $ $answerplaatje <br /> $ to $textanswer1


    formula1=\left\{ \begin{array}{l} q_{v} = $rc \times p + $begin \\ \\ \textrm{Gevraagd : De prijs per $p1 } \end{array} \right.
    formula2=\left\{ \begin{array}{l} q_{v} = $rc \times p + $begin \\ \\ \textrm{Gevraagd : De prijselasticiteit van $p1 } \end{array} \right.
    formula3=\left\{ \begin{array}{l} q_{v} = $rc \times p + $begin \\ \\ \textrm{Gevraagd : De verwachtte } \\ \textrm{verkochte hoeveelheid $produkt2 } \end{array} \right.

