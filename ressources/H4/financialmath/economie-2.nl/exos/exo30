<param name="convert_initial_tsv_to_matrix" value="0"/>\
<param name="fontsize" value="18"/>\
$nojava\
</object>

ss=Verwerk <span style="color:blue">deze</span> gegevens in het spreadsheet van de balans<br />:\
<br /><br /><table summary="" ><tr><th>Verkochte goederen</th><th>&nbsp;</th></tr><tr><td>Op rekening</td>\
<td>$oprekening</td></tr><tr><td>Contant</td><td>$contant</td></tr><tr><td>Inkoopwaarde</td><td>$inkoop</td></tr></table><hr />

question$n =<a onmouseover="ttLeft=true ;return escape('$static_tabel')">$ss</a>

 
!exit
