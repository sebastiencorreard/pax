# Eigenvermogen II
# 
n=$counter
viewlogo=1
!if $counter=1
    var9=!shuffle 1,2,3,4,5,6,7,8,9
!endif
nm=!item $counter of $var9
logo=<img src="$module_dir/gifs/aandeel_klein.jpg" alt="noalt" />
logotext=<img src=\'$module_dir/gifs/aandeel$nm.jpg\' alt=\'noalt\' />
mathview=0
checkfile=exos/precheck1.proc
make_tr=1
cols=10
rows=1

#fffff0=#e2ffc8
koers1=!randint 6,12
koers1=$[$koers1/2]
plus=!randint 30,80
plus=$[$plus/10]
koers2=$[$koers1+$plus]
tot=!exec moneyprint  $koers1,$koers2
koers1=$(tot[1])
koers2=$(tot[2])

aantal=!randint 400,800
aantal=$[100*$aantal]
aandelen=$[$aantal*$koers1]
answer$n=$[$aantal*($koers2-$koers1)]

textanswer$n=<ul><li>Aantal geplaatste aandelen : $aandelen &divide; $koers1 = $aantal stuks</li><li>De totale omvang van de reserves is : $aantal &times; ($koers2 &minus; $koers1) = $aantal &times; $[$koers2-$koers1] = &euro; $(answer$n)</li></ul>

rounding=1
roundingtext=Rond geldbedragen af  op hele &euro;&rsquo;s [0 decimalen]
inputs=1.1

bedrijf=!randitem Somsen Export BV,Hadjema BV,Vriesekamp BV,Agio NV,Ritsma trading,Bergsma,HaGeBo,Molenkamp BV,VNZ supplies,Wienke trading 

ss=Gegeven:<br />Van $bedrijf is bekend dat de intrinsieke waarde per aandeel &euro; $koers2 bedraagt.<br />De nominale waarde van een aandeel bedraagt &euro; $koers1.<br />Het geplaatste aandelenvermogen is &euro; $aandelen.<br />Bereken de totale omvang van de reserves van $bedrijf. 
description=De totale omvang van de reserves
ex1=&euro;
question$n=<a onmouseover="return escape('$roundingtext')">$ss </a>

!exit
