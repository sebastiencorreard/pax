# netto winst
rounding=100
n=$counter
viewlogo=1
mathview=0
checkfile=exos/precheck2.proc
cols=10
rows=1
k=!randint 1,2
Hij=!item $k of Hij,Zij
hij=!item $k of hij,zij
winkelier=!randitem Oldenkamp,Fries,Smits,Wienke,Scharenborg,Roelhof,Berenschot,Van Waaijen
winkel=!randitem kantoorboekhandel,sigarenwinkel,lingeriezaak,meubelzaak,stoffeerbedrijf,banketbakkerij
perc=!randint 20,300
inkoop=!randint 30,300
inkoopwaarde=$[1000*$inkoop]
f=!randint 50,150
!if $f=100
    f=101
!endif
bedrijfskosten=$[1000*$inkoop*$f/100]
brutowinst=$[$inkoopwaarde*$perc/100]
wv=$[$brutowinst-$bedrijfskosten]
!if $wv=0
    bedrijfskosten=$[$bedrijfskosten-100]
    wv=100
!endif

ss=Winkelier $winkelier is eigenaar van een $winkel.<br />$Hij hanteert een gemiddelde brutowinstopslag van $perc %.<br />De gezamenlijke inkoopwaarde van de artikelen die $hij het <br />afgelopen jaar heeft verkocht,bedroeg &euro; $inkoopwaarde .<br />De totale bedrijfskosten bedroegen &euro; $bedrijfskosten .<br />Bereken de behaalde nettowinst (of verlies) over het vorige jaar.<br /><small><em>Geef je getals antwoord op in 2 decimalen nauwkeurig.</em></small>


!if $wv>0
    ww=1
    txt=is groter dan 0 ; er wordt dus winst gemaakt.
!else
    ww=-1
    txt=is kleiner dan 0 ; er wordt dus verlies gemaakt.
!endif
textanswer$n=De brutowinst = inkoopwaarde &times; brutowinstopslag % = $inkoopwaarde &times; $perc/100 = &euro; $brutowinst<br />De nettowinst =  brutowinst &minus; bedrijfskosten =  $brutowinst &minus; $bedrijfskosten =  &euro; $wv <br /> $txt

answer$n=$ww,$[abs($wv)]
make_tr=1
inputs=2
ex1=?
ex2=&euro;
question$n=<a onmouseover="return escape('voer bij de eerste vraag iets in  als<ul><li>winst  / verlies</li><li>+ / &minus;</li><li>ja / nee </li></ul>')">$ss</a>
description=Maakt $winkelier winst of verlies?,En hoeveel winst of verlies ?
#fffff0=#e2ffc6
