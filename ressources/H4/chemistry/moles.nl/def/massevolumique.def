!set title=Soortelijke massa
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
email=georgesk@ofset.org
precision=100

ansorder=r,r,r,r,r,r
varcnt=11
prevarcnt=10
postvarcnt=0
replycnt=6
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/triplerelation/tabular                                                                                                        	 (Massa van de gouden kroon,g,1050,2925,y*z),                                                                                                   	 (Volume van de gouden kroon,ml,100,150,x/z),                                                                                                   	 (Rho (soortelijk gewicht),g/ml,10.5,19.5,x/y),3,2,2 
tmp0=$slib_out
val6=$(tmp0)
tmp0=!item 1 of $val6

val7=$(tmp0)
tmp0=!item 2 of $val6

val8=$[rint($(tmp0))]
val9=$[rint($val8+1)]
val10=$[rint(2+$val8)]
tmp0=!item 3 to $val10 of  $val6

val11=$(tmp0)
val12=$[rint($val10+1)]
val13=$[rint($val12+$val8)]
tmp0=!item $val12 to $val13 of  $val6

val14=$(tmp0)
tmp0=!item $val9 of  $val14

val15=$(tmp0)
replytype1=units
replyname1=
replygood1=$(val11[1])
replytype2=units
replyname2=
replygood2=$(val11[2])
replytype3=units
replyname3=
replygood3=$(val11[3])
replytype4=units
replyname4=
replygood4=$(val11[4])
replytype5=units
replyname5=
replygood5=$(val11[5])
replytype6=units
replyname6=
replygood6=$(val11[6])
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<script type="text/javascript" src="scripts/js/wz_tooltip.js"></script> 	De koning van Syracuse vroeg aan Archimedes of deze kon vaststellen	of een kroon van puur goud danwel van een veel goedkopere legering van zilver was gemaakt...	zonder deze te smelten.<br>En "ja" dat kon hij !	(<a href="http://nl.wikipedia.org/wiki/Wet_van_Archimedes" target="_new">klik hier</a> voor het hele verhaal...)	<br>	<a onmouseover="Tip('<img src=$val1/../example1.jpg>', BGCOLOR, '#D3E3F6')">Vul nu de <u><font color=blue>tabel</font></u> in </a>		 <br>	  
!if $m_debug=1 
$()	  debug/tricherie : $val11	  <br>	  
!endif
$()	  
!for m_i=1 to $val8 
$()	  $(val14[$m_i])	   
!read oef/embed.phtml reply\i,10 
$()	  
!next
$()	 $val15	
$()
!exit

