!set title=Bereken de verdunning (1)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
email=georgesk@ofset.org
precision=100

ansorder=r
varcnt=6
prevarcnt=5
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem zout, natriumchloride , zilvernitraat,natriumthiosulfaat, ijzer(III)chloride, citroenzuur, suiker, kopersulfaat, kaliumpermanganaat, zwavelzuur, glucose, natriumhydroxide

val6=$(tmp0)
tmp0=!randitem 0.001,0.002,0.005,0.01,0.02,0.05,0.1,0.2,0.5,1

val7=$[$(tmp0)]
tmp0=!randitem 5,10,20,25

val8=$[$(tmp0)]
tmp0=!randitem 50,100,200,250,500,750,1000

val9=$[$(tmp0)]
val10=$[$val8*$val7/$val9]
replytype1=units
replyname1=concentratie $val6
replygood1=$val10 mol/L
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<br>	<img src=$val1/../verrerie.jpg align=left>	We hebben een stamoplossing $val6 met een concentratie van <b>$val7 mol/l</b>.<br>	We pipeteren uit deze stamoplossing $val8 ml in een maatkolf van <b>$val9 ml</b><br>	Vullen aan met water tot de streep.	<hr width=60%>	Wat is nu de concentratie $val6 in de maatkolf ?	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=1,6,7,8,9
embedcnt=0
