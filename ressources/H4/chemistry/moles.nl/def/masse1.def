!set title=Molmassa I
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
email=georgesk@ofset.org
precision=100

ansorder=r,r,r,r,r,r,r,r,r
varcnt=13
prevarcnt=12
postvarcnt=0
replycnt=9
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=$[rint($val2+2)]
tmp=!trim water,H2O	kooldioxide,CO2	koolmonoxide,CO	ijzersulfide,FeS	ijzer(III)oxide,Fe2O3	aluminiumoxide,Al2O3	ijzer(II)sulfaat,FeSO4	ijzer(III)sulfaat,Fe2(SO4)3	aluminiumsulfaat,Al2(SO4)3	ammoniumsulfaat,(NH4)2SO4	natriumbicarbonaat [bakpoeder],NaHCO3	natriumcarbonaat [soda],Na2CO3	kaliumpermanganaat ,KMnO4	natriumthiosulfaat [thio],Na2(S2O3)	kwik(I)chloride [calomel],Hg2Cl2	kwik(II)chloride,HgCl2 	tin(II)chloride,SnCl2	molybdeendisulfide,MoS2	waterstof,H2	zuurstof,O2	stikstof,N2	argon,Ar	Helium,He	bicarbonaat ion,HCO3^-	fluoride ion, F^-	natrium ion, Na^+	cyanide ion, CN^-	sulfiet ion, SO3^2-	sulfaat ion, SO4^2-	sulfide ion, S^2-	ijzer(II) ion, Fe^2+	aluminium ion, Al^3+	ammonium ion, NH4^+
val7=!translate internal $	\
$ to ;; in $tmp
tmp0=!itemcnt $val7

val8=$[rint($(tmp0)-1)]
tmp0=!shuffle $val8

tmp1=$(tmp0)

val9=$(tmp1)
val10=
val11=
val12=
!for val13 =1 to $val6 
val14=$(val7[$(val9[$val13]);2])
!readproc slib/chemistry/chemeq_tex $val14 
tmp0=$slib_out
val10=$val10 $(tmp0),
!readproc slib/chemistry/chemeq_mass $val14 
tmp0=$slib_out
val11=$val11 $(tmp0),
val12=$val12 r$val13,
!next
oefsteps=$val12 
nextstep=!nosubst $val12 
!readproc oef/steps.proc
replytype1=units
replyname1=
replygood1=$(val11[1]) g/mol
replytype2=units
replyname2=
replygood2=$(val11[2]) g/mol
replytype3=units
replyname3=
replygood3=$(val11[3]) g/mol
replytype4=units
replyname4=
replygood4=$(val11[4]) g/mol
replytype5=units
replyname5=
replygood5=$(val11[5]) g/mol
replytype6=units
replyname6=
replygood6=$(val11[6]) g/mol
replytype7=units
replyname7=
replygood7=$(val11[7]) g/mol
replytype8=units
replyname8=
replygood8=$(val11[8]) g/mol
replytype9=units
replyname9=
replygood9=$(val11[9]) g/mol
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Bereken de molmassa in -minimaal- twee decimalen nauwkeurig van het molecuul (of ion) :	<table cellspacing="5" cellpadding="5" border="1">	  <tr>	    <th>Chemische stof</th>	    <th>Chemische formule</th>	    <th>Molmassa</th>	  </tr>	 
!for m_j=1 to $val6 
$()	 <tr>	  <td>$(val7[$(val9[$m_j]);1])</td>	  <td>
!insmath $(val10[$m_j])
$()</td>	  <td> 
!read oef/embed.phtml r\j 
$()</td>	 </tr>	 
!next
$()	</table>	<hr>	<a href="$val1/../m.html" target="_new">hier</a> staat het <tt>periodiek systeem de elementen</tt>.	
$()
!exit

