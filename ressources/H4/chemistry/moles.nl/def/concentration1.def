!set title=Bereken de concentratie
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
email=georgesk@ofset.org
precision=100
precision=100

ansorder=r,r,r,r,r,r
varcnt=12
prevarcnt=11
postvarcnt=0
replycnt=6
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem zout, natriumchloride , zilvernitraat,natriumthiosulfaat, ijzer(III)chloride, citroenzuur, suiker, kopersulfaat, kaliumpermanganaat, zwavelzuur, glucose, natriumhydroxide

val6=$(tmp0)
!readproc slib/triplerelation/tabular 	 (Hoeveelheid chemische stof,mol,0.01,0.2,y*z),	 (Volume,l,0.15,0.99,x/z),	 (Concentratie,mol/l,0.01,1.5,x/y),3,2,2 
tmp0=$slib_out
val7=$(tmp0)
tmp0=!item 1 of $val7

val8=$(tmp0)
tmp0=!item 2 of $val7

val9=$[rint($(tmp0))]
val10=$[rint($val9+1)]
val11=$[rint(2+$val9)]
tmp0=!item 3 to $val11 of  $val7

val12=$(tmp0)
val13=$[rint($val11+1)]
val14=$[rint($val13+$val9)]
tmp0=!item $val13 to $val14 of  $val7

val15=$(tmp0)
tmp0=!item $val10 of  $val15

val16=$(tmp0)
replytype1=units
replyname1=
replygood1=$(val12[1])
replytype2=units
replyname2=
replygood2=$(val12[2])
replytype3=units
replyname3=
replygood3=$(val12[3])
replytype4=units
replyname4=
replygood4=$(val12[4])
replytype5=units
replyname5=
replygood5=$(val12[5])
replytype6=units
replyname6=
replygood6=$(val12[6])
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<script type="text/javascript" src="scripts/js/wz_tooltip.js"></script> 	We bereiden een oplossing van $val6 door een hoeveelheid van 	<i>n</i> mol op te lossen in een volume V water.	Dit geeft een concentratie <i>c</i>.	<a onmouseover="Tip('<img src=$val1/../example2.jpg>', BGCOLOR, '#D3E3F6')">Vul nu de <u><font color=blue>tabel</font></u> in </a>		 <br>	  
!if $m_debug=1 
$()	  debug/tricherie : $val12	  <br>	  
!endif
$()	  
!for m_i=1 to $val9 
$()	  $(val15[$m_i])	   
!read oef/embed.phtml reply\i,15 
$()	  
!next
$()	 $val16	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=1,6,9,12,15,16
embedcnt=1
