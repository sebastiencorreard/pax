    vraag5=<input id="myinput4" size="10" style="font-size:18px;background-color:yellow;border:1px solid #ff0000;" type="text" value="" />
    vraag6=<input id="myinput5" size="10" style="font-size:18px;background-color:yellow;border:1px solid #ff0000;" type="text" value="" />
    
    applettext=$Atom + O_{2} \rightarrow
!endif

