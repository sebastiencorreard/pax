!endif
num=!item $counter of $var5
data=!record $num of docs/data2.def
# vraag1
bruto=!line 4 of $data
verhouding=!words2items $bruto
verhouding=!replace [A-za-z] by $empty in  $verhouding
ans2=!item 1 of $verhouding
ans3=!item 2 of $verhouding
mfactor=$[($ans3/$ans2)/2]
M_metaloxide=!line 5 of $data
ans1=$M_metaloxide
Mo2=31.9988
Av=24.5
# molmassa metaal uitrekenen
# M_metaloxide = $ans2*M_metal + $ans3*M_o
# $ans2*M_metal =  M_metaloxide - $ans3*Mo
# $ans2*M_metal =  M_metaloxide - ($ans3/2)*Mo2
# M_metal = ( $M_metaloxide - ($ans3/2)*$Mo2)/$ans2
M_metal = $[($M_metaloxide - ($ans3/2)*$Mo2)/$ans2]

texanswer$n=!line 9 of $data
Atom=!line 11 of $data
!if $taal=en
    chemical=!line 1 of $data
!else
    !if $taal=nl
	chemical=!line 2 of $data
	chemical=!item 1 of $chemical
    !else
        chemical=!line 1 of $data
    !endif
!endif

metal=!word 1 of $chemical
metaloxide=!nospace $chemical
w=!randint 100,999
w=$[$w/100]
pow=-1
weight=$[$w*10^($pow)]
# weight in gr !
mols_metal=$[($weight)/$M_metal]
# mols = $weight*10^-3/$M
k=!randint 0,1
!if $k=0
    # metal_weight is html
    metal_weight=$w&times;10<sup>$pow</sup>
    weight_unit=g
!else
    pow=$[$pow+3]
    !if $pw=0
	metal_weight=$w
    !else
        metal_weight=$w&times;10<sup>$pow</sup>
    !endif
    weight_unit=mg
!endif

# mol O2 voor $weight $metal
ans4=$[$mfactor*$mols_metal]
ans5=$[$ans4*$Mo2]
ans6=$[$Av*$ans4]

!for p=42 to 51
    L$p=!record $p of lang/remarks.$taal
!next p
text=!nosubst $L42<ol><li>$L43</li><li>$L44</li><li>$L45</li><li>$L46</li><li>$L47<ol><li>$L48<li>$L49<li>$L50</ol></li></ol>$L51
tot=!exec moneyprint $ans1,$ans2,$ans3,$ans4,$ans5,$ans6 3
!for p=1 to 6
    ans_$p=!item $p of $tot
!next p

