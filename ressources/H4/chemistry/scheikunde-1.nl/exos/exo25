     file=m_alcohols.js.el
    !endif
   !else
    !if $subject=29
     !if $R=1 
      file=n_acids.js.el
     !else
      file=m_acids.js.el
     !endif
    !else
     !if $subject=30
      file=aromatics.js.el
     !endif
    !endif
   !endif
  !endif
 !endif
!endif

deffile=docs/$file
# altijf een andere vraag
!if $counter=1
    max=!recordcnt $deffile
    var9=$empty
    !for p=1 to $max
	var9=!append item $p to $var9
    !next p
    var9=!shuffle $var9
!endif
num=!item $counter of $var9
this=!record $num of $deffile

chemical=!line 2 of $this

!if $taal=nl
    answer$n=!word 1 of $chemical
!else
    !if $taal=fr
	answer$n=!word 1 of $chemical
    !else
	answer$n=!line 1 of $this
    !endif
!endif

# WIMSchem file in js-format
var1=!line 3 of $this
var5=gr/mol
question$n=!record 66 of lang/remarks.$taal
