 !if $R=1 
    file=n_alkanes.js.el
 !else
    file=m_alkanes.js.el
 !endif
!else
 !if $subject=26
  !if $R=1 
    file=n_alkenes.js.el
  !else
    file=m_alkenes.js.el
  !endif
 !else
  !if $subject=27
   !if $R=1 
     file=n_alkynes.js.el
