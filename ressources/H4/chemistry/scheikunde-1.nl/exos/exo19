math=0
# let op dit niet veranderen ivm verschillende lengtes datafiles n_alkanes.js.el,m_alkanes.js.el
!if $level<2
    R=1
!else
    R=2
!endif
!if $subject=19
    template=no
    !if $R=1
	file=n_alkanes 
    !else
	file=m_alkanes 
    !endif
!else
    !if $subject=20
    	template=no
	!if $R=1
	    file=n_alkenes 
	!else	
	    file=m_alkenes 
	!endif
    !else
	!if $subject=21
	    template=no
    	    !if $R=1
		file=n_alkynes 
	    !else
    		file=m_alkynes 
	    !endif
	!else
	    !if $subject=22
		template=no
		!if $R=1
		    file=n_alcohols 
		!else
		    file=m_alcohols 
		!endif
	    !else
		!if $subject=23
		    template=no
		    # limited to normal-hydrocarbonacids
		    file=n_acids 
		!else
		    !if $subject=24
			template=yes
			file=aromatics 
		    !endif
		!endif
	    !endif
	!endif
    !endif
!endif
checkversion=!char 1 to 4 of $wims_version
checkversion=$[$checkversion*100]
new=1
file=!nospace $file .molrecords
checkfile=exos/checkfile4b.proc
javascript=js/wimschem3.js

inputs=0
deffile=docs/$file
# altijd een andere vraag
!if $counter=1
    max=!recordcnt $deffile
    var9=$empty
    # maak een lijst
    !for p=1 to $max
	var9=!append item $p to $var9
    !next p
    var9=!shuffle $var9
!endif

num=!item $counter of $var9
this=!record $num of $deffile
names=!line 1 of $this
!if $taal=nl
    naam=!word 2 of $names
!else
    # english
    naam=!word 1 of $names
!endif
data=!line 2 to -1 of $this
var1=answer.$counter.mol
!filewrite getfile/$var1 $data
# checklist: zie anstype/chemdraw.$taal
