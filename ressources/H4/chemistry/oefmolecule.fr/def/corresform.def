!set title=Correspondance image-formule chimique
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Benoît, Markey; Bernadette,Perrin-Riou ; Marie-joëlle Ramage
email=bernadette.m.riou@orange.fr
language=fr

ansorder=r
varcnt=33
prevarcnt=31
postvarcnt=1
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=2
val7=4
val8=formules chimiques
val9=3
val10=150
val11=130x130x130
val12=image
tmp0=!lookup $val12 in ind.cles

val13=$(tmp0)
tmp0=!shuffle $val13

tmp1=!item 1 to $val9+10 of $(tmp0)

val14=$(tmp1)
val15=
!for val16 =1..$val9 
tmp0=!lookup $(val14[$val16]) in descriptif

val17=$(tmp0)
val17=$(val17[$val7])
tmp0=!translate internal | to , in $val17

val17=$(tmp0)
tmp=!nonempty items $val17

tmp0=!randitem $tmp
val17=$(tmp0)

!ifval $val7 = 4 
tmp0=!append item \($val17) to $val15

val15= $(tmp0) 
!else
tmp1=!append item $val17 to $val15

val15= $(tmp1)
!endif
!next
val18=
!for val16 =$val9+1 to $val9+\redundant 
tmp0=!lookup $(val14[$val16]) in descriptif

val17=$(tmp0)
val17=$(val17[$val7])
tmp0=!translate internal | to , in $val17

val17=$(tmp0)
tmp=!nonempty items $val17

tmp0=!randitem $tmp
val17=$(tmp0)

!ifval $val7 = 4 
tmp0=!append item \($val17) to $val15

val18= $(tmp0) 
!else
tmp1=!append item $val17 to $val15

val18= $(tmp1)
!endif
!next
val19=
!for val16 =1..$val9 
tmp0=!lookup $(val14[$val16]) in descriptif

val20=$(tmp0)
val20=$(val20[$val6])
tmp0=!translate | to , in $val20

val20=$(tmp0)
tmp=!nonempty items $val20

tmp0=!randitem $tmp
val20=$(val14[$val16])/$(tmp0)
tmp0=!append item $val20 to $val19

val19=$(tmp0)
!next
tmp0=!makelist imgrename($val1/ttt	        width=$val10) for ttt in $val19

val21=$(tmp0)
replytype1=correspond
replyoption1=split 
replyname1=Correspondance
replygood1=$val21;$val15
question=__EXECUTED_1692754_EXERCISE__
help=!nosubst  Voici le code des couleurs des atomes : <table class="wimscenter wimsborder"> <tr> <th>Nom</th><th>Symbole</th><th>Image</th><th>Nom</th><th>Symbole</th> <th>Image</th><th>Nom</th><th>Symbole</th><th>Image</th> </tr><tr> <td>bore</td> <td>B</td> <td><img src="$val1/atome/b.png" $val11 alt=""></td> <td>béryllium</td> <td>Be</td> <td><img src="$val1/atome/be.png" $val11 alt=""></td> <td>carbone</td> <td>C</td> <td><img src="$val1/atome/c.png" $val11 alt=""></td> </tr><tr> <td>chlore</td> <td>Cl</td> <td><img src="$val1/atome/cl.png" $val11 alt=""></td> <td>fluor</td> <td>F </td> <td><img src="$val1/atome/f.png" $val11 alt=""></td> <td>hydrogčne</td> <td>H</td> <td><img src="$val1/atome/h.png" $val11 alt=""></td> </tr><tr> <td>azote</td> <td>N</td> <td><img src="$val1/atome/n.png" $val11 alt=""></td> <td>oxygčne</td> <td>O</td> <td><img src="$val1/atome/o.png" $val11 alt=""></td> <td>phosphore</td> <td>P</td> <td><img src="$val1/atome/p.png" $val11 alt=""></td> </tr><tr> <td>soufre</td> <td>S</td> <td><img src="$val1/atome/s.png" $val11 alt=""></td> </tr> </table> 


!goto stat

!exit

:question
$()	<div class="wims_instruction">Le code des couleurs se trouve en indication.</div>	<div class="wims_question">Mettre en correspondance les images des modčles	moléculaires avec leur $val8.	<div class="wimscenter"> 
!read oef/embed.phtml r1,$val11 
$()</div></div>	
$()
!exit

