!set title=Click : Molécules et noms
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Benoît, Markey; Bernadette,Perrin-Riou ; Marie-joëlle Ramage
email=bernadette.m.riou@orange.fr
language=fr

ansorder=r
varcnt=33
prevarcnt=31
postvarcnt=1
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=1
val7=2
val8=le nom
val9=3
val10=130
val11=image
tmp0=!lookup $val11 in ind.cles

val12=$(tmp0)
tmp0=!shuffle $val12

tmp1=!item 1 to $val9+10 of $(tmp0)

val13=$(tmp1)
val14=
!for val15 =1..$val9 
tmp0=!lookup $(val13[$val15]) in descriptif

val16=$(tmp0)
val16=$(val16[$val7])
tmp0=!translate | to , in $val16

val16=$(tmp0)
tmp=!nonempty items $val16

tmp0=!randitem $tmp
val16=$(val13[$val15])/$(tmp0)
tmp0=!append item $val16 to $val14

val14=$(tmp0)
!next
tmp0=!makelist imgrename($val1/ttt	        width=$val10) for ttt in $val14

val17=$(tmp0)
tmp0=!randint 1, $val9

val18=$[rint($(tmp0))]
val19=
!for val15 =1..$val9 
tmp0=!lookup $(val13[$val15]) in descriptif

val20=$(tmp0)
val20=$(val20[$val6])
tmp0=!translate internal | to , in $val20

val20=$(tmp0)
tmp=!nonempty items $val20

tmp0=!randitem $tmp
val20=$(tmp0)

!ifval $val6 = 4 
tmp0=!append item \($val20) to $val19

val19= $(tmp0) 
!else
tmp1=!append item $val20 to $val19

val19= $(tmp1)
!endif
!next
val21=
!for val15 =$val9+1 to $val9+\redundant 
tmp0=!lookup $(val13[$val15]) in descriptif

val20=$(tmp0)
val20=$(val20[$val6])
tmp0=!translate internal | to , in $val20

val20=$(tmp0)
tmp=!nonempty items $val20

tmp0=!randitem $tmp
val20=$(tmp0)

!ifval $val6 = 4 
tmp0=!append item \($val20) to $val19

val21= $(tmp0) 
!else
tmp1=!append item $val20 to $val19

val21= $(tmp1)
!endif
!next
replytype1=click
replyname1=Bonne réponse
replygood1=$val18;$val17
question=__EXECUTED_1692754_EXERCISE__
help=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="wims_instruction">On peut consulter le code des couleurs en aide.</div>	<div class="wims_question">	Voici une série d'images représentant les modčles éclatés de différentes molécules,	cliquez sur la molécule dont	$val8 est <b>$(val19[$val18])</b>.	<ul class="inline wimscenter wims_nopuce">	  
!for m_c=1 to $val9 
$()<li> 
!read oef/embed.phtml r1,\c 
$()</li> 
!next
$()	 </ul></div>	
$()
!exit

:hint
$()
$()
!exit

:help
$() Voici le code des couleurs des atomes :	<table class="wimscenter wimsborder">	<tr>	 <th>Nom</th><th>Symbole</th><th>Image</th><th>Nom</th><th>Symbole</th>	 <th>Image</th><th>Nom</th><th>Symbole</th><th>Image</th>	</tr><tr>	 <td>bore</td>	 <td>B</td>	 <td><img src="$val1/atome/b.png" $m_size alt=""></td>	 <td>béryllium</td>	 <td>Be</td>	 <td><img src="$val1/atome/be.png" $m_size alt=""></td>	 <td>carbone</td>	 <td>C</td>	 <td><img src="$val1/atome/c.png" $m_size alt=""></td>	</tr><tr>	 <td>chlore</td>	 <td>Cl</td>	 <td><img src="$val1/atome/cl.png" $m_size alt=""></td>	 <td>fluor</td>	 <td>F </td>	 <td><img src="$val1/atome/f.png" $m_size alt=""></td>	 <td>hydrogčne</td>	 <td>H</td>	 <td><img src="$val1/atome/h.png" $m_size alt=""></td>	 </tr><tr>	<td>azote</td>	 <td>N</td>	 <td><img src="$val1/atome/n.png" $m_size alt=""></td>	 <td>oxygčne</td>	 <td>O</td>	 <td><img src="$val1/atome/o.png" $m_size alt=""></td>	 <td>phosphore</td>	 <td>P</td>	 <td><img src="$val1/atome/p.png" $m_size alt=""></td>	 </tr><tr>	<td>soufre</td>	 <td>S</td>	 <td><img src="$val1/atome/s.png" $m_size alt=""></td>	</tr>	</table>	
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:postdef
val22=style="width:70px;height:70px;"

!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=1,8,9,18,19
embedcnt=1
