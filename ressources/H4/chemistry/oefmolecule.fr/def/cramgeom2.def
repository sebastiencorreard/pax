!set title=Représentation de Cram (avec repčre)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Benoît, Markey; Bernadette, Perrin-Riou; Marie-joëlle, Ramage
email=bernadette.m.riou@orange.fr
language=fr

ansorder=r
varcnt=32
prevarcnt=31
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=1
tmp0=!lookup cramimage in ind.cles

val7=$(tmp0)
tmp0=!shuffle $val7

tmp1=!item 1 of $(tmp0)

val8=$(tmp1)
tmp0=!lookup $val8 in descriptif

val9=$(tmp0)
val10=$(val9[1])
tmp0=!lower $val10

!readproc slib/lang/frapostrophe de $(tmp0) 
tmp1=$slib_out
val11=$(tmp1)
val12=$(val9[4])
tmp0=!translate | to , in $(val9[3])

val13=$(tmp0)
tmp=!nonempty items $val13

tmp0=!randitem $tmp
val13=$(tmp0)
tmp0=!declosing $val13

val13=$(tmp0)
val14=$val8/$(val13[1])
tmp0=!itemcnt $val13

val15=$(tmp0)
tmp0=!translate | to , in $(val9[2])

val16=$(tmp0)

!ifval $val15 = 1 
tmp=!nonempty items $val16

tmp0=!randitem $tmp
val16= $val8/$(tmp0)
!else
val16=	$val8/$(val13[2])
!endif
val17=C1
val18=arrow 30,50,30,7,10,black	arrow 30,50,70,50,10,black	arrow 30,50,10,70,10,black	text black,12,68,medium,x	text black,35,5,medium,z	text black,72,50,medium,y	text black,30,52,medium,$val17
val19=$val17
tmp0=!append word yz to $val19

val19=$(tmp0)
tmp0=!nospace $val19

val19=$(tmp0)
val20=dans le plan $val19, en avant du plan $val19, en arričre du plan $val19
val21=$(val9[7])
tmp0=!replace internal | by , in $val21

val21=$(tmp0)
val22=
tmp0=!replace item number 1 by $val22 in $val21

val21=$(tmp0)
val23=$(val9[8])
tmp0=!replace internal | by , in $val23

val23=$(tmp0)
val24=$(val9[9])
tmp0=!replace internal | by , in $val24

val24=$(tmp0)
tmp0=!nonempty items $val21,$val23,$val24

tmp=!nonempty items $(tmp0)

tmp1=!randitem $tmp
val25=$(tmp1)

!ifval $val25 isin $val21 
val26= 1
!else
val26= 3
!endif

!ifval $val25 isin $val23 
val26= 2
!endif
replytype1=radio
replyname1=
replygood1=$val26;$val20
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Voici la représentation de Cram de la molécule	$val11 dont la formule chimique est 
!insmath $val12
$() :	<div class="wimscenter"><img src="$val1/$val14" alt=""></div>	On considčre le repčre	<div class="wimscenter"> 
!read oef/draw.phtml 80,80 \
$val18 
$()</div>	L'atome $val25 est	<ul>	 <li> 
!read oef/embed.phtml reply1,1 
$()</li>	 <li> 
!read oef/embed.phtml reply1,2 
$()</li>	 <li> 
!read oef/embed.phtml reply1,3 
$()</li>	</ul>
$()
!exit

:hint
$()
$()
!exit

