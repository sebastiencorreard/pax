\text{listereponse=\liaison}
\text{reponse=}
\text{taille=40}
\integer{cnt=items(\molecule[;1])-1}
\matrix{mol=\molecule[2,3,4,5,6,7;]}
\integer{M=items(\molecule[2;])}
\integer{N=(\M+1)/2}
\text{compt=0}
\text{rangex=0.5,\M+1}
\text{rangey=0,\cnt+0.5}
\integer{SIZEy=\taille*(\cnt+1)}
\integer{SIZEx=\taille*(\M+1)}

\text{tableau=<table class="wimscenter">}
\matrix{POS=}
\for{k=1 to \cnt}{
  \text{tableau=\tableau
      <tr>}
  \text{ligne=\mol[\k;]}
  \for{u=1 to \M}{
    \text{ato=\ligne[\u]}
    \text{ato=wims(declosing \ato)}
    \text{atome=item(1,\ato)}
    \if{\ato <> 100}{
      \integer{compt=\compt+1}
      \text{h=slib(draw/convpixel \u,\cnt+1-\k,\SIZEx,\SIZEy,\rangex,\rangey,10,pixels)}
      \matrix{POS=\POS
r \compt, \h[1] x\h[2]
}
    \if{\atome notsametext LL}{
      \text{place = position(\ato[2],\listeposition)}
      \text{placeatom=position(\ato[1],\listeatome)}
      \text{R=\choixposition[\placeatom;]}
      \text{Rs=items(\R)}
      \for{a=1 to \Rs}{
        \text{placechoix=position(\R[\a],\listeposition)}
        \text{listereponse1=wims(replace internal SSS by \atome in \SS[\placechoix])}
        \text{listereponse=\listereponse,\listereponse1}
        \if{\ion=1}{
          \text{listereponse=\listereponse, wims(replace internal SSS by \atome+ in \SS[\placechoix])}
          \text{listereponse=\listereponse, wims(replace internal SSS by \atome- in \SS[\placechoix])}
        }
      }
      \text{listereponse1=wims(replace internal SSS by \atome in \SS[\place])}
      \text{listereponse=\listereponse,\listereponse1}
      \if{\ion=1}{
        \text{listereponse=\listereponse, wims(replace internal SSS by \atome+ in \SS[\place])}
        \text{listereponse=\listereponse, wims(replace internal SSS by \atome- in \SS[\place])}
        \text{reponse=\ato[3] issametext   ?\reponse,\listereponse[-3]}
        \text{reponse=\ato[3] issametext +  ?\reponse,\listereponse[-2]}
        \text{reponse=\ato[3] issametext -  ?\reponse,\listereponse[-1]}
      }{
        \text{reponse=\reponse,\listereponse[-1]}
      }
        \text{tableau=\tableau<td>\atome</td>}
      }{
        \text{reponse=\reponse,\listereponse[\ato[2]]}
        \text{tableau=\tableau<td>......</td>}
      }
    }{\text{tableau=\tableau<td> </td>}}
  }
  \text{tableau=\tableau</tr>}
}
\text{tableau=\tableau</table>}
   \text{dessin= draw(\SIZEx,\SIZEy
   xrange \rangex
   yrange \rangey
)}
\text{reponse=wims(nonempty items \reponse)}
\text{listereponse=wims(nonempty items \listereponse)}
\text{listereponse=wims(listuniq \listereponse)}
\text{H=}
\for{a=1 to \compt}
{ \text{H=\H,position(\reponse[\a],\listereponse)}
}
\text{H=wims(nonempty items \H)}
\text{url=}
\text{cnt_liste=items(\listereponse)}
\for {a =1 to \cnt_liste}{
 \text{b=wims(declosing \listereponse[\a])}
 \text{url=\url,<img src="draw(\taille,\taille
\prelim
\b)" alt="">}
}
\text{url=wims(nonempty items \url)}
\text{reponseurl=\url[\H]}

\text{STEPS=wims(makelist r x for x = 1 to \compt)}
\steps{\STEPS}

** affichage du nom de la molécule **
\text{nombrut=\molecule[1;1]}
\text{nomvrai=}
\integer{nbchar=wims(charcnt \nombrut)}
\for{i1=1 to \nbchar}{
  \text{word1=wims(char \i1 of \nombrut)}
  \if {\word1 notsametext _}{\text{\nomvrai=wims(append word \word1 to \nomvrai)}}
}
\text{\nomvrai=wims(nospace \nomvrai)}

\text{chainemj=wims(record 0 of 1centre)}
\integer{nbrecord=wims(linecnt \chainemj)}
\for{imj=1 to \nbrecord}{
  \text{recordmj=wims(line \imj of \chainemj)}
  \text{symbole=\recordmj[2]}
  \text{\symbole=wims(nospace \symbole)}
  \if{\symbole issametext \nomvrai}{\text {nomenclature=\recordmj[3]}}
}

\text{chainemj=wims(record 0 of 2centres)}
\integer{nbrecord=wims(linecnt \chainemj)}
\for{imj=1 to \nbrecord}{
  \text{recordmj=wims(line \imj of \chainemj)}
  \text{symbole=\recordmj[2]}
  \text{\symbole=wims(nospace \symbole)}
  \if{\symbole issametext \nomvrai}{\text {nomenclature=\recordmj[3]}}
}

\text{denom=slib(lang/frapostrophe de \nomenclature)}
******************************************
\statement{Donner la représentation de Lewis de la molécule \denom
  de symbole chimique \(\molecule[1;1]).

<p>Remarque: Il faut placer les atomes ainsi que les liaisons (ou doublets liants)
 (en rouge) ŕ choisir parmi les propositions.
  Les traits bleus représentent les doublets non liants.</p>

<div class="wimscenter">\special{imagefill \dessin,\SIZEx x \SIZEy,\taille x \taille
\POS
}
</div>
<div class="wims_instruction">
<p>On trouvera en indication la classification périodique.</p>
<p>Consigne : On respectera la disposition suivante des atomes:</p>
\tableau
</div>
}
