** pour choisir sa molecule **
text{choix=18}
*****************************

\matrix{molecule=row(\choix,\liste)}
\matrix{molecule=wims(declosing \molecule)}
\text{LISTECHOIX=\molecule[1;]}
\text{cnt_ato=items(\LISTECHOIX)}
\text{listeatome=}
\matrix{choixposition=}
\for{i=2 to \cnt_ato}{
  \text{B=item(\i,\LISTECHOIX)}
  \text{B=wims(declosing \B)}
  \text{listeatome=\listeatome,\B[1]}
  \matrix{choixposition=\choixposition
  \B[1;2..-1]}
  }
\text{listeatome=wims(nonempty items \listeatome)}
\text{taille=40}
\text{range=-1.5,1.5}
\text{milieu=-0.2,0.5}
\text{couleur=blue}
\text{couleur2=red}
\text{prelim=xrange \range
yrange \range
linewidth 2}
\text{liaison=[polyline \couleur2,-1,0,1,0],
[polyline \couleur2,-1,0.25,1,0.25
polyline \couleur2,-1,-0.25,1,-0.25],
[polyline \couleur2,-1,0.5,1,0.5
polyline \couleur2,-1,0,1,0.
polyline \couleur2,-1,-0.5,1,-0.5],
[polyline \couleur2,0,-1,0,1],
[polyline \couleur2,0.25,-1,0.25,1
polyline \couleur2,-0.25,-1,-0.25,1],
[polyline \couleur2,0.5,-1,0.5,1
polyline \couleur2,0,-1,0,1.
polyline \couleur2,-0.5,-1,-0.5,1],
[polyline \couleur2,-1,-1,1,1],
[polyline \couleur2,-0.75,-0.75,0.75,1.25
polyline \couleur2,-0.75,-1.25,0.75,0.75],
[],
[polyline \couleur2,-1,1,1,-1]
}

\text{listeposition=0,r,u,l,d,r1,ru,ul,ld,dr,ud,rl,rr,ll,uu,dd,rul,uld,ldr,dru,rru,
ull,lld,drr,rul1,u1d1}
\text{SS=[text black,\milieu,medium,SSS],
