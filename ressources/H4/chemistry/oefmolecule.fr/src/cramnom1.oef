\title{Cram ŗ partir du nom}
Mettre l'aide de la molťcule dans un confparm1 par la suite
\text{aide=1}
\real{SIZEX=200}
\real{SIZEY=200}
\text{taille=20 x 20}
\text{rangex=-2,2}
\text{rangey=-2,2}
\text{liste=}
\for{i= 1 to 20}{
  \text{liste=\liste, wims(record \i of dessinCram)}}
\text{a = wims(declosing wims(record 1 of dessinCram))}
\text{angle=pi/24}
text{h=1.3}
\real{cos=cos(\angle)}
\real{sin=sin(\angle)}
\text{Ftriangle=ftriangle 0,0,\cos, -\sin,\cos,\sin,black}
\text{Dtriangle1=triangle 0,0,\cos, -\sin,\cos,\sin,yellow}
\text{Dtriangle2=hatchfill 2*\cos/3,0,5,0,0,black}
\text{Dtriangle3=transparent yellow}
\text{mol=A,X1,X2,X3,X4,X5,X6,X7}
\matrix{M=1,3,6,10
2,5,9
4,8,13
7,12,11
}
