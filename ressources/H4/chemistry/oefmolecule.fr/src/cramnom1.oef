AX_3,AX_3E,AX_3E_2
AX_4,AX_4E,AX_4E_2
AX_5,AX_5E,AX_6
}
===== Choisir les objets dans la catťgorie dťsirťe
On ne prend que les molťcules ayant un seul centre et ayant la clť drawcram
ce qui peut permettre d'ťliminer les ambigus en leur mettant pas cette clť
ťventuelleemnt
\text{all1=wims(lookup drawcram in ind.cles)}
\text{all2=wims(lookup 1centre in ind.cles)}
\text{all = wims(listintersect \all1 and \all2)}
\text{obj=item(1,shuffle(\all))}
\text{molecule=wims(lookup \obj in descriptif)}
\text{nommol = \molecule[1]}
\text{nommol=randitem(wims(translate | to , in \nommol))}
\text{denommol=slib(lang/frapostrophe de wims(lower \nommol))}
\text{formule = \molecule[4]}
\text{type = \molecule[5]}
\text{reponse = wims(translate | to , in \molecule[6])}
\text{reponse = randitem(\reponse)}
\text{reponse = wims(declosing \reponse)}
adresse de l'image
\text{adresse= wims(translate | to , in \molecule[2])}
\text{adresse = \obj/randitem(\adresse)}
%%%
ligne ou se trouve le type
\integer{cnt_X= wims(char 4 of \type)-1}
\text{bon= position(\type,\typeCram[\cnt_X;])}
\text{dessin=}
*** choix des figures ŗ afficher
pas de type AX_2E_3 en seconde : u de 1 ŗ 3
\text{U = shuffle(3)}
*** dťtermination de la bonne rťponse
\text{bon= position(\type,\typeCram[\cnt_X;\U])}
\for{u=1 to 3}{
  \text{h=\M[\cnt_X;\U[\u]]}
  \text{dessin1=wims(record \h of dessinCram)}
  \text{dessin1=randitem(\dessin1)}
  \text{dessin1=wims(declosing \dessin1)}
  \text{dessin1=wims(replace internal Ftriangle by \Ftriangle in \dessin1)}
  \text{dessin1=wims(replace internal Dtriangle1 by \Dtriangle1 in \dessin1)}
  \text{dessin1=wims(replace internal Dtriangle2 by \Dtriangle2 in \dessin1)}
  \text{dessin1=wims(replace internal Dtriangle3 by \Dtriangle3 in \dessin1)}
  \if{ \u = \bon}{
    \text{bondessin=\dessin1}
    \for{s=1 to 7}{
      \text{bondessin=wims(replace internal mol[\s] by in \bondessin)}
    }
    \text{bondessin=draw(\SIZEX, \SIZEY
\bondessin)}
    \matrix{position=}
    \text{posit=wims(record \h of positionpoints)}
    \integer{N = \cnt_X + 2}
    \for {j = 2 to \N+1}{
      \text{p = row(\j-1, \posit)}
      \text{pos=slib(draw/convpixel \p ,\SIZEX,\SIZEY,\rangex,\rangey,10,pixels)}
      \matrix{position=\position
        r \j,\pos[1]x\pos[2]}
    }
  }
  \for{s=1 to 7}{
    \text{dessin1=wims(replace internal mol[\s] by \mol[\s] in \dessin1)}
  }
  \text{dessin1=draw(150,150
   \dessin1)}
  \text{dessin=\dessin, <img src="\dessin1" alt="">}
}
\text{dessin=wims(nonempty items \dessin)}
