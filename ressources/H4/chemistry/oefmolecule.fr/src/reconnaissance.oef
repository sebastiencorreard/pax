\text{file=randomrow(\file_tir)}

\text{enonce=
  Voici la molécule dénommée <i>\file[4]</i>. Cliquez sur les
  atomes formant le groupement \file[1].}
\text{instruction=Ŕ l'aide du bouton gauche de la souris vous pouvez faire pivoter
la molécule.
  Ŕ l'aide de la molette vous pouvez zoomer (positivement ou négativement.)}
\text{A=slib(chemistry/jmolbutton select all)}
\statement{
\A
\enonce
<div class="wimscenter">
\embed{r1, 400x400
;
select all;label %e;select none;
select all;label %e;select none;}
</div>
<div class="wims_instruction">\instruction</div>}

\answer{}{\file[3];\file[2]}{type=jmolclick}

\feedback{1=1}{La bonne réponse s'obtient en cliquant sur les atomes
apparaissant en jaune. En vert: votre bonne réponse. En rouge: votre réponse fausse}
