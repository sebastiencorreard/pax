\integer{j=randint(4..8)}
\integer{px=200}
\integer{py=175}

\text{mots=identiques,isomŤres,non isomŤres}

---------------tirage molecule 1----------------


\text{K=}
\for{i=1 to \p-1}{
\text{K=\K C}
}
\text{K=\K C(=O)}
\for{i2=\p to \j-1}{
\text{K=\K C}
}
\text{mol=slib(text/whitespace ,,\K) }
\comment{\text{A=slib(chemistry/jmolshow @\mol,333,267,,,0)}}


---------------tirage molecule 2----------------

\text{Kbis=}
\for{ibis=1 to \j-2}{
\text{Kbis=\Kbis C}
}
\text{Kbis=\Kbis O}
\for{ibis=\j-1 to \j}{
\text{Kbis=\Kbis C}
}
\text{molbis=slib(text/whitespace ,,\Kbis)}
