---------------tirage molecule 3----------------

\text{Kter=}
\for{iter=1 to \j}{
\text{Kter=\Kter C}
}
\text{Kter=\Kter =O}
\text{molter=slib(text/whitespace ,,\Kter)}
\comment{\text{Ater=slib(chemistry/jmolshow @\molter,\px,\py,,,2)}}

\text{choix1=\mol,\molbis,\molter}

\integer{tir=randint(1..2)}

\if{\tir=1}{
\text{choix2=shuffle(3)}
\text{choix=slib(chemistry/jmolshow @\choix1[\choix2[1]],\px,\py,,,0),slib(chemistry/jmolshow @\choix1[\choix2[2]],\px,\py,,,1),slib(chemistry/jmolshow @\choix1[\choix2[3]],\px,\py,,,2)}
\integer{n1=position(1,\choix2)}
\integer{n2=position(2,\choix2)}
\integer{n3=position(3,\choix2)}

\if{\n1=1}{
\text{rep1=3}
\text{rep2=2}
\text{rep3=3}
}
\if{\n1=2}{
\text{rep1=3}
\text{rep2=3}
\text{rep3=2}
}
\if{\n1=3}{
\text{rep2=3}
\text{rep1=2}
\text{rep3=3}
}
}{
----------ici tir=2---------------
