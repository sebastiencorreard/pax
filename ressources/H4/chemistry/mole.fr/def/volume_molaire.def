!set title=Volume molaire
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Markey,Benoît
email=benoit.markey@ac-lille.fr
keywords=chimie,mole,masse,molaire,concentration,dilution,atom,periodic_table,molecules
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=yes
precision=100

ansorder=r,r
varcnt=14
prevarcnt=13
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=22.4,24.0,30.6,63.4,104.0
val7=0,20,100,500,1000
tmp0=!randint 1, 5

val8=$[rint($(tmp0))]
val9=$[$(val6[$val8])]
val10=$[$(val7[$val8])]
tmp0=!randitem dihydrogène, azote, dioxyde de carbone, hélium, dioxygène, acétylène

val11=$(tmp0)
!readproc slib/lang/frapostrophe de $val11 
tmp0=$slib_out
val12=$(tmp0)
tmp0=!randint 10, 100

val13=$[rint($(tmp0))]
val14=$[$val13/100]
tmp0=!randint 10, 100

val15=$[rint($(tmp0))]
val16=$[$val15/100]
val17=$[$val16*$val9]
val18=$[$val14*$val9]
replytype1=units
replyname1=\(V) 
replygood1=$val18 L
replytype2=units
replyname2=\(n) 
replygood2=$val16 mol
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="wims_question">	<ol><li>Quel est le volume 
!insmath V
$() occupé par $val14 moles  $val12 à la 	température de $val10 °C et à la pression de 1013 hPa, sachant qu'à cette température, le volume molaire vaut $val9 L &times; mol<sup>-1</sup> ?	<div class="spacer"> 
!insmath V
$()= 
!read oef/embed.phtml reply1,10 
$()</div></li>	<li>Quelle est la quantité de matière 
!insmath n
$() contenue dans $val17 L $val12 placé dans les mêmes conditions que précédemment ?	<div class="spacer"> 
!insmath n
$()= 
!read oef/embed.phtml reply2,10 
$()</div></li></ol></div>		<div class="wims_instruction">	Consigne :	<ul class="wims_nopuce">	<li>Ne pas oublier l'unité.</li></ul></div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=9,10,12,14,17
embedcnt=2
