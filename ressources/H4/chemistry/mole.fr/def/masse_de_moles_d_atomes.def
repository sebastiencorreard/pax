val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!trim H,hydrogĶne,1,1,1,0,0,1.01,+	He,Hķlium,4,2,2,0,0,4,2+	Li,Lithium,7,3,2,1,0,6.94,+	Be,Bķryllium,9,4,2,2,0,9,2+	B,Bore,11,5,2,3,0,10.8,3+	C,Carbone,12,6,2,4,0,12,n'existe pas	N,Azote,14,7,2,5,0,14,3-	O,OxygĶne,16,8,2,6,0,16,2-	F,Fluor,19,9,2,7,0,19,-	Ne,Nķon,20,10,2,8,0,20.2,n'existe pas	Na,Sodium,23,11,2,8,1,23,+	Mg,Magnķsium,24,12,2,8,2,24.3,2+	Al,Aluminium,27,13,2,8,3,27,3+	Si,Silicium,28,14,2,8,4,28.1,n'existe pas	P,Phosphore,31,15,2,8,5,31,3-	S,Soufre,32,16,2,8,6,32.1,2-	Cl,Chlore,35,17,2,8,7,35.5,-	Ar,Argon,40,18,2,8,8,39.9,n'existe pas	
val6=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val6

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$(tmp0)
val8=$[rint($(val7[3])-$(val7[4]))]
val9=$[1.7E-27*($(val7[3]))]
tmp0=!randint 1, 26

val10=$[rint($(tmp0))]
val11=$[$val10*$val9*6.02E26]
!readproc slib/lang/frapostrophe de $(val7[2]) 
tmp0=$slib_out
val12=$(tmp0)
!readproc slib/chemistry/leftind $(val7[3]),$(val7[4]),$(val7[1]), 
tmp0=$slib_out
val13=$(tmp0)
replytype1=units
replyname1=protons
replygood1=$val9 kg
replytype2=units
replyname2=Question 2
replygood2=$val11 g 
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

