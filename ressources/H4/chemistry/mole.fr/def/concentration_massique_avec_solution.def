!set title=Concentration massique : exercice avec solution
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Markey, Benoît
email=benoit.markey@ac-lille.fr
keywords=chimie,mole,masse,molaire,concentration,dilution,atom,periodic_table,molecules
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no

ansorder=r
varcnt=16
prevarcnt=15
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 100, 9999

val6=$[rint($(tmp0))]
val7=$[$val6/10000]
tmp0=!randint 2, 4

val8=$[rint($(tmp0))]
!readproc slib/text/sigunits $val7 ,$val8 
tmp0=$slib_out
val9=$(tmp0)
tmp0=!randint 10, 200

val10=$[rint($(tmp0))]
tmp0=!randint 2, 4

val11=$[rint($(tmp0))]
!readproc slib/text/sigunits $val10 ,$val11 
tmp0=$slib_out
val12=$(tmp0)
val13=$[rint(min($val8,$val11))]
val14=$[$val9/($val12/1000) ]
val15=$[$val12*0.001]
!readproc slib/text/sigunits $val14 g/L,$val13 
tmp0=$slib_out
val16=$(tmp0)
!readproc slib/text/sigunits $val14 g,$val13 
tmp0=$slib_out
val17=$(tmp0)
tmp=!trim de diiode,d'hydroxyde de sodium,de saccharose,d'acide chlorhydrique, d'acide nitrique, de soude, d'acide acétique,de chlorure de sodium
val18=!translate internal $	\
$ to ;; in $tmp
tmp0=!shuffle $val18

tmp=!trim $(tmp0)
val19=!translate internal $	\
$ to ;; in $tmp
val20=$(val19[1])
replytype1=sigunits
replyname1=\(c_m) 
replygood1=$val16
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="wims_question">	Calculer la concentration massique 
!insmath c_m
$() d'une solution de volume 
!insmath V
$() =
!insmath $val12
$() mL	contenant m=
!insmath $val9
$() g $val20.	<div class="spacer">
!insmath c_m
$() =  
!read oef/embed.phtml reply1 
$()</div></div>		<div class="wims_instruction">Consignes : 	<ul class="wims_nopuce"><li>Ne pas oublier l'unité. </li>	<li>Les chiffres significatifs sont pris en compte.</li>	<li> Le séparateur de décimales est le point (.).</li>	<li> Vous pouvez utiliser l'écriture scientifique pour répondre : 
!insmath 3.01E-5 mol
$() s'écrit 3.01e-5 mol (un espace entre le nombre et l'unité).</li></ul></div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()La réponse s'obtient en calculant 
!insmath c_m
$()=
!insmath m/V
$() sans oublier de convertir 	le volume 
!insmath V
$() en litres : 
!insmath V=$val10 mL = $val15 L
$() . 	<div class="wims_emph spacer">Sans tenir compte des chiffres significatifs, le calcul donne : 
!insmath c_m
$()=$val14 g/L</div>	<div class="spacer">La réponse doit ętre donnée avec $val13 chiffres significatifs car  
!insmath m=$val9 g
$() est écrit avec $val8 chiffres significatifs 	 et 
!insmath V=$val12 mL
$() est écrit avec  $val11 chiffres significatifs. Si le nombre de chiffres significatifs est différent, 	la solution est présentée avec le plus petit nombre de chiffres significatifs. </div>	<div class="wims_emph">Ce qui nous donne, en tenant compte des chiffres significatifs : 
!insmath c_m
$()=$val16.</div>
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=8,9,10,11,12,13,14,15,16,20
embedcnt=1
