!set title=Masse molaire : exercice avec solution
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Markey,Benoît
email=benoit.markey@ac-lille.fr
keywords=chimie,mole,masse,molaire,concentration,dilution,atom,periodic_table,molecules
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=yes
precision=100

ansorder=r
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem 	H2,H2 O,C H4,C O2,C2 H6,C3 H8,C4 H10, C5 H12,C6 H14,C7 H16,C8 H18,C9 H20,C10 H22,S O2,S O3,C O,Mg O,Zn O,Na2 O,Li2 O,Na Cl,Li Cl,Na Br,Li Br,Fe Cl2,Mg Cl2,Zn Cl2,Fe Cl3,Al Cl3,Li Al H4, Li O H,H2 O2,I2,Al2 S3,C12 H22 O11,C6 H12 O6,Ca C O3, C2 H6 O, Si O2, C Cl4, Cu S O4, U F4, N O2

val6=$(tmp0)
!readproc slib/chemistry/molarmass $val6 
tmp0=$slib_out
val7=$(tmp0)
tmp0=!randint 10, 100

val8=$[rint($(tmp0))]
val9=$[$val8/100]
val10=$[$val9*$val7]
val11=$[rint($val10*10)]
val12=$[$val11/10]
replytype1=units
replyname1=\(m =)
replygood1=$val12 g
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Une expérience de chimie nécessite l'utilisation de $val9 mol de	
!insmath $val6
$().	<div class="wims_question">Quelle est la masse de 
!insmath $val6
$() faut-il prendre ?	<div class="spacer">	La masse de 
!insmath $val6
$() ŕ prendre est M(
!insmath $val6
$())= 
!read oef/embed.phtml reply1,10 
$()</div>	</div>		<div class="wims_instruction">	Le tableau périodique est donné en <span class="wims_color3">indication</span>.	<div class="spacer">Consignes :</div> 	<ul class="wims_nopuce">	<li>Ne pas oublier les unités éventuelles.</li>	<li>Le séparateur de décimales est un point (.).</li>	<li>Vous pouvez utiliser l'écriture scientifique 
!insmath x=3.2*10^2 L
$() s'écrit 3.2e2 L</li></ul></div>	
$()
!exit

:hint
$()	 
!read oef/img.phtml $val1/periodique.png  
$() 	<div class="wims_small">Ce tableau est une copie d'écran du site http://www.periodni.com/fr/, consulté le 20/3/2023. Nous avons copié cette page pour éviter de perdre le lien ŕ long terme. Nous vous engageons ŕ profiter de ce site tant qu'il est encore actif.</div>
$()
!exit

:help
$()
$()
!exit

:solution
$()	<h3>Les détails des calculs</h3>	La masse molaire 
!insmath M
$() de 
!insmath $val6
$() est le rapport entre la masse 
!insmath m
$() d'une certaine quantité de 
!insmath $val6
$() 	rapportée au nombre de moles 
!insmath n
$() de 
!insmath $val6
$() présentes dans cette męme quantité, soit la relation 
!insmath M=\frac{m}{n}
$().<br>	<div class="wims_emph">Attention, la masse molaire n'est pas une masse mais un rapport entre une masse et un nombre de moles.</div>		Dans une premičre étape, il faut calculer la masse molaire de 
!insmath $val6
$(). La masse molaire de 
!insmath $val6
$() est la somme des masses molaires de chacun des 	atomes constituant 
!insmath $val6
$(). La masse molaire de 
!insmath $val6
$() vaut 
!insmath M=$val7
$() g/mol. C'est une constante du problčme.<br>		<h4>Calcul numérique de la masse </h4>	la masse d'une mole de 
!insmath $val6
$() vaut 
!insmath $val7
$() g<br>	la masse de 
!insmath $val9
$() moles de 
!insmath $val6
$() vaut 
!insmath m
$() g. On cherche 
!insmath m
$()<br>		On écrit la relation de proportionnalité entre la masse de 
!insmath $val6
$() et le nombre de moles puisque la masse molaire est constante :	 
!insmath \frac{m}{$val9}=\frac{$val7}{\un}
$() puis on calcule 
!insmath m=$val9*$val7 = $val12
$() g.		<h4>Calcul littéral de la masse </h4>	la masse de 
!insmath $val9
$() moles de 
!insmath $val6
$() vaut 
!insmath m
$() g. <br>	Les variables sont la masse 
!insmath m
$() et le nombre de moles 
!insmath n
$(). On cherche 
!insmath m
$(), soit une relation du type 
!insmath m=h(n)
$(). <br>	On écrit simplement la définition de la masse molaire : 
!insmath \frac{m}{n}=M
$() que l'on récrit l'équation sous la forme 
!insmath m=n*M=$val9*$val7=$val12
$() g.<br>
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=1,6,7,9,12
embedcnt=1
