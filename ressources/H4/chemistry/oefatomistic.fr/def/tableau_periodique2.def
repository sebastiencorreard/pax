!set title=Tableau pÈriodique (2)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
leftrange=-5.000000
rightrange=5.000000
author=Markey BenoÓt
email=benoit.markey@nomade.fr
computeanswer=no
precision=10000

ansorder=r,r,r,r,r,r,r
varcnt=6
prevarcnt=3
postvarcnt=2
replycnt=7
choicecnt=0
conditioncnt=1
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!record 2 of tableau

tmp=!trim $(tmp0)
val6=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val6

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$(tmp0)
val8=$[rint($(val7[3])-$(val7[4]))]
replytype1=case
replyname1=X
replygood1=$(val7[1])
replytype2=atext
replyname2=nom
replygood2=$(val7[2])
replytype3=numeric
replyname3=K
replygood3=$[$(val7[5])]
replytype4=numeric
replyname4=L
replygood4=$[$(val7[6])]
replytype5=numeric
replyname5=M
replygood5=$[$(val7[7])]
replytype6=case
replyname6=X
replygood6=$(val7[1])
replytype7=raw
replyname7=charge
replygood7=?analyze 9
question=__EXECUTED_1692754_EXERCISE__
help=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	RÈpondez aux questions en vous aidant du tableau pÈriodique <b>qui se trouve dans 	l'aide:</b>	<p>		On considËre l'ÈlÈment dont le numÈro atomique est 
!insmath Z = $(val7[4])
$().<br>	<ol><li>	Quel est le symbole chimique de cet ÈlÈment?  
!read oef/embed.phtml reply 1,4 
$()<br>Quel est son nom?  
!read oef/embed.phtml reply 2,10 
$()<br><br>	</li>	<li>Donner la configuration Èlectronique de cet ÈlÈment : 	<center>(K)<sup> 
!read oef/embed.phtml reply 3,4 
$()</sup>(L)<sup> 
!read oef/embed.phtml reply 4,4 
$()</sup>(M)<sup>	 
!read oef/embed.phtml reply 5,4 
$()</sup></center>		<i>On complÈtera tous les champs, avec la valeur 0 si nÈcessaire</i>	</li><li> Indiquer la formule chimique de l'ion envisageable:	 
!read oef/embed.phtml reply 6,4 
$()<sup> 
!read oef/embed.phtml reply 7,4 
$()</sup>	</li></ol>		<p><font size=-1><i>L'aide s'ouvre dans une fenÍtre sÈparÈe si vous cliquez sur Aide dans la barre de menu en haut.</i></font>
$()
!exit

:hint
$()
$()
!exit

:help
$()<center> <img src="$val1/tableau.gif"></center>
$()
!exit

:solution
$()
$()
!exit

:postdef
tmp0=!text select +012345678- in $val9

val9=$(tmp0)

!ifval $val9  issametext $(val7[9]) 
val10= 1
!else
val10=0
!endif

!exit

:feedback

!exit

:test

!ifval $val10=1
 condtest1=1
!else
 condtest1=0
!endif
condname1=La charge est bonne

!exit

:stat
vsavelist=1,7,9
embedcnt=7
