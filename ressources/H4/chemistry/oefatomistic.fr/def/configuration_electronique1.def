!set title=Stucture Úlectronique d'un atome (1)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
leftrange=-5.000000
rightrange=5.000000
author=Markey Beno¯t
email=benoit.markey@nomade.fr
computeanswer=no
precision=10000

ansorder=r,r,r
varcnt=6
prevarcnt=5
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!record 1 of tableau

tmp=!trim $(tmp0)
val6=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val6

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$(tmp0)
val8=$[rint($(val7[3])-$(val7[4]))]
val9=$(val7[2])
tmp0=!lower $val9

!readproc slib/lang/frapostrophe de $(tmp0) 
tmp1=$slib_out
val9=$(tmp1)
replytype1=numeric
replyname1=K
replygood1=$[$(val7[5])]
replytype2=numeric
replyname2=L
replygood2=$[$(val7[6])]
replytype3=numeric
replyname3=M
replygood3=$[$(val7[7])]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Donner la structure Úlectronique de l'atome suivant $val9 dont le symbole chimique est: <br>	<center><table bgcolor="skyblue">	<tr> 	    <td align=right>$(val7[3])</td>    <td rowspan="2">$(val7[1])</td></tr>	<tr><td align=right>$(val7[4])</td>    </tr>	</table> </center><br> 			L'atome  <i>$val9</i> a pour configuration Úlectronique: 	<center>(K)<sup> 
!read oef/embed.phtml reply 1,4 
$()</sup>(L)<sup> 
!read oef/embed.phtml reply 2,4 
$()</sup>(M)<sup> 
!read oef/embed.phtml reply 3,4 
$()</sup>	</center><p>		<i>Les champs doivent Ûtre complÚtÚs, avec la valeur 0 au besoin </i> 	
$()
