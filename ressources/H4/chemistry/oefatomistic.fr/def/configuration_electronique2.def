!set title=Structure électronique d'un atome (2)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
leftrange=-5.000000
rightrange=5.000000
author=Markey Benoit
email=benoit.markey@nomade.fr
computeanswer=no
precision=10000

ansorder=c
varcnt=4
prevarcnt=3
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!record 1 of tableau

tmp=!trim $(tmp0)
val6=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val6

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$(tmp0)
val8=$[rint($(val7[3])-$(val7[4]))]
choicename1=X est représenté par
choicegood1=<table>	<tr> 	    <td align=right>$(val7[3])</td>    <td rowspan=2>$(val7[1])</td></tr>	<tr><td align=right>$(val7[4])</td>    </tr>	</table> 
choicebad1=<table>	<tr> 	    <td align=right>$(val7[4])</td>    <td rowspan=2>$(val7[1])</td></tr>	<tr><td align=right>$(val7[3])</td>    </tr>	</table> ,	 <table>	<tr> 	    <td align=right>$val8</td>    <td rowspan=2>$(val7[1])</td></tr>	<tr><td align=right>$(val7[4])</td>    </tr>	</table> ,	<table>	<tr> 	    <td align=right>$(val7[4])</td>    <td rowspan=2>$(val7[1])</td></tr>	<tr><td align=right>$val8</td>    </tr>	</table>	
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()		Soit un atome 
!insmath X
$() dont la structure électronique est la suivante:	<center><table bgcolor="skyblue"><tr><td>	(K)<sup>$(val7[5])</sup>(L)<sup>$(val7[6])</sup>(M)<sup>$(val7[7])</sup>	</td></tr></table>	</center>	Parmi la liste proposée, choisissez l'atome correspondant ŕ la configuration électronique précédente.<br>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7
embedcnt=0
