!set title=Composition d'un atome (2)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
leftrange=-5.000000
rightrange=5.000000
author=Markey Benoit
email=benoit.markey@nomade.fr
computeanswer=no
precision=10000

ansorder=r
varcnt=10
prevarcnt=9
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!record 1 of tableau

tmp=!trim $(tmp0)
val6=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val6

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$(tmp0)
val8=$[rint($(val7[3])-$(val7[4]))]
tmp0=!shuffle 4

val9=$(tmp0)
val10=<table><tr><td align=right>$(val7[3])</td><td rowspan=2>$(val7[1])</td></tr>	<tr><td align=right>$(val7[4])</td></tr></table> , 	 <table><tr><td align=right>$(val7[4])</td><td rowspan=2>$(val7[1])</td></tr>	<tr><td align=right>$(val7[3])</td></tr>	</table> ,	 <table>	<tr> <td align=right>$val8</td>    <td rowspan=2>$(val7[1])</td></tr>	<tr><td align=right>$(val7[4])</td> </tr></table> ,<table><tr> 	<td align=right>$(val7[4])</td>    <td rowspan=2>$(val7[1])</td></tr>	<tr><td align=right>$val8</td>    </tr>	</table>	
val10=$(val10[$val9])
tmp0=!positionof item 1 in $val9

val11=$(tmp0)
val12=$(val7[2])
tmp0=!lower $val12

!readproc slib/lang/frapostrophe de $(tmp0) 
tmp1=$slib_out
val12=$(tmp1)
replytype1=radio
replyname1=
replygood1=$val11;$val10
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Soit un atome $val12 dont la composition est la suivante : il contient <font color="blue">$(val7[4])  
!if $(val7[4])>1 
$()protons 
!else
$() proton 
!endif
$()</font>, 	<font color="blue">$(val7[3])  
!if $(val7[3]) >1 
$()nucléons 
!else
$() nucléon 
!endif
$()</font>, 	<font color="blue">$(val7[4])  
!if $(val7[4]) >1 
$()électrons 
!else
$() électron 
!endif
$()</font>,  	<font color="blue">$val8  
!if $(val7[3]) >1 
$()neutrons 
!else
$() neutron 
!endif
$()</font>. <br>		Dans la liste proposée, choisissez l'atome correspondant ŕ la composition précédente :	<table align="center" width=80%><tr><td> 
!read oef/embed.phtml reply1,1 
$()</td>	<td>&nbsp</td><td> 
!read oef/embed.phtml reply1,2 
$()</td><td>&nbsp</td>	<td> 
!read oef/embed.phtml reply1,3 
$()</td><td>&nbsp</td>	<td> 
!read oef/embed.phtml reply1,4 
$()</td></tr></table>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,8,12
embedcnt=4
