!set title=Configuration Õlectronique d'un ion (1)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
leftrange=-5.000000
rightrange=5.000000
author=Markey Benoit
email=benoit.markey@nomade.fr
computeanswer=no
precision=10000

ansorder=r,r,r
varcnt=3
prevarcnt=2
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!record 3 of tableau

tmp=!trim $(tmp0)
val6=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val6

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$(tmp0)
replytype1=numeric
replyname1=K
replygood1=$[$(val7[5])]
replytype2=numeric
replyname2=L
replygood2=$[$(val7[6])]
replytype3=numeric
replyname3=M
replygood3=$[$(val7[7])]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Donner la structure Õlectronique de l'ion dont le symbole chimique est: <br>	<center><table bgcolor="skyblue"><font color=#00CC00>	<tr> 	    <td align=right>$(val7[3])</td>    <td rowspan="2">$(val7[1])<sup>$(val7[9])</sup></td></tr>	<tr><td align=right>$(val7[4])</td>    </tr>	</font></table> </center><br> 	<br>  <br>		L'ion <i>$(val7[1])<sup>$(val7[9])</sup></i> a pour configuration Õlectronique:	(K)<sup> 
!read oef/embed.phtml reply 1,4 
$()</sup>(L)<sup> 
!read oef/embed.phtml reply 2,4 
$()</sup>(M)<sup> 
!read oef/embed.phtml reply 3,4 
$()</sup>		<p><i>Tous les champs doivent õtre complÕtÕs, 	avec la valeur 0 au besoin.</i></p>
$()
!exit

