!set title=Composition d'un atome (1)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
leftrange=-5.000000
rightrange=5.000000
author=Markey Beno¯t
email=benoit.markey@ac-lille.fr
computeanswer=no
precision=10000

ansorder=r,r,r,r
varcnt=6
prevarcnt=5
postvarcnt=0
replycnt=4
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!record 1 of tableau

tmp=!trim $(tmp0)
val6=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val6

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$(tmp0)
val8=$(val7[2])
tmp0=!lower $val8

!readproc slib/lang/frapostrophe de $(tmp0) 
tmp1=$slib_out
val8=$(tmp1)
val9=$[rint($(val7[3])-$(val7[4]))]
replytype1=numeric
replyname1=protons
replygood1=$[$(val7[4])]
replytype2=numeric
replyname2=nuclÚons
replygood2=$[$(val7[3])]
replytype3=numeric
replyname3=Úlectrons
replygood3=$[$(val7[4])]
replytype4=numeric
replyname4=neutrons
replygood4=$[$val9]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Donner la composition de l'atome $val8 dont le symbole chimique est : <br>	<center> <table bgcolor="skyblue">	<tr> 	    <td align=right>$(val7[3])</td>    <td rowspan="2">$(val7[1])</td></tr>	<tr><td align=right>$(val7[4])</td>    </tr>	</table> </center><br>    		L'atome  <i>$val8</i> contient  
!read oef/embed.phtml reply 1,4 
$() protons,  
!read oef/embed.phtml reply 2,4 
$() nuclÚons,  
!read oef/embed.phtml reply 3,4 
$() Úlectrons et  
!read oef/embed.phtml reply 4,4 
$() neutrons.<br>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,8
embedcnt=4
