!set title=RĶgles du duet et de l'octet (1)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
leftrange=-5.000000
rightrange=5.000000
author=Markey Benoit
email=benoit.markey@nomade.fr
computeanswer=no
precision=10

ansorder=r
varcnt=9
prevarcnt=5
postvarcnt=3
replycnt=1
choicecnt=0
conditioncnt=1
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!record 1 of tableau

tmp=!trim $(tmp0)
val6=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val6

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$(tmp0)
val8=$(val7[2])
tmp0=!lower $val8

!readproc slib/lang/frapostrophe de $(tmp0) 
tmp1=$slib_out
val8=$(tmp1)

!ifval existe notin $(val7[9]) 
val9= \($(val7[1])^($(val7[9])))
!else
val9= l'ion n'existe pas
!endif
replytype1=raw
replyname1=ion
replygood1=?analyze 10
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Soit l'atome  $val8  dont le symbole chimique est : <br>	<center><table bgcolor="skyblue">	<tr> 	    <td align=right>$(val7[3])</td>    <td rowspan="2">$(val7[1])</td></tr>	<tr><td align=right>$(val7[4])</td>    </tr>	</table></center><br>    		En utilisant la rĶgle de l'octet ou du duet, 	complķter le symbole suivant en indiquant la charge de l'ion que 	cet atome peut former. Si l'ion n'existe pas, complķter le champ en indiquant: <i>n'existe pas</i><br>		<center><table>	<tr><td rowspan="2">$(val7[1])</td> 	    <td> 
!read oef/embed.phtml reply 1,10 
$()</td>    </tr>	<tr>  <td>  &nbsp;</td>    </tr>	</table></center>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:postdef
tmp0=!text select +012345678- in $val10

val10=$(tmp0)

!ifval $val10 issametext 
val10= n'existe pas
!endif

!ifval $val10  issametext $(val7[9]) 
val11= 1
!else
val11=0
!endif

!exit

:feedback

!exit

:test

!ifval $val11=1
 condtest1=1
!else
 condtest1=0
!endif
condname1=La bonne rķponse est <i>$val9</i>

!exit

:stat
vsavelist=7,8,9,10
embedcnt=1
