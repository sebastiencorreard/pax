!set title=Masse d'un atome (1)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
leftrange=-5.000000
rightrange=5.000000
author=Markey Benoit
email=benoit.markey@nomade.fr
computeanswer=no
precision=10

ansorder=r
varcnt=7
prevarcnt=6
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!record 1 of tableau

tmp=!trim $(tmp0)
val6=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val6

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$(tmp0)
val8=$[rint($(val7[3])-$(val7[4]))]
val9=$[1.675E-27*$val8+1.673E-27*$(val7[4])+9.1E-31*$(val7[4])]
val10=$(val7[2])
tmp0=!lower $val10

!readproc slib/lang/frapostrophe de $(tmp0) 
tmp1=$slib_out
val10=$(tmp1)
replytype1=units
replyname1=La masse de l'atome est:
replygood1=$val9 kg
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Soit l'atome suivant $val10 dont le symbole chimique est : <br>	<center><table bgcolor="skyblue">	<tr> 	    <td align=right>$(val7[3])</td>    <td rowspan="2">$(val7[1])</td></tr>	<tr><td align=right>$(val7[4])</td>    </tr>	</table></center><br>    		Sachant que la masse d'un neutron est 
!insmath m_n  = 1.675*10^-27
$() kg, 	que celle d'un proton est 
!insmath m_p = 1.673*10^-27
$() kg et 	que celle d'un ťlectron est 
!insmath m_(e) = 9.1*10^-31
$() kg, 	calculer la masse d'un atome $val10  :	<p> 
!insmath m_($(val7[2])) = 
$()  
!read oef/embed.phtml reply 1,20 
$() </p>	<p> 	<i>Pour entrer un nombre comportant 	des puissances de 10, utilisez la lettre E. Pour entrer un nombre dťcimal, 	utilisez le point exemple: 
!insmath 5,4*10^-8
$() se note 5.4E-8. </i><p><font color=red><b> ATTENTION: 	il ne faut pas entrer d'espace entre le nombre et la lettre E </font></b><p>	<b> N'oubliez pas les unitťs.</b><br>		
$()
!exit

