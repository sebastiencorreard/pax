!set title=Composition d'un ion (1)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
leftrange=-5.000000
rightrange=5.000000
author=Markey Beno¯t
email=benoit.markey@nomade.fr
computeanswer=no
precision=10000

ansorder=r,r,r,r
varcnt=12
prevarcnt=11
postvarcnt=0
replycnt=4
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!record 2 of tableau

tmp=!trim $(tmp0)
val6=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val6

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$(tmp0)
val8=$[rint($(val7[3])-$(val7[4]))]
val9=$(val7[2])
tmp0=!lower $val9

!readproc slib/lang/frapostrophe de $(tmp0) 
tmp1=$slib_out
val9=$(tmp1)
!if $(val7[9]) issametext + 
val10=$[rint($(val7[4])-1)]
!endif
!if $(val7[9]) issametext 2+ 
val10=$[rint($(val7[4])-2)]
!endif
!if $(val7[9]) issametext 3+ 
val10=$[rint($(val7[4])-3)]
!endif
!if $(val7[9]) issametext - 
val10=$[rint($(val7[4])+1)]
!endif
!if $(val7[9]) issametext 2- 
val10=$[rint($(val7[4])+2)]
!endif
!if $(val7[9]) issametext 3- 
val10=$[rint($(val7[4])+3)]
!endif
replytype1=numeric
replyname1=protons
replygood1=$[$(val7[4])]
replytype2=numeric
replyname2=nuclÚons
replygood2=$[$(val7[3])]
replytype3=numeric
replyname3=Úlectrons
replygood3=$[$val10]
replytype4=numeric
replyname4=neutrons
replygood4=$[$val8]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	ConsidÚrons l'atome suivant $val9 dont le symbole chimique est: <br>	<center> <table bgcolor="skyblue"><font color="#00CC00">	<tr> 	    <td align=right>$(val7[3])</td>    <td rowspan="2">$(val7[1])</td></tr>	<tr><td align=right>$(val7[4])</td>    </tr>	</font></table> </center><br> Cet atome forme l'ion $(val7[1])<sup>$(val7[9])</sup>. 	 Donner la composition de cet ion. <br>		L'ion $(val7[1])<sup>$(val7[9])</sup> contient  
!read oef/embed.phtml reply 1,4 
$() protons.<br>	L'ion $(val7[1])<sup>$(val7[9])</sup>  contient  
!read oef/embed.phtml reply 2,4 
$() nuclÚons.<br>	L'ion $(val7[1])<sup>$(val7[9])</sup>  contient  
!read oef/embed.phtml reply 3,4 
$() Úlectrons.<br>	L'ion $(val7[1])<sup>$(val7[9])</sup>  contient  
!read oef/embed.phtml reply 4,4 
$() neutrons.<br>	
$()
!exit

