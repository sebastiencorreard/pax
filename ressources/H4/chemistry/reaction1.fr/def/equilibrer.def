replygood6=$(val10[6])
replytype7=chemeq
replyname7=
replygood7=$(val10[7])
replytype8=chemeq
replyname8=
replygood8=$(val10[8])
replytype9=chemeq
replyname9=
replygood9=$(val10[9])
