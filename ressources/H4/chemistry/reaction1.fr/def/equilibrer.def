!set title=&Eacute;quilibrer des réactions
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Georges Khaznadar
email=georges.khaznadar@free.fr
oefcss= <style> table tr th,td{ border: 1px black solid; border-collapse: collapse; } </style> 

ansorder=r,r,r,r,r,r,r,r,r
varcnt=21
prevarcnt=20
postvarcnt=0
replycnt=9
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=H2 + O2 -> H2O, 2H2 + O2 -> 2H2O, -2, -1, 2;	CH4 + O2 -> CO2 + H2O, CH4 + 2O2 -> CO2 + 2H2O, -1, -2, 1, 2;	C2H6 + O2 -> CO2 + H2O, 2C2H6 + 7O2 -> 4CO2 + 6H2O, -2,-7,4,6;	C3H8 + O2 -> CO2 + H2O, C3H8 + 5O2 -> 3CO2 + 4H2O,-1,-5,3,4;	S + O2 -> SO2, S + O2 -> SO2, -1,-1,1;	S + O2 -> SO3, S + 3/2O2 -> SO3,-2,-3,2;	C + O2 -> CO2, C + O2 -> CO2, -1,-1,1;	C + O2 -> CO, C + 1/2O2 -> CO, -2,-1,2;	Mg + O2 -> MgO, Mg + 1/2O2 -> MgO, -2,-1,2;	Zn + O2 -> ZnO, Zn + 1/2O2 -> ZnO, -2,-1,2;	Na + O2 -> Na2O, 2Na + 1/2O2 -> Na2O,-4,-1,2;	Li + O2 -> Li2O, 2Li + 1/2O2 -> Li2O, -4,-1,2;	Na + O2 -> Na2O2, 2Na + O2 -> Na2O2, -2,-1,1;	Na + Cl2 -> NaCl, Na + 1/2Cl2 -> NaCl, -2,-1,2;	Li + Cl2 -> LiCl, Li + 1/2Cl2 -> LiCl, -2,-1,2;	Na + Br2 -> NaBr, Na + 1/2Br2 -> NaBr, -2,-1,2;	Li + Br2 -> LiBr, Li + 1/2Br2 -> LiBr, -2,-1,2;	Mg + Cl2 -> MgCl2, Mg + Cl2 -> MgCl2, -1,-1,1;	Zn + Cl2 -> ZnCl2, Zn + Cl2 -> ZnCl2, -1,-1,1;	Fe + Cl2 -> FeCl3, Fe + 3/2Cl2 -> FeCl3, -2,-3,-2;	Al + Cl2 -> AlCl3, Al + 3/2Cl2 -> AlCl3, -2,-3,-2;	Fe + H^+ -> Fe^2+ + H2, Fe + 2H^+ -> Fe^2+ + H2, -1,-2,1,1;	Mg + H^+ -> Mg^2+ + H2, Mg + 2H^+ -> Mg^2+ + H2, -1,-2,1,1;	Zn + H^+ -> Zn^2+ + H2, Zn + 2H^+ -> Zn^2+ + H2, -1,-2,1,1;	Al + H^+ -> Al^3+ + H2, Al + 3H^+ -> Al^3+ + 3/2H2, -2,-6,2,3;	Fe + Cu^2+ -> Fe^2+ + Cu, Fe + Cu^2+ -> Fe^2+ + Cu, -1,-1,1,1;	Al + Cu^2+ -> Al^3+ + Cu, 2Al + 3Cu^2+ -> 2Al^3+ + 3Cu, -2,-3,2,3;	Cu + Ag^+ -> Cu^2+ + Ag, Cu + 2Ag^+ -> Cu^2+ + 2Ag, -1,-2,1,2;	Al + Ag^+ -> Al^3+ + Ag, Al + 3Ag^+ -> Al^3+ + 3Ag, -1,-3,1,3;	Fe + Ag^+ -> Fe^2+ + Ag, Fe + 2Ag^+ -> Fe^2+ + 2Ag, -1,-2,1,2	
tmp0=!itemcnt $(val6[;1])

val7=$[rint($(tmp0))]
tmp0=!shuffle $val7

val8=$(tmp0)
val9=$[rint(5)]
val10=
val11=
val12=
val13=
val14=
val15=
!for val16 =1 to $val9 
tmp0=!item $val16 of $val8

val17=$[rint($(tmp0))]
val18=$(val6[$val17;])
tmp0=!item 1 of $val18

val11=$val11 $(tmp0),
tmp0=!item 2 of $val18

val10=$val10 $(tmp0),
tmp0=!item 1 of $val18

!readproc slib/chemistry/chemeq_tex $(tmp0) 
tmp1=$slib_out
val13=$val13 $(tmp1);
tmp0=!item 2 of $val18

!readproc slib/chemistry/chemeq_tex $(tmp0) 
tmp1=$slib_out
val12=$val12 $(tmp1);
tmp0=!item 3 to -1 of $val18

val14=$val14 $(tmp0);
!if $val16=1 
val15=r1
!else
val15=$val15, r$val16
!endif
!next
oefsteps=$val15 
nextstep=!nosubst $val15 
!readproc oef/steps.proc
replytype1=chemeq
replyname1=
replygood1=$(val10[1])
replytype2=chemeq
replyname2=
replygood2=$(val10[2])
