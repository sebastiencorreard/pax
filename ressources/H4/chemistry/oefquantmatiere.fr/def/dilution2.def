tmp0=!randint 10, 1000

val6=$[rint($(tmp0))]
val7=$[$val6/100]
tmp0=!randint 2, 4

val8=$[rint($(tmp0))]
!readproc slib/text/sigunits $val7,$val8 
tmp0=$slib_out
val9=$(tmp0)
tmp0=!translate . to , in $val9

val10=$(tmp0)
tmp0=!randint 1, 10

val11=$[rint($(tmp0))]
tmp0=!randint 2, 4

val12=$[rint($(tmp0))]
!readproc slib/text/sigunits $val11,$val12 
tmp0=$slib_out
val13=$(tmp0)
tmp0=!translate . to , in $val13

val14=$(tmp0)
