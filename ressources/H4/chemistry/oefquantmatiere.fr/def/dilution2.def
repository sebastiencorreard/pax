val15=$[rint($(tmp0))]
tmp0=!randint 2, 4

val16=$[rint($(tmp0))]
!readproc slib/text/sigunits $val15,$val16 
tmp0=$slib_out
val17=$(tmp0)
tmp0=!translate . to , in $val17

val18=$(tmp0)
val19=$[$val9*$val13/$val17]
tmp0=!translate . to , in $val19

val20=$(tmp0)
val21=$[rint(min($val8,$val12))]
val22=$[rint(min($val21,$val16))]
!readproc slib/text/sigunits $val19 mol/L,$val22 
tmp0=$slib_out
val23=$(tmp0)
!readproc slib/text/sigunits $val19 ,$val22 
