!set title=Solution massique (1)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Benoît, Markey;Marie-Claude,David
email=benoit.markey@ac-lille.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=1000

ansorder=r
varcnt=22
prevarcnt=21
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 10, 1000

val6=$[rint($(tmp0))]
val7=$[$val6/100]
tmp0=!randint 2, 4

val8=$[rint($(tmp0))]
!readproc slib/text/sigunits $val7,$val8 
tmp0=$slib_out
val9=$(tmp0)
tmp0=!translate . to , in $val9

val10=$(tmp0)
tmp0=!randint 1, 10

val11=$[rint($(tmp0))]
val12=$[$val11*100]
tmp0=!randint 2, 4

val13=$[rint($(tmp0))]
!readproc slib/text/sigunits $val12,$val13 
tmp0=$slib_out
val14=$(tmp0)
tmp0=!translate . to , in $val14

val15=$(tmp0)
tmp0=!randint 1, $val6/2

val16=$[rint($(tmp0))]
val17=$[$val16/100]
tmp0=!randint 2, 4

val18=$[rint($(tmp0))]
!readproc slib/text/sigunits $val17,$val18 
tmp0=$slib_out
val19=$(tmp0)
tmp0=!translate . to , in $val19

val20=$(tmp0)
val21=$[$val17*$val12/(1000*$val7)]
val21=$[$val19*$val14/(1000*$val9)]
val22=$[rint(min($val8,$val13))]
val23=$[rint(min($val22,$val18))]
!readproc slib/text/sigunits $val21 L,$val23 
tmp0=$slib_out
val24=$(tmp0)
tmp0=!translate . to , in $val24

val25=$(tmp0)
replytype1=sigunits
replyoption1=noanalyzeprint 
replyname1=\(V)
replygood1=$val24
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<p>On dispose d'une solution mère de concentration 
!insmath C = $val10
$()
!insmath \textrm{g.L}^{-1}
$().	On souhaite obtenir un volume 
!insmath V' = $val15
$() mL de solution fille	à la concentration 
!insmath C' = $val20
$()
!insmath  \textrm{g.L}^{-1}
$().</p>	<p>Quel volume 
!insmath V
$() de la solution mère faut-il prélever ?</p>	<div class="wimscenter">
!insmath V = 
$()  
!read oef/embed.phtml reply1 
$()</div>	<div class="wims_instruction">Pour entrer la réponse, remplacer la virgule par un point.</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback
!ifval 1=1
 <div class='oef_feedbacks'><p>La bonne réponse est 
!insmath V = $val25
$(). Si votre réponse est fausse, vérifiez la valeur numérique, le nombre de chiffres significatifs et l'unité.</p>
$()</div>
!endif

!exit

:test

!exit

:stat
vsavelist=10,15,20,25
embedcnt=1
