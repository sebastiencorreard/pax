\title{Concentration molaire (1)}
\language{fr}
\range{-5..5}
\author{Benoît, Markey ; Marie-Claude, David}
\email{benoit.markey@ac-lille.fr}
\computeanswer{no}
\format{html}

\integer{N=randint(100..9999)}
\real{n1=\N/10000}
\integer{cs1=randint(2..4)}
\text{n=slib(text/sigunits \n1 ,\cs1)}
\text{nvirg=wims(translate . to , in \n)}%pour afficher une virgule au lieu d'un point
n1 est en mol !

\integer{V=randint(10..2000)}
\integer{cs2=randint(2..4)}
\text{v=slib(text/sigunits \V ,\cs2)}
\text{vvirg=wims(translate . to , in \v)}%pour afficher une virgule au lieu d'un point
V est en millilitre !


\integer{in=min(\cs1,\cs2)}

\real{rep=\n/(\v/1000) }
\text{repvirg=wims(translate . to , in \rep)}%pour afficher une virgule au lieu d'un point
\text{rep1=slib(text/sigunits \rep mol/L,\in)}
\text{reponse=slib(text/sigunits \rep ,\in)}
\text{reponsevirg=wims(translate . to , in \reponse)}%pour afficher une virgule au lieu d'un point

\matrix{l=de diiode,d'hydroxyde de sodium,de saccharose,d'acide chlorhydrique, d'acide nitrique, de soude, d'acide acétique,de chlorure de sodium}
\matrix{list2=shuffle(\l)}
\text{sol=\list2[1]}

\statement{<p>En tenant compte des chiffres significatifs, calculer la concentration molaire \(c) d'une solution dont
le volume connu avec précision est \(v = \vvirg \) mL
et qui contient \(n = \nvirg \) mol \sol.
</p>
<div class="wimscenter">\(c = \) \embed{reply1}</div>
<div class="wims_instruction">Pour entrer la réponse, remplacer la virgule par un point.</div>
}


\answer{\(c) =}{\rep1}{type=sigunits}{option=noanalyzeprint}
\feedback{1=1}{<p>La bonne réponse est \(c = \reponsevirg\) mol/L.
Si votre réponse est fausse, vérifiez la valeur numérique, le nombre de chiffres significatifs et l'unité.</p>}
\solution{On utilise la formule \(c = n/V\) et,
<i>sans tenir compte des chiffres significatifs</i>, on obtient :
<p class="wimscenter"> \( c = \repvirg\) mol/L.</p>
La bonne réponse doit ętre donnée avec \in chiffres significatifs
car \(\nvirg\) a \(\cs1\) chiffres significatifs
 et \(\vvirg\) a \cs2 chiffres significatifs.<br>
La réponse est donc : \(c = \reponsevirg\) mol/L.}
