\title{Concentration molaire (2)}
\language{fr}
\range{-5..5}
\author{Benoît, Markey ; Marie-Claude, David}
\email{benoit.markey@ac-lille.fr}
\computeanswer{no}
\format{html}

\integer{C=randint(100..9999)}
\real{c1=\C/10000}
\integer{cs1=randint(1..4)}
\text{c=slib(text/sigunits \c1 ,\cs1)}
\text{cvirg=wims(translate . to , in \c)}%pour afficher une virgule au lieu d'un point
c1 est en mol par litre !

\integer{V=randint(1..10)}
\integer{cs2=randint(1..4)}
\text{v=slib(text/sigunits \V ,\cs2)}
\text{vvirg=wims(translate . to , in \v)}%pour afficher une virgule au lieu d'un point
V est en millilitre !


\integer{in=min(\cs1,\cs2)}

\real{rep=\c*\v/1000 }
\text{repvirg=wims(translate . to , in \rep)}%pour afficher une virgule au lieu d'un point
\text{rep1=slib(text/sigunits \rep mol,\in)}
\text{reponse=slib(text/sigunits \rep,\in)}
\text{reponsevirg=wims(translate . to , in \reponse)}%pour afficher une virgule au lieu d'un point

\matrix{l=de diiode,d'hydroxyde de sodium,de saccharose,d'acide chlorhydrique, d'acide nitrique, de soude, d'acide acétique,de chlorure de sodium}
\matrix{list2=shuffle(\l)}
\text{sol=\list2[1]}

\statement{<p>On dispose d'une solution \sol de concentration
\(c = \cvirg\) \(\textrm{mol.L}^{-1}\).
Le volume connu avec précision est \(v = \vvirg \) mL.
</p>
<p>Donnez, en tenant compte des chiffres significatifs, la quantité \(n\) \sol introduite.</p>
<div class="wimscenter">\(n \) = \embed{reply1}</div>
<div class="wims_instruction">Pour entrer la réponse, remplacer la virgule par un point.</div>}

\answer{\(n =\)}{\rep1}{type=sigunits}{option=noanalyzeprint}
\feedback{1=1}{<p>La bonne réponse est \(n = \reponsevirg\) mol.
Si votre réponse est fausse, vérifiez la valeur numérique,
le nombre de chiffres significatifs et l'unité.</p>}


\solution{On utilise la formule \(n = c.v\) et, <i>sans tenir compte des chiffres significatifs</i>, on obtient :
<p class="wimscenter"> \(n = \repvirg\) mol.</p>
La bonne réponse doit ętre donnée avec \in chiffre(s) significatif(s)
car \(\cvirg\) a \cs1 chiffre(s) significatif(s)
 et \(\vvirg\) a \cs2 chiffre(s) significatif(s).<br>
La réponse est donc : \(n = \reponsevirg\) mol.}
