\title{Concentration massique (2)}
\language{fr}
\range{-5..5}
\author{Benoît, Markey ;Marie-Claude, David}
\email{benoit.markey@ac-lille.fr}
\computeanswer{no}
\format{html}

\integer{C=randint(100..9999)}
\real{c1=\C/10000}
\integer{cs1=randint(2..4)}
\text{c=slib(text/sigunits \c1 ,\cs1)}
\text{cvirg=wims(translate . to , in \c)}%pour afficher une virgule au lieu d'un point
c1 est en g par litre !
text{c=wims(replace e by 10^{ in \c)}}
\integer{V=randint(1..100)}
\integer{cs2=randint(2..4)}
\text{v=slib(text/sigunits \V ,\cs2)}
\text{vvirg=wims(translate . to , in \v)}%pour afficher une virgule au lieu d'un point
V est en millilitre !

\integer{in=min(\cs1,\cs2)}
\real{rep=\c*\v/1000 }
\text{repvirg=wims(translate . to , in \rep)}%pour afficher une virgule au lieu d'un point
\text{rep1=slib(text/sigunits \rep g,\in)}
\text{rep1virg=wims(translate . to , in \rep1)}%pour afficher une virgule au lieu d'un point

\matrix{l=de diiode,d'hydroxyde de sodium,de saccharose,d'acide chlorhydrique, d'acide nitrique, de soude, d'acide acétique, de chlorure de sodium}
\matrix{list2=shuffle(\l)}
\text{sol=\list2[1]}

\statement{<p>On dispose d'une solution \sol de concentration
\(c = \cvirg \)\(\textrm{g.L}^{-1}\).
Le volume connu avec précision est \(v = \vvirg\) mL.</p>
<p>Donnez, en tenant compte des chiffres significatifs, la masse \(m\) \sol introduite.</p>
<div class="wimscenter">\(m\) = \embed{reply1}</div>
<div class="wims_instruction">Pour entrer la réponse, remplacer la virgule par un point.</div>}
\answer{\(m) =}{\rep1}{type=sigunits}{option=noanalyzeprint}
\feedback{1=1}{<p>La bonne réponse est \(m = \rep1virg\). Si votre réponse est fausse, vérifiez la valeur numérique, le nombre de chiffres significatifs et l'unité.</p>}
\solution{On utilise la formule \(m = c.v\) et, <i>sans tenir compte des chiffres significatifs</i>, on obtient
:
<p class="wimscenter"> \(m = \repvirg\) g.</p>
La bonne réponse doit ętre donnée avec \(\in\) chiffres significatifs car \(\cvirg\) a \(\cs1\) chiffres significatifs
 et \(\vvirg\) a \(\cs2\) chiffres significatifs.<br>
La réponse est donc : \(m = \rep1virg \).}
