\title{Solution massique (1)}
\language{fr}
\range{-5..5}
\author{Benoît, Markey;Marie-Claude,David}
\email{benoit.markey@ac-lille.fr}
\computeanswer{no}
\format{html}
\precision{1000}
\integer{c1=randint(10..1000)}
\real{c11=\c1/100}
\integer{n1=randint(2..4)}
\text{C1=slib(text/sigunits \c11,\n1)}
\text{C1virg=wims(translate . to , in \C1)}%pour afficher une virgule au lieu d'un point
\integer{v1=randint(1..10)}
\real{v11=\v1*100}
\integer{n2=randint(2..4)}
\text{v=slib(text/sigunits \v11,\n2)}
\text{vvirg=wims(translate . to , in \v)}%pour afficher une virgule au lieu d'un point
\integer{c2=randint(1..\c1/2)}
\real{c22=\c2/100}
\integer{n3=randint(2..4)}
\text{C2=slib(text/sigunits \c22,\n3)}
\text{C2virg=wims(translate . to , in \C2)}%pour afficher une virgule au lieu d'un point
#\real{rep=\c22*\v11/(1000*\c11)}
\real{rep=\C2*\v/(1000*\C1)}

\integer{in1=min(\n1,\n2)}
\integer{in=min(\in1,\n3)}
\text{rep2=slib(text/sigunits \rep L,\in)}
\text{rep2virg=wims(translate . to , in \rep2)}%pour afficher une virgule au lieu d'un point
\statement{<p>On dispose d'une solution mère de concentration \(C = \C1virg\)\(\textrm{g.L}^{-1}\).
On souhaite obtenir un volume \(V' = \vvirg\) mL de solution fille
à la concentration \(C' = \C2virg\)\( \textrm{g.L}^{-1}\).</p>
<p>Quel volume \(V) de la solution mère faut-il prélever ?</p>
<div class="wimscenter">\(V = \) \embed{reply1}</div>
<div class="wims_instruction">Pour entrer la réponse, remplacer la virgule par un point.</div>}

\answer{\(V)= }{\rep2}{type=sigunits}{option=noanalyzeprint}
\feedback{1=1}{<p>La bonne réponse est \(V = \rep2virg\). Si votre réponse est fausse, vérifiez la valeur numérique, le nombre de chiffres significatifs et l'unité.</p>}