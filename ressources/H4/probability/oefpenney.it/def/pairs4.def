tmp=!trim 111,112	111,121	111,221	111,222	112,122	112,222	
val19=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val19

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val20=$(tmp0)
val21=
!for val22 =1 to 3 
tmp0=!char $val22 of $(val20[1])

val23=$(tmp0)
val23=$(val10[$val23])
val21=$val21,$val23
!next
tmp0=!nonempty items $val21

val21=$(tmp0)
tmp0=!makelist $val13/t$val14 t$val15 for t in $val21

val24=$(tmp0)
tmp0=!items2words $val24

val24=$(tmp0)
val25=
!for val22 =1 to 3 
tmp0=!char $val22 of $(val20[2])

val23=$(tmp0)
val23=$(val10[$val23])
val25=$val25,$val23
!next
tmp0=!nonempty items $val25

val25=$(tmp0)
tmp0=!makelist $val13/t$val14 t$val15 for t in $val25

val26=$(tmp0)
tmp0=!items2words $val26

val26=$(tmp0)
val27=p,1-p
tmp0=!itemcnt \ans_list

val28=$[rint($(tmp0))]
replyname1=
replygood1=$(val27[2])
