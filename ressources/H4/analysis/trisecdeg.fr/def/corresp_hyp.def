!set title=Hyperboles: correspondance.
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Frédéric, Pitoun
keywords=hyperbola
email=frederic.pitoun@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=25
prevarcnt=24
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 4

tmp1=!randint 1, 4

tmp2=!randint 1, 4

tmp3=!randint 1, 4

val6=$(tmp0),$(tmp1),-1*$(tmp2),-1*$(tmp3)
tmp0=!randint 1, 3

tmp1=!randint 1, 3

tmp2=!randint 1, 3

tmp3=!randint 1, 3

val7=$(tmp0),$(tmp1),-1*$(tmp2),-1*$(tmp3)
tmp0=!randint 1, 4

tmp1=!randint 1, 4

tmp2=!randint 1, 4

tmp3=!randint 1, 4

val8=$(tmp0),-1*$(tmp1),$(tmp2),-1*$(tmp3)
tmp0=!randint 1, 5

val9=$[rint($(tmp0))]
val10=$[rint(150)]
val11=$[rint(150)]
val12=$[rint(-6)]
val13=$[rint(6)]
val14=$[rint(-6)]
val15=$[rint(6)]
val16=
!for val17 =$val12 to $val13 
val16=$val16	dline $val17,$val14,$val17,$val15,black
!next
val18=
!for val17 =$val14 to $val15 
val18=$val18	dline $val12,$val17,$val13,$val17,black
!next
val19=blue,red,green,yellow
!for val17 =1 to 4 
!if $val17=1 
t_=!replace internal \( by ( in $(val6[$val17])+$(val7[$val17])/(x+$(val8[$val17]))
tmp0=!exec maxima $t_

val20=$(tmp0)
val21=\(y=$val20)
!readproc oef/draw.phtml $val10,$val11, \
xrange $val12,$val13	yrange $val14,$val15	linewidth 1	$val18	$val16	linewidth 2	line 0,$val14,0,$val15,black	line $val12,0,$val13,0,black	plot $(val19[$val17]),$(val20[$val17])	 
tmp0=$ins_url
val22=<img src="$(tmp0)" alt="">	
!else
t_=!replace internal \( by ( in $(val6[$val17])+$(val7[$val17])/(x+$(val8[$val17]))
tmp0=!exec maxima $t_

val20=$val20,$(tmp0)
val21=$val21,\(y= $(val20[$val17]))
!readproc oef/draw.phtml $val10,$val11, \
xrange $val12,$val13	yrange $val14,$val15	linewidth 1	$val18	$val16	linewidth 2	line 0,$val14,0,$val15,black	line $val12,0,$val13,0,black	plot $(val19[$val17]),$(val20[$val17])	 
tmp0=$ins_url
val22=$val22,<img src="$(tmp0)" alt="">	
!endif
!next
replytype1=correspond
replyname1=
replygood1=$val21;$val22
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Associer chacune des hyperboles ci-dessous ŕ son équation.	<div class="wimscenter">	 
!read oef/embed.phtml reply 1,150x180x180 
$()	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

