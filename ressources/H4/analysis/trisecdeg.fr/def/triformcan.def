!set title=Forme canonique d'un trinŰme.
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
keywords=canonical_form
author=Frťdťric, Pitoun
email=frederic.pitoun@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r,r,r,r
varcnt=10
prevarcnt=9
postvarcnt=0
replycnt=4
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem -1,1

tmp1=!randint 1, 5

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -10, 10

val7=$[rint($(tmp0))]
tmp0=!randint -10, 10

val8=$[rint($(tmp0))]
t_=!replace internal \( by ( in $val6*x^2+$val7*x+$val8
tmp0=!exec maxima $t_

val9=!rawmath $(tmp0)
t_=!rawmath -$val7/(2*$val6)
val10=!exec pari print($t_)
t_=!replace internal \( by ( in subst($val10,x,$val9)
tmp0=!exec maxima $t_

t_=!rawmath $(tmp0)
val11=!exec pari print($t_)
t_=!replace internal \( by ( in $val6*(x-$val10)^2+$val11
tmp0=!exec maxima $t_

val12=!rawmath $(tmp0)
!if $val6>0 
val13=$[rint(1)]
!else
val13=$[rint(2)]
!endif
oefsteps=reply 1	reply 2, reply3, reply 4 
nextstep=!nosubst reply 1	reply 2, reply3, reply 4 
!readproc oef/steps.proc
replytype1=algexp
replyname1=Forme canonique
replygood1=$val12
replytype2=menu
replyname2=Extrema
replygood2=$val13;minimum,maximum
replytype3=rational

replyname3=xS
replygood3=$val10
replytype4=rational

replyname4=yS
replygood4=$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()On considŤre le trinŰme 
!insmath f(x)=$val9
$(). Dťterminer la forme canonique de 
!insmath f
$().	
!if $m_step=1 
$()	<div class="spacer">	La forme canonique de 
!insmath f
$() est :  
!read oef/embed.phtml reply 1,20 
$().	</div>	 
!endif
$()	
!if $m_step=2 
$()	<p>Oui, la forme canonique de 
!insmath f
$() est bien 
!insmath f(x)=$val12
$(). </p>	La fonction 
!insmath f
$() possŤde un  
!read oef/embed.phtml reply 2,10 
$() sur l'ensemble des rťels.	<div class="spacer">	Cet extrema est atteint pour 
!insmath x=
$() 
!read oef/embed.phtml reply3,6 
$() et vaut  
!read oef/embed.phtml reply 4,8 
$().	</div>	 
!endif
$()	
$()
!exit

:hint
