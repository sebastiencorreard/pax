t_=!rawmath $(tmp0)
val14=!exec pari print($t_)
tmp0=!randint -5, -1

val15=$[rint($(tmp0))]
t_=!replace internal \( by ( in subst($val15,x,$val10)
tmp0=!exec maxima $t_

t_=!rawmath $(tmp0)
val16=!exec pari print($t_)
!endif
