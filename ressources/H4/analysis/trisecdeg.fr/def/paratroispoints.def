tmp0=!randint 1, 2

val6=$[rint($(tmp0))]
tmp0=!randitem -1,1

tmp1=!randint 1, 5

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -5, 5

val8=$[rint($(tmp0))]
tmp0=!randint -5, 5

val9=$[rint($(tmp0))]
t_=!replace internal \( by ( in $val7*(x-$val8)^2+$val9
tmp0=!exec maxima $t_

val10=$(tmp0)
t_=!replace internal \( by ( in expand($val10)
tmp0=!exec maxima $t_

val10=$(tmp0)
!if $val6=1 
