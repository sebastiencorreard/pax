tmp1=!randint 1, 3

val11=$[rint($val8+$(tmp0)*$(tmp1))]
t_=!replace internal \( by ( in subst($val11,x,$val10)
tmp0=!exec maxima $t_

t_=!rawmath $(tmp0)
val12=!exec pari print($t_)
!endif
!if $val6=2 
val11=$[rint(0)]
t_=!replace internal \( by ( in subst($val11,x,$val10)
tmp0=!exec maxima $t_

t_=!rawmath $(tmp0)
val12=!exec pari print($t_)
tmp0=!randint 1, 5

val13=$[rint($(tmp0))]
t_=!replace internal \( by ( in subst($val13,x,$val10)
