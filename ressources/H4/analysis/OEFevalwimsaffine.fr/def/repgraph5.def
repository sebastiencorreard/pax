!set title=ReprÈsentation graphique 5
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=c
varcnt=15
prevarcnt=14
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items f,g,h

tmp0=!randitem $tmp
val6=$(tmp0)
val7=$[rint(300)]
tmp0=!values v for v=4 to 9

val8=$(tmp0)
tmp0=!shuffle $val8

val8=$(tmp0)
tmp0=!randint -2, 2

val9=$[rint($(tmp0))]
tmp0=!randitem 1,-1

tmp1=!randint 1, 3

val10=$[rint($(tmp0)*$(tmp1))]
tmp=!nonempty items 1/2,-1/2,2,3,4,-2,-3,-4,1/3,-1/3

tmp0=!randitem $tmp
val11=$(tmp0)
tmp=!translate ";': to $     $ in 1/($val11)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val12=$(tmp0)
val13=$val11*(x-$val10)+$val9+($val11-$val12)*(x-$val10)/2*(1+abs($val10-x)/($val10-x))
val14=Non
!readproc slib/draw/repere $val7,$val7,0,-10,10,-10,10,1,1,black,grey 
tmp0=$slib_out
val15=$(tmp0)
tmp0=!line 3 to -1 of $val15

val15=$(tmp0)
val16=
!readproc oef/draw.phtml $val7,$val7 \
$val15	range -10,10,-10,10	plot blue,$val13	text black,9.5,-0.3,medium,X	text black,-1.5,10,medium,$val6(X)	text black,0.9,-0.3,medium,1	text black,-0.5,1.5,medium,1 
tmp0=$ins_url
val17=$(tmp0)
choicename1=rÈponse
choicegood1=$val14
choicebad1=Oui,Non
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Voici la reprÈsentation graphique d'une fonction :	<div class="wimscenter"><img src="$val17" alt=""></div>	  Cette fonction est-elle une fonction affine ?
$()
!exit

