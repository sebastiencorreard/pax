tmp=!nonempty items f,g,h

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!randint 20, 50

val7=$[rint($(tmp0))]
tmp=!nonempty items 10,15,20,25,30,35,40

tmp0=!randitem $tmp
val8=$[rint($(tmp0))]
tmp=!nonempty items -,+

tmp0=!randitem $tmp
val9=$(tmp0)
val10=$[(1$val9$val8/100)*$val7]
