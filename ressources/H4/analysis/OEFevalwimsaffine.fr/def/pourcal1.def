val14=$(tmp0)
tmp0=!positionof item $val15 in $val14

val17=$(tmp0)
val18=<ul>
tmp0=!itemcnt $val14

val19=$[rint($(tmp0))]
!for val20 =1 to $val19 
val18=$val18<li><b>$(val16[$val20])</b> : $(val14[$val20])</li>
!next
val18=$val18</ul>
tmp0=!item $val17 of $val16

val21=$(tmp0)
tmp0=!item 1 to $val19 of $val16

val22=$(tmp0)
replytype1=menu
replyname1=rÈponse
replygood1=$val17;$val22
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

