val12=$[abs($val7-$val10)]
val13=$[rint($val12/$val10*10000)]
val13=$[$val13/100]
val14=C'est une augmentation de \($val8 \%),C'est une diminution de \($val8 \%),C'est une augmention de \($val12 \%),C'est une diminution de \($val12 \%),C'est une diminution de \($val13 \%),C'est une augmentation de \($val13 \%)

!ifval $val7-$val10<0
val15=1
!else
val15=2
!endif
val16=A,B,C,D,E,F,G,H
tmp0=!item $val15 of $val14

val15=$(tmp0)
