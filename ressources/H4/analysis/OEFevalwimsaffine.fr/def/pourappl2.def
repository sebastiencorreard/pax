!set title=Appliquer un pourcentage 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=9
prevarcnt=8
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/lang/fname girl,fr 
tmp0=$slib_out
val6=$(tmp0)
tmp0=!randint 1000, 2000

val7=$[rint($(tmp0))]
tmp0=!randint 20, 50

val8=$[rint($(tmp0)/10)]
val9=$val6 gagne \($val7) par mois. Son patron lui propose une augmentation de \($val8 \%). Combien gagnera-t-elle après cette augmentation
val10=$[rint($val7*(100+$val8))]
val10=$[$val10/100]
val11=euros.<div class="wims_instruction">Arrondir votre résultat aux centimes d'euro.</div>
val12=$val6 gagnera
replytype1=numexp
replyname1=réponse
replygood1=$val10
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val9 ?	<p><b>Votre réponse :</b></p>	<label for="reply1">$val12</label> :  
!read oef/embed.phtml r1 
$() $val11	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=9,11,12
embedcnt=1
