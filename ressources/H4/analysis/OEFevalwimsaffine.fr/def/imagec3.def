!set title=Calcul d'image 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=12
prevarcnt=11
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items f,g,h

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!values v,-v for v=2 to 15

val7=$(tmp0)
tmp0=!shuffle $val7

val7=$(tmp0)
val8=$(val7[1])*x+$(val7[2])
tmp=!translate ";': to $     $ in $(val7[3])/$(val7[4])

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val9=$(tmp0)
evaltmp=$val8

evaltmp=!mathsubst x=($val9) in $evaltmp
tmp0=($evaltmp)
val10=$(tmp0)
val11=Calculer l'image de $val9 par \($val6\)
val12=\($val6($val9) = )
tmp0=!texmath $val8

val8=$(tmp0)
tmp=!translate ";': to $     $ in $val10

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val10=$(tmp0)
val13=Soit \($val6\) la fonction affine dÈfinie par
replytype1=numexp
replyname1=rÈponse
replygood1=$val10
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val13 
!insmath $val6 : x \mapsto $val8
$().<br>	$val11 ?	<p><b>Votre rÈponse :</b></p>	<label for="reply1">$val12</label>  
!read oef/embed.phtml r1 
$().					
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

