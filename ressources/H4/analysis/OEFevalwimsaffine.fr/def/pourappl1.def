!set title=Appliquer un pourcentage 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=11
prevarcnt=10
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/lang/fname boy,fr 
tmp0=$slib_out
val6=$(tmp0)
!readproc slib/life/frcommodity 100,1000 
tmp0=$slib_out
val7=$(tmp0)
tmp0=!randint 100, 1000

val8=$[rint($(tmp0))]
tmp0=!randint 11, 19

val9=$[rint($(tmp0))]
tmp0=!item 1 of $val7

val10=$(tmp0)
tmp0=!item 2 of $val7

val7=$(tmp0)
val11=$val6 voit $val10 $val7 ‡ $val8 euros dans un magasin. Le vendeur lui propose une remise de \($val9 \%). Quel prix va-t-il payer
val12=$val6 payera
val13=euros.<div class="wims_instruction">Arrondir votre rÈsultat aux centimes d'euro.</div>
val14=$[$val8*(100-$val9)/100]
replytype1=numexp
replyname1=rÈponse
replygood1=$val14
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val11 ?	<p><b>Votre rÈponse :</b></p>	<label for="reply1">$val12</label> :  
!read oef/embed.phtml r1 
$() $val13	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=11,12,13
embedcnt=1
