tmp=!nonempty items f,g,h

tmp0=!randitem $tmp
val6=$(tmp0)
val7=$[rint(300)]
tmp0=!values v,-v for v=2 to 5

val8=$(tmp0)
tmp0=!shuffle $val8

val8=$(tmp0)
val9=$(val8[1])*x+$(val8[2]),-$(val8[1])*x+$(val8[2]),1/$(val8[1])*x+$(val8[2]),-1/$(val8[1])*x+$(val8[2])
