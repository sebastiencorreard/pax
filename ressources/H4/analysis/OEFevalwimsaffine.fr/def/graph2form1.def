val10=$(tmp0)
!readproc oef/draw.phtml $val7,$val7 \
$val10	range -10,10,-10,10	plot blue,$(val9[1])	text black,9.5,-0.3,medium,X	text black,-0.6,10,medium,Y	text black,0.9,-0.3,medium,1	text black,-0.6,1.5,medium,1 
tmp0=$ins_url
val11=$(tmp0)
val12=
!for val13 =1 to 4 
t_=!replace internal \( by ( in $(val9[$val13]);
tmp0=!exec maxima $t_

val14=$(tmp0)
tmp0=!texmath $val14

val14=$(tmp0)
tmp0=!append item $val14 to $val12

val12=$(tmp0)
!next
val15=F,G,H,J
tmp0=!item 1 of $val12

val16=$(tmp0)
tmp0=!shuffle $val12

val17=$(tmp0)
tmp0=!positionof item $val16 in $val17

val18=$(tmp0)
val19=$(val15[$val18])
choicename1=rÈponse
choicegood1=$val19
choicebad1=$val15
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

