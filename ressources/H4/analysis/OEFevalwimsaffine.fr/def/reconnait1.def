!set title=ReconnaÓtre une fonction affine 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=c
varcnt=9
prevarcnt=8
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items f,g,h

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!values v,-v for v=2 to 20

val7=$(tmp0)
tmp0=!shuffle $val7

val7=$(tmp0)
val8=Oui
tmp0=!texmath $(val7[1])*x+$(val7[2])

val9=$(tmp0)
val10=Soit \($val6\) la fonction dÈfinie par : <div class="wimscenter"> \($val6 : x \mapsto $val9)</div>
val11=Cette fonction est-elle une fonction affine
val12=Oui,Non
choicename1=rÈponse
choicegood1=$val8
choicebad1=$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val10<br>	$val11 ?
$()
!exit

