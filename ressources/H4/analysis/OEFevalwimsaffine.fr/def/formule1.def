!set title=Établir une formule NUM
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no

ansorder=r
varcnt=7
prevarcnt=6
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=x
!readproc slib/lang/fname fr,boy 
tmp0=$slib_out
val7=$(tmp0)
tmp0=!randint 9, 17

val8=$[rint($(tmp0))]
tmp0=!randint 5, 19

val9=$[$(tmp0)/100]
val10=L'abonnement téléphonique de $val7 est composé d'un forfait de base de $val8 euros et d'un prix pour chaque heure de communication de $val9 euros.<br>	  Ecrire le prix à payer en euros pour $val6 heures de communication
val11=$val8+$val9*$val6
replytype1=auto

replyname1=Réponse
replygood1=$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val10 ?	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=10
embedcnt=0
