 !exit
!endif

tmp=!nonempty items 20,30,40,50,60,70,75,80,90

tmp0=!randitem $tmp
val6=$[$(tmp0)]
val7=Un commerńant souhaite vendre les articles de son magasin $val6 % plus cher que le prix o∙ il les achĶte. Par quel nombre doit-il multiplier le prix d'achat pour obtenir le prix de vente aux clients
