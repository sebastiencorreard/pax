!set title=Retrouver la reprÈsentation graphique 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=c
varcnt=20
prevarcnt=19
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items f,g,h

tmp0=!randitem $tmp
val6=$(tmp0)
val7=$[rint(300)]
tmp0=!values v,-v for v=2 to 5

val8=$(tmp0)
tmp0=!shuffle $val8

val8=$(tmp0)
val9=$(val8[1])*x+$(val8[2]),-$(val8[1])*x+$(val8[2]),1/$(val8[1])*x+$(val8[2]),-1/$(val8[1])*x+$(val8[2])
tmp0=!texmath $(val9[1])

val10=$(tmp0)
!readproc slib/draw/repere $val7,$val7,0,-10,10,-10,10,1,1,black,grey 
tmp0=$slib_out
val11=$(tmp0)
tmp0=!line 3 to -1 of $val11

val11=$(tmp0)
val12=
!for val13 =1 to 4 
tmp0=!item $val13 of $val9

val14=\$(tmp0)
!readproc oef/draw.phtml $val7,$val7 \
$val11	range -10,10,-10,10	plot blue,$val14	text black,9.5,-0.3,medium,X	text black,-0.6,10,medium,Y	text black,0.9,-0.3,medium,1	text black,-0.6,1.5,medium,1 
tmp0=$ins_url
val15=$(tmp0)
tmp0=!append item $val15 to $val12

val12=$(tmp0)
!next
val16=A,B,C,D,E,F,G,H
tmp0=!item 1 of $val12

val17=$(tmp0)
tmp0=!shuffle $val12

val18=$(tmp0)
tmp0=!positionof item $val17 in $val18

val19=$(tmp0)
tmp0=!item $val19 of $val16

val20=$(tmp0)
val21=A,B,C,D
choicename1=rÈponse
choicegood1=$val20
choicebad1=$val21
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Soit 
!insmath $val6
$() la fonction affine dÈfinie par : 
!insmath $val6 : x\mapsto $val10
$().	  Quelle est sa reprÈsentation graphique ?	<table class="wimscenter wimsborder">	 <tr>	   <td>RÈponse A :<br><img src="$(val18[1])" alt=""></td>	   <td>RÈponse B :<br><img src="$(val18[2])" alt=""></td>	 </tr><tr>	   <td>RÈponse C :<br><img src="$(val18[3])" alt=""></td>	   <td>RÈponse D :<br><img src="$(val18[4])" alt=""></td>	 </tr>	</table>	<b>Votre rÈponse :</b>	<div class="wimscenter">	  La bonne rÈponse est :  
!read oef/embed.phtml c1 
$().	</div>
$()
!exit

