!set title=Calculer un pourcentage 5
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=31
prevarcnt=30
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items f,g,h

tmp0=!randitem $tmp
val6=$(tmp0)
tmp=!nonempty items 25,20,40,50

tmp0=!randitem $tmp
val7=$[rint($(tmp0))]
tmp0=!shuffle 5,10,15,20,25

val8=$(tmp0)
val9=$[rint($(val8[1]))]
val10=$[rint($(val8[2]))]
tmp0=!randint $val7/3, 2*$val7/3

val11=$[rint($(tmp0))]
val12=$[rint($val7-$val11)]
!if $val12=$val11 
val11=$[rint($val11-5)]
val12=$[rint($val12+5)]
!endif
val7=$[rint(20*$val7)]
val8=$[rint(20*$val11)]
val13=$[rint(20*$val12)]
val14=Dans un groupe d'adolescent composé de $val8 filles et $val13 garçons, \($val9 \%) des filles et \($val10 \%) des garçons ont des lunettes. Quel est le pourcentage des enfants qui portent des lunettes
val15=$[rint(($val9+$val10)/2)/10]
val16=$[$val9+$val10]
val17=$[max($val9-$val10,$val10-$val9)]
val18=$[rint(($val8*$val9+$val13*$val10)/$val7*10)/10]
val19=\($val15 \%),\($val16 \%),\($val17 \%),\($val18 \%)
val20=4
val21=A,B,C,D,E,F,G,H
tmp0=!item $val20 of $val19

val20=$(tmp0)
tmp0=!shuffle $val19

val19=$(tmp0)
tmp0=!positionof item $val20 in $val19

val22=$(tmp0)
val23=<ul>
tmp0=!itemcnt $val19

val24=$[rint($(tmp0))]
!for val25 =1 to $val24 
val23=$val23<li><b>$(val21[$val25])</b> : $(val19[$val25])</li>
!next
val23=$val23</ul>
tmp0=!item $val22 of $val21

val26=$(tmp0)
tmp0=!item 1 to $val24 of $val21

val27=$(tmp0)
replytype1=menu
replyname1=réponse
replygood1=$val22;$val27
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val14 ? <br>	$val23	<p><b>Votre réponse :</b></p>	  <label for="reply1">Ma réponse est</label> :  
