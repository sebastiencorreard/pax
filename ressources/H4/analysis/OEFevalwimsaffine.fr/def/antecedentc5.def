tmp=!nonempty items f,g,h

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!randint 2, 15

val7=$(tmp0)
tmp=!nonempty items 2,3,5,6,7,11

tmp0=!randitem $tmp
val8=$(tmp0)
val9=sqrt($val8)*x+$val7
val10=sqrt($val8)
