evaltmp=!mathsubst x=($val10) in $evaltmp
tmp0=($evaltmp)
tmp=!translate ";': to $     $ in $(tmp0)

tmp=!lower $tmp
tmp1=!exec maxima fullratsimp($tmp);
val11=$(tmp1)
tmp0=!texmath $val11

val11=$(tmp0)
val12=Calculer le nombre qui a pour image \($val11) par \($val6\)
val13=Le nombre qui a pour image \($val11\) par \($val6\) est 
tmp0=!texmath $val9

val9=$(tmp0)
tmp=!translate ";': to $     $ in $val10

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val10=$(tmp0)
val14=Soit \($val6\) la fonction affine dÈfinie par
replytype1=algexp
replyname1=rÈponse
replygood1=$val10
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val14 
!insmath $val6 : x \mapsto $val9
$().<br>	$val12 ?	<p><b>Votre rÈponse :</b></p>	<label for="reply1">$val13</label>  
