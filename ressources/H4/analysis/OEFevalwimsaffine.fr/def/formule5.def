!set title=…tablir une formule NUM
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no

ansorder=r
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=x
!readproc slib/lang/fname fr,boy 
tmp0=$slib_out
val7=$(tmp0)
tmp0=!randint 18, 30

val8=$[rint($(tmp0)*100)]
tmp0=!randint 30, 50

val9=$[$(tmp0)*6]
val10=Un parachutiste saute d'un avion ‡ $val8 mËtres d'altitude. Sa vitesse de chute est de $val9 Km/H.<br>	  Quelle est son altitude en mËtre aprËs x minutes de descente
tmp=!translate ";': to $     $ in $val9*100/6

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val11=$(tmp0)
tmp=!translate ";': to $     $ in $val8-$val11*$val6

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val12=$(tmp0)
replytype1=auto

replyname1=RÈponse
replygood1=$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

