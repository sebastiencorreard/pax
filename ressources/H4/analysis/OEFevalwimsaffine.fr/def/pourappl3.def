!set title=Appliquer un pourcentage 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=11
prevarcnt=10
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/lang/fname girl,fr 
tmp0=$slib_out
val6=$(tmp0)
tmp0=!randint 12, 45

val7=$[$(tmp0)/10]
tmp0=!randint 21, 39

val8=$[$(tmp0)/10]
tmp=!nonempty items 2,3,4,5

tmp0=!randitem $tmp
val9=$[rint($(tmp0))]
tmp=!nonempty items pommes de terre,carottes,courgettes,pommes,poires,oranges,citrons,clķmentines

tmp0=!randitem $tmp
val10=$(tmp0)
val11=$val6 achĶte $val7 Kg de $val10 Ó $val8 euro/Kg. Comme elle possĶde une carte de fidķlitķ, le vendeur lui fait une remise de $val9 % en caisse.<br>Quel est le montant de son ķconomie
val12=euros.<div class="wims_instruction">Arrondir votre rķsultat aux centimes d'euro.</div>
val13=$[rint($val7*$val8*$val9)]
val13=$[$val13/100]
val14=Elle ķconomisera
replytype1=numexp
replyname1=rķponse
replygood1=$val13
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val11 ?	<p><b>Votre rķponse :</b></p>	<label for="reply1">$val14</label> :  
!read oef/embed.phtml r1 
$() $val12	
$()
!exit

