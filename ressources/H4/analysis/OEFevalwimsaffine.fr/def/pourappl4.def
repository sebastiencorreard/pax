!set title=Appliquer un pourcentage 4
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=16
prevarcnt=15
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 50, 500

val6=$[$(tmp0)]
tmp0=!values v for v=5 to 15

val7=$(tmp0)
tmp0=!shuffle $val7

val7=$(tmp0)
tmp0=!item 1 of $val7

val8=$[rint($(tmp0))]
tmp0=!item 2 of $val7

val9=$[rint($(tmp0))]
tmp=!nonempty items 1,2

tmp0=!randitem $tmp
val10=$[rint($(tmp0))]
val11=baisse,augmentation
tmp0=!item $val10 of $val11

val11=$(tmp0)
val12=-,+
tmp0=!item $val10 of $val12

val12=$(tmp0)
val13=Dans un magasin, le prix d'un article était de $val6 euros. Il subit une $val11 de $val8 % suivie d'une $val11 de $val9 %. Quel est le prix de cet article après la deuxième $val11
val14=euros.<div class="wims_instruction">Arrondir votre résultat aux centimes d'euro.</div>
val15=$[rint($val6*(1$val12$val8/100)*(1$val12$val9/100)*100)]
val15=$[$val15/100]
val16=Le nouveau prix est de
replytype1=numexp
replyname1=réponse
replygood1=$val15
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val13 ?	<p><b>Votre réponse :</b></p>	<label for="reply1">$val16</label> :  
!read oef/embed.phtml r1 
$() $val14	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=13,14,16
embedcnt=1
