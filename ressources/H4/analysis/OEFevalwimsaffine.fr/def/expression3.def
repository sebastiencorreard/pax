!set title=Retrouver la formule 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no

ansorder=r
varcnt=10
prevarcnt=9
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items f,g,h

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!values v for v=2 to 9

val7=$(tmp0)
tmp0=!shuffle $val7

val7=$(tmp0)
val8=$[rint($(val7[2]))]
val9=$[rint($(val7[1]))]
tmp0=!values v for v=2 to 9

val10=$(tmp0)
tmp0=!shuffle $val10

val10=$(tmp0)
tmp=!translate ";': to $     $ in $val9*$(val10[1])+$val8

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
tmp1=!texmath $(tmp0)

tmp=!translate ";': to $     $ in $val9*$(val10[2])+$val8

tmp=!lower $tmp
tmp2=!exec maxima fullratsimp($tmp);
tmp3=!texmath $(tmp2)

val11=$(tmp1),$(tmp3)
tmp=!translate ";': to $     $ in $val9*x+$val8

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val12=$(tmp0)
replytype1=auto

replyname1=RÈponse
replygood1=$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Soit 
!insmath $val6
$() une fonction affine. Retrouver la formule de la fonction 
!insmath $val6
$() sachant que :	<div class="wimscenter"> 
!insmath $val6($(val10[1])) = $(val11[1]) \quad\quad\quad $val6($(val10[2])) = $(val11[2])
$()</div>	<b>Votre rÈponse :</b>	<div class="wimscenter">	<label for="reply1">
!insmath $val6 : x \mapsto 
$()</label>  
!read oef/embed.phtml r1,9 
$()	</div>
$()
!exit

