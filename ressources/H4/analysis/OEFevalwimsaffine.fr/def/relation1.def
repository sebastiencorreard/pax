!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items f,g,h

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!randint 10, 90

val7=$[rint($(tmp0))]
val8=Augmenter une quantité de $val7 % c'est la multiplier par
val9=$[1+$val7/100]
val10=$[$val7+100]
val11=$[100-$val7]
val12=$[1-$val7/100]
val13=$val9,0.$val7,$val7,$val10,$val11,$val12
val14=1
val15=A,B,C,D,E,F,G,H
tmp0=!item $val14 of $val13

val14=$(tmp0)
tmp0=!shuffle $val13

val13=$(tmp0)
tmp0=!positionof item $val14 in $val13

val16=$(tmp0)
val17=<ul>
tmp0=!itemcnt $val13

val18=$[rint($(tmp0))]
!for val19 =1 to $val18 
val17=$val17<li><b>$(val15[$val19])</b> : $(val13[$val19])</li>
!next
val17=$val17</ul>
tmp0=!item $val16 of $val15

val20=$(tmp0)
tmp0=!item 1 to $val18 of $val15

val21=$(tmp0)
replytype1=menu
replyname1=réponse
replygood1=$val16;$val21
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

