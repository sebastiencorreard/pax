t_=!rawmath ($val22-$val24)/($val19-$val21)
val32=!exec pari print($t_)
t_=!rawmath $val19*$val32+$val24
val33=!exec pari print($t_)
t_=!rawmath ($val26-$val24)/($val19-$val21)
val34=!exec pari print($t_)
t_=!rawmath $val19*$val34+$val24
val35=!exec pari print($t_)
