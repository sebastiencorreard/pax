!set title=Systčmes linéaires IV
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
keywords=linear_system

ansorder=r
varcnt=33
prevarcnt=32
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 9

tmp1=!randitem 1,-1

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 9

tmp1=!randitem 1,-1

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 9

val8=$[rint($(tmp0))]
tmp0=!randint 1, 9

val9=$[rint($(tmp0))]
tmp0=!randint 1, 6

val10=$[rint($(tmp0))]
tmp0=!randint 1, 9

val11=$[rint($(tmp0))]
tmp0=!randint 1, 9

val12=$[rint($(tmp0))]
!if $val10=1 
val13=$[rint(0)]
t_=!rawmath $val11 / $val7
val14=!exec pari print($t_)
t_=!rawmath $val9*$val14
val12=!exec pari print($t_)
val15=$[rint(1)]
!endif
!if $val10=2 
val14=$[rint(0)]
t_=!rawmath $val11 / $val6
val13=!exec pari print($t_)
t_=!rawmath $val8*$val13
val12=!exec pari print($t_)
val15=$[rint(1)]
!endif
!if $val10=3 
tmp0=!randint -5, 5

val13=$[rint($(tmp0))]
t_=!rawmath ($val11 -$val6*$val13) / $val7
val14=!exec pari print($t_)
t_=!rawmath $val8*$val13+$val9*$val14
val12=!exec pari print($t_)
val15=$[rint(1)]
!endif
!if $val10=4 
val13=$[rint(0)]
t_=!rawmath $val11 / $val7
val14=!exec pari print($t_)
t_=!rawmath -$val9*$val14
val12=!exec pari print($t_)
val15=$[rint(2)]
!endif
!if $val10=5 
val14=$[rint(0)]
t_=!rawmath $val11 / $val6
val13=!exec pari print($t_)
tmp0=!randint 1, 5

t_=!rawmath $val8*$val13+$(tmp0)
val12=!exec pari print($t_)
val15=$[rint(2)]
!endif
!if $val10=6 
tmp0=!randint -5, 5

val13=$[rint($(tmp0))]
t_=!rawmath ($val11 -$val6*$val13) / $val7
val14=!exec pari print($t_)
tmp0=!randint 1, 5

t_=!rawmath $val8*$val13+$val9*$val14-$(tmp0)
val12=!exec pari print($t_)
val15=$[rint(2)]
!endif
tmp0=!texmath $val6*x+$val7*y

tmp1=!texmath $val8*x + $val9*y

val16=$(tmp0),$(tmp1)
replytype1=radio
replyname1=Solution ?
replygood1=$val15;Oui,Non
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Le couple ($val13,$val14) est-il solution du systčme	<div class="wimscenter">
!insmath  \left \lbrace \begin{array}{rcll} $(val16[1])&=&$val11 & (1)\\ $(val16[2])&=&$val12 & (2)\end{array}\right .
$()	</div>	<div class="wimscenter"> 
!read oef/embed.phtml reply1 
$()</div>	
$()
!exit

