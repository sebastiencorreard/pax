\if{\k=1}
 {
%% x=\a*sqrt(s1) y entier, systeme x*sqrt(s1)+\b*y= entier, \c*x+sqrt(\d*s1)*y=sqrt(\f*s1)
 \integer{a=randint(1..5)}
 \integer{b=randint(1..9)}
 \integer{y=randint(1..9)}
