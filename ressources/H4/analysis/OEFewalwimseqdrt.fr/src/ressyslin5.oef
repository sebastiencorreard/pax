 \text{e1=x \sqrt{\s2} + y \sqrt{\s1}}
 \text{f1=\e \sqrt{\ss}}
 \text{e2=\c \sqrt{\s1} x + \d \sqrt{\s2} y}
 \text{f2=\f}
 \text{x=\a*sqrt(\s1)}
 \text{y=\b*sqrt(\s2)}
}
