$val6	segment $(val8[1]),$val9,0,0,black	segment $(val8[1]),$val9,$(val8[3]),$val10,black	fcircle $(val8[1]),$val9,5,red	fcircle $(val8[3]),$val10,5,red	text black,$(val8[1])-5,$val9-5,medium,$(val7[4])	text black,0,-3,medium,O	text black,$(val8[3]),$val10-10,medium,$(val7[6])	text black,-60,10,medium,$(val7[14]) 
tmp0=$ins_url
val12=$(tmp0)
tmp0=!randint -45, -30

tmp1=!randint 30, 45

val8=$(tmp0),,$(tmp1)
val9=$[-sqrt(2500-($(val8[1]))^2)]
val10=$[-sqrt(2500-($(val8[3]))^2)]
