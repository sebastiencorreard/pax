$val6	segment $val8,$val14,-$val8,-$val14,black	fcircle $val8,$val14,5,red	fcircle -$val8,-$val14,5,red	text black,0,-3,medium,O	text black,$val8-5,$val14-5,medium,$(val7[10])	text black,-$val8+15,-$val14,medium,$(val7[12])	text black,-60,10,medium,$(val7[16]) 
