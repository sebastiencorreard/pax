!set title=Calcul 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=10
prevarcnt=9
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items cos(x),sin(x),tan(x)

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!texmath $val6

val7=$(tmp0)
tmp0=!randint 5, 85

val8=$(tmp0)
tmp0=!replace internal x by $val8^\circ in $val7

val9=$(tmp0)
tmp=!nonempty items A,B,C,D,E,F,G,H

tmp0=!randitem $tmp
val10=$(tmp0)
tmp0=!randint 1, 3

val11=$[rint($(tmp0))]
tmp0=!item $val11 of au dixième,au centième,au millième

val12=$(tmp0)
evaltmp=$val6

evaltmp=!mathsubst x=($val8*pi/180) in $evaltmp
tmp0=($evaltmp)
val13=$[$(tmp0)]
val13=$[rint($val13*10^$val11)/10^$val11]
replytype1=numexp
replyname1=$val10
replygood1=$val13
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Utiliser votre calculatrice et donner l'arrondi $val12 de :	<div class="wimscenter">	 <label for="reply1">
!insmath $val10 = $val9 = 
$()</label> 
!read oef/embed.phtml r1,6 
$()	</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=9,10,12
embedcnt=1
