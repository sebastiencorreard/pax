!set title=Formule 4
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r,r,r
varcnt=10
prevarcnt=9
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items A,B,C,O,T,R,U,X

tmp0=!randitem $tmp
val6=$(tmp0)
val6=\widehat{$val6}
val7=180x30x1
val8=\(\cos($val6))
val9=C¶tķ adjacent Ó \($val6)
val10=Hypotķnuse
val11=C¶tķ opposķ Ó \($val6),\(\sin($val6)),\(\tan($val6))
val12=$[rint(2)]

!ifval $val12=1
val13=r1,r2
!else
val13=r3
!endif
oefsteps=$val13 
nextstep=!nosubst $val13 
!readproc oef/steps.proc
replytype1=clickfill
replyname1=Numķrateur
replygood1=$val9;$val11,$val8
replytype2=clickfill
replyname2=Dķnominateur
replygood2=$val10;$val11
replytype3=clickfill
replyname3=Rķponse
replygood3=$val8;$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	
!insmath $val6
$() est l'un des deux angles aigus d'un triangle rectangle. Complķter l'ķgalitķ suivante :	
!if $val12=1 
$()	 <table class="wimscenter wimsnoborder">	  <tr>	  <td rowspan="3">$val8</td>	  <td rowspan="3"> = </td>	  <td> 
!read oef/embed.phtml reply1,$val7 
$()</td>	  </tr>	  <tr><td><hr></td></tr>	  <tr>	  <td> 
!read oef/embed.phtml reply2,$val7 
$()</td>	  </tr>	 </table>	 
!else
$() 	<table class="wimscenter wimsnoborder">	  <tr>	   <td>$val9</td>	   <td>&nbsp;</td>	   <td>&nbsp;</td>	  </tr><tr>	   <td><hr></td>	   <td> = </td>	   <td> 
!read oef/embed.phtml r3,$val7 
$()</td>	  </tr><tr>	   <td>$val10</td>	   <td>&nbsp;</td>	   <td>&nbsp;</td>	  </tr>	 </table>	 
!endif
$()	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,10,12
embedcnt=3
