!set title=Vocabulaire 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=16
prevarcnt=15
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!translate internal $	$ to ; in A,B,C	T,R,I	S,V,T	R,S,T	E,F,G

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val6=$(tmp0)
tmp0=!shuffle $val6

val6=$(tmp0)
tmp0=!item 1 of $val6

val7=$(tmp0)
tmp0=!item 2 of $val6

val8=$(tmp0)
tmp0=!item 3 of $val6

val9=$(tmp0)
val10=Quelle est l'hypotÈnuse de ce triangle
val11=\([$val8$val9])
tmp0=!shuffle $val8,$val9

val12=$(tmp0)
tmp0=!randint 1, 4

val13=$[rint($(tmp0))]
!if $val13=1 
val14=range -0.1,1.1,-0.2,1.2	square 0,0.1,10,red	triangle 0,0,1,0,0,1,black	text black,-0.05,0,medium,$val7	text black,-0.05,1.05,medium,$(val12[1])	text black,1,0,medium,$(val12[2])
!else
!if $val13=2 
val14=range -0.1,1.1,1.2,-0.2	square 0,0,10,red	triangle 0,0,1,0,0,1,black	text black,-0.05,0,medium,$val7	text black,-0.05,0.95,medium,$(val12[1])	text black,1,0,medium,$(val12[2])
!else
!if $val13=3 
val14=range 1.1,-0.1,-0.2,1.2	square 0.05,0.1,10,red	triangle 0,0,1,0,0,1,black	text black,-0.05,0,medium,$val7	text black,-0.05,1.05,medium,$(val12[1])	text black,1.05,0,medium,$(val12[2])
!else
val14=range 1.1,-0.1,1.2,-0.2	square 0.05,0,10,red	triangle 0,0,1,0,0,1,black	text black,-0.05,-0.05,medium,$val7	text black,-0.05,0.95,medium,$(val12[1])	text black,1.05,-0.05,medium,$(val12[2])
!endif
!endif
!endif
val15=\([$val8$val9]),\([$val7$val9]),\([$val7$val8])
!readproc oef/draw.phtml 240,140 \
$val14 
tmp0=$ins_url
val16=$(tmp0)
replytype1=dragfill
replyname1=RÈponse
replygood1=$val11;$val15
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

