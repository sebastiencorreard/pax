!set title=Calcul d'angle 5
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=15
prevarcnt=14
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items A,B,C,D

tmp0=!randitem $tmp
val6=$(tmp0)
val6=\widehat{$val6}
tmp0=!randint 1, 2

val7=$[rint($(tmp0))]
tmp0=!item $val7 of arccos(x),arcsin(x),arctan(x)

val8=$(tmp0)
tmp0=!item $val7 of \cos($val6),\sin($val6),\tan(x)

val9=$(tmp0)
tmp0=!values v for v=4 to 9

val10=$(tmp0)
tmp0=!shuffle $val10

val10=$(tmp0)
tmp0=!randint 2, 7

val11=$(tmp0)/($(val10[1])+$(val10[2]))
tmp0=!replace internal x by $val11 in $val8

val12=$(tmp0)
tmp0=!randint 0, 2

val7=$[rint($(tmp0))]
tmp0=!item $val7+1 of au degré,au dixième de degré,au centième de degré

val13=$(tmp0)
val14=$[$val12/pi*180]
val14=$[rint($val14*10^$val7)/10^$val7]
tmp0=!texmath $val11

val15=$(tmp0)
replytype1=numexp
replyname1=\($val6)
replygood1=$val14
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Utiliser la calculatrice et donner l'arrondi $val13 de la mesure de l'angle aigu	
!insmath $val6
$() vérifiant :	<div class="wimscenter">	 
!insmath $val9 = $val15 
$()	</div>	<b>Réponse :</b><br>	 <label for="reply1">
!insmath $val6 \simeq 
$()</label>  
!read oef/embed.phtml r1,5 
$() °.
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,9,13,15
embedcnt=1
