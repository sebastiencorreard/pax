!set title=Calcul 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=14
prevarcnt=13
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 9

val6=$(tmp0)
tmp0=!randint 1, 3

val7=$[rint($(tmp0))]
tmp0=!item $val7 of cos,tan,sin

val8=$(tmp0)
tmp0=!item $val7 of \cos,\tan,\sin

val9=$(tmp0)
val10=$val6/$val8(x)
val11=\frac{$val6}{$val9(x)}
tmp0=!randint 5, 85

val12=$(tmp0)
tmp0=!replace internal x by $val12^\circ in $val11

val13=$(tmp0)
tmp=!nonempty items A,B,C,D,E,F,G,H

tmp0=!randitem $tmp
val14=$(tmp0)
tmp0=!randint 1, 3

val7=$[rint($(tmp0))]
tmp0=!item $val7 of au dixième,au centième,au millième

val15=$(tmp0)
evaltmp=$val10

evaltmp=!mathsubst x=($val12*pi/180) in $evaltmp
tmp0=($evaltmp)
val16=$[$(tmp0)]
val16=$[rint($val16*10^$val7)/10^$val7]
replytype1=numexp
replyname1=$val14
replygood1=$val16
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Utiliser votre calculatrice et donner l'arrondi $val15 de :	<div class="wimscenter">	 <label for="reply1">
!insmath $val14 = $val13 = 
$()</label> 
!read oef/embed.phtml r1,6 
$()	</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=13,14,15
embedcnt=1
