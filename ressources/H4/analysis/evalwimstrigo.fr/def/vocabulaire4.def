!set title=Vocabulaire 4
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=22
prevarcnt=21
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!translate internal $	$ to ; in A,B,C	T,R,I	S,V,T	R,S,T	E,F,G

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val6=$(tmp0)
tmp0=!shuffle $val6

val6=$(tmp0)
tmp0=!item 1 of $val6

val7=$(tmp0)
tmp0=!item 2 of $val6

val8=$(tmp0)
tmp0=!item 3 of $val6

val9=$(tmp0)
val10=Quelle est l'hypotÈnuse de ce triangle
val11=\([$val8$val9])
tmp0=!shuffle $val8,$val9

val12=$(tmp0)
tmp0=!randint 4, 16

val13=$[$(tmp0)/10]
val14=$[sqrt(1-($val13-1)^2)]
val15=$[sqrt($val13^2+$val14^2)/0.1]
val16=$[sqrt((2-$val13)^2+$val14^2)/0.1]
val17=$[$val13-$val13/$val15]
val18=$[$val14-$val14/$val15]
val19=$[$val17+(2-$val13)/$val16]
val20=$[$val18-$val14/$val16]
val21=$[$val13+(2-$val13)/$val16]
val22=$[$val14-$val14/$val16]
val23=range -0.2,2.2,-0.2,1.2	segment $val17,$val18,$val19,$val20,red	segment $val19,$val20,$val21,$val22,red	triangle 0,0,2,0,$val13,$val14,black	text black,$val13,$val14+0.14,medium,$val7	text black,-0.05,0,medium,$(val12[1])	text black,2,0,medium,$(val12[2])
val24=\([$val8$val9]),\([$val7$val9]),\([$val7$val8])
!readproc oef/draw.phtml 240,140 \
$val23 
tmp0=$ins_url
val25=$(tmp0)
replytype1=dragfill
replyname1=RÈponse
replygood1=$val11;$val24
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	 $val7$val8$val9 est un triangle rectangle en $val7.	 <div class="wimscenter">	 <img src="$val25" alt="">	</div>	 $val10 ?  
!read oef/embed.phtml r1,80x30 
$()	
$()
!exit

