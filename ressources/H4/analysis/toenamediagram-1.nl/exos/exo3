ystep=$[10*(round($maxstep/10))]

var9=size 540,380\
xrange $[$xmin-$xstep],$[$xmax+$xstep]\
yrange $[-1*$ystep-2],$[$ystep+2]\
xlabel x-as     \
ylabel y-as        \
axisnumbering\
axis\
