val18=$val11 x^2 
val19=$val11*x^2
!if $val12 !=0 

!ifval $val13>0
tmp=!translate ";': to $     $ in  -$val12 / $val11

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val20=!exec pari print($t_)
!else
tmp=!translate ";': to $     $ in $val12 / $val11

tmp=!lower $tmp
tmp1=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp1)
val20=!exec pari print($t_)
!endif
val18=$val18 $val16 $val12 x 
val19=$val20 * x
!endif
!if $val9 !=0 
tmp=!translate ";': to $     $ in  $val9 / $val11

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val21=!exec pari print($t_)
val18=$val18 $val17 $val9 

!ifval $val14>0
val19=$val19 - $val21
!else
val19=$val19 + $val21
!endif
!endif
val18=$val18=0
tmp0=!replace * by in $val19

val22=$(tmp0)
val23=$[rint(1)]
val24=r1	r2	
!else
tmp0=!values x for x = -4 to 4

val25=$(tmp0)
tmp0=!shuffle $val25

val25=$(tmp0)
t_=!rawmath $(val25[1])
val26=!exec pari print($t_)
tmp0=!randitem 1,2

val27=$[rint($(tmp0))]
val28=$[rint($val26)]
t_=!rawmath $val26/$val27
val26=!exec pari print($t_)
!if $val7=1 
t_=!rawmath $val26
val29=!exec pari print($t_)
val30=$[rint($val27)]
val31=$[rint($val28)]
val23=$[rint(2)]
val32=$val26
!else
t_=!rawmath $(val25[2])
val29=!exec pari print($t_)
tmp0=!randitem 1,2

val30=$[rint($(tmp0))]
val31=$[rint($val29)]
t_=!rawmath $val29/$val30
val29=!exec pari print($t_)
val23=$[rint(3)]
!if $val26=$val29 
val7=$[rint(1)]
val23=$[rint(2)]
val32=$val26
!else
val32=$val26,$val29
!endif
!endif
val15=!rawmath $val27*$val30*(x- ($val26))*(x-($val29))
val11=$[rint($val27*$val30)]
val12=$[rint(-$val11*(($val26)+($val29)))]

!ifval $val12>0
val16=+
!else
val16=-
!endif

!ifval $val12<0
val12=$[rint($val12*(-1))]
!endif
val9=$[rint($val11*($val26)*($val29))]

!ifval $val9>0
val17=+
!else
val17=-
!endif

