val12=$[rint($val9*$(tmp0))]
val13=$[rint($val12)]
val9=$[rint($val9+$val10)]
val14=$[rint($val9)]
val15=!rawmath $val11*x^2+($val12)*x+$val9

!ifval $val12>0
val16=+
!else
val16=-
!endif

!ifval $val12<0
val12=$[rint($val12*(-1))]
!endif

!ifval $val9>0
val17=+
!else
val17=-
!endif

!ifval $val9<0
val9=$[rint($val9*(-1))]
