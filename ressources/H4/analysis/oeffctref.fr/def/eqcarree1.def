val18=$val11 x^2 
!if $val12 !=0 
val18=$val18 $val16 $val12 x 
!endif
!if $val9 !=0 
val18=$val18 $val17 $val9 
!endif
val18=$val18=0
tmp=!translate ";': to $     $ in (($val26)+($val29))*x -($val26)*($val29)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val19=!rawmath $(tmp0)
val22=$val19
tmp0=!replace * by in $val22

val22=$(tmp0)
val24=r1	r2	r3	
!endif
val33=xrange -5,5	yrange -1.2,16	gridfill 0,0,5,5,$val6	linewidth 1	linewidth 2	  parallel -5,-1,-5,16,1,0,12,blue	  parallel -5,-1,5,-1,0,1,18,blue	linewidth 2	vline 0,0,black	hline 0,0,black	arrow 0,0,1,0,10,magenta	arrow 0,0,0,1,10,magenta	text red,0.7,-0.1,medium,i	text red,-0.2,0.7,medium,j	text black,-0.2,-0.1,medium,O	    linewidth 2	    plot red,x^2	
val34=$val33	    plot green,$val19	
