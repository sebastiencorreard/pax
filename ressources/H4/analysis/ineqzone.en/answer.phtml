!! Place here the code to show analysis of reply to the exercise

!if $error!=$empty
  !exit
!endif
<div>
$(name_answer[1;]): <em>$(text$choice)</em>
<div>
!if $diagnostics=good
  $(name_answer[2;])
!else
  !if $choice=C and $good=C
    $(name_answer[3;])
  !else
    $(name_answer[4;]):
    <div style="color:blue">$(text$good)</div>
  !endif
!endif
</div><div>
!if $status=done
  $name_score
  !if $repeat<2
    $name_foranswer
  !else
    $name_forrepeat
  !endif
!else
  $(name_repeat[1])
  !set wims_ref_class=wims_button
  !href cmd=next $(name_repeat[2])
  $name_repeat2
!endif
</div>
</div>
