tmp=!nonempty items d,p,D

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!randint -10, 10

val7=$[rint($(tmp0))]
tmp=!nonempty items 1,-1

tmp0=!randitem $tmp
tmp1=!randint 1, 10

val8=$[rint($(tmp0)*$(tmp1))]
val9=Soit \(($val6)\) la droite d'ťquation&nbsp;
val10=Rťponse&nbsp;
val11=Donner les coordonnťes d'un point appartenant ŗ la droite \(($val6)\)	  mais n'appartenant pas ŗ l'axe des ordonnťes
val12=Oui,Non
tmp0=!randitem -2,1,-1,2

val13=$[rint($(tmp0))]
tmp0=!randint -10, 10

val14=$[rint($(tmp0))]
tmp=!nonempty items 1,2

tmp0=!randitem $tmp
val15=$[rint($(tmp0))]

!ifval $val15=1 
t_=!replace internal \( by ( in $val7*x + $val8*y
tmp0=!exec pari $t_

val16= $(tmp0) = $val14 
!else
t_=!replace internal \( by ( in $val8*y+$val7*x
tmp1=!exec pari $t_

val16= $(tmp1) = $val14
!endif
tmp=!translate ";': to $     $ in $val16

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val16=$(tmp0)
t_=!rawmath ($val14-$val7*$val13)/$val8
val17=!exec pari print($t_)
val18=$[rint($val7*$val13+$val8*$val17)]

!ifval $val15=1 
t_=!replace internal \( by ( in $val7*$val13 + $val8*y
tmp0=!exec pari $t_

val19= $(tmp0) = $val14 
!else
t_=!replace internal \( by ( in $val8*y+$val7*$val13
tmp1=!exec pari $t_

val19= $(tmp1) = $val14
!endif
val9=Soit \(($val6)\) la droite d'ťquation&nbsp;
val10=Rťponse&nbsp;
val11=Donner les coordonnťes d'un point appartenant ŗ la droite \(($val6)\)	  mais n'appartenant pas ŗ l'axe des ordonnťes
