tmp=!nonempty items D,d,m,p,q

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!values v for v=-10 to 10

val7=$(tmp0)
tmp0=!shuffle $val7

val7=$(tmp0)
tmp0=!randint 1, 2

val8=$[rint($(tmp0))]
val9=Soit \(($val6)\) la droite d'équation&nbsp;
val10=Réponse&nbsp;
val11=Oui,Non
val12=Soient,et, les deux droites d'équation&nbsp;
