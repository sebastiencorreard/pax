tmp=!nonempty items -1,-2,1,2

tmp0=!randitem $tmp
val15=$[rint($(tmp0))]

!ifval $val8=1
val16=$[rint($(val7[1])*($val15))]
!else
val16=$[rint($(val7[4]))]
!endif

!ifval $val8=1
val17=$[rint($(val7[2])*($val15))]
!else
val17=$[rint($(val7[5]))]
!endif

!ifval $(val7[1])*($(val7[5]))-($(val7[2]))*($(val7[4]))=0
val8=$[rint(1)]
!endif
!if $(val7[1])!=0 and $(val7[2])!=0 
tmp0=!texmath $(val7[1])*x + $(val7[2])*y

tmp1=!texmath $(val7[2])*y + $(val7[1])*x

tmp=!nonempty items $(tmp0),$(tmp1)

tmp2=!randitem $tmp
val18=$(tmp2)
!else

!ifval $(val7[1])=0
tmp=!translate ";': to $     $ in $(val7[2])*y

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val18=$(tmp0)
!else
tmp=!translate ";': to $     $ in $(val7[1])*x

tmp=!lower $tmp
tmp1=!exec maxima fullratsimp($tmp);
val18=$(tmp1)
!endif
!endif
!if $val16!=0 and $val17!=0 
tmp0=!texmath $val16*x + $val17*y

tmp1=!texmath $val17*y+$val16*x

tmp=!nonempty items $(tmp0),$(tmp1)

tmp2=!randitem $tmp
val19=$(tmp2)
!else

!ifval $val16=0
tmp=!translate ";': to $     $ in $val17*y

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val19=$(tmp0)
!else
tmp=!translate ";': to $     $ in $val16*x

tmp=!lower $tmp
tmp1=!exec maxima fullratsimp($tmp);
val19=$(tmp1)
!endif
!endif
tmp0=!shuffle $val18= $(val7[3]) , $val19 = $(val7[6]) 

val20=$(tmp0)
tmp0=!item $val8 of $val11

val21=$(tmp0)
