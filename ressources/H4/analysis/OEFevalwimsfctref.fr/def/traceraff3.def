$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!ifval $(val20[1]) isitemof $val14 and $(val20[2]) isitemof $val14
 condtest1=1
!else
 condtest1=0
!endif
condname1=points

!exit

:stat
vsavelist=10,14,19,20
embedcnt=1
