!set title=Tracer de fonctions affines 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rťgine, Mangeard
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=18
prevarcnt=17
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=1
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!makelist x/2 for x=-4 to 4

val6=$(tmp0)
tmp=!nonempty items $val6

tmp0=!randitem $tmp
t_=!rawmath $(tmp0)
val7=!exec pari print($t_)
tmp0=!makelist x/2 for x=-4 to 4

val8=$(tmp0)
tmp=!nonempty items $val8

tmp0=!randitem $tmp
t_=!rawmath $(tmp0)
val9=!exec pari print($t_)
val10=$val9*x+$val7
val11=$[rint(2*$val7+6)]
val12=$[rint(2*($val9+$val7)+6)]
val13=$[rint(2*(-$val9+$val7)+6)]
val14=A$val11,B$val12,C$val13
val15=
!for val16 =-6 to 6 
val17=$[rint($val16+6)]
val15=$val15	   point 0,$val16/2,red	   text black,-0.3,$val16/2,medium,A$val17	   point 1,$val16/2,red	   text black,0.7,$val16/2,medium,B$val17	   point -1,$val16/2,red	   text black,-1.3,$val16/2,medium,C$val17	  
!next
val18=lightblue
val19=xrange -3,3	yrange -3.5,3.5	gridfill 0,0,5,5,$val18	linewidth 3	vline 1,0,$val18	vline 2,0,$val18	vline 3,0,$val18	vline -1,0,$val18	vline -2,0,$val18	vline -3,0,$val18	hline 0,1,$val18	hline 0,2,$val18	hline 0,3,$val18	hline 0,-1,$val18	hline 0,-2,$val18	hline 0,-3,$val18	linewidth 1	vline 0,0,black	hline 0,0,black	arrow 0,0,1,0,10,magenta	arrow 0,0,0,1,10,magenta	text red,0.7,-0.1,medium,i	text red,-0.2,0.7,medium,j	text black,-0.2,-0.1,medium,O	linewidth 5	$val15	

!ifval $val7=0
tmp0=!texmath $val9*x

val10=$(tmp0)
!else
tmp1=!texmath $val10

val10=$(tmp1)
!endif

!ifval $val9=0
tmp0=!texmath $val7

val10=$(tmp0)
!endif
replytype1=fset
replyname1=points
replygood1=?analyze 20
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="grid-x grid-margin-x">	  <div class="cell small-12 medium-6 large-7">	  On considŤre une fonction affine d'expression algťbrique	<div class="wimscenter"> 
!insmath f(x)=$val10
$() </div>	<label for="reply1">Nommer deux points appartenant ŗ sa reprťsentation graphique.</label>	<div class="wimscenter"> 
!read oef/embed.phtml r1,5 
$()</div>	  </div>	  <div class="cell auto">	     
!read oef/draw.phtml 400,400 \
$val19 
$()	  </div>	</div>	
$()
!exit

