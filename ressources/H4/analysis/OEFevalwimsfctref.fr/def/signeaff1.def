!set title=Signe de mx+p 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
email=regine@mangeard.fr
oefcss=<style> table.tab_var {margin-left:auto;margin-right:auto; border:solid 1px black;} table.tab_var tr, table.tab_var td, table.tab_var th { padding:7pt;margin-top:10px; margin-bottom:10px; text-align:center; border-collapse:collapse; min-width:10pt; } table.tab_var th { border:solid 1px black} table.tab_var tr { border:solid 1px black} .big{color:red;font-size:120%;font-weight:bold} </style> 

ansorder=r,r,r,r
varcnt=11
prevarcnt=10
postvarcnt=0
replycnt=4
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 9

tmp1=!randitem 1,-1

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 9

tmp1=!randitem 1,-1

val7=$[rint($(tmp0)*$(tmp1))]
t_=!rawmath -$val7 / $val6
val8=!exec pari print($t_)
tmp0=!texmath $val6*x+$val7

val9=\($(tmp0))
val10=<span class="big">+</span>
val11=<span class="big">-</span>

!ifval $val6>0
val12=$val11
!else
val12=$val10
!endif

!ifval $val6<0
val13=$val11
!else
val13=$val10
!endif
val14=$val10,$val11
val15=30x30x1
replytype1=numeric
replyname1=valeur de x
replygood1=$[$val8]
replytype2=numeric
replyname2=ligne des x
replygood2=$[$val8]
replytype3=clickfill
replyname3=signe ‡ gauche
replygood3=$val12;$val14
replytype4=clickfill
replyname4=signe ‡ droite
replygood4=$val13;$val14
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  ComplÈter&nbsp;:<div>	  <label for="reply1">L'expression $val9 s'annule et change de signe en 
!insmath x=
$()	  </label> 
!read oef/embed.phtml reply1,3 
$().</div>	  Puis remplir le tableau des signes suivant&nbsp;:	<table class="tab_var">	  <tr><th>
!insmath x
$()</th>	  <td style="width:20%">
!insmath -\infty
$()</td>	  <td style="width:20%"> 
!read oef/embed.phtml reply2,3 
$()</td>	  <td style="width:30%">&nbsp;</td>	  <td style="width:20%">
!insmath +\infty
$()</td>	</tr><tr>	<th>$val9</th>	<td style="width:30%"> 
!read oef/embed.phtml reply3,$val15 
$()</td>	<td style="width:20%">0</td>	<td style="width:30%"> 
!read oef/embed.phtml reply4,$val15 
$()</td>	<td style="width:20%">&nbsp;</td>	</tr>	</table>	
$()
!exit

