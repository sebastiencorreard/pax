!set title=Propriétés de sinus et cosinus 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr
computeanswer=yes
precision=1000

ansorder=r
varcnt=10
prevarcnt=9
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=xrange -1,1	 yrange -1,1	 circle 0,0,200,black	 darrow -1,0,1,0,10,black	 darrow 0,-1,0,1,10,black	 dsegment -cos(pi/6),-sin(pi/6),cos(pi/6),sin(pi/6),green	 dsegment -cos(pi/3),-sin(pi/3),cos(pi/3),sin(pi/3),green	 dsegment -cos(-pi/6),-sin(-pi/6),cos(-pi/6),sin(-pi/6),green	 dsegment -cos(-pi/3),-sin(-pi/3),cos(-pi/3),sin(-pi/3),green	 dsegment cos(pi/4),sin(pi/4),-cos(pi/4),-sin(pi/4),red	 dsegment cos(-pi/4),sin(-pi/4),-cos(-pi/4),-sin(-pi/4),red	 
val7=$[3.1415926535897932385]
val8=xrange -6.28,6.28	 yrange -2,2	 arrow -6.28,0,6.28,0,10,black	 arrow 0,-2,0,2,10,black	 parallel -2*$val7,-0.1,-2*$val7,0.1,$val7/4,0,17,black	 parallel -0.1,-2,0.1,-2,0,1,5,black	 text black,0.2,1.2,large,+1	 text black,0.2,-0.8,large,-1	 plot red,sin(x)	
val9=xrange -6.28,6.28	  yrange -2,2	  arrow -6.28,0,6.28,0,10,black	  arrow 0,-2,0,2,10,black	  parallel -2*$val7,-0.1,-2*$val7,0.1,$val7/4,0,17,black	  parallel -0.1,-2,0.1,-2,0,1,5,black	  text black,0.2,1.2,large,+1	  text black,0.2,-0.8,large,-1	  plot red,cos(x)	
val10=\(\cos{x} \le 0),\(\cos{x} \ge 0)
val11=&#91; \(0;\frac{\pi}{2}) &#93;,2	&#91; \(\frac{\pi}{2};\pi) &#93;,1	&#91; \(\frac{3\pi}{4};\frac{5\pi}{4}) &#93;,1	&#91; \(\pi;\frac{3\pi}{2}) &#93;,1	&#91; \(\frac{3\pi}{2};2\pi) &#93;,2	&#91; \(\frac{-\pi}{4};\frac{\pi}{4}) &#93;,2	
tmp=!translate internal $	$ to ; in $val11

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val12=$(tmp0)
val13=$(val12[1])
val14=$[rint($(val12[2]))]
replytype1=radio
replyname1=Signe de cos x
replygood1=$val14;$val10
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="grid-x grid-margin-x">	  <div class="cell small-12 medium-6 large-7">	   A l'aide du cercle trigonométrique ci-contre, déterminer le signe de 
!insmath \cos{x}
$()	  lorsque 
!insmath x \in
$() $val13.	  <div class="wimscenter"> 
!read oef/embed.phtml reply1 
$()</div>	  </div>	  <div class="cell auto">	     
!read oef/draw.phtml 200,200 \
$val6 
$()	  </div>	</div>	
$()
!exit

