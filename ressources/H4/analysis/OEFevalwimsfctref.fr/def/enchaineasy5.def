rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=16
prevarcnt=15
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 8

tmp1=!randitem 1,-1

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 8

tmp1=!randitem 1,-1

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!texmath x^2

val8=!rawmath $(tmp0)
tmp0=!texmath 1/x

val9=!rawmath $(tmp0)
val10=$val6 x
val11=!rawmath $val6/(x^2)
val12=!rawmath 1/($val6*x^2)
val13=!rawmath 1/($val6*x)^2
val14=\(\begin{array}{ccccccc}& $val8&&$val9&&$val10&\\ x & \longmapsto &\cdots &\longmapsto & \cdots & \longmapsto & \cdots\end{array})
val15=\(\begin{array}{ccccccc}& $val8&&$val10&&$val9&\\ x & \longmapsto &\cdots &\longmapsto & \cdots & \longmapsto & \cdots\end{array})
val16=\(\begin{array}{ccccccc}& $val10&&$val8&&$val9&\\ x & \longmapsto &\cdots &\longmapsto & \cdots & \longmapsto & \cdots\end{array})
tmp0=!randint 1, 3

val17=$[rint($(tmp0))]
val18=\($val11),\($val12),\($val13)
val19=$val14,$val15,$val16
val20=$(val18[$val17])
replytype1=radio
replyname1=Enchainement ?
replygood1=$val17;$val19
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

