!set title=Propriété de la fonction inverse 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr
precision=1000
computeanswer=yes

ansorder=r
varcnt=6
prevarcnt=5
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 9

tmp1=!randitem 1,-1

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -9, 9

val7=$[rint($(tmp0))]
tmp0=!randint -9, 9

val8=$[rint($(tmp0))]
tmp0=!texmath 1/($val6*x+$val7)+$val8

val9=$(tmp0)
t_=!rawmath -$val7/$val6
val10=!exec pari print($t_)
replytype1=numeric
replyname1=axe
replygood1=$[$val10]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Quel est le réel 
!insmath x_0
$() qui n'a pas d'image par la fonction 
!insmath f
$() définie par	<div class="wimscenter">
!insmath f(x)=$val9
$()</div>	<div class="wimscenter">
!insmath x_0=
$() 
!read oef/embed.phtml reply1 
$()</div>	
$()
!exit

