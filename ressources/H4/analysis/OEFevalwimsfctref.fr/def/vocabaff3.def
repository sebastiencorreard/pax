tmp0=!makelist x,-x for x=1 to 20

val6=$(tmp0)
tmp0=!shuffle 40

val7=$(tmp0)
val8=$[rint($(val6[$(val7[1])]))]
val9=$[rint($(val6[$(val7[2])]))]
val10=$[rint($(val6[$(val7[3])]))]
tmp0=!randint 1, 9

tmp1=!randitem 1,-1

tmp2=!randint 1, 7

tmp=!translate ";': to $     $ in $(tmp0)*$(tmp1)/$(tmp2)

tmp=!lower $tmp
tmp3=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp3)
val11=!exec pari print($t_)
tmp0=!randint 1, 9

tmp1=!randitem 1,-1

tmp2=!randint 1, 7

tmp=!translate ";': to $     $ in $(tmp0)*$(tmp1)/$(tmp2)

tmp=!lower $tmp
tmp3=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp3)
val12=!exec pari print($t_)
t_=!rawmath $val11*$val8+$val12
val13=!exec pari print($t_)
t_=!rawmath $val11*$val9+$val12
val14=!exec pari print($t_)
t_=!rawmath $val11*$val10+$val12
val15=!exec pari print($t_)

!ifval $val12=0
tmp0=!texmath $val11*x

val16=$(tmp0)
!else
tmp1=!texmath $val11*x+$val12

val16=$(tmp1)
!endif
tmp0=!randint -30, 30

val12=$[$(tmp0)/10]
tmp0=!randint 1, 3

tmp1=!randitem 1,-1

tmp=!translate ";': to $     $ in $val11+$(tmp0)*$(tmp1)

tmp=!lower $tmp
tmp2=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp2)
val17=!exec pari print($t_)
tmp0=!randitem 0.5,1,-0.5,-1

val18=$[$val12+$(tmp0)]
tmp0=!randint 1, 3

val19=$[rint($(tmp0))]
!if $val19=1 
t_=!rawmath $val12
val18=!exec pari print($t_)
!endif
!if $val19=2 
t_=!rawmath $val11
val17=!exec pari print($t_)
!endif
val20=$val17*x+$val18
val16=$val11*x+$val12
val21=lightblue
val22=xrange -3,3	yrange -3.5,3.5	gridfill 0,0,5,5,$val21	linewidth 3	vline 1,0,$val21	vline 2,0,$val21	vline 3,0,$val21	vline -1,0,$val21	vline -2,0,$val21	vline -3,0,$val21	hline 0,1,$val21	hline 0,2,$val21	hline 0,3,$val21	hline 0,-1,$val21	hline 0,-2,$val21	hline 0,-3,$val21	linewidth 1	vline 0,0,black	hline 0,0,black	arrow 0,0,1,0,10,magenta	arrow 0,0,0,1,10,magenta	text red,0.7,-0.1,medium,i	text red,-0.2,0.7,medium,j	text black,-0.2,-0.1,medium,O	linewidth 2	plot red,$val16	plot green,$val20	
val23=l'ordonnée ŕ l'origine mais pas le coefficient directeur,le coefficient directeur mais pas l'ordonnée ŕ l'origine, ni le coefficient directeur ni l'ordonnée ŕ l'origine, le coefficient directeur et l'ordonnée ŕ l'origine
