!set title=Conversion degrť / radian 5
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rťgine, Mangeard
email=regine@mangeard.fr
precision=1000
computeanswer=yes

ansorder=r,r,r
varcnt=22
prevarcnt=21
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=30,45,60,90,120,135,150,180,210,235,240,270,300,315,330
val7=pi/6,pi/4,pi/3,pi/2,2*pi/3,3*pi/4,5*pi/6,pi,7*pi/6,5*pi/4,4*pi/3,3*pi/2,5*pi/3,7*pi/4,11*pi/6
val8=\frac{\pi}{6},\frac{\pi}{4},\frac{\pi}{3},\frac{\pi}{2},\frac{2\pi}{3},\frac{3\pi}{4},\frac{5\pi}{6},\pi,\frac{7\pi}{6},\frac{5\pi}{4},\frac{4\pi}{3},\frac{3\pi}{2},\frac{5\pi}{3},\frac{7\pi}{4},\frac{11\pi}{6}
tmp0=!randitem 3,4,6,8,12

val9=$[rint($(tmp0))]
tmp0=!makelist x for x=1 to $val9-1

tmp1=!makelist x for x=$val9+1 to 2*$val9-1

val10=$(tmp0),$(tmp1)
tmp0=!shuffle $val10

val10=$(tmp0)
val11=
!for val12 =1 to 4 
val13=$[rint($(val10[$val12]))]
tmp=!translate ";': to $     $ in $val13 / $val9

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val14=!exec pari print($t_)
val15=$val14
tmp0=!replace internal / by , in $val15

val15=$(tmp0)

!ifval $(val15[1])=1
val15=\frac{\pi}{$(val15[2])}
!else
val15=\frac{$(val15[1]) \pi}{$(val15[2])}
!endif
tmp0=!append item $val15 to $val11

val11=$(tmp0)
!next
val16=
tmp=!translate ";': to $     $ in $(val10[1]) / $val9

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val17=!exec pari print($t_)
!for val12 =2 to 4  
val13=$[rint($(val10[$val12]))]
tmp=!translate ";': to $     $ in $val13 / $val9

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val14=!exec pari print($t_)
tmp=!translate ";': to $     $ in ($val14) / ($val17)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val18=!exec pari print($t_)
tmp0=!append item $val18 to $val16

val16=$(tmp0)
!next
replytype1=numeric
replyname1=angle 1
replygood1=$[$(val16[1])]
replytype2=numeric
replyname2=angle 2
replygood2=$[$(val16[2])]
replytype3=numeric
replyname3=angle 3
replygood3=$[$(val16[3])]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Un angle 
!insmath \alpha
$() mesure 
!insmath $(val11[1])
$() rad.	  Ecrire chacune des mesures suivantes en radian sous la forme 
!insmath k \times \alpha
$(),	  avec 
!insmath k
$() rationnel.	<ol>	<li><label for="reply1">
!insmath $(val11[2])
$() rad=</label>  
!read oef/embed.phtml reply1,3 
$()
!insmath \alpha
$()</li>	<li><label for="reply2">
!insmath $(val11[3])
$() rad=</label>  
!read oef/embed.phtml reply2,3 
$()
!insmath \alpha
$()</li>	<li><label for="reply3">
!insmath $(val11[4])
$() rad=</label>  
!read oef/embed.phtml reply3,3 
$()
!insmath \alpha
$()</li>	</ol>	
$()
!exit

