 !exit
!endif

val6=\(0 < a < b),\(\frac{1}{b}),\(\frac{1}{a})	\(a< b  \le 0),\(\frac{1}{b}),\(\frac{1}{a})	\(a < 0 < b),\(\frac{1}{a}),\(\frac{1}{b})	
tmp=!translate internal $	$ to ; in $val6

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$(tmp0)
val8=$(val7[1])
val9=$(val7[2])
val10=$(val7[3])
val11=$val9,$val10
val12=40x40x1
replytype1=clickfill
replyname1=
replygood1=$val9;$val11
replytype2=clickfill
replyname2=
replygood2=$val10;$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

