    \integer{val4=\v2}
    \text{qrep=\brepb}
    \text{qrepb=\brep}
    \text{cas=4}
  }
}
\if{\kt=2}
  {%%%% intersection
   \if{\val3>=\val2}
     {\if{\val3 != \val2}
        {\text{grep=\empt}
         \text{casSol=1}
        }
        {\if{\qrep[5]=\crocd and \qrepb[1]=\crocg}
          {\text{grep=\bracg,\qrep[4],\bracd | \crocg,\qrep[4],\ptvirg,\qrep[4],\crocd}
           \text{casSol=2}
          }
          {\text{grep=\empt}
           \text{casSol=3}
          }
        }
     }
     {\if{\val1 = \val3}
        {\if{\qrep[1]=\qrepb[1]}
          {\text{grep=\qrep[1],\qrep[2],\ptvirg}}
          {\text{grep=\crocd,\qrep[2],\ptvirg}}
        }
        {\text{grep=\qrepb[1],\qrepb[2],\ptvirg}}
        \if{\val4<=\val2}
          {\text{grep=\grep,\qrepb[4]}
           \if{\val4 != \val2 or \qrep[5]=\qrepb[5]}
             {\text{grep=\grep,\qrepb[5]}
              \text{casSol=4}
             }
             {\text{grep=\grep,\crocg}
              \text{casSol=5}
             }
          }
          {\text{grep=\grep,\qrep[4],\qrep[5]}
           \text{casSol=6}
          }
     }
  }
  {%%%% union
  \if{\val2<\val3}
    {\text{grep=\qrep,\slien,\qrepb}}
    {\if{\val2=\val3}
      {\if{\qrep[5]=\crocg and \qrepb[1]=\crocd}
        {\text{grep=\qrep,\slien,\qrepb}}
        {\text{grep=\qrep[1],\qrep[2],\ptvirg,\qrepb[4],\qrepb[5]}}
      }
      {\text{interv=\qrep[2],\ptvirg,\qrepb[4]}
       \if{\qrep[1]=\qrepb[1]}{\text{c1=\qrep[1]}}{\text{c1=\crocg}}
       \if{\qrep[5]=\qrepb[5]}{\text{c2=\qrep[5]}}{\text{c2=\crocd}}
       \if{\val1=\val3}
         {\if{\val2=\val4}
           {\text{grep=\c1,\interv,\c2}}
