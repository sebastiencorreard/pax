%%%% taille des symboles et des champs ŕ remplir par clic LxHxnb ##
\text{size=40x40x12}
  \integer{a=random(1..8)*random(1,-1)}
  \integer{b=random(1..8)*random(1,-1)}
  \integer{c=random(1..8)*random(1,-1)}
  \integer{d=random(1..8)*random(1,-1)}
  \integer{a=1}
  \integer{c=1}
  \integer{b=0}
  \integer{d=0}
   \title{Réunion d'intervalles V}
  \integer{u1=\a*(\sing1)+(\b)}
  \integer{u2=\a*(\sing2)+(\b)}
  \integer{ub1=\c*(\sing3)+(\d)}
  \integer{ub2=\c*(\sing4)+(\d)}
  \if{\k=1}{
    \if{\a>0}{
      \text{eqx=\u1 \symboles[\symbx1] \(texmath(maxima(\a*x+(\b)))) \symboles[\symbx2] \u2 }
    }{
      \text{eqx=\u2 \symboles[\symbx2] \(texmath(maxima(\a*x+(\b)))) \symboles[\symbx1] \u1 }
    }
    \text{eqx1=\sing1 \symboles[\symbx1] \(x) \symboles[\symbx2] \sing2 }
  }{
    \if{\a>0}{
      \text{eqx=\k=2? \(texmath(maxima(\a*x+(\b)))) \symboles[\symbx] \u2: \u1 \symboles[\symbx] \(texmath(maxima(\a*x+(\b)))) }
     }{
      \text{eqx=\k=2? \u2 \symboles[\symbx] \(texmath(maxima(\a*x+(\b)))) : \(texmath(maxima(\a*x+(\b)))) \symboles[\symbx] \u1}
     }
    \text{eqx1=\k=2? \(x) \symboles[\symbx] \sing2: \sing1 \symboles[\symbx] \(x) }
  }
  \if{\kb=1}{
    \if{\c>0}{
      \text{eqxb=\ub1 \symboles[\symbx3] \(texmath(maxima(\c*x+(\d)))) \symboles[\symbx4] \ub2 }
    }{
      \text{eqxb=\ub2 \symboles[\symbx4] \(texmath(maxima(\c*x+(\d)))) \symboles[\symbx3] \ub1 }
    }
    \text{eqx2=\sing3 \symboles[\symbx3] \(x) \symboles[\symbx4] \sing4 }
  }{
    \if{\c>0}{
      \text{eqxb=\kb=2? \(texmath(maxima(\c*x+(\d)))) \symboles[\symbbx] \ub2: \ub1 \symboles[\symbbx] \(texmath(maxima(\c*x+(\d)))) }
    }{
      \text{eqxb=\kb=2? \ub2 \symboles[\symbbx] \(texmath(maxima(\c*x+(\d)))) : \(texmath(maxima(\c*x+(\d)))) \symboles[\symbbx] \ub1}
    }
    \text{eqx2=\kb=2? \(x) \symboles[\symbbx] \sing4: \sing3 \symboles[\symbbx] \(x) }
  }
  \statement{
  Si
