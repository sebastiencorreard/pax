       }
  }
%%%% choix intersection ou union
 \integer{kt=1}
\text{slien=\kt=1?\union:\inter}
\text{sverb=\kt=1?OU:ET}
%%%% calcul de la réponse ###
\text{qrep=\brep}
\text{qrepb=\brepb}
\if{\v1<\v3}{
  \integer{val1=\v1}
  \integer{val2=\v2}
  \integer{val3=\v3}
  \integer{val4=\v4}
