         }
         {\if{\val2<=\val4}
           {\if{\val2=\val4}
             {\text{grep=\qrep[1],\interv,\c2}}
             {\text{grep=\qrep[1],\interv,\qrepb[5]}}
           }
           {\text{grep=\qrep}}
         }
      }
    }
  }
