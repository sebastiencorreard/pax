\rational{x1=simplify(-\b / \a)}
\rational{x2=simplify(\b / \a)}
\rational{x3=simplify(\a / \b)}
\rational{x4=simplify(-\a / \b)}
\rational{x5=\a}
\rational{x6=\b}
