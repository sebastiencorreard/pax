!set title=Valeur absolue et distance I
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=RÈgine, Mangeard;Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=19
prevarcnt=18
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val6=$[rint($(tmp0)* $(tmp1))]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val7=$[rint($(tmp0)* $(tmp1))]

!ifval $val7=$val6
val7=$[rint($val7+2)]
!endif
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val8=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem 1,2

val9=$[rint($(tmp0))]

!ifval $val9=1
tmp0=!randitem -1,-2,2

t_=!rawmath $(tmp0)
val10=!exec pari print($t_)
!else
tmp1=!randitem -1,-2,-3,2,3

t_=!rawmath $(tmp1)/$val7
val10=!exec pari print($t_)
!endif

!ifval $val10=1
t_=!rawmath 2
val10=!exec pari print($t_)
!endif
tmp0=!randitem 1,2

val11=$[rint($(tmp0))]

!ifval $val7<0
val7=$[rint(-1*$val7)]
!endif

!ifval ($val6=$val7 or $val6=-$val7)
val7=$[rint(2*$val7)]
!endif
val12=Traduire mathÈmatiquement avec une valeur absolue,Choisir la phrase qui traduit l'ÈgalitÈ
val13=$(val12[$val11])
val14=Sur une droite graduÈe&#44; la distance du point \(M\) d'abscisse \(x\) au point \(A\) d'abscisse \($val6\) vaut \($val7\),	  Sur une droite graduÈe&#44; la distance du point \(M\) d'abscisse \(x\) au point \(A\) d'abscisse \(-$val6\) vaut \($val7\),	  Sur une droite graduÈe&#44; la distance du point \(M\) d'abscisse \(x\) au point \(A\) d'abscisse \($val7\) vaut \($val6\),	\(abs(x-($val6))=$val7\),\(abs(x-($val7))=$val6\),\(abs(x+($val6))=$val7\)
!if $val11=1 
val15=$(val14[1])
tmp0=!item 4 to 6 of $val14

val16=$(tmp0)
!else
val15=$(val14[4])
tmp0=!item 1 to 3 of $val14

val16=$(tmp0)
!endif
val17=$[rint(1)]
replytype1=radio
replyoption1=shuffle 
replyname1=traduction
replygood1=$val17;$val16
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

