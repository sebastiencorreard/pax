tmp0=!randint 2, 9

val6=$[rint($(tmp0))]
tmp0=!randint 2, 9

val7=$[rint($(tmp0))]
tmp0=!randint 2, 9

val8=$[rint($(tmp0))]
tmp0=!texmath $val6/(x+$val7) < $val6/(x-$val8)

val9=\($(tmp0)\)
tmp0=!texmath $val6*(x-$val8) < $val6*(x+$val7)

val10=\($(tmp0)\)
val11=$[rint($val6*$val8)]
val12=$[rint($val6*$val7)]
tmp0=!texmath $val6*x-$val11 < $val6*x+$val12

val13=\($(tmp0)\)
tmp0=!texmath -$val11 < $val12

val14=\($(tmp0)\)
val15=1/($val6+1)
val16=C'est correct,C'est faux&#44; l'inégalité est fausse pour \(x = 0\),L'inégalité est fausse pour une infinité de valeurs,L'inégalité est vraie seulement pour \(x > 0\)
val17=Caroline,Charlotte,Johanna,Kevin,Jacques,Pierre,Gaspard
tmp0=!randint 1, 7

val18=$[rint($(tmp0))]
val19=$(val17[$val18])

!ifval $val18<4
val20=Elle
!else
val20=Il
!endif
val21=2,3
replytype1=checkbox
replyname1=Votre réponse
replygood1=$val21;$val16
