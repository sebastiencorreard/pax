!set title=Transformation d'une inégalité 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard;Jean-Pierre, Boudine
email=regine@mangeard.fr

ansorder=r,r
varcnt=9
prevarcnt=8
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 9

tmp1=!randitem 1,-1

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 2, 9

tmp1=!randitem 1,-1

val7=$[rint($(tmp0)*$(tmp1))]

!ifval $val6=$val7
val7=$[rint(-1*$val6)]
!endif
val8=$[rint($val6+$val7)]
val9=$[rint($val7-$val6)]
tmp0=!texmath $val6*x+$val7 <= $val8*x+$val9

val10=\($(tmp0)\)
val11=$val6-$val7*x
val12=$val7*x-$val6
replytype1=algexp
replyname1=équation 1 gauche
replygood1=$val11
replytype2=algexp
replyname2=équation 2 gauche
replygood2=$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<ol>	<li>Transformez l'inéquation suivante en une inéquation équivalente,	  de manière à ce que votre résultat soit de la forme <span class="nowrap">
!insmath A <= 0
$().</span>	<div class="wimscenter"><label for="reply1">$val10 équivaut à</label>	 
!read oef/embed.phtml reply1,7 
$()
!insmath <=0
$()</div>	</li><li>	  Transformez à nouveau cette inéquation en une inéquation	  équivalente, de manière à ce que votre résultat soit de la forme <span class="nowrap">
!insmath B >= 0
$().</span>	<div class="wimscenter"><label for="reply2">$val10 équivaut à </label>	 
!read oef/embed.phtml reply2,7 
$()
!insmath >=0
$()</div></li>	</ol>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=10
embedcnt=2
