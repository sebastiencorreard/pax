tmp0=!randint 2, 9

val6=$[rint($(tmp0))]
tmp0=!randint 2, 9

val7=$[rint($(tmp0))]
tmp0=!randint 2, 9

val8=$[rint($(tmp0))]
tmp0=!texmath $val6/(x+$val7) < $val6/(x-$val8)

val9=\($(tmp0)\)
tmp0=!texmath $val6*(x-$val8) < $val6*(x+$val7)

val10=\($(tmp0)\)
val11=$[rint($val6*$val8)]
val12=$[rint($val6*$val7)]
tmp0=!texmath $val6*x-$val11 < $val6*x+$val12

val13=\($(tmp0)\)
tmp0=!texmath -$val11 < $val12

val14=\($(tmp0)\)
val15=1/($val6+1)
val16=Caroline,Charlotte,Johanna,Kevin,Jacques,Pierre,Gaspard
tmp0=!randint 1, 7

val17=$[rint($(tmp0))]
val18=$(val16[$val17])

!ifval $val17<4
val19=Elle
!else
val19=Il
!endif

!ifval $val17<4
val20=elle
!else
val20=il
!endif
val21=2
val22=L'inégalité finale ne comportant pas \(x\)&#44; on ne peut pas conclure,Si on multiplie les deux membres par \((x-$val8)\) ou par \((x+$val7)\)&#44; on n'a pas une inégalité équivalente,Il y a une faute de signe dans le calcul quand $val20 a développé et réduit puis simplifié,Une inégalité n'est vraie que si \(x > 0\) 
replytype1=checkbox
replyname1=Votre réponse
replygood1=$val21;$val22
question=__EXECUTED_1692754_EXERCISE__

!goto stat

