 !exit
!endif

tmp0=!randitem 2,3,5,6,7,8

val6=$[rint($(tmp0))]
val7=$val6^2+$val6-1+2*$val6*sqrt($val6)
tmp0=!texmath $val6+sqrt($val6)=sqrt(x+1)

val8=\($(tmp0)\)
replytype1=algexp
replyname1=membre de gauche
replygood1=$val7
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Dans cette ķquation, on suppose que 
!insmath x \ge -1
$(), pour que le membre de droite ait un sens.<p>	  Transformez cette ķquation de maniĶre Ó ce que le membre de droite soit <span class="nowrap">"
!insmath x
$() " :</span>	</p>	<div class="wimscenter"><label for="reply1">$val8 ķquivaut Ó</label>  
!read oef/embed.phtml reply1,10 
$()=
!insmath x
$()</div>	<div class="wims_instruction"> Taper <span class="tt">sqrt(a)</span> pour 
!insmath sqrt(a)
$().</div>	
$()
