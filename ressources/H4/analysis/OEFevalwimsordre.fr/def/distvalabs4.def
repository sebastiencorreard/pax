tmp1=!randitem 1,-1

val7=$[rint($(tmp0)* $(tmp1))]

!ifval $val7=$val6
val7=$[rint($val7+2)]
!endif
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val8=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem 1,2

val9=$[rint($(tmp0))]

!ifval $val9=1
tmp0=!randitem -1,-2,2

t_=!rawmath $(tmp0)
val10=!exec pari print($t_)
!else
tmp1=!randitem -1,-2,-3,2,3

t_=!rawmath $(tmp1)/$val7
val10=!exec pari print($t_)
!endif

!ifval $val10=1
t_=!rawmath 2
val10=!exec pari print($t_)
!endif

!ifval $val8<0
val8=$[rint(-1*$val8)]
!endif
val10=$[rint(abs($val7-($val6)))]
val11=le point \(M\) d'abscisse \(x\) est ŕ égale distance des points \(A\) d'abscisse \($val6\) et \(B\) d'abscisse \($val7\),abs(x-($val6))=abs(x-($val7)),\(M A = M B\),\(\mathrm{d}(x,$val6)=\mathrm{d}(x,$val7)\)	  la distance du point \(M\) d'abscisse \(x\) au point \(B\) d'abscisse \($val7\) vaut \($val8\),abs(x-($val7))=$val8,\(M B = $val8\),\(\mathrm{d}(x,$val7)=$val8\)	  la distance du point \(M\) d'abscisse \(x\) au point \(B\) d'abscisse \($val7\) est le double de la distance de \(M\) ŕ \(A\) d'abscisse \($val6\),abs(x-($val7))=2*abs(x-($val6)),\(M B = 2  M A\),\(\mathrm{d}(x,$val7)=2 \times \mathrm{d}(x,$val6)\)	  le point \(M\) d'abscisse \(x\) est le milieu du segment \([AB]\),abs(x-($val6))=abs(x-($val7)),\(M A = M B\),\(\mathrm{d}(x,$val6)=\mathrm{d}(x,$val7)\)	  le point \(M\) d'abscisse \(x\) est le symétrique du point \(A\) d'abscisse \($val6\) par rapport au point \(B\) d'abscisse \($val7\),abs(x-($val7))=abs($val7-$val6),\(M B = B A\),\(\mathrm{d}(x,$val7)=\mathrm{d}($val7,$val6)\),\(abs(x-($val7))=$val10\)
