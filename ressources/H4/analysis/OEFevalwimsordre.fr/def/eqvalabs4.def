val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem 1,2

val6=$[rint($(tmp0))]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 3

tmp1=!randitem 1,-1

val8=$[rint($val7+$(tmp0)*$(tmp1))]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val9=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 10

tmp1=!randitem 1,1,1,1,-1

val10=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val11=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val12=$[rint($(tmp0)*$(tmp1))]
val13=$[rint(20)]
val14=$[rint(10)]
tmp0=!randint 1, $val14

tmp1=!randitem 1,-1

val15=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, $val13

val16=$[rint($(tmp0))]
tmp0=!randitem 1,-1

val7=$[rint($(tmp0))]
tmp0=!randitem 1,-1

val8=$[rint($(tmp0))]

!ifval $val6=1
tmp0=!texmath $val7 * x-($val9)

tmp1=!texmath $val8 * x-($val10)

val17=\(abs($(tmp0)) = abs($(tmp1))) 
!else
tmp2=!texmath -($val9)+ $val7 *x

tmp3=!texmath $val8 * x-($val10)

val17=\(abs($(tmp2)) = abs($(tmp3))) 
!endif
tmp0=!texmath $val7 * x-($val9)

val18=$(tmp0)
tmp0=!texmath $val8 * x-($val10)

val19=$(tmp0)
tmp0=!texmath -($val8) * x+($val10)

val20=$(tmp0)
val21=
val22=$[rint($val9 - ($val10))]
val23=$[rint($val7 - ($val8))]
!if $val23<>0 
t_=!rawmath $val22 /($val23)
val24=!exec pari print($t_)
tmp0=!append item $val24 to $val21

val21=$(tmp0)
!endif
val25=$[rint($val9 + ($val10))]
val26=$[rint($val7 + ($val8))]
!if $val26<>0 
t_=!rawmath $val25 /($val26)
val27=!exec pari print($t_)
tmp0=!append item $val27 to $val21

val21=$(tmp0)
!endif
tmp0=!listuniq $val21

val21=$(tmp0)
replytype1=fset
replyname1=
replygood1=$val21
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

