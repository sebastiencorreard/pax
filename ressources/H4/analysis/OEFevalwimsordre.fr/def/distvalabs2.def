:test
tmp0=!texmath $val14


!ifval $(tmp0) isitemof $val12
 condtest1=1
!else
 condtest1=0
!endif
condname1=d(x,$val7) bonne réponse 
tmp0=!texmath $val15


!ifval $(tmp0) isitemof $val13
 condtest2=1
!else
 condtest2=0
!endif
condname2=d($val8,x) bonne réponse 

