!set title=Valeur absolue et distance II
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard;Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r,r
varcnt=11
prevarcnt=10
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=2
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val6=$[rint($(tmp0)* $(tmp1))]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val7=$[rint($(tmp0)* $(tmp1))]

!ifval $val7=$val6
val7=$[rint($val7+2)]
!endif
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val8=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem 1,2

val9=$[rint($(tmp0))]

!ifval $val9=1
tmp0=!randitem -1,-2,2

t_=!rawmath $(tmp0)
val10=!exec pari print($t_)
!else
tmp1=!randitem -1,-2,-3,2,3

t_=!rawmath $(tmp1)/$val7
val10=!exec pari print($t_)
!endif

!ifval $val10=1
t_=!rawmath 2
val10=!exec pari print($t_)
!endif
val11=xrange -13,13	  yrange -2,2	  hline 0,0,red	  parallel -12,-0.2,-12,0.2,1,0,2,blue	  parallel -10,-0.4,-10,0.4,5,0,5,blue	  parallel -9,-0.2,-9,0.2,1,0,4,blue	  parallel -4,-0.2,-4,0.2,1,0,4,blue	  parallel 1,-0.2,1,0.2,1,0,4,blue	  parallel 6,-0.2,6,0.2,1,0,4,blue	  parallel 11,-0.2,11,0.2,1,0,2,blue	  text red,-0.1,1,medium,O	  text red,$val7-0.1,1,medium,B	  text red,$val8-0.1,1,medium,C	  text red,-0.1,-0.75,medium,0	  text red,$val7-0.1,-0.75,medium,$val7	  text red,$val8-0.1,-0.75,medium,$val8	  segment $val7,-0.2,$val7,0.2,red	  segment $val8,-0.2,$val8,0.2,red	  
tmp0=!texmath x-($val7)

tmp1=!texmath $val7-x

tmp2=!texmath -x+($val7)

tmp3=!texmath -($val7)+x

val12=$(tmp0),$(tmp1), $(tmp2), $(tmp3)
tmp0=!texmath x-($val8)

tmp1=!texmath $val8-x

tmp2=!texmath -($val8)+x

tmp3=!texmath -x+($val8)

val13=$(tmp0),$(tmp1),$(tmp2),$(tmp3)
replyname1=dxa
replygood1=?analyze 14
replyname2=dxb
replygood2=?analyze 15
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Soit M le point d'abscisse 
!insmath x
$() sur la droite graduée d'origine O.	<div class="wimscenter">	 
!read oef/draw.phtml 800,64 \
$val11 
$()	</div>	  Donner l'expression de la distance de M ŕ B puis de C ŕ M, ŕ l'aide d'une valeur absolue.	<div class="wimscenter"><label for="reply1">d(
!insmath x
$(),$val7) =</label> &#124;  
!read oef/embed.phtml r1,5 
$()&#124;<br>	<label for="reply2">d($val8,
!insmath x
$()) = </label>&#124;  
!read oef/embed.phtml r2,5 
$()&#124;<br>	</div>	 
$()
!exit

