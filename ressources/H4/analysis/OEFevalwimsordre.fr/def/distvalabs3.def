tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val6=$[rint($(tmp0)* $(tmp1))]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val7=$[rint($(tmp0)* $(tmp1))]

!ifval $val7=$val6
val7=$[rint($val7+2)]
!endif
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val8=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem 1,2

val9=$[rint($(tmp0))]

!ifval $val9=1
tmp0=!randitem -1,-2,2

t_=!rawmath $(tmp0)
val10=!exec pari print($t_)
!else
tmp1=!randitem -1,-2,-3,2,3

t_=!rawmath $(tmp1)/$val7
val10=!exec pari print($t_)
!endif

!ifval $val10=1
t_=!rawmath 2
val10=!exec pari print($t_)
!endif
val11=$[rint(20)]
val12=$[rint(10)]
tmp0=!randint 1, $val12

tmp1=!randitem 1,-1

val13=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, $val11

val14=$[rint($(tmp0))]
tmp0=!texmath x-($val13)

val15=\(abs($(tmp0))) = $val14 
replytype1=numeric
replyname1=
replygood1=$[$val13]
replytype2=numeric
replyname2=
replygood2=$[$val14]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

