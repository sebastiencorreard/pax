/** les rťponses **/
\integer{\rep1=(\casf==4 or \casf==6)?pari(round(\y3)):\y3}
\integer{\rep2=pari(floor(\y2))}
\integer{\rep3=\rep2+1}
\text{choix=strictement infťrieure,ťgale,strictement supťrieure}
\integer{\rep4=(\y1<\y4)?1}
