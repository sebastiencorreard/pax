\integer{\rep4=(\y1>\y4)?3}
\statement{\ll<div class="wims_columns">
  <div class="medium_size img_col">
<div class="wimscenter">
\draw{350,350}{
xrange -\xsize,\xsize
yrange \ymin,\ymax
