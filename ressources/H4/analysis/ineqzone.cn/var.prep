w1=!item $wlevel of 1, 6,30
w2=!item $wlevel of 3,20,60

aa=!randint -50,50
aa=$[$aa/10]
az=!randint $w1,$w2
az=$[$az/10]
ba=!randint -50,50
ba=$[$ba/10]
bz=!randint $w1,$w2
bz=$[$bz/10]
a0=$[$aa-$az]
a1=$[$aa+$az]
b0=$[$ba-$bz]
b1=$[$ba+$bz]
l=$[(randint(40)+10)/10*(randint(2)*2-1)]
m=$[(randint(40)+10)/10*(randint(2)*2-1)]
c0=$[(randint(400)-200)/10]
f=!rawmath $l*a+$m*b
orient=!randitem 1,2
sign=!item $orient of &lt;,&gt;

status=waiting
