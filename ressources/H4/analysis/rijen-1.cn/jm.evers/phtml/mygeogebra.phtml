<form name="sendtext" method="get">

<p align="center">
<table bgcolor=$bgcolor1 cellpadding=$cellpadding cellspacing=$cellspacing>
    <td valign="top" align="left">
	$(question$n)
	!if $exotext != $empty
	    <br>
	    $exotext
	!endif
	!if $(formula$n) != $empty
	    <p align="center">
		<table border="1" cellpadding="15" bgcolor="#ffffa0">
		    <th>
			!insmath $(formula$n)
		    </th>
		</table>    
	    </p>
	!endif
	<p align="left">
	    !href target=wims_mhelp module=$module&+session=$session&+cmd=help
	    $helptext
	</p>                                                                                    
    <td>
    <tr>
    <td  valign="top">
	!if $width=$empty
	    !set width=640
	    !set height=480
	!endif
	<p align="center">
    	    <applet name="ggbApplet" code="geogebra.GeoGebraApplet" codebase="java/geogebra" archive="geogebra.jar" width=$width height=$height>
	    <param name="language" value="$lang">
	    <param name="filename" value="../../$module_dir/$ggb">
	    <param name="showToolBar"  value="$showToolBar">
	    <param name="showMenuBar"  value="$showMenuBar">
	    <param name="framePossible" value="$framePossible">
	    <param name="customToolBar" value=$customToolBar>
	    $nojava
	    </applet>    
	    <script language="JavaScript">
		$appletcommand
	    </script>
	    !read $authordir/js/geogebra2wims.js
	    <table>
		!if $inputs=1
		<td>
		    <center>
			!if $wims_user=supervisor
			    $inputtext1 $m_rightarrow <input  style=$textareastyle name="myvar1" size=$cols value=$(answer$n)>
			!else
			    $inputtext1 $m_rightarrow <input  style=$textareastyle name="myvar1" size=$cols value="$myvar1">
			!endif
		    </center>
		</td>
		<tr>
		!endif
		<td>	
		    <center>
		    <table>
			<th>
			    <input type=button style=$mybuttonstyle onclick="geogebra2wims();" name="but1" value="$send">
			</th>
			<th>
			    <input type=button style=$mybuttonstyle onclick="dontknow();" name="but2" value="$dontknow">
			</th>
		    </table>
		    </center>
		</td>
	    </table>    
	</p>
    </td>
</table>
</p>
</form>
