!set title=Trinôme du second degré 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr
precision=100
oefcss=<style> table.tab_var {margin-left:auto;margin-right:auto; border:solid 1px black;} table.tab_var tr, table.tab_var td, table.tab_var th { padding:7pt;margin-top:10px; margin-bottom:10px; text-align:center; border-collapse:collapse; min-width:10pt; } table.tab_var th { border:solid 1px black} table.tab_var tr { border:solid 1px black} </style> 

ansorder=r
varcnt=13
prevarcnt=12
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint -10, 10

val6=$[rint($(tmp0))]
tmp0=!randint -10, 10

val7=$[rint($(tmp0))]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val8=$[rint($(tmp0)*$(tmp1))]
val9=$val8*(x-$val6)^2+$val7
t_=!replace internal \( by ( in $val9
tmp0=!exec maxima $t_

tmp1=!texmath $(tmp0)

val10=$(tmp1)
t_=!rawmath $val6
val11=!exec pari print($t_)
t_=!rawmath $val7
val12=!exec pari print($t_)
val13=\(\searrow),\(\nearrow)

!ifval $val8>0
val14=1,2
!else
val14=2,1
!endif
val15=$(val13[$val14])

!ifval $val8>0
val16=$[rint(1)]
!else
val16=$[rint(2)]
!endif
val17=x=$val6
replytype1=monequation

replyname1=équation de l'axe
replygood1=$val17
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()On considère la parabole d'équation 
!insmath y = $val10
$().	  <label for="reply1">Quelle est l'équation de son axe de symétrie?</label>	<div class="wimscenter"> 
!read oef/embed.phtml reply1,20 
$()</div>	
$()
!exit

