tmp1=!randitem 1,-1

val24=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 2, 5

tmp1=!randitem 1,-1

val25=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 3

val26=$[rint($(tmp0))]
!if $val26=1 
val27=($val13*x + $val15)/($val17*x+$val19)
tmp0=!texmath $val27=0

val27=\($(tmp0))
