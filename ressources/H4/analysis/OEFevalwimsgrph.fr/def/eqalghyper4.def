val6=$[rint(1)]
val7=$[rint(1)]
val8=$[rint(1)]
val9=$[rint(1)]
val10=$[rint(1)]
val11=$[rint(1)]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val12=$[rint($(tmp0)*$(tmp1))]
tmp=!translate ";': to $     $ in $val12/($val6)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val13=!exec pari print($t_)
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val14=$[rint($(tmp0)*$(tmp1))]
tmp=!translate ";': to $     $ in $val14/($val7)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val15=!exec pari print($t_)
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val16=$[rint($(tmp0)^2*$(tmp1))]
tmp=!translate ";': to $     $ in $val16/($val8)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val17=!exec pari print($t_)
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val18=$[rint($(tmp0)*$(tmp1))]
tmp=!translate ";': to $     $ in $val18/($val9)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val19=!exec pari print($t_)
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val20=$[rint($(tmp0)*$(tmp1))]
tmp=!translate ";': to $     $ in $val20/($val10)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val21=!exec pari print($t_)
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val22=$[rint($(tmp0)*$(tmp1))]
tmp=!translate ";': to $     $ in $val22/($val11)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val23=!exec pari print($t_)
tmp0=!randint 2, 5

tmp1=!randitem 1,-1

val24=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 2, 5

tmp1=!randitem 1,-1

val25=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 2

val26=$[rint($(tmp0))]
!if $val26=1 
t_=!rawmath $val13-($val21)*($val17)
val27=!exec pari print($t_)
!if $val27=0 
t_=!rawmath $val13+1
val13=!exec pari print($t_)
!endif
val28=($val13*x+$val15)/($val17*x+$val19) 
tmp0=!texmath $val28=$val21

val28=\($(tmp0))
t_=!rawmath ($val21*($val19)-($val15))/($val13-($val21)*($val17))
val29=!exec pari print($t_)
val30=$val29
!endif
!if $val26=2 
t_=!rawmath $val13*($val23)-($val21)*($val17)
val27=!exec pari print($t_)
!if $val27=0 
t_=!rawmath $val13+1
val13=!exec pari print($t_)
!endif
val31=$val23/($val17*x+$val19) 
val32=$val21/($val13*x+$val15) 
tmp0=!texmath $val31=$val32

val28=\($(tmp0))
t_=!rawmath ($val23*($val15)-($val21)*($val19))/($val21*($val17)-($val13)*($val23))
val29=!exec pari print($t_)
val30=$val29
!endif
replytype1=fset
replyname1=Solution(s)
replygood1=$val30
replytype2=matrix
replyoption2=default=empty 
replyname2=
