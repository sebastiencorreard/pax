!set title=Équation algébrique carrée 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr

ansorder=r,r
varcnt=31
prevarcnt=30
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=$[rint(1)]
val7=$[rint(1)]
val8=$[rint(1)]
val9=$[rint(1)]
val10=$[rint(1)]
val11=$[rint(1)]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val12=$[rint($(tmp0)*$(tmp1))]
tmp=!translate ";': to $     $ in $val12/($val6)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val13=!exec pari print($t_)
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val14=$[rint($(tmp0)*$(tmp1))]
tmp=!translate ";': to $     $ in $val14/($val7)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val15=!exec pari print($t_)
tmp0=!randint 1, 10

val16=$[rint($(tmp0))]
tmp0=!randitem 1,-1

val17=$[rint($val16^2*$(tmp0))]
tmp=!translate ";': to $     $ in $val17/($val8)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val18=!exec pari print($t_)
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val19=$[rint($(tmp0)*$(tmp1))]
tmp=!translate ";': to $     $ in $val19/($val9)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val20=!exec pari print($t_)
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val21=$[rint($(tmp0)*$(tmp1))]
tmp=!translate ";': to $     $ in $val21/($val10)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val22=!exec pari print($t_)
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val23=$[rint($(tmp0)*$(tmp1))]
tmp=!translate ";': to $     $ in $val23/($val11)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val24=!exec pari print($t_)
tmp0=!randint 2, 5

tmp1=!randitem 1,-1

val25=$[rint($(tmp0)*$(tmp1))]
val15=$[rint($val14)]
val26=($val13*x+$val15)^2 
tmp0=!texmath $val13*x+$val15

val27=$(tmp0)
tmp0=!texmath $val26=$val18

val26=\($(tmp0))
!if $val18>0 
t_=!rawmath ($val16-$val15) / ($val13)
val28=!exec pari print($t_)
t_=!rawmath (-$val16-$val15) / ($val13)
val29=!exec pari print($t_)
val30=$val28,$val29
val31=$val26 \(\Leftrightarrow $val27=$val16) ou \($val27=-$val16)<br>	 On est donc ramené ŕ résoudre deux équations du premier degré.
!else
val30=vide
val31=un carré est toujours positif donc il n'y a pas de solution.
!endif
replytype1=fset
replyname1=Solution(s)
replygood1=$val30
replytype2=draft

replyoption2=default=empty 
replyname2=
replygood2=?analyze 32
question=__EXECUTED_1692754_EXERCISE__
solution=!nosubst $val31


!goto stat

!exit

:question
$()	  Résoudre dans 
!insmath \ \RR
$() l'équation:	<div class="wimscenter"> $val26 .</div>	<div class="wims_instruction"> S'il n'y a pas de solution, taper <span class="tt">vide</span>.<br>	  S'il y a plusieurs solutions, les séparer par une virgule.<br>	  Pour saisir une racine carrée, taper <span class="tt">sqrt(..)</span>,	  par exemple, taper <span class="tt">sqrt(2)</span> pour saisir 
!insmath \sqrt{2}
$().	</div>	<div class="wimscenter"><label for="reply1">S=</label> 
!read oef/embed.phtml reply1 
$()</div>	<div class="wimscenter"><b>Brouillon</b></div>	<div class="wimscenter"> 
!read oef/embed.phtml reply2,10x30 
$()</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()$val31
$()
!exit

:latex
$()
$()
!exit

:feedback

