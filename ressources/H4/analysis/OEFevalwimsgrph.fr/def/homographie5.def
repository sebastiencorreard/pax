!set title=Fonction homographique 5
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rťgine, Mangeard
email=regine@mangeard.fr
precision=100
oefcss=<style> table.tab_var {margin-left:auto;margin-right:auto; border:solid 1px black;} table.tab_var tr, table.tab_var td, table.tab_var th { padding:7pt;margin-top:10px; margin-bottom:10px; text-align:center; border-collapse:collapse; min-width:10pt; } table.tab_var th { border:solid 1px black} table.tab_var tr { border:solid 1px black} </style> 

ansorder=r
varcnt=35
prevarcnt=34
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint -10, 10

val6=$[rint($(tmp0))]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val8=$[rint($(tmp0)*$(tmp1))]
val9=$val8/(x-$val6)+$val7
t_=!replace internal \( by ( in $val9
tmp0=!exec maxima $t_

tmp1=!texmath $(tmp0)

val10=$(tmp1)
t_=!rawmath $val6
val11=!exec pari print($t_)
t_=!rawmath $val7
val12=!exec pari print($t_)
val13=\(\searrow),\(\nearrow)

!ifval $val8>0
val14=1,1
!else
val14=2,2
!endif
val15=$(val13[$val14])

!ifval $val8>0
val16=$[rint(1)]
!else
val16=$[rint(2)]
!endif
val17=x=$val6
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val8=$[rint($(tmp0)*$(tmp1))]

!ifval $val6=$val7
val7=$[rint(2*$val7)]
!endif
val9=$val8/(x-$val6)+$val7
t_=!replace internal \( by ( in $val9
tmp0=!exec maxima $t_

tmp1=!texmath $(tmp0)

val10=$(tmp1)
t_=!rawmath $val6
val11=!exec pari print($t_)
t_=!rawmath $val7
val12=!exec pari print($t_)
val13=\(\searrow),\(\nearrow)
val15=$(val13[$val14])

!ifval $val8>0
val16=$[rint(1)]
!else
val16=$[rint(2)]
!endif
val17=x=$val6
val13=\(\searrow),\(\nearrow)

!ifval $val8<0
val18=bottom,top
!else
val18=top,bottom
!endif

!ifval $val8>0
val14=1,1
!else
val14=2,2
!endif
val19=$(val13[$val14])

!ifval $val8>0
val20=\(-\infty),\(+\infty)
!else
val20=\(+\infty),\(-\infty)
!endif
t_=!replace internal \( by ( in $val8/(x-$val6)+$val7
tmp0=!exec maxima $t_

tmp1=!texmath $(tmp0)

val21=$(tmp1)
t_=!replace internal \( by ( in $val8/(x+$val6)+$val7
tmp0=!exec maxima $t_

tmp1=!texmath $(tmp0)

val22=$(tmp1)
t_=!replace internal \( by ( in $val8/(x-$val6)-$val7
tmp0=!exec maxima $t_

tmp1=!texmath $(tmp0)

val23=$(tmp1)
t_=!replace internal \( by ( in $val8/(x-$val7)+$val6
tmp0=!exec maxima $t_

tmp1=!texmath $(tmp0)

val24=$(tmp1)
val25=\($val21),\($val22),\($val23),\($val24)
replytype1=radio
replyoption1=shuffle 
replyname1=expression possible
replygood1=1;$val25
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Le tableau des variations d'une fonction homographique 
!insmath f
$() est:	<table class="tab_var">	<tr>	  <th style="width:15%">
!insmath x
$()</th>	      <td style="width:15%;text-align:left"> 
!insmath -\infty
$()</td>	      <td style="width:8%"></td>	      <td style="width:8%"></td>	      <td style="width:1%">$val11</td>	      <td style="width:8%"></td>	      <td style="width:8%"></td>	      <td style="width:15%;text-align:right">
!insmath +\infty
$()</td>	</tr><tr>	  <th style="width:15%" valign="middle">
!insmath var f
$()</th>	     <td style="width:15%;text-align:left" valign="$(val18[1])"> $val12 </td>	     <td style="width:8%"> $(val19[1]) </td>	     <td style="width:8%" valign="$(val18[2])"> $(val20[1]) </td>	  <td style="width:1%;color:red">||</td>	     <td style="width:15%" valign="$(val18[1])"> $(val20[2]) </td>	     <td style="width:8%"> $(val19[2])</td>	     <td style="width:15%;text-align:right" valign="$(val18[2])">$val12  </td>	      </tr>	</table>	  Retrouver parmi les expressions suivantes, une expression possible pour 
!insmath f(x)
$():	<ul>	<li> 
!read oef/embed.phtml reply1,1 
$()</li>	<li> 
!read oef/embed.phtml reply1,2 
$()</li>	<li> 
!read oef/embed.phtml reply1,3 
$()</li>	<li> 
!read oef/embed.phtml reply1,4 
$()</li>	</ul>	
$()
!exit

