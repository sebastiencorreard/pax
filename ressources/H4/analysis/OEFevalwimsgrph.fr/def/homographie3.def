tmp1=!randitem 1,-1

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val8=$[rint($(tmp0)*$(tmp1))]
val9=$val8/(x-$val6)+$val7
