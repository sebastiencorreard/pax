tmp0=!exec maxima $t_

tmp1=!texmath $(tmp0)

val10=$(tmp1)
t_=!rawmath $val6
val11=!exec pari print($t_)
t_=!rawmath $val7
val12=!exec pari print($t_)
val13=\(\searrow),\(\nearrow)

!ifval $val8>0
val14=1,1
!else
val14=2,2
!endif
val15=$(val13[$val14])

!ifval $val8>0
val16=$[rint(1)]
!else
val16=$[rint(2)]
!endif
val17=x=$val6
replytype1=numeric
replyname1=Abscisse du centre
replygood1=$[$val11]
replytype2=numeric
replyname2=Ordonnťe du centre
replygood2=$[$val12]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

