tmp0=!randint 2, 5

tmp1=!randitem 1,-1

val25=$[rint($(tmp0)*$(tmp1))]
val26=($val13*x + $val15)/($val17*x+$val19)
tmp0=!texmath $val26=0

val26=\($(tmp0))
