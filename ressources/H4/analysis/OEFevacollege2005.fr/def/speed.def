!set title=Vitesse moyenne
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rectorat de Nice
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r,r,r
varcnt=12
prevarcnt=11
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!trim 9,12,40,50	16,11,50,40	8,13,50,40	4,7,20,30
val6=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val6

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$(tmp0)
tmp0=!item 1 of $val7

val8=$[rint($(tmp0))]
tmp0=!item 2 of $val7

val9=$[rint($(tmp0))]
tmp0=!item 3 of $val7

val10=$[rint($(tmp0))]
tmp0=!item 4 of $val7

val11=$[rint($(tmp0))]
!readproc slib/lang/fname fr,boy 
tmp0=$slib_out
val12=$(tmp0)
val13=$[rint($val8+$val9)]
val14=$[$val8/$val10*60]
val15=$[$val9/$val11*60]
val16=$[($val13)/($val10+$val11)*60]
replytype1=numexp
replyweight1=3 
replyname1=Vitesse 1
replygood1=$val14
replytype2=numexp
replyweight2=3 
replyname2=Vitesse 2
replygood2=$val15
replytype3=numexp
replyweight3=4 
replyname3=Vitesse 3
replygood3=$val16
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val12 doit effectuer une course à pied de $val13 km.	Les $val8 premiers kilomètres sont en montée et les $val9 derniers kilomètres sont en descente.	$val12 a parcouru :	<ul>	 <li>les $val8 premiers kilomètres en $val10 minutes ;</li>	 <li>les $val9 derniers kilomètres en $val11 minutes.</li>	</ul>	<ol>	 <li>Calculer en kilomètre par heure la vitesse moyenne de $val12 en montée.	 <div><b>Votre réponse</b> : 
!read oef/embed.phtml r1,7 
$() km/H.</div>	 </li><li>	   Calculer en kilomètre par heure la vitesse moyenne de $val12 en descente.	 <div><b>Votre réponse</b> : 
!read oef/embed.phtml r2,7 
$() km/H.</div>	 </li><li>	   Calculer en kilomètre par heure la vitesse moyenne de $val12 sur la parcours total.	 <div><b>Votre réponse</b> : 
!read oef/embed.phtml r3,7 
$() km/H.</div>	</li>	</ol>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=8,9,10,11,12,13
embedcnt=3
