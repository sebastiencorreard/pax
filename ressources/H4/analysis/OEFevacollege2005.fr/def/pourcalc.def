!set title=Calculer un pourcentage
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rectorat de Nice
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=2
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items 16,20,25,40

tmp0=!randitem $tmp
val6=$[rint($(tmp0))]
tmp=!nonempty items filles,garÁons

tmp0=!randitem $tmp
val7=$(tmp0)
tmp0=!randint $val6/3, 2*$val6/3

val8=$[rint($(tmp0))]
val9=$[$val8/$val6*100]
val10=$[ceil($val9)]
val11=$[floor($val9)]
val12=$[rint($val9)]
replytype1=numeric
replyname1=Pourcentage
replygood1=?analyze 13
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Dans un groupe de $val6 adolescents, il y a $val8 $val7.	Quel est le pourcentage de $val7 dans ce groupe ?	<div class="spacer">	<b>Votre rÈponse</b> :   
!read oef/embed.phtml r1,7 
$()%.	</div>	<div class="wims_instruction"> Vous arrondirez si nÈcessaire le rÈsultat	‡ l'entier le plus proche.</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test
condweight1=8 

!ifval $val13<=$val10 and $val13>=$val11
 condtest1=1
!else
 condtest1=0
!endif
condname1=Valeur
condweight2=2 

!ifval $val12 issametext $val13
 condtest2=1
!else
 condtest2=0
!endif
condname2=arrondi

!exit

:stat
vsavelist=6,7,8,10,11,12,13
embedcnt=1
