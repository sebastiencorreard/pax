!set title=Ordre 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rectorat de Nice
email=fwguerima@free.fr
language=fr

ansorder=r,r,r,r,r,r
varcnt=7
prevarcnt=6
postvarcnt=0
replycnt=6
choicecnt=0
conditioncnt=2
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=65x30x1
val7=nombre
tmp0=!shuffle 2,3,4,5,6,7,8

val8=$(tmp0)
tmp0=!item 1 of $val8

val9=$[rint($(tmp0))]
tmp=!translate ";': to $     $ in -$val9*11.0/100

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
tmp=!translate ";': to $     $ in -($val9+1)/10.0

tmp=!lower $tmp
tmp1=!exec maxima fullratsimp($tmp);
tmp=!translate ";': to $     $ in -$val9/100.0

tmp=!lower $tmp
tmp2=!exec maxima fullratsimp($tmp);
tmp=!translate ";': to $     $ in $val9/100.0

tmp=!lower $tmp
tmp3=!exec maxima fullratsimp($tmp);
tmp=!translate ";': to $     $ in $val9/10.0

tmp=!lower $tmp
tmp4=!exec maxima fullratsimp($tmp);
tmp=!translate ";': to $     $ in (($val9-1)*10+$val9)/100.0

tmp=!lower $tmp
tmp5=!exec maxima fullratsimp($tmp);
val10=$(tmp0),$(tmp1),$(tmp2),$(tmp3),$(tmp4),$(tmp5)
tmp0=!sort numeric items $(val10[1..6])

val10=$(tmp0)
replytype1=clickfill
replyname1=$val7 1
replygood1=?analyze 11;$val10
replytype2=clickfill
replyname2=$val7 2
replygood2=?analyze 12
replytype3=clickfill
replyname3=$val7 3
replygood3=?analyze 13
replytype4=clickfill
replyname4=$val7 4
replygood4=?analyze 14
replytype5=clickfill
replyname5=$val7 5
replygood5=?analyze 15
replytype6=clickfill
replyname6=$val7 6
replygood6=?analyze 16
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Rangez les nombres en bas, du plus petit au plus grand.		<table class="wimscenter wimsnoborder">	<tr><td> 
!read oef/embed.phtml r1,$val6 
$()</td>	 
!for m_t=2 to 6 
$()	 <td> 
!insmath <
$() </td><td> 
!read oef/embed.phtml r\t,$val6 
$()</td>	 
!next
$()	</tr></table>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test
condweight1=6 

!ifval $(val10[1]) issametext $val11 and $(val10[2]) issametext $val12 and $(val10[3]) issametext $val13
 condtest1=1
!else
 condtest1=0
!endif
condname1=Classement des nombres nťgatifs
condweight2=4 

!ifval $(val10[4]) issametext $val14 and $(val10[5]) issametext $val15 and $(val10[6]) issametext $val16
 condtest2=1
!else
 condtest2=0
!endif
condname2=Classement des nombres positifs

!exit

:stat
vsavelist=6,10,11,12,13,14,15,16
embedcnt=2
