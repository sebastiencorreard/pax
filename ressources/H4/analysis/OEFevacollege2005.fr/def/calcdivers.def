val8=$(tmp0)
val9=
val10=
!for val11 =1 to 3 
tmp=!translate internal $	$ to ; in $val6

tmp=!row $(val8[$val11]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val12=$(tmp0)
tmp0=!item 1 of $val12

val13=$(tmp0)
tmp0=!item 2 of $val12

val12=$(tmp0)
tmp0=!append item $val12 to $val10

val10=$(tmp0)
tmp=!translate ";': to $     $ in $val13

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val12=$(tmp0)
tmp0=!append item $val12 to $val9

val9=$(tmp0)
!next
