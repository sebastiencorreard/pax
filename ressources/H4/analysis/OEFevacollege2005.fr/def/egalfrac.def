!set title=Fraction diffÈrente
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rectorat de Nice
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=16
prevarcnt=15
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items 1/2,3/2,5/2,1/3,2/3,4/3,5/3,1/4,3/4,5/4,7/4,1/5,2/5,3/5,4/5,7/5,8/5

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!replace internal / by , in $val6

val7=$(tmp0)
tmp0=!item 2 of $val7

val8=$(tmp0)
tmp0=!item 1 of $val7

val9=$(tmp0)
tmp0=!shuffle 2,3,4,5,9,10

val10=$(tmp0)
tmp0=!texmath $val6

val7=$(tmp0)
val11=\($val7)
tmp0=!randint 1, 4

val12=$[rint($(tmp0))]
!for val13 =1 to 4 
val14=$[rint($(val10[$val13])*$val9)]
val15=$[rint($(val10[$val13])*$val8)]
!if $val12=$val13 
tmp0=!randint 2, 10

val15=$[rint($val15+$(tmp0))]
tmp0=!texmath $val14/$val15

val16=$(tmp0)
!else
tmp0=!texmath $val14/$val15

val7=$(tmp0)
tmp0=!append item \($val7) to $val11

val11=$(tmp0)
!endif
!next
replytype1=clickfill
replyname1=RÈponse
replygood1=\($val16);$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Parmi les fractions proposÈes ci-dessous, laquelle n'est pas Ègale aux autres ?	<div class="spacer">	<b>Votre rÈponse</b> :  
!read oef/embed.phtml r1,60x60x1 
$().	</div>
$()
!exit

