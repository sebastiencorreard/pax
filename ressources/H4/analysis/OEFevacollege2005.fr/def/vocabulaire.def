!set title=Vocabulaire
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rectorat de Nice
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r,r,r,r
varcnt=15
prevarcnt=14
postvarcnt=0
replycnt=4
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!values v for v=4 to 11

val6=$(tmp0)
tmp0=!shuffle $val6

val6=$(tmp0)
tmp=!nonempty items 120,130,140

tmp0=!randitem $tmp
val7=$[rint($(tmp0))]
val8=$[rint($(val6[5])*$(val6[6]))]
tmp0=!randint 14, 24

val9=$[rint($(tmp0))]
tmp0=!randitem 1,2

val10=$[rint($(tmp0))]
!if $val10=1 
val11=somme de,diffÈrence entre
val12=+,-
!else
val11=diffÈrence entre,somme de
val12=-,+
!endif
val13=$[rint($(val6[1])*$(val6[2]))]
val14=$[rint($val9$(val12[1])$(val6[4]))]
val15=$[rint($(val6[6]))]
val16=$[rint($val7$(val12[2])$(val6[6])*$(val6[7]))]
replytype1=numexp
replyname1=Question 1
replygood1=$val13
replytype2=numexp
replyname2=Question 2
replygood2=$val14
replytype3=numexp
replyname3=Question 3
replygood3=$val15
replytype4=numexp
replyname4=Question 4
replygood4=$val16
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Donner la rÈponse aux calculs suivants :	<ol>	 <li>Le produit de $(val6[1]) et $(val6[2]).	  <div><b>RÈponse</b> :  
!read oef/embed.phtml r1,8 
$().</div></li>	 <li>La $(val11[1]) $val9 et $(val6[4]).	  <div><b>RÈponse</b> :  
!read oef/embed.phtml r2,8 
$().</div></li>	 <li>Le quotient de $val8 par $(val6[5]).	  <div><b>RÈponse</b> :  
!read oef/embed.phtml r3,8 
$().</div></li>	<li>La $(val11[2]) $val7 et 
!if $val10=1 
$()le 
!else
$() du 
!endif
$() produit de $(val6[6]) et $(val6[7]).	  <div><b>RÈponse</b> :  
!read oef/embed.phtml r4,8 
$().</div></li>	</ol>
$()
!exit

