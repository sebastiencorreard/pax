val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=$[rint(15)]
tmp0=!randitem -1,1

tmp1=!randint 2, 11

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 2, 11

val8=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 2, 11

val9=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 2, 11

val10=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 2, 11

val11=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 2, 11

val12=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 2, 11

val13=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 2, 11

val14=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 2, 11

val15=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 2, 11

val16=$[rint($(tmp0)*$(tmp1))]
tmp=!nonempty items x,y,a,b

tmp0=!randitem $tmp
val17=$(tmp0)
val18=$val7*$val17*($val8*$val17-($val9)),($val10-$val11*$val17)*($val12*$val17-($val13)),$val14-($val15*$val17-($val16))
tmp0=!shuffle $val18

val18=$(tmp0)
val19=
val20=
!for val16 =1 to 3 
tmp0=!item $val16 of $val18

val21=$(tmp0)
tmp0=!texmath $val21

val22=$(tmp0)
tmp0=!append item $val22 to $val20

val20=$(tmp0)
t_=!replace internal \( by ( in expand($val21);
tmp0=!exec maxima $t_

val23=$(tmp0)
t_=!replace internal \( by ( in hipow($val23,$val17);
tmp0=!exec maxima $t_

val24=$[rint($(tmp0))]
val25=
!for val15 =0 to $val24 
t_=!replace internal \( by ( in coeff($val23,$val17,$val15)*($val17^$val15);
tmp0=!exec maxima $t_

val22=$(tmp0)

!ifval $val22 issametext 0
val25=$val25
!else
tmp0=!append item $val22 to $val25

val25=$(tmp0)
!endif
!next
tmp0=!itemcnt $val25

val26=$[rint($(tmp0))]
!if $val26=2 
tmp0=!texmath $(val25[1])+$(val25[2])

tmp1=!texmath $(val25[2])+$(val25[1])

val22=$(tmp0),$(tmp1)
!else
tmp0=!texmath $(val25[1])+$(val25[2])+$(val25[3])

tmp1=!texmath $(val25[1])+$(val25[3])+$(val25[2])

tmp2=!texmath $(val25[2])+$(val25[1])+$(val25[3])

tmp3=!texmath $(val25[2])+$(val25[3])+$(val25[1])

tmp4=!texmath $(val25[3])+$(val25[1])+$(val25[2])

tmp5=!texmath $(val25[3])+$(val25[2])+$(val25[1])

val22=$(tmp0),$(tmp1),$(tmp2),$(tmp3),$(tmp4),$(tmp5)
!endif
tmp0=!append line $val22 to $val19

val19=$(tmp0)
!next
tmp=!translate internal $	$ to ; in $val19

tmp=!row 1 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val27=$(tmp0)
tmp=!translate internal $	$ to ; in $val19

tmp=!row 2 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val28=$(tmp0)
tmp=!translate internal $	$ to ; in $val19

tmp=!row 3 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val29=$(tmp0)
