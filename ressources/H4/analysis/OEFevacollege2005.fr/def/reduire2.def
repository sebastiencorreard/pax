!set title=RÈduire 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=19
prevarcnt=18
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif


!ifval $val3=
val3=$[rint(2)]
!endif
val2=$[rint(2)]
val6=$[rint($val2*8)]
val7=$[rint(3)]
tmp0=!randitem x,y,z,a,b

val8=$(tmp0)
tmp0=!values v for v=0 to $val2

val9=$(tmp0)
val10=
!for val11 =0 to $val2 
tmp0=!randint 2, $val7

val12=$[rint($(tmp0))]
!for val13 =1 to $val12 
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
tmp1=!randint 2, 10

val14=$[rint($(tmp0)*$(tmp1))]
tmp=!translate ";': to $     $ in $val14*$val8^$val11

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val15=($(tmp0))
tmp0=!append item $val15 to $val10

val10=$(tmp0)
!next
!next
tmp0=!shuffle $val10

val10=$(tmp0)
tmp0=!replace internal , by + in $val10

val10=$(tmp0)
t_=!replace internal \( by ( in $val10;
tmp0=!exec maxima $t_

val16=$(tmp0)
!readproc slib/commutesom $val16,$val8 
tmp0=$slib_out
val16=$(tmp0)
tmp0=!texmath $val10

val10=$(tmp0)
replytype1=litexp
replyname1=RÈponse 1
replygood1=$val16
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

