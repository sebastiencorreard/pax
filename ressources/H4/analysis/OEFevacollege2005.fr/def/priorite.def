!set title=Prioritťs opťratoires
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rectorat de Nice
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r,r,r
varcnt=12
prevarcnt=11
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=4-7-8,4-7-8	3-(14-3),3-(14-3)	(7.6-9.6)+(-10.75-2.25),(7.6-9.6)+(-10.75-2.25)
tmp0=!shuffle 1,2,3

val7=$(tmp0)
val8=
val9=
!for val10 =1 to 3 
tmp=!translate internal $	$ to ; in $val6

tmp=!row $(val7[$val10]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val11=$(tmp0)
tmp0=!item 1 of $val11

val12=$(tmp0)
tmp0=!item 2 of $val11

val11=$(tmp0)
tmp0=!append item $val11 to $val9

val9=$(tmp0)
tmp=!translate ";': to $     $ in $val12

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val11=$(tmp0)
tmp0=!append item $val11 to $val8

val8=$(tmp0)
!next
replytype1=numexp
replyname1=Rťponse
replygood1=$(val8[1])
replytype2=numexp
replyname2=Rťponse
replygood2=$(val8[2])
replytype3=numexp
replyname3=Rťponse
replygood3=$(val8[3])
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Calculer les expressions suivantes $m_compenonce :	<ul>	<li>
!insmath A = $(val9[1])
$()	<div>
!insmath A
$() =  
!read oef/embed.phtml r1,\size 
$()</div>	</li><li>	 
!insmath B = $(val9[2])
$()	<div>
!insmath B
$() =  
!read oef/embed.phtml r2,\size 
$()</div>	</li><li>	 
!insmath C = $(val9[3])
$()	<div>
!insmath C
$() =  
!read oef/embed.phtml r3,\size 
$()</div>	</li>	</ul>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
