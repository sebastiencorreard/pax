!set title=Les quatre r×gles (puissance 10)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r,r,r,r,r
varcnt=15
prevarcnt=14
postvarcnt=0
replycnt=5
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=quotient,inverse,produit,puissance
tmp0=!shuffle $val6

val6=$(tmp0)
val2=$[rint(4)]
val7=
val8=
val9=
!for val10 =1 to $val2 
tmp0=!item $val10 of $val6

val11=$(tmp0)
!readproc slib/calcpuis $val11,8 
tmp0=$slib_out
val12=$(tmp0)
tmp0=!item 1 of $val12

val13=$(tmp0)
tmp0=!item 2 of $val12

val14=$(tmp0)
tmp0=!append item $val13 to $val7

val7=$(tmp0)
tmp0=!append item $val14 to $val8

val8=$(tmp0)
tmp0=!append item r$val10 to $val9

val9=$(tmp0)
!next
oefsteps=$val9 
nextstep=!nosubst $val9 
!readproc oef/steps.proc
replytype1=numexp
replyname1=\($(val7[1]))
replygood1=$(val8[1])
replytype2=numexp
replyname2=\($(val7[2]))
replygood2=$(val8[2])
replytype3=numexp
replyname3=\($(val7[3]))
replygood3=$(val8[3])
replytype4=numexp
replyname4=\($(val7[4]))
replygood4=$(val8[4])
replytype5=numexp
replyname5=\($(val7[5]))
replygood5=$(val8[5])
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	
!if $val2=1 
$()Calculer l'expression suivante :	<div class="wimscenter">
!insmath $val7 = 10
$()<sup> 
!read oef/embed.phtml r1,2 
$()</sup>.</div> 
!else
$()	 Calculer les expressions suivantes :	<ul>	  
!for m_k=1 to $val2 
$()	  <li>
!insmath $(val7[$m_k]) = 10
$()<sup> 
!read oef/embed.phtml r\k,3 
$()</sup>.</li>	   
!next
$()	</ul> 
!endif
$()	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

