!set title=Situation de proportionnalité
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rectorat de Nice
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r,r,r,r,r
varcnt=22
prevarcnt=21
postvarcnt=0
replycnt=5
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=60x25x1
val7=A,B,E,F,M
tmp0=!shuffle $val7

val7=$(tmp0)
tmp0=!item 1 of $val7

val8=$(tmp0)
tmp0=!item 2 of $val7

val9=$(tmp0)
tmp0=!item 3 of $val7

val10=$(tmp0)
tmp0=!item 4 of $val7

val11=$(tmp0)
tmp0=!item 5 of $val7

val12=$(tmp0)
val13=(L'âge d'une personne est proportionnel au nombre de ses dents.,2),(La vitesse d'une calčche est proportionnelle au nombre de chevaux.,2),(A vitesse constante&#44; la distance parcourue est proportionnelle au temps de parcours.,1),(Le prix en euros d'un article est proportionnel ŕ son prix en francs.,1),(L'âge d'une personne est proportionnel ŕ sa taille,2)
tmp0=!shuffle $val13

val13=$(tmp0)
val14=Vrai,Faux
val15=
val16=
!for val17 =1 to 5 
tmp0=!item $val17 of $val13

val18=$(tmp0)
tmp0=!declosing $val18

val18=$(tmp0)
tmp0=!item 1 of $val18

val19=$(tmp0)
tmp0=!item 2 of $val18

val20=$(tmp0)
tmp0=!item $val20 of $val14

val20=$(tmp0)
tmp0=!append item $val19 to $val15

val15=$(tmp0)
tmp0=!append item $val20 to $val16

val16=$(tmp0)
!next
replytype1=clickfill
replyname1=Phrase 1
replygood1=$(val16[1]);$val14
replytype2=clickfill
replyname2=Phrase 2
replygood2=$(val16[2]);$val14
replytype3=clickfill
replyname3=Phrase 3
replygood3=$(val16[3]);$val14
replytype4=clickfill
replyname4=Phrase 4
replygood4=$(val16[4]);$val14
replytype5=clickfill
replyname5=Phrase 5
replygood5=$(val16[5]);$val14
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

