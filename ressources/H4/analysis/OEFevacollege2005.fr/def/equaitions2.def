val13=$(tmp0)
tmp0=!replace internal YY by $val16 in $val13

val13=$(tmp0)
tmp0=!item 1 of $val13

val17=$(tmp0)
tmp0=!item 2 of $val13

tmp=!translate ";': to $     $ in $(tmp0)

tmp=!lower $tmp
tmp1=!exec maxima fullratsimp($tmp);
val18=$(tmp1)
tmp0=!append item $val17 to $val10

val10=$(tmp0)
