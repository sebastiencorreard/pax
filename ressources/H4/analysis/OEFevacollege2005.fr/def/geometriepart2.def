tmp=!trim Si les diagonales d'un quadrilatčre non croisé se coupent en leurs milieux alors c'est un parallčlogramme.	Si les côtés opposés d'un quadrilatčre ont męme longueur deux ŕ deux alors c'est un parallélogramme.	Si les côtés opposés d'un quadrilatčre sont parallčles deux ŕ deux alors c'est un parallélogramme.	Si un quadrilatčre est un parallélogramme alors ses diagonales se coupent en leurs milieux.	Si un quadrilatčre est un parallélogramme alors ses côtés opposés sont égaux.	Si un quadrilatčre est un parallélogramme alors ses côtés opposés sont parallčles.
val6=!translate internal $	\
$ to ;; in $tmp
tmp0=!shuffle 1,3

val7=$(tmp0)
tmp0=!item 1 of $val7

val8=$[rint($(tmp0))]
tmp0=!item 2 of $val7

tmp1=!shuffle 2,$(tmp0)

val7=$(tmp1)
tmp0=!item 1 of $val7

val9=$[rint($(tmp0))]
tmp0=!item 2 of $val7

val10=$[rint($(tmp0))]
val11=$[rint($val8+3)]
tmp0=!shuffle $val8,$val10,4,5,6

val12=$val9,$(tmp0)
tmp0=!positionof item $val8 in $val12

val7=$[rint($(tmp0))]
tmp=!translate internal $	$ to ; in $val6

tmp=!row $(val12[1]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val13=$(tmp0)
tmp=!translate internal $	$ to ; in $val6

tmp=!row $(val12[2]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val14=$(tmp0)
tmp=!translate internal $	$ to ; in $val6

tmp=!row $(val12[3]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val15=$(tmp0)
tmp=!translate internal $	$ to ; in $val6

tmp=!row $(val12[4]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val16=$(tmp0)
tmp=!translate internal $	$ to ; in $val6

tmp=!row $(val12[5]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val17=$(tmp0)
tmp=!translate internal $	$ to ; in $val6

tmp=!row $(val12[6]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val18=$(tmp0)
val19=Propriété A,Propriété B,Propriété C,Propriété D,Propriété E,Propriété F
tmp0=!item $val7 of $val19

val20=$(tmp0)
tmp0=!positionof item $val11 in $val12

val7=$(tmp0)
tmp0=!item $val7 of $val19

val21=$(tmp0)
!readproc slib/lang/fname fr,boy 
tmp0=$slib_out
val22=$(tmp0)
