!set title=Lire les coordonnķes d'un point
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fwguerima@free.fr
language=fr
computeanswer=no
precision=10000

ansorder=r,r
varcnt=18
prevarcnt=17
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=$[rint(400)]
val7=$[rint(400)]
tmp=!nonempty items A,B,C,D,E

tmp0=!randitem $tmp
val8=$(tmp0)
tmp0=!randint -5, 5

val9=$[rint($(tmp0))]
tmp0=!randint -5, 5

val10=$[rint($(tmp0))]
!readproc slib/draw/repere $val6,$val7,20,-6,6,-6,6,1,1,black,grey 
tmp0=$slib_out
val11=$(tmp0)
tmp=!translate internal $	$ to ; in $val11

tmp=!row 1 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val12=$(tmp0)
tmp0=!item 1 of $val12

val13=$[rint($(tmp0))]
tmp0=!item 2 of $val12

val14=$[rint($(tmp0))]
tmp=!translate internal $	$ to ; in $val11

tmp=!row 2 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val12=$(tmp0)
tmp0=!item 1 of $val12

val15=$[$(tmp0)]
tmp0=!item 2 of $val12

val16=$[$(tmp0)]
tmp0=!line 3 to -1 of $val11

val17=$(tmp0)
val17=$val17	text black,$val13-10,$val14+4,small,O	text black,$val13+$val15-4,$val14+4,small,1	text black,$val13-12,$val14+$val16-4,small,1
val18=$[rint($val13+($val15)*($val9))]
val19=$[rint($val14+($val16)*($val10))]
val20=$val17	linewidth 1	segment $val18-4,$val19+4,$val18+4,$val19-4,red	segment $val18-4,$val19-4,$val18+4,$val19+4,red	text red,$val18-10,$val19+4,medium,$val8
replytype1=numexp
replyname1=Abscisse de \($val8)
replygood1=$val9
replytype2=numexp
replyname2=Ordonnķe de \($val8)
replygood2=$val10
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Quelles sont les coordonnķes du point 
!insmath $val8
$() dans le repĶre ci-dessous ?	<div class="wimscenter">	 
!read oef/draw.phtml $val6,$val7 \
$val20 
$()	</div>	<div class="spacer">	<b>Votre rķponse</b> :	
!insmath $val8
$() a pour coordonnķes ( 
!read oef/embed.phtml r1,3 
$() ;  
!read oef/embed.phtml r2,3 
$()).	</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,20
embedcnt=2
