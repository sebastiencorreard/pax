!set title=Placer un point
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fwguerima@free.fr
language=fr
computeanswer=no
precision=10000

ansorder=r
varcnt=18
prevarcnt=17
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=$[rint(400)]
val7=$[rint(400)]
tmp=!nonempty items A,B,C,D,E

tmp0=!randitem $tmp
val8=$(tmp0)
tmp0=!randint -5, 5

val9=$[rint($(tmp0))]
tmp0=!randint -5, 5

val10=$[rint($(tmp0))]
!readproc slib/draw/repere $val6,$val7,20,-6,6,-6,6,1,1,black,grey 
tmp0=$slib_out
val11=$(tmp0)
tmp=!translate internal $	$ to ; in $val11

tmp=!row 1 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val12=$(tmp0)
tmp0=!item 1 of $val12

val13=$[rint($(tmp0))]
tmp0=!item 2 of $val12

val14=$[rint($(tmp0))]
tmp=!translate internal $	$ to ; in $val11

tmp=!row 2 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val12=$(tmp0)
tmp0=!item 1 of $val12

val15=$[$(tmp0)]
tmp0=!item 2 of $val12

val16=$[$(tmp0)]
tmp0=!line 3 to -1 of $val11

val17=$(tmp0)
val17=$val17	text black,$val13-10,$val14+4,small,O	text black,$val13+$val15-4,$val14+4,small,1	text black,$val13-12,$val14+$val16-4,small,1
val18=$[rint($val13+($val15)*($val9))]
val19=$[rint($val14+($val16)*($val10))]
!readproc oef/draw.phtml $val6,$val7, \
$val17 
tmp0=$ins_url
val20=$(tmp0)
replytype1=coord
replyname1=Point \($val8)
replygood1=$val20;point,$val18,$val19
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Cliquer dans le repère ci-dessous pour placer le point de coordonnées 
!insmath ($val9;$val10)
$().	<div class="spacer">	<b>Votre réponse</b> :	<div class="wimscenter"> 
!read oef/embed.phtml r1 
$()</div>	</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=9,10
embedcnt=1
