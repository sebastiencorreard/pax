!set title=Graphique et proportionnalité
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rectorat de Nice
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r,r,r,r
varcnt=30
prevarcnt=29
postvarcnt=0
replycnt=4
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=120x40x1
tmp0=!values v for v=1 to 4

val7=$(tmp0)
tmp0=!shuffle $val7

val7=$(tmp0)
tmp=!nonempty items 2,-2,3,-3

tmp0=!randitem $tmp
val8=$[rint($(tmp0))]
tmp=!trim $(val7[1])/10*x^2,2	$(val7[2])*x,1	$(val7[3])*x+$val8,2	2*x-$(val7[4])+abs(x-$(val7[4])),2
val9=!translate internal $	\
$ to ;; in $tmp
val10=Situation de proportionnalité,Pas de proportionnalité
tmp0=!shuffle 1,2,3,4

val11=$(tmp0)
!readproc slib/draw/repere 200,200,0,0,10,0,10,1,1,black,grey 
tmp0=$slib_out
val12=$(tmp0)
tmp=!translate internal $	$ to ; in $val12

tmp=!row 1 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val13=$(tmp0)
tmp0=!item 1 of $val13

val14=$(tmp0)
tmp0=!item 2 of $val13

val15=$(tmp0)
tmp=!translate internal $	$ to ; in $val12

tmp=!row 2 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val13=$(tmp0)
tmp0=!item 1 of $val13

val16=$(tmp0)
tmp0=!item 2 of $val13

val17=$(tmp0)
tmp0=!line 3 to -1 of $val12

val12=$(tmp0)
val18=!rawmath (x-($val14))/$val16
val19=!rawmath x*($val17)+($val15)
evaltmp=\f

evaltmp=!mathsubst x=($val18) in $evaltmp
tmp0=($evaltmp)
evaltmp=$val19

evaltmp=!mathsubst x=($(tmp0)) in $evaltmp
tmp1=($evaltmp)
tmp=!translate ";': to $     $ in $(tmp1)

tmp=!lower $tmp
tmp2=!exec maxima fullratsimp($tmp);
val20=!rawmath $(tmp2)
val21=
val22=
!for val23 =1 to 4 
tmp=!translate internal $	$ to ; in $val9

tmp=!row $(val11[$val23]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val24=$(tmp0)
tmp0=!item 1 of $val24

val25=!rawmath $(tmp0)
tmp0=!item 2 of $val24

val26=$(tmp0)
tmp0=!item $val26 of $val10

val26=$(tmp0)
tmp0=!append item $val26 to $val21

val21=$(tmp0)
evaltmp=$val25

evaltmp=!mathsubst x=($val18) in $evaltmp
tmp0=($evaltmp)
evaltmp=$val19

evaltmp=!mathsubst x=($(tmp0)) in $evaltmp
tmp1=($evaltmp)
tmp=!translate ";': to $     $ in $(tmp1)

tmp=!lower $tmp
tmp2=!exec maxima fullratsimp($tmp);
val20=!rawmath $(tmp2)
!readproc oef/draw.phtml 200,200 \
$val12	plot blue,$val20 
tmp0=$ins_url
val13=$(tmp0)
tmp0=!append item $val13 to $val22

val22=$(tmp0)
!next
replytype1=clickfill
replyname1=Graphique 1
replygood1=$(val21[1]);$val10
replytype2=clickfill
replyname2=Graphique 2
replygood2=$(val21[2]);$val10
replytype3=clickfill
replyname3=Graphique 3
replygood3=$(val21[3]);$val10
replytype4=clickfill
replyname4=Graphique 4
replygood4=$(val21[4]);$val10
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Parmi les graphiques suivants indiquer, en utilisant les étiquettes,	ceux qui correspondent ŕ des situations de proportionnalité.	<table class="wimscenter wimsnoborder">	 <tr><td>	   <img src="$(val22[1])" alt="">	<div> 
!read oef/embed.phtml r1,$val6 
$()</div>	  </td><td>	   <img src="$(val22[2])" alt="">	<div> 
!read oef/embed.phtml r2,$val6 
$()</div>	  </td></tr><tr><td>	   <img src="$(val22[3])" alt="">	<div> 
!read oef/embed.phtml r3,$val6 
$()</div>	  </td><td>	   <img src="$(val22[4])" alt="">	<div> 
!read oef/embed.phtml r4,$val6 
$()</div>	  </td></tr>	</table>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

