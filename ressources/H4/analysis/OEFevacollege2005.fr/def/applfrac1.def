!set title=Calculer une part 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rectorat de Nice
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=5
prevarcnt=4
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items 1/4,1/3,2/3,3/4,2/5,1/5,3/5,4/5

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!randitem 5,7,9,12

val7=$[rint(3*4*5*$(tmp0))]
val8=$[$val6*$val7]
tmp0=!texmath $val6

val9=$(tmp0)
replytype1=numexp
replyname1=Montant
replygood1=$val8
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Un berger possède un troupeau de $val7 moutons. Il a tondu les	
!insmath $val9
$() de son troupeau. Combien a-t-il tondu de moutons ?	<div>	<b>Votre réponse</b> :  
!read oef/embed.phtml r1,7 
$() moutons.	</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,9
embedcnt=1
