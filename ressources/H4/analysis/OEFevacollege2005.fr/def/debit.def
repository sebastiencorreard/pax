!set title=Débit
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rectorat de Nice
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=4
prevarcnt=3
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 10, 15

val6=$[rint($(tmp0))]
tmp=!nonempty items 1/5,1/4,1/8,1/10

tmp0=!randitem $tmp
val7=$[$(tmp0)]
val8=$[$val6/$val7]
replytype1=auto

replyname1=Durée
replygood1=$val8
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Un seau à une capacité de $val6 litres. Combien de temps faudra-t-il	pour le remplir à un robinet dont le débit est de $val7 litre par seconde ?	<div class="spacer">	<b>Votre réponse </b> :  
!read oef/embed.phtml r1,5 
$() secondes.	</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7
embedcnt=1
