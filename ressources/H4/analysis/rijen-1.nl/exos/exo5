!if $R>3
    !if $rounding<1
	rounding=100
        !readproc $remarkdir/rounding.$taal
    !endif
    # checkfile=$checkdir/number.proc
    r=!randint 12,20
    r=$[$r/10]
    options=!randint 15,26
    a=!randint 2,20
    ss=!record 45 of lang/remarks.$taal
    #@ Gegeven is de Recursie formule van een Meetkundige rij\
    #@ c<p align="center">U<sub>n</sub>=$r*U<sub>n-1</sub> met U<sub>0</sub>=$a</p>\
    #@ Bereken de som van de eerste $options termen.
    
    question$n=$ss
    formula$n = \left[ \begin{array}{l} U_{n} = $r\cdot U_{n-1} \wedge U_{0} = $a \\ S = U_{0} + \cdots + \cdots +U_{$[$options -1]} \end{array} \right.

    wimsanswer=$[($a*(1-$r^$options))/(1-$r)]    

    tot=!exec pari A=($a*(1-$r^$options))/(1-$r)\
    abs(A - $wimsanswer)

    answer$n=!line 1 of $tot
    var2=!line 2 of $tot
    texanswer$n=U_{n} = $a \cdot $r ^{n} \rightarrow  \frac{$a \cdot $r^{$options}-$a}{$r-1}= $(answer$n)  \simeq $wimsanswer
 !exit
!endif
