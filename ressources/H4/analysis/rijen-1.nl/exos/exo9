 !readproc $remarkdir/rounding.$taal
 
 description=u<sub>1</sub>/u<sub>0</sub>,u<sub>2</sub>/u<sub>1</sub>,u<sub>3</sub>/u<sub>2</sub>,u<sub>4</sub>/u<sub>3</sub>,u<sub>5</sub>/u<sub>4</sub>,u<sub>6</sub>/u<sub>5</sub>,u<sub>7</sub>/u<sub>8</sub>
  
!endif
