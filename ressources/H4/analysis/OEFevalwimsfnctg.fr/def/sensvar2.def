!set title=Sens de variation 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
oefcss=<style> table.tab_var {margin-left:auto;margin-right:auto; border:solid 1px black;} table.tab_var tr, table.tab_var td, table.tab_var th { padding:7pt;margin-top:10px; margin-bottom:10px; text-align:center; border-collapse:collapse; min-width:10pt; } table.tab_var th { border:solid 1px black} table.tab_var tr { border:solid 1px black} </style>

ansorder=r,r,r
varcnt=16
prevarcnt=15
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint -10, -5

val6=$[rint($(tmp0))]
tmp0=!randint 5, 10

val7=$[rint($(tmp0))]
tmp0=!makelist x for x=$val6 to $val7

val8=$(tmp0)
val9=strictement croissante, strictement décroissante
tmp0=!shuffle $val7-$val6+1

val10=$(tmp0)
tmp0=!randint $val6+3, $val7-3

val11=$[rint($(tmp0))]
tmp0=!randint 1, 4

tmp1=!randitem 1,-1

val12=$[rint($val11+$(tmp0)*$(tmp1))]
val9=strictement croissante, strictement décroissante, non monotone
tmp0=!randint $val6+3, $val7-3

val11=$[rint($(tmp0))]
tmp0=!randitem 1,2

val13=$[rint($(tmp0))]

!ifval $val13=1
val14=1,2
!else
val14=2,1
!endif
val15=<,>
val16=$[rint(3)]
val17=$[rint($(val14[1]))]
val18=$[rint($(val14[2]))]
replytype1=menu
replyname1=sur \(&#91; $val6 ; $val7 &#93;)
replygood1=$val16;$val9
replytype2=menu
replyname2=sur \(&#91; $val6 ; $val11 &#93;)
replygood2=$val17;$val9
replytype3=menu
replyname3=sur \(&#91; $val11 ; $val7 &#93;)
replygood3=$val18;$val9
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Soit une fonction 
!insmath h
$() définie sur l'intervalle 
!insmath &#91; $val6 ; $val7 &#93;
$() , telle que	<ol>	<li>pour tous réels 
!insmath x_1
$() et 
!insmath x_2
$() de 
!insmath &#91; $val6 ; $val11 &#93;
$(), tels que 
!insmath x_1 < x_2
$(), on a 
!insmath h(x_1) $(val15[$(val14[1])]) h(x_2)
$()</li>	<li>pour tous réels 
!insmath x_1
$() et 
!insmath x_2
$() de 
!insmath &#91; $val11 ; $val7 &#93;
$(), tels que 
!insmath x_1 < x_2
$(), on a 
!insmath h(x_1) $(val15[$(val14[2])]) h(x_2)
$()</li>	</ol>	  Alors, on peut en déduire que :	<ul>	<li>
!insmath h
$() est  
!read oef/embed.phtml reply1 
$() sur 
!insmath &#91; $val6 ; $val7 &#93;
$()</li>	<li>
!insmath h
$() est  
!read oef/embed.phtml reply2 
$() sur 
!insmath &#91; $val6 ; $val11 &#93;
$()</li>	<li>
!insmath h
$() est  
!read oef/embed.phtml reply3 
$() sur 
!insmath &#91; $val11 ; $val7 &#93;
$()</li>	</ul>	
$()
!exit

