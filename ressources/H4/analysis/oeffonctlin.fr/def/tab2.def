!set title=Tableau (entiers relatifs)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=P. BYACHE
email=paul-marcel-rog.byache@ac-aix-marseille.fr
precision=10000

ansorder=r,r,r
varcnt=11
prevarcnt=10
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem 2,3,4,5,6,7,8,9

val6=$[rint($(tmp0))]
tmp0=!randitem -1,1

val7=$[rint($(tmp0))]
val8=$[rint($val6*$val7)]
tmp=!translate internal $	$ to ; in <I>f</I> est la fonction linéaire qui ŕ <I>x</I> fait correspondre $val8 × <I>x</I>.	<I>f</I> est la fonction linéaire qui ŕ <I>x</I>  associe $val8 × <I>x</I>. 	<I>f</I> est la fonction linéaire <br> <center> <I>f</I> : <I>x</I> \(\mapsto) $val8 × <I>x</I>.</center>

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val9=$(tmp0) 
tmp0=!values x for x=-9 to 9

val10=$(tmp0)
tmp0=!shuffle $val10

val10=$(tmp0)
val11=$[rint($(val10[1]))]
val12=$[rint($(val10[2]))]
val13=$[rint($(val10[3]))]
val14=n1,n2,n3
replytype1=numeric
replyname1=La valeur de \(A) est
replygood1=$[$val11*$val8]
replytype2=numeric
replyname2=La valeur de \(B) est
replygood2=$[$val12*$val8]
replytype3=numeric
replyname3=La valeur de \(C) est
replygood3=$[$val13*$val8]
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$() <br> <br> <big> <strong> $val9 </strong></big> <br> 	<p>Compléter le tableau de valeurs ci-dessous : 		<CENTER>	 <TABLE WIDTH=514 BORDER=1 BORDERCOLOR="#000000" CELLPADDING=4 CELLSPACING=0>	  <TR VALIGN=TOP>	   <TH WIDTH=119 align="center">
!insmath x
$()</TD>	   <TD WIDTH=120 align="center">$val11</TD>	   <TD WIDTH=120 align="center">$val12</TD>	   <TD WIDTH=120 align="center">$val13</TD>	  </TR>	  <TR VALIGN=TOP>	   <TH WIDTH=119 align="center">
!insmath f(x)
$()</TD>	   <TD WIDTH=120 align="center">
!insmath A
$()</TD>	   <TD WIDTH=120 align="center">
!insmath B
$()</TD>	   <TD WIDTH=120 align="center">
!insmath C
$()</TD>	  </TR>	 </TABLE>	</CENTER>	
$()
!exit

:hint
$() <FONT COLOR="#ff0000">Pour multiplier deux nombres relatifs (nombres avec un signe), 	on les multiplie sans leur signe et on donne au produit <b>le signe “+” 	si les deux nombres avaient le męme signe et le signe “-” si les deux nombres 	étaient de signes contraires.</b> <I>(Les amis de mes amis sont mes amis, etc.)</I></font>
$()
!exit

