precision=10000

ansorder=r,r,r
varcnt=20
prevarcnt=19
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=6
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 9

tmp1=!randint 2, 9

t_=!rawmath $(tmp0)/$(tmp1)
val6=!exec pari print($t_)
tmp=!translate internal $	$ to ; in <I>f</I> est la fonction linéaire qui ŕ <I>x</I> fait correspondre \($val6) × <I>x</I>. 	<I>f</I> est la fonction linéaire qui ŕ <I>x</I>  associe \($val6) × <I>x</I>. 	<I>f</I> est la fonction linéaire <br> <center> <I>f</I> : <I>x</I> \(\mapsto) \($val6) × <I>x</I>.</center>

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$(tmp0) 
tmp0=!shuffle 9

val8=$(tmp0)
val9=$[rint($(val8[1]))]
val10=$[rint($(val8[2]))]
val11=$[rint($(val8[3]))]
tmp0=!shuffle 9

val12=$(tmp0)
val13=$[rint($(val12[1]))]
val14=$[rint($(val12[2]))]
val15=$[rint($(val12[3]))]
t_=!rawmath $val9/$val13
val16=!exec pari print($t_)
t_=!rawmath $val10/$val14
val17=!exec pari print($t_)
t_=!rawmath $val11/$val15
val18=!exec pari print($t_)
t_=!rawmath $val16*$val6
val19=!exec pari print($t_)
t_=!rawmath $val17*$val6
val20=!exec pari print($t_)
t_=!rawmath $val18*$val6
val21=!exec pari print($t_)
tmp=!translate ";': to $     $ in $val19

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val22=!exec pari print($t_)
tmp=!translate ";': to $     $ in $val20

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val23=!exec pari print($t_)
tmp=!translate ";': to $     $ in $val21

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val24=!exec pari print($t_)
replytype1=numeric
replyname1=La valeur de \(A) est
replygood1=?analyze 25
replytype2=numeric
replyname2=La valeur de \(B) est
replygood2=?analyze 26
replytype3=numeric
replyname3=La valeur de \(C) est
replygood3=?analyze 27
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$() <br> <br> <big> <strong> $val7 <br>  </strong> </big>	<p>	Compléter le tableau de valeurs ci-dessous :	</p>	<p> 	<CENTER><TABLE WIDTH=514 BORDER=1 BORDERCOLOR="#000000" CELLPADDING=4 CELLSPACING=0>	<TR VALIGN=TOP>	 <TH WIDTH=119 align="center"> 
!insmath x
$() </TD>	 <TD WIDTH=120 align="center">
!insmath $val16
$()</TD>	 <TD WIDTH=120 align="center">
!insmath $val17
$()</TD>	 <TD WIDTH=120 align="center">
!insmath $val18
$()</TD>	</TR>	<TR VALIGN=TOP> 	 <TH WIDTH=119 align="center">
!insmath f(x)
$()</TD>	 <TD WIDTH=120 align="center">
!insmath A
$()</TD>	 <TD WIDTH=120 align="center">
!insmath B
$()</TD>	 <TD WIDTH=120 align="center">
!insmath C
$()</TD>	</TR>	</TABLE></CENTER>		<p><i><font color=red>	Attention : la réponse doit ętre donnée sous forme de fraction et 	il faut la simplifier le plus possible !</font> 	</i>	
$()
!exit

:hint
$() <FONT COLOR="#ff0000">Pour multiplier deux nombres relatifs (fractions), 	il faut <b> multiplier les numérateurs entre eux et multiplier les dénominateurs entre eux :</b>		<p align="center">	
!insmath \frac{a}{b} \times \frac{c}{d} = \frac{ a \times c}{b \times d}
$() 	</p>
$()
!exit

