!set n=$counter
mathview=0
math=1
display=1
helptext=$empty
multiimage=0
checkfile=$checkdir/multiplechoice.proc
!if $questiontype=0
    questiontype=1
!endif
!if $questiontype=2
    graph=!record 20 of lang/remarks.$taal
!else
    graph=!record 21 of lang/remarks.$taal
!endif 

Domein=!record 14 of lang/remarks.$taal
Bereik=!record 15 of lang/remarks.$taal

a=!randitem 2,3,4,5,6,7,8,9
b=!randitem 1,2,3,4,5,6,7,8,9
lijst=!randitem lijst5a.def,lijst5b.def
options=4
answer$n=!randint 1,$options
vraag=!randfile exos/$lijst
functie=!line 1 of $vraag
functie=!replace internal @ by , in $functie
FF=!item 2 of $functie
functie=!item 1 of $functie
formula$n=!texmath f(x) = $functie
keus=!randitem 1,2
soort=!randitem 1,0
!if $keus=1
    bereik=$Domein
    !if $soort=0
	DB=D_{f} :
    !else
	DB=D_{f} =
    !endif
    vraag=!line 2 to 5 of $vraag
    # eerste item van $vraag is goed
!else
    !if $soort=0
	DB=B_{f} :
    !else
	DB=B_{f} =
    !endif
    bereik=$Bereik
    vraag=!line 6 to 9 of $vraag
    # eerste item van $vraag is goed
!endif

keuzes=!shuffle 1,2,3,4
!for p=1 to 4
    nummer=!item $p of $keuzes
    ex$p=!line $nummer of $vraag
    ex$p=$DB  $(ex$p)
    !if $nummer=1
	answer$n=$p
	texanswer$n=$(ex$p)
    !endif
!next p

!if $image=1 or $teaching=1
    functie=$FF
    !readproc exos/image.proc
!endif
txt1=!record 25 of lang/remarks.$taal
# Domein en Bereik van de 'Logaritmische'-functie.
txt2=!record 26 of lang/remarks.$taal
# Welk <kbd>$bereik</kbd> past bij de $image van de logarithmische functie?
question$n=$txt1<br />$txt2
!exit
