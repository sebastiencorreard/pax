:$[$a+$b]*x/(x-$b) 
x < $b \bigvee x > $b
x < $[$a+$b] \bigvee x > $[$a+$b]
x < -$b \bigvee x > -$b
\mathbb{R} 
y < $[$a+$b] \bigvee y > $[$a+$b]
y < $b \bigvee y > $b
y < -$b \bigvee y > -$b
y < 0 \bigvee y > 0

