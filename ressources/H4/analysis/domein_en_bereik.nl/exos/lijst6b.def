:(x-$a)/(x+$b) 
x < -$b \bigvee x > -$b
x < $b \bigvee x > $b
x < 0 \bigvee x > 0
\mathbb{R} 
y < 1 \bigvee y > 1
y < $a \bigvee y > $a
y < -$a \bigvee y > -$a
y < 0 \bigvee y > 0

:1/(x^2 + 1) 
\mathbb{R} 
x < 1 \bigvee x > 1
x < -1 \bigvee x > -1
x < 0 \bigvee x > 0
0 < y \le 1
0 < y \bigvee y > 1
y > 0
\mathbb{R} 

:1/(x^2 + $a) 
\mathbb{R} 
x < $a \bigvee x > $a
x < -\sqrt{$a} \bigvee x > -\sqrt{$a}
x < 0 \bigvee x > 0
0 < y \le \frac{1}{$a} 
0 < y \le \sqrt{$a} 
0 < y \le -$a 
0 < y \le 1 


:1/(x^2-1) 
x < -1 \bigvee -1 < x < 1 \bigvee x > 1
\mathbb{R} 
x < -1 \bigvee x > 1
x < 1 \bigvee x > 1
y \le -1 \bigvee y > 0
-1 \le y < 0
-1 \le y < 1
\mathbb{R} 

:$[$c*$a*$a]/(x^2 - $[$a^2])
x < -$a \bigvee -$a < x < $a \bigvee x > $a 
x < -$[$a*$a] \bigvee -$[$a*$a] < x < $[$a*$a] \bigvee x > $[$a*$a] 
x < -$[$c*$a*$a] \bigvee -$[$c*$a*$a] < x < $[$c*$a*$a] \bigvee x > $[$c*$a*$a] 
\mathbb{R} 
y \le -$c \bigvee y > 0
y \le -$[$c*$a*$a] \bigvee y > 0
y \le -$c \bigvee y > $c 
y \le -$[$c*$a*$a] \bigvee y > $[$a*$a]


















