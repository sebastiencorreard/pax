:1/(x^2 + 1) 
 langle mininfty S plusinfty rangle 
 \mathbb{R}
 \langle -\infty : +\infty \rangle
 langle 0 S 1 rangle 
 0   <   y   <   1
 \langle 0 : 1 \rangle

:1/(x^2 + $a) 
 langle mininfty S plusinfty rangle 
 \mathbb{R}
 \langle -\infty : +\infty \rangle
 langle 0 S 1/$a rbracket 
 0   <   y   \le    \frac{1}{$a}
\left. \langle 0 : \frac{1}{$a} \right]















