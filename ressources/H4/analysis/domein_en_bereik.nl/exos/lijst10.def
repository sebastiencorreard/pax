# hyperbolische functie 
# line 1 is functie                                                                                                                        

# line 2 is Domein string : voor nakijken                                                                                                  
# line 3 is latex1 Domein x<0 V x>0
# line 4 is latex2 Domein   <-infty:+infty>
                                                                                                               
# line 5 is Bereik string : voor nakijken                                                                                                  
# line 6 is latex1 Bereik   y<0 V y>0                                                                                
# line 7 is latex2 Bereik   <-infty:+infty>

:1/x
 langle mininfty S 0 rangle U langle 0 S plusinfty rangle 
 x  <  0 \bigvee x   >   0
 \langle -\infty : 0 \rangle \bigcup \langle 0 : +\infty \rangle
 langle mininfty S 0 rangle U langle 0 S plusinfty rangle 
 y  <  0 \bigvee y   >   0
 \langle -\infty : 0 \rangle \bigcup \langle 0 : +\infty \rangle

:$a/x
 langle mininfty S 0 rangle U langle 0 S plusinfty rangle
 x  <  0 \bigvee x   >   0
 \langle -\infty : 0 \rangle \bigcup \langle 0 : +\infty \rangle
