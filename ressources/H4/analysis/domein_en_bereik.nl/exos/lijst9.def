# syntaxregels
# 0<x && x<4 voor 0<x<4
# x<0&&x>4 voor x<0 en x>4
# x<0&&1<x&&x<4&&x>5  voor x<0 en 1<x<4 en x>5 

:sqrt(x) 
lbracket,0,S,plusinfty,rangle
x \ge 0
[ 0 : +\infty\rangle
lbracket,0,S,plusinfty,rangle
y \ge 0
[ 0 : +\infty\rangle


:-sqrt(x) 
lbracket,0,S,plusinfty,rangle
x \ge 0
[ 0 : +\infty\rangle
langle,mininfty,S,0,rbracket
y \le 0
\langle -\infty : 0 ]

:sqrt($a -x)
langle,mininfty,S,$a,rbracket
x \le $a
\langle -\infty : $a ]
lbracket,0,S,plusinfty,rangle
y \ge 0
[ 0 : +\infty\rangle

:sqrt(x-$a) 
lbracket,$a,S,plusinfty,rangle
