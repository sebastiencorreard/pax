# syntaxregels
# 0<x && x<4 voor 0<x<4
# x<0&&x>4 voor x<0 en x>4
# x<0&&1<x&&x<4&&x>5 voor x<0 en 1<x<4 en x>5 

:1/x
x<0&&x>0
x < 0 \bigvee x > 0
y<0&&y>0
y < 0 \bigvee y > 0


:$a/x
x<0&&x>0
x < 0 \bigvee x > 0
y<0&&y>0
y < 0 \bigvee y > 0

:$b + $[$a+$b]/x
x<0&&x>0
x < 0 \bigvee x > 0
y<$b&&y>$b
y < $b \bigvee y > $b

:$b - $[$a+$b]/x
x<0&&x>0
x < 0 \bigvee x > 0
y<$b&&y>$b
y < $b \bigvee y > $b

:1/(x+$a) 
x<-$a&&x>-$a
x < -$a \bigvee x > -$a
y<0&&y>0
y < 0 \bigvee y > 0

:1/(x-$a)
x<$a && x>$a
x < $a \bigvee x > $a
y<0&&y>0
y < 0 \bigvee y > 0

:1/($a-x)
x<$a&&x>$a
x < $a \bigvee x > $a
y<0&&y>0
y < 0 \bigvee y > 0

:$b + 1/(x+$a) 
x<-$a&&x>-$a
x < -$a \bigvee x > -$a
y<$b&&y>$b
y < $b \bigvee y > $b

:$b + 1/(x-$a)
x<$a&&x>$a
x < $a \bigvee x > $a
y<$b&&y>$b
y < $b \bigvee y > $b

:$b + 1/($a-x)
x<$a && x>$a
x < $a \bigvee x > $a
y<$b&&y>$b
y < $b \bigvee y > $b

:$[$a+$b]*x/(x-$b) 
x<$b && x>$b
x < $b \bigvee x > $b
y<$[$a+$b]&&y>$[$a+$b]
y < $[$a+$b] \bigvee y > $[$a+$b]

:$[$a+$b]*x/(x+$b) 
x<-$b && x>-$b
x < -$b \bigvee x > -$b
y<$[$a+$b]&&y>$[$a+$b]
y < $[$a+$b] \bigvee y > $[$a+$b]

:(x-$a)/(x+$b) 
x<-$b&&x>-$b
x < -$b \bigvee x > -$b
y<1&&y>1
y < 1 \bigvee y > 1

:1/(x^2 + 1) 
R 
\mathbb{R}
0 < y&&y < 1
0 < y < 1

:1/(x^2 + $a) 
R 
\mathbb{R}
0<y&&y<=1/$a 
0 < y \le \frac{1}{$a}

:1/(x^2-1) 
x<-1&&-1<x&&x<1&&x>1
x < -1 \bigvee -1 < x < 1 \bigvee x > 1
y<=-1&&y>0
y \le -1 \bigvee y > 0

:$[$c*$a*$a]/(x^2 - $[$a^2])
x<-$a&&-$a<x&&x<$a&&x>$a 
x < -$a \bigvee -$a < x < $a \bigvee x > $a
y <= -$c && y > 0
y \le -$c \bigvee y > 0


















