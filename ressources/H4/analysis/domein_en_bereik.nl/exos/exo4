!set n=$counter
display=1
math=1
mathview=0
!if $questiontype=0
    questiontype=1
!endif
options=4
multiimage=0
checkfile=$checkdir/multiplechoice.proc
!if $questiontype=2
    graph=!record 20 of lang/remarks.$taal
!else
    graph=!record 21 of lang/remarks.$taal
!endif
Domein=!record 14 of lang/remarks.$taal
Bereik=!record 15 of lang/remarks.$taal

a=!randitem 2,3,4,5,6,7,8,9
b=!randitem 1,2,3,4,5,6,7,8,9
lijst=!randitem lijst4a.def,lijst4b.def
answer$n=!randint 1,$options

basis=!randfile exos/$lijst
functie=!line 1 of $basis
functie=!replace internal @ by , in $functie
f1=!item 1 of $functie
functie=!item 2 of $functie

formula$n=!texmath f(x) = $f1
keus=!randitem 1,2
soort=!randitem 1,0
!if $keus=1
    bereik=$Domein
    !if $soort=0
	DB=D_{f} :
    !else
	DB=D_{f} =
    !endif
    vraag=!line 2 to 5 of $basis
    # eerste item van $vraag is goed
!else
    !if $soort=0
	DB=B_{f} :
    !else
	DB=B_{f} =
    !endif
    bereik=$Bereik
    vraag=!line 6 to 9 of $basis
    # eerste item van $vraag is goed
!endif

keuzes=!shuffle 1,2,3,4
!for p=1 to 4
    nummer=!item $p of $keuzes
    ex$p=!line $nummer of $vraag
    ex$p=$DB  $(ex$p)
    !if $nummer=1
	answer$n=$p
	texanswer$n=$(ex$p)
    !endif
!next p

!if $image=1 or $teaching=1
    !readproc exos/image.proc
!endif

txt1=!record 23 of lang/remarks.$taal
# Domein en Bereik van de 'absolute waarde'-functie.
txt2=!record 24 of lang/remarks.$taal
question$n=$txt1<br />$txt2
# Welk <kbd>$bereik</kbd> past bij de $image  van de absolute-waarde functie?
helptext=$empty
!exit
