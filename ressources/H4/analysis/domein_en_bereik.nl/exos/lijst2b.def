# wortelfunctie 
# domein: 1 goede en daarna 3 foute oplossingen domein 
# bereik: 1 goede en daarna 3 foute oplossingen bereik ?
# elke functie twee domein/bereik schrijfwijzen: x>1 en [1;-->> alles in TeX
# deze file x<3 schrijwijze
:sqrt(x) 
x\ge 0 
x > 0
x < 0
x\le 0
y \ge 0
y >  0
y <  0
y \le 0

:-sqrt(x) 
x\ge 0
0\ge x
x > 0
x < 0 
y \le 0
x \ge 0
y > 0
y < 0

:sqrt($a -x)
x \le $a
y \le $a
x \ge $a
y \ge $a
y \ge 0
x \ge 0
x \le 0
y \le 0

:sqrt(x-$a) 
x\ge $a
x > -$a
x\ge -$a
x\le -$a
y \ge 0
y \ge $a
$a \le y
y \ge -$a

:sqrt(x+$a) 
x\ge -$a
x\le $a
x\ge $a
x\le -$a
y \ge 0
$a < y
y \ge $a
y \le -$a

:$a + sqrt(x) 
x \ge 0
x \ge -$a
0 \ge x
$a \ge x
y \ge $a
y \ge 0
x \ge -$a
$a \ge y

:$a - sqrt(x) 
x \ge 0
x > 0
x \le 0
x < 0
y \le $a
y > $a
y \ge $a
x < $a

:$a + sqrt(x - $b) 
x \ge $b 
x > $b 
x \ge -$b
x \le -$b
y \ge $a 
y > $a
x \ge -$a
y > -$a

:$a - sqrt(x - $b)
x \ge $b 
x \ge -$b 
x \le $b 
x \le -$b 
y \le $a 
x \ge $b 
y \ge $a 
x \le $b

:$a + sqrt($b - x)
x \le $b 
y \le $b 
x \ge $b 
y \ge $b 
y \ge $a
x \ge $a
x \le $a
y \le $a

:$a - sqrt(x + $b)
x \ge -$b
y \ge -$b 
x \ge $b 
y \ge $b 
y \le $a 
x \le $a 
y \ge -$a 
x \ge -$a 
