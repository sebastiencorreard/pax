# functie @ gnuplot log=ln log10=log 
# domein: 1 goede en daarna 3 foute oplossingen domein x 
# bereik: 1 goede en daarna 3 foute oplossingen bereik y
# elke functie twee domein/bereik schrijfwijzen: x>1 en [1;-->> alles in TeX
# deze file [a;b> schijfwijze
:$a*log(x)@$a*log10(x) 
x > 0 
\mathbb{R}
x > $a 
x \ge $a
\mathbb{R}
\mathbb{N}
y > 0
y > $a

:$a*log(-x)@$a*log10(-x) 
x < 0
x \le 0
x < $a
x \le $a
\mathbb{R}
y < 0
y > 0
y \ge $a

:$a*log(x - $b)@$a*log10(x - $b) 
x > $b
x > -$b
x \ge $b
x \le -$b
\mathbb{R}
\mathbb{Z}
\mathbb{N}
y > $b


:$a*log($b - x)@$a*log10($b - x)
x < $b 
x < -$b 
x \le $b 
x \le -$b 
\mathbb{R}
\mathbb{Z}
y < 0
y < $b

:$a*log($b + x)@$a*log10($b + x) 
x > -$b
x > $b
x \ge -$b
x \ge $b
\mathbb{R}
\mathbb{Z}
y < 0
y > -$b

:$a + log(x)@$a + log10(x)
x > 0 
x \ge 0 
x > -$a 
x \ge -$a 
\mathbb{R}
\mathbb{Z}
y > -$a
y > 0


:$a - log(x)@$a - log10(x) 
x > 0 
x \ge 0 
x > -$a 
x \ge -$a 
\mathbb{R}
\mathbb{Z}
y > -$a
y > 0

