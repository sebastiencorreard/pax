!set title=Choix d'une parabole
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr
language=fr

ansorder=r
varcnt=45
prevarcnt=44
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=Dans le plan muni d'un repčre orthonormé \((O,I,J)\), on considčre la fonction	  réelle \(f) définie sur l'intervalle \(\ [-2,2]\) par	  XXXX. Indiquez dans la liste ci-dessous la courbe représentative de \(f).
val8=L'expression de \( f(x) \) est donnée sous forme canonique :	  \(f(x)=a\left(x-\alpha\right)^2+\beta\)<br>	  Rappel (propriétés) :	  <ul>	  <li>La droite d'équation \(x=\alpha\) est l'axe de symétrie de la parapole qui représente \(f\);	  <li>Si \(a>0\), la fonction \(f\) admet pour minimum \(\beta\), et il est atteint en \(x=\alpha\);	  <li>Si \(a<0\), la fonction \(f\) admet pour maximum \(\beta\), et il est atteint en \(x=\alpha\).	  </ul>	
val9=Graphe
val10=lightblue
val11=xrange -2,2	yrange -2.5,2.5	gridfill 0,0,5,5,$val10	linewidth 3	vline 1,0,$val10	vline 2,0,$val10	vline -1,0,$val10	vline -2,0,$val10	hline 0,1,$val10	hline 0,2,$val10	hline 0,-1,$val10	hline 0,-2,$val10	linewidth 1	vline 0,0,black	hline 0,0,black		linewidth 3	points red,1,0,0,1,0,0	text red,1,-0.1,medium,I	text red,-0.2,1.2,medium,J	text red,-0.2,-0.1,medium,O	linewidth 2		
val12=2
val13=-2,-1,1,2
val14=-3/2,-1,-1/2,0,1/2,1,3/2
val15=-1,-3/4,-1/2,-1/4,0,1/4,1/2,3/4,1
val16=
!for val17  in $val13 
!for val18  in $val14 
!for val19  in $val15 
val20=($val17)*(x-($val18))^$val12+$val19
tmp0=!append item $val20 to $val16

val16=$(tmp0)
!next
!next
!next
tmp0=!shuffle $val16

val16=$(tmp0)
tmp0=!shuffle 4

val21=$(tmp0)
tmp0=!item 1 of $val21

val22=$[rint($(tmp0))]
tmp0=!item 2 of $val21

val23=$[rint($(tmp0))]
tmp0=!item 3 of $val21

val24=$[rint($(tmp0))]
tmp0=!item 4 of $val21

val25=$[rint($(tmp0))]
val26=$(val16[$val22])
t_=!replace internal \( by ( in $val26;
tmp0=!exec maxima $t_

val26=$(tmp0)
tmp0=!texmath $val26

val26=$(tmp0)
val27=$(val16[$val23])
t_=!replace internal \( by ( in $val27;
tmp0=!exec maxima $t_

val27=$(tmp0)
tmp0=!texmath $val27

val27=$(tmp0)
val28=$(val16[$val24])
t_=!replace internal \( by ( in $val28;
tmp0=!exec maxima $t_

val28=$(tmp0)
tmp0=!texmath $val28

val28=$(tmp0)
val29=$(val16[$val25])
t_=!replace internal \( by ( in $val29;
tmp0=!exec maxima $t_

val29=$(tmp0)
tmp0=!texmath $val29

val29=$(tmp0)
tmp0=!item 1 of $val16

val30=$(tmp0)
t_=!replace internal \( by ( in $val30;
tmp0=!exec maxima $t_

val30=$(tmp0)
tmp0=!texmath $val30

val30=$(tmp0)
tmp0=!positionof item 1 in $val21

val31=$[rint($(tmp0))]
tmp0=!shuffle red,blue,orange,green

val32=$(tmp0)
val33=$val11		plot $(val32[1]),$(val16[$val22])	
val34=$val11		plot $(val32[2]),$(val16[$val23])	
val35=$val11		plot $(val32[3]),$(val16[$val24])	
val36=$val11		plot $(val32[4]),$(val16[$val25])	
tmp0=!replace internal XXXX by \(f(x)=$val30\) in $val7

val37=$(tmp0)
replytype1=radio
replyname1=\rep
replygood1=$val31;1,2,3,4
question=__EXECUTED_1692754_EXERCISE__
solution=!nosubst $val8


!goto stat

!exit

:question
$()	$val37	  <table class="wimscenter wimsborder">	    <tr>	      <td>	         
!read oef/embed.phtml reply 1,1 
$()	      </td><td>	         
!read oef/draw.phtml 200,200 \
$val33 
$()	      </td><td>	         
!read oef/embed.phtml reply 1,2 
$()	      </td><td>	         
!read oef/draw.phtml 200,200 \
$val34 
$()	      </td>	    </tr><tr>	      <td>	         
!read oef/embed.phtml reply 1,3 
$()	      </td><td>	         
!read oef/draw.phtml 200,200 \
$val35 
$()	      </td><td>	         
!read oef/embed.phtml reply 1,4 
$()	      </td><td>	         
!read oef/draw.phtml 200,200 \
$val36 
$()	      </td>	    </tr>	  </table>	
$()
!exit

