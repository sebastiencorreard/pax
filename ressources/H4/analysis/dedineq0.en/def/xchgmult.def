varcnt=30
prevarcnt=28
postvarcnt=1
replycnt=0
choicecnt=0
conditioncnt=1
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=the exchange of the sides of an inequality is a composition	    of an addition of terms to the two sides of the inequality and the	  multiplication of the inequality by a number.
val8=the multiplication of an inequality by -1 is a composition	  of an addition of terms to the two sides of the inequality and the	  exchange of sides.
val9=You know that,	  So please transform the inequality,	  into,	  using the given methods
!if $val6=fr 
val7=la multiplication d'une inégalité par -1 est la composition	  d'une addition de termes aux deux côtés de l'inégalité et l'échange des	  côtés.
val8=l'échange des côtés d'une inégalité est la composition d'une	  addition de termes aux deux côtés de l'inégalité et la multiplication de	  l'inégalité par un nombre.
val9=Vous savez que,	  Transformez donc l'inégalité,	  en,	  par les méthodes fournies
!endif
m_options=nofloat fixedgoal askcontext askresult
tmp=!trim a,b	c,d	p,q	s,t	x,y	
val10=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val10

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val10=$(tmp0)
tmp0=!item 1 of $val10

val11=$(tmp0)
tmp0=!item 2 of $val10

val12=$(tmp0)
tmp0=!randint 2, 10

tmp1=!randint 2, 10

tmp2=!randint 1, 10

tmp3=!randitem -1,1

tmp4=!randint 1, 10

tmp5=!randitem -1,1

tmp6=!randitem 1,-1

tmp7=!randint 2, 10

tmp8=!randitem sin,cos,log

tmp9=!randint 0, 10

tmp10=!randitem -1,1

tmp11=!randitem sin,cos,log

tmp12=!randitem -1,1

tmp13=!randint 0, 10

tmp14=!randitem -1,1

tmp=!trim $val11+$(tmp0)*$val12,$(tmp1)*$val11-$val12	$val11,$(tmp2)*$(tmp3)*$val12	$val11+$(tmp4)*$(tmp5),$val12	$val11^2,$(tmp6)*$(tmp7)*$val12	$(tmp8)($val11),$val12+$(tmp9)*$(tmp10)	$(tmp11)($val11+$(tmp12)*$val12),$(tmp13)*$(tmp14)	
val10=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val10

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val10=$(tmp0)
tmp0=!shuffle $val10

val10=$(tmp0)
tmp0=!item 1 of $val10

val11=!rawmath $(tmp0)
tmp0=!item 2 of $val10

val12=!rawmath $(tmp0)
tmp0=!randitem ,=

val13=$(tmp0)
tmp0=!shuffle <$val13,>$val13

val14=$(tmp0)
tmp0=!item 1 of $val14

val15=$(tmp0)
tmp0=!item 2 of $val14

val16=$(tmp0)
tmp=!translate ";': to $     $ in $val11 $val15 $val12

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val17=$(tmp0)
tmp0=!randitem 1,2

val18=$[rint($(tmp0))]
!if $val18=1 
m_methods=ineq/addterm ineq/exsides
val19=-($val11) $val16 -($val12)
m_minsteps=2
val20=$val7
!else
m_methods=ineq/addterm ineq/mulnum
val19=$val12 $val16 $val11
m_minsteps=2
val20=name_phrase2
!endif
tmp=!translate ";': to $     $ in $val19

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val19=$(tmp0)
m_equivalence=$val17
tmp0=!nospace $val19

val21=$(tmp0)
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()$(val9[1]) $val20.	<p>	$(val9[2]) 
!insmath  $val17 
$() $(val9[3]) 
!insmath  $val19 
$() $(val9[4]).	</p>	
$()
!exit

