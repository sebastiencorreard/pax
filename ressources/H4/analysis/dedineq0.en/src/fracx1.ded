\function{left=(\x + \a)/(\x + \b)}
\real{tester=(\a-(\b))*(\it)}
\integer{c=\tester>0?1+\c:1-\c}
\text{sign=random(<,>,<=,>=)}
\equivalence{\left \sign \c}
\context{\x \s1 \d}
\statement{
  \name_statement[1] \(\left \sign \c), \name_statement[2] \(\x \s1 \d).
