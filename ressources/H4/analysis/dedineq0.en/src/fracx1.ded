\language{fr}
\options{nofloat askresult}
\methods{ineq/addterm, ineq/mulexp, ineq/divexp, ineq/exsides}
\minsteps{3}
\text{x=random(a,b,c,d,p,q,r,s,t,u,v,x,y,z)}
\text{sh=shuffle(15)}
\integer{a=(item(1,\sh)+1)*random(-1,1)}
\integer{b=(item(2,\sh)+1)*random(-1,1)}
