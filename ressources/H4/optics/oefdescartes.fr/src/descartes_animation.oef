\title{Recherche d'un indice}
\author{Benoît, Markey}

\precision{100}
##real{n11=randint(100..110)}
##real{n1=\n11/100}
\integer{n1=1}
\real{n22=randint(120..200)}
\real{n2=\n22/100}
\real{v=300000/\n2}
\real{conv=3.141592/180}
\integer{i11=randint(5..15)}
\integer{i12=randint(20..35)}
\integer{i13=randint(40..55)}
\integer{i14=randint(60..75)}
\real{sini11=sin(\i11*\conv)}
\real{sini12=sin(\i12*\conv)}
\real{sini13=sin(\i13*\conv)}
\real{sini14=sin(\i14*\conv)}
\real{sini21=\n1*sin(\i11*\conv)/\n2}
\real{sini22=\n1*sin(\i12*\conv)/\n2}
\real{sini23=\n1*sin(\i13*\conv)/\n2}
\real{sini24=\n1*sin(\i14*\conv)/\n2}
\integer{i21=asin(\sini21)/\conv}
\integer{i22=asin(\sini22)/\conv}
\integer{i23=asin(\sini23)/\conv}
\integer{i24=asin(\sini24)/\conv}

\css{
<style>
  
body{
  padding:0px;
  margin:0px;} 

