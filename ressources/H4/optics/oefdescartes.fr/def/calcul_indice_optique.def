!set title=calcul d'un indice optique
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Clotilde, Tomimitsu
email=tomimitsu@ac-creteil.fr
language=fr
precision=10

ansorder=r,r,r
varcnt=20
prevarcnt=19
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 2

val6=$[rint($(tmp0))]
tmp0=!randint 3, 10

val7=$[rint($(tmp0))]
val8=$[$val7*5]
val9=\(sin(i_1)=n sin(i_2)) , \(n sin(i_1)= sin(i_2))
tmp=!trim l'eau,1.33	la glace, 1.31	l'éthanol, 1.36	l'eau sucrée, 1.38	le plexiglass, 1.49	le verre Crown, 1.52	le verre flint, 1.62	le diamant, 2.42	l'huile d'olive, 1.47
val10=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val10

tmp0=!rowcnt $tmp
val11=$[rint($(tmp0))]
tmp=!translate internal $	$ to ; in $val10

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
tmp=!trim $(tmp0)
val12=!translate internal $	\
$ to ;; in $tmp
val13=$[$(val12[;2])]
tmp0=!positionof item $(val12[;1]) in $(val10[;1])

val14=$[rint($(tmp0))]
!if $val6=1 
val15=$[arcsin(sin($val8/180*pi)/$val13)*180/pi]
val16=image1.png
!endif
!if $val6=2 
val17=$[arcsin(1/$val13)*180/pi]
!if $val17<$val8 
val8=$[$val17-5]
!endif
val15=$[arcsin($val13*sin($val8/180*pi))*180/pi]
val16=image2.png
!endif
val18=$[round(10*$val8)/10]
val19=$[round(10*$val15)/10]
!readproc slib/text/sigunits $val13 ,3 
tmp0=$slib_out
val20=$(tmp0)
val21=r1	r2	r3
oefsteps=$val21 
nextstep=!nosubst $val21 
!readproc oef/steps.proc
replytype1=radio
replyoption1=shuffle 
replyname1=
replygood1=$val6;$val9
replytype2=sigunits
replyname2=
replygood2=$val20
replytype3=menu
replyname3=
replygood3=$val14;$(val10[;1])
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<p>	Soit la situation de réfraction schématisée ci-dessous. 	On note 
!insmath n
$() l'indice optique du milieu transparent de nature inconnue.	</p>	<div class="wimscenter">	<img src="$val1/$val16" alt="schéma de réfraction">	</div>	on a :	<ul class="wims_nopuce">	<li>
!insmath i_1=$val18
$() ° </li>	<li>
!insmath i_2=$val19
$() ° </li>	<li>on rappelle que 
!insmath n_air=1.00
$()</li>	</ul>			
!if $m_step = 1 
$()	<div class="wims_question">Quelle est la loi de Snell-descartes qui décrit la situation 	ci-dessus ?	<ul class="wims_nopuce"><li>	 
!read oef/embed.phtml r1,1 
$()	</li>	<li>	 
!read oef/embed.phtml r1,2 
$()	</li>	</ul>	</div>	 
!endif
$()	
!if $m_step = 2 
$()	<div class="wimscenter">La relation de Snell-descartes modélisant la situation est : 	<p>$(val9[$val6]).</p></div>	<div class="wims_question">	Calculer l'indice optique 
!insmath n
$() du milieu transparent de nature inconnu.</p>	<p>n= 
!read oef/embed.phtml r2 
$()</p></div>	<div class="wims_instruction">Donner le résultat avec 3 chiffres significatifs</div>		 
!endif
$()	
!if $m_step = 3 
$()	<div class="wimscenter">	L'indice optique du milieu transparent est : 
!insmath n=$val13
$() .</div>	<div class="wims_question">Identifier ŕ l'aide du tableau ci dessous la nature du milieu transparent.</p>		<table class="wimscenter wimsborder">	<tr><th>matičre transparente</th><th>indice optique</th></tr>	 
!for m_u=1 to $val11 
$()<tr><th>$(val10[$m_u;1])</th><th>$(val10[$m_u;2])</th></tr> 
!next
$()	</table>	<hr/>	Le milieu transparent est :  
!read oef/embed.phtml r3 
$()</div>	 
!endif
$()	
$()
!exit

