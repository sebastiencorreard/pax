val6=$[rint(3)]
val7=
!for val8 =1 to 2 
val9=$[rint($val6)]
tmp0=!randint 0, 2

val10=$[rint($(tmp0))]
val9=$[rint($val9-$val10)]
tmp0=!randint 0, $val9

val11=$[rint($(tmp0))]
val9=$[rint($val9-$val11)]
tmp0=!randint 0, $val9

val12=$[rint($(tmp0))]
val9=$[rint($val9-$val12)]
tmp0=!randint 0, $val9

val13=$[rint($(tmp0))]
val9=$[rint($val9-$val13)]
