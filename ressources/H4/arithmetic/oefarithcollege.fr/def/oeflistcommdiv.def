val14=$[rint($(tmp0))]
val9=$[rint($val9-$val14)]
tmp0=!randint 0, $val9

val15=$[rint($(tmp0))]
val9=$[rint($val9-$val15)]
val16=
!if $val10+$val11+$val12+$val13+$val14+$val15=0 
!if j=1 
val17=$[rint(126)]
val16=1,2,83,126
!else
val17=$[rint(8)]
val16=1,2,4,8
!endif
!else
val17=$[rint(2^$val10*3^$val11*5^$val12*7^$val13*11^$val14*13^$val15)]
!for val18 =0 to $val10 
!for val19 =0 to $val11 
!for val20 =0 to $val12 
!for val21 =0 to $val13 
!for val22 =0 to $val14 
!for val23 =0 to $val15 
val24=$[rint(2^$val18*3^$val19*5^$val20*7^$val21*11^$val22*13^$val23)]
tmp0=!append item $val24 to $val16

val16=$(tmp0)
!next
!next
!next
!next
!next
!next
!endif
val25=$val17,$val16
tmp0=!append line $val25 to $val7

tmp=!trim $(tmp0)
val7=!translate internal $	\
$ to ;; in $tmp
!next
tmp=!translate internal $	$ to ; in $val7

tmp=!row 1 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val25=$(tmp0)
tmp0=!item 1 of $val25

val26=$[rint($(tmp0))]
tmp0=!item 2 to -1 of $val25

val27=$(tmp0)
tmp=!translate internal $	$ to ; in $val7

tmp=!row 2 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val25=$(tmp0)
tmp0=!item 1 of $val25

val28=$[rint($(tmp0))]
