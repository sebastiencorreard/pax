!set title=Vocabulaire 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=c
varcnt=11
prevarcnt=10
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=Votre rťponse&nbsp;
val8=est un diviseur de,est un multiple de,est divisible par
val9=Laquelle de ces affirmations est juste&nbsp;
tmp=!trim 3,5,7,9	2,4,6,8,7	3,5,7,9	2,3,4,6,7,8,9	5,7	2,3,4,5,6,8,9	3,5,7,9	2,4,5,7,8
val10=!translate internal $	\
$ to ;; in $tmp
tmp0=!randint 2, 9

val11=$[rint($(tmp0))]
tmp=!translate internal $	$ to ; in $val10

tmp=!row $val11-1 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
tmp=!nonempty items $(tmp0)

tmp1=!randitem $tmp
val12=$[rint($(tmp1))]
val13=$[rint($val11*$val12)]
val14=$val13 $(val8[3]) $val11
val15=$val11 $(val8[3]) $val12,$val11 $(val8[3]) $val13
choicename1=$val7
choicegood1=$val14
choicebad1=$val15
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div class="wimscenter">	 
!insmath $val13 = $val11 \times $val12
$()	 </div>	 $val9? 
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=9,11,12,13
embedcnt=0
