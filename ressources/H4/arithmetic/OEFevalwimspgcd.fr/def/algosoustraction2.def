 !exit
!endif

tmp0=!randint 301, 569

val6=$[rint($(tmp0))]
tmp0=!randint 101, 299

val7=$[rint($(tmp0))]
val8=$[rint($val6+$val7)]
!readproc slib/lang/fname boy,fr 
tmp0=$slib_out
val9=$(tmp0)
val10=Il doit calculer $val6 - $val7
val11=Il doit calculer $val8 - $val7,Il doit calculer $val7 - $val6,Il doit calculer $val8 + $val7,Il peut directement conclure que le PGCD de $val6 et $val8 est $val7
choicename1=RÈponse
choicegood1=$val10
choicebad1=$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val9 veut calculer le Plus Grand Diviseur Commun (PGCD) de $val6 et $val8 en utilisant l'algorithme des soustractions.< br>	Il a dÈj‡ calculÈ la diffÈrence suivante :	<div class="wimscenter">
!insmath $val8 - $val6 = $val7 
