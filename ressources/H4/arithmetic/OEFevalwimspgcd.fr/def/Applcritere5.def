val24=$[rint($(tmp0))]
val25=$val23,$val17
tmp0=!listuniq $val25

val25=$(tmp0)
tmp0=!itemcnt $val25

val26=$[rint($(tmp0))]
tmp0=!listuniq $val23

val27=$(tmp0)
tmp0=!itemcnt $val27

val28=$[rint($(tmp0))]

!exit

:feedback

!exit

:test

