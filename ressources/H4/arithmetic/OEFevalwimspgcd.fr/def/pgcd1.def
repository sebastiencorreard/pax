!set title=PGCD 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=12
prevarcnt=11
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=Votre rÈponse&nbsp;
tmp=!trim Quel est le plus grand diviseur commun ‡,et	  Le plus grand diviseur commun ‡ , et , est
val8=!translate internal $	\
$ to ;; in $tmp
tmp=!nonempty items 2,3,5,10,11,13

tmp0=!randitem $tmp
val9=$[rint($(tmp0))]
tmp0=!randint 7, 19

val10=$[rint($(tmp0))]
tmp0=!randint 7, 19

val11=$[rint($(tmp0))]
val12=$[rint(gcd($val11,$val10))]
!if $val12!=1 
val10=$[rint(7)]
val11=$[rint(15)]
!endif
val13=$[rint($val10*$val9)]
val14=$[rint($val11*$val9)]
replytype1=numexp
replyname1=PGCD
replygood1=$val9
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  $(val8[1;1]) $val13 $(val8[1;2]) $val14 ?	<br class="spacer">	<b>$val7:</b>	  <label for="reply1">$(val8[2;1]) $val13 $(val8[2;2])	  $val14 $(val8[2;3])</label>  
!read oef/embed.phtml r1,6 
$().	
$()
!exit

