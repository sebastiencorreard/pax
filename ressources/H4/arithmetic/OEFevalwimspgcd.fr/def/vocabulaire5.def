!set title=Vocabulaire 5
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=15
prevarcnt=14
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=Votre rÈponse&nbsp;
val8=est un diviseur de,est un multiple de,est divisible par
val9=Parmi les affirmations suivantes, lesquelles sont vraies&nbsp;
tmp=!trim 3,5,7,9	2,4,6,8,7	3,5,7,9	2,3,4,6,7,8,9	5,7	2,3,4,5,6,8,9	3,5,7,9	2,4,5,7,8
val10=!translate internal $	\
$ to ;; in $tmp
tmp0=!randint 2, 9

val11=$[rint($(tmp0))]
tmp=!translate internal $	$ to ; in $val10

tmp=!row $val11-1 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
tmp=!nonempty items $(tmp0)

tmp1=!randitem $tmp
val12=$[rint($(tmp1))]
val13=$[rint($val11*$val12)]
val14=$val11 $(val8[1]) $val13,$val13 $(val8[3]) $val11
val15=$val11 $(val8[1]) $val12,$val13 $(val8[1]) $val11,$val11 $(val8[3]) $val12,$val11 $(val8[3]) $val13
tmp0=!shuffle $val14,$val15

val16=$(tmp0)
tmp0=!item 1 of $val14

val17=$(tmp0)
tmp0=!item 2 of $val14

val18=$(tmp0)
tmp0=!positionof item $val17 in $val16

tmp1=!positionof item $val18 in $val16

val19=$(tmp0),$(tmp1)
replytype1=checkbox
replyname1=$val7
replygood1=$val19;$val16
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div class="wimscenter">	 
!insmath $val13 = $val11 \times $val12
$()	 </div>	 $val9?	 <ul>	   
!for m_k=1 to 6 
$()	   <li> 
!read oef/embed.phtml r1,\k 
$()</li>	   
!next
$()	  </ul>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=9,11,12,13
embedcnt=1
