!set title=Algorithme des soustractions 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=c
varcnt=16
prevarcnt=15
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 3, 5

val6=$[rint($(tmp0))]
tmp0=!randint 101, 199

val7=$[rint($(tmp0))]
tmp0=!randint 21, 39

val8=$[rint($(tmp0))]
val9=$[rint($val7+$val8)]
!for val10 =1 to $val6-1 
tmp0=!shuffle $(val7[1]),$(val9[1])

val11=$(tmp0)
val12=$[rint($(val11[1])+$(val11[2]))]
val9=$val12,$val9
val7=$(val11[1]),$val7
val8=$(val11[2]),$val8
!next
!readproc slib/lang/fname boy,fr 
tmp0=$slib_out
val13=$(tmp0)
val14=$[rint(min($(val7[$val6]),$(val8[$val6])))]
val15=$[rint(max($(val7[$val6]),$(val8[$val6])))]
val16=Il doit calculer $val15 - $val14
val17=Il doit calculer $val14 - $val15,Il doit calculer $(val8[$val6]) - $(val9[$val6]),Il doit calculer $(val9[$val6]) - $(val8[$val6]),Il doit calculer $val14 + $val15,Il peut directement conclure que le PGCD de $val12 et $(val11[1]) est $(val8[$val6])
choicename1=RÈponse
choicegood1=$val16
choicebad1=$val17
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val13 veut calculer le Plus Grand Diviseur Commun (PGCD) de $val12 et $(val11[1])	en utilisant l'algorithme des soustractions.<br>	Il a dÈj‡ calculÈ les diffÈrences suivantes :	<table class="wimscenter wimsnoborder">	 
!for m_l=1 to $val6 
$()	 <tr><td>$(val9[$m_l]) - $(val7[$m_l]) </td><td> = </td><td> $(val8[$m_l])</td></tr>	 
!next
$()	</table>	Quelle est l'Ètape suivante ?
$()
