!set title=Réduction de fractions 5
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fguerima@free.fr
leftrange=-5.000000
rightrange=5.000000
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r,r
varcnt=13
prevarcnt=12
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=Votre réponse&nbsp;
val8=Quelle est l'écriture irréductible de la fraction
val9=numérateur, dénominateur
tmp=!nonempty items 2,3,5

tmp0=!randitem $tmp
tmp1=!randint 2, 13

val10=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 7, 19

val11=$[rint($(tmp0))]
tmp0=!randint 7, 19

val12=$[rint($(tmp0))]
val13=$[rint(gcd($val12,$val11))]
!if $val13!=1 
val11=$[rint(7)]
val12=$[rint(15)]
!endif
val14=$[rint($val11*$val10)]
val15=$[rint($val12*$val10)]
replytype1=numexp
replyname1=$(val9[1])
replygood1=$val11
replytype2=numexp
replyname2=$(val9[2])
replygood2=$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  $val8 
!insmath \frac{$val14}{$val15}
$() ?	$m_complement	<div class="spacer">	<b>$val7:</b>	 
!read oef/special.phtml mathmlinput [\frac{$val14}{$val15} = \frac{reply1}{reply2}],2,noanswer	reply1	reply2	 
$()	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,8,14,15
embedcnt=1
