!set title=Algorithme d'Euclide 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=c
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 301, 569

val6=$[rint($(tmp0))]
tmp0=!randint 25, 99

val7=$[rint($(tmp0))]
tmp0=!randint 2, 9

val8=$[rint($(tmp0))]
val9=$[rint($val8*$val6+$val7)]
!readproc slib/lang/fname boy,fr 
tmp0=$slib_out
val10=$(tmp0)
val11=Il doit calculer la division entière de $val6 par $val7
val12=Il doit calculer la division entière de $val9 par $val7,Il doit calculer la division entière de $val6 par $val9,Il doit calculer la somme de $val6 et $val7,Il peut directement conclure que le PGCD de $val6 et $val9 est $val7
choicename1=Réponse
choicegood1=$val11
choicebad1=$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val10 veut calculer le Plus Grand Diviseur Commun (PGCD) de $val6 et $val9 en utilisant l'algorithme d'Euclide.<br>	Il a déjà calculé le quotient et le reste de la division entière de $val9 par $val6 qu'il a écrit sous la forme suivante :	<div class="wimscenter">
!insmath $val9 = $val6 \times $val8 + $val7
$()</div>	Quelle est l'étape suivante ?
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,10
embedcnt=0
