!set title=Algorithme des soustractions 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=c
varcnt=6
prevarcnt=5
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 201, 569

val6=$[rint($(tmp0))]
tmp0=!randint 201, 299

val7=$[rint($val6+$(tmp0))]
!readproc slib/lang/fname boy,fr 
tmp0=$slib_out
val8=$(tmp0)
val9=\($val7 - $val6)
val10=\($val7 : $val6),\($val7 \times $val6),\($val7 + $val6)
choicename1=RÈponse
choicegood1=$val9
choicebad1=$val10
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val8 veut calculer le Plus Grand Diviseur Commun (PGCD) de $val6 et $val7 en utilisant l'algorithme des soustractions.<br>	Quelle opÈration doit-il commencer par effectuer ?
$()
!exit

