!set title=Nombres premiers entre eux 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=c
varcnt=20
prevarcnt=19
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=Votre rÈponse&nbsp;
val8=Oui,Non
val9=et,sont-ils premiers entre eux
val10=7,8,13,21,15,12
val11=2,3,5,7,11,13,17,19
tmp0=!shuffle $val11

val11=$(tmp0)
tmp0=!shuffle $val10

val10=$(tmp0)
tmp=!translate internal $	$ to ; in \couples

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val12=$(tmp0)
tmp0=!shuffle $val12

val12=$(tmp0)
tmp0=!item 1 of $val11

val13=$[rint($(tmp0))]
tmp0=!item 2 of $val11

val14=$[rint($(tmp0))]
tmp0=!randint 0, 1

val15=$[rint($(tmp0))]
!if $val15=1 
val16=$[rint($(val10[1])*$val13)]
val17=$[rint($(val10[1])*$val14)]
!else
val16=$[rint($(val10[1])*$val13)]
val17=$[rint($(val10[2])*$val14)]
!endif
val18=$[rint(gcd($val16,$val17))]

!ifval $val18=1
val19=$(val8[1])
!else
val19=$(val8[2])
!endif
choicename1=PGCD
choicegood1=$val19
choicebad1=$val8
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val16 $(val9[1]) $val17 $(val9[2]) ?	<div class="spacer">	<b>$val7 :</b>	 
!read oef/embed.phtml c1,6 
$().	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,9,16,17
embedcnt=1
