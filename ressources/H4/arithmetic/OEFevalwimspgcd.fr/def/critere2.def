!set title=Critères de divisibilité 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=c
varcnt=13
prevarcnt=12
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=Votre réponse&nbsp;
val8=Son chiffre des unités est XXXX.,	  La somme de ses chiffres est divisible par YYYY.,	  La somme de son chiffre des unités et de son chiffre des centaines est égal à celui des dizaines.,	  La somme de ses deux derniers chiffres est divisible par YYYY.
val9=Le nombre formé par ses deux derniers chiffres est divisible par YYYY
val10=Un nombre est divisible par, si
val11=$[rint(3)]
val12=\(3,6) ou 9
val13=$[rint(2)]
tmp0=!replace internal XXXX by $val12 in $val8

val14=$(tmp0)
tmp0=!replace internal YYYY by $val11 in $val14

val14=$(tmp0)
tmp0=!replace internal YYYY by $val11 in $val9

val15=$(tmp0)

!ifval $val13!=0
tmp0=!item $val13 of $val14

val16=$(tmp0)
!else
val16=	  $val15
!endif
choicename1=$val7
choicegood1=$val16
choicebad1=$val14
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  $(val10[1]) $val11 $(val10[2]):
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=10,11
embedcnt=0
