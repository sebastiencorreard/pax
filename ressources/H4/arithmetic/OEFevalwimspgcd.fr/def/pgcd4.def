!set title=PGCD 4
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=14
prevarcnt=13
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=Votre rÈponse&nbsp;
tmp=!trim Quel est le plus grand diviseur commun ‡,et	  Le plus grand diviseur commun ‡ , et , est
val8=!translate internal $	\
$ to ;; in $tmp
val9=Utiliser un algorithme de calcul.
tmp0=!randint 23, 65

val10=$[rint($(tmp0))]

!ifval 0 isin $val10
val10=$[rint(23)]
!endif
tmp0=!randint 7, 19

val11=$[rint($(tmp0))]
tmp0=!randint 7, 19

val12=$[rint($(tmp0))]
val13=$[rint(gcd($val12,$val11))]
!if $val13!=1 
val11=$[rint(7)]
val12=$[rint(15)]
!endif
val14=$[rint($val11*$val10)]
val15=$[rint($val12*$val10)]
replytype1=numexp
replyname1=PGCD
replygood1=$val10
question=__EXECUTED_1692754_EXERCISE__
hint=!nosubst $val9


!goto stat

!exit

:question
$()	  $(val8[1;1]) $val14 $(val8[1;2]) $val15 ?	<br class="spacer">	<b>$val7:</b>	  <label for="reply1">$(val8[2;1]) $val14 $(val8[2;2])	  $val15 $(val8[2;3])</label>  
!read oef/embed.phtml r1,6 
$().	
$()
!exit

:hint
$()$val9
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,8,9,14,15
embedcnt=1
