val6=Aucun logiciel de programmation n'est autorisé pour répondre ŕ cet exercice, sans quoi il ne sert pas ŕ grand chose pour progresser.	<br />En revanche, une calculatrice est parfois nécessaire pour trouver la bonne réponse.
val7=$[rint(3)]
val8=$[rint(1)]
val9=
val10=
val11=
tmp0=!randint 6, 12

val12=$[rint($(tmp0))]
tmp0=!randint 15, 30

val13=$[rint($(tmp0))]
tmp0=!randitem 1,2,3,4

val14=$[rint($(tmp0))]
tmp0=!randitem 1,2

val15=$[rint($(tmp0))]
val16=$[rint($val12+$val13)]
tmp0=!item $val14 of 2*$val12,3*$val12,2*$val13,3*$val13

val17=$[rint($(tmp0))]
tmp0=!item $val15 of $val16+$val17,$val16-$val17

val18=$[rint($(tmp0))]
tmp0=!item $val14 of 2*x,3*x,2*y,3*y

val19=$(tmp0)
tmp0=!item $val15 of u+v,u-v

val20=$(tmp0)
tmp0=!item $val14 of 2\times$val12,3\times$val12,2\times$val13,3\times$val13

val21=$(tmp0)
tmp0=!item $val15 of $val16+$val17,$val16-$val17

val22=$(tmp0)
tmp0=!nosubst Que retourne <span class="tt">mystere($val12,$val13)</span>	  écrit en langage Python ?

val23=$(tmp0)
val24=def mystere(x,y):	  u=x+y	  v=$val19	  return($val20)	
val25=C'est une fonction en langage Python,	<span class="tt">mystere($val12,$val13)</span> fait la chose suivante :
val26=\(u\) prend la valeur \($val12+$val13\)	\(v\) prend la valeur \($val21)	Retourner la valeur \($val22)	
val27=La fonction retourne donc $val18.	
replytype1=formal
replyname1=
replygood1=$val18
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

