tmp=!trim <img src="$val1/parcours1.png" width="70%">, Donne la rťponse	<img src="$val1/parcours2.png" width="70%">, Donne la rťponse	<img src="$val1/parcours3.png" width="70%">, Donne la rťponse	<img src="$val1/parcours4.png" width="70%">, Erreur de syntaxe	<img src="$val1/parcours5.png" width="70%">, Erreur de syntaxe	<img src="$val1/parcours6.png" width="70%">, Erreur de syntaxe	<img src="$val1/parcours7.png" width="70%">, Erreur ŗ l'exťcution	<img src="$val1/parcours8.png" width="70%">, Erreur ŗ l'exťcution	<img src="$val1/parcours9.png" width="70%">, Erreur ŗ l'exťcution	<img src="$val1/parcours10.png" width="70%">, Erreur ŗ l'exťcution	<img src="$val1/parcours11.png" width="70%">, Ne donne pas la rťponse cherchťe	<img src="$val1/parcours12.png" width="70%">, Ne donne pas la rťponse cherchťe	<img src="$val1/parcours13.png" width="70%">, Ne donne pas la rťponse cherchťe	<img src="$val1/parcours14.png" width="70%">, Ne donne pas la rťponse cherchťe	<img src="$val1/parcours15.png" width="70%">, Ne donne pas la rťponse cherchťe	<img src="$val1/parcours16.png" width="70%">, Erreur ŗ l'exťcution	
val13=!translate internal $	\
$ to ;; in $tmp
tmp0=!item 1 of 1 oui, 2 non

val14=$(tmp0)
