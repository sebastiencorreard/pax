val9=$[rint($(tmp0))]
tmp0=!randint 9, 15

val10=$[rint($(tmp0))]
val11=\($val10,$val9\)
val12=\($val9,$val10\)
val13=\($val9,$val9\)
val14=\($val10,$val10\)
tmp0=!nosubst 	 $val11	 

tmp=!trim $(tmp0)
val15=!translate internal $	\
$ to ;; in $tmp
tmp0=!nosubst 	$val12	$val13	$val14	

tmp=!trim $(tmp0)
val16=!translate internal $	\
$ to ;; in $tmp
tmp0=!nosubst 	x,y=$val9,$val10	c=y	y=x	x=c	print(x,y)	

val17=$(tmp0)
val18=En langage naturel le programme est :
val19=\(x) prend la valeur $val9	\(y) prend la valeur $val10	\(c) prend la valeur \(y)	\(y) prend la valeur \(x)	\(x) prend la valeur \(c)	Afficher la valeur de \(x) , \(y)	
val20=Le programme affiche donc $val11.	Plus généralement, il échange les valeurs des variables \(x) et \(y).	
val21=$[rint(1)]
val22=$[rint(0)]
val23=
val24=
val25=
val26=
