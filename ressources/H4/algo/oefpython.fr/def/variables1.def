!endif
!if $val26 != $val28 
!endif
tmp0=!nonempty rows $val15

val15=$(tmp0)
tmp0=!nonempty rows $val16

val16=$(tmp0)
tmp=!translate internal $	$ to ; in $val15

tmp0=!rowcnt $tmp
val30=$[rint($(tmp0))]
tmp=!translate internal $	$ to ; in $val16

tmp0=!rowcnt $tmp
val31=$[rint($(tmp0))]

!ifval $val21<1
val21=$[rint(1)]
!endif

!ifval $val21>$val30
val21=$[rint($val30)]
!endif

!ifval $val7 > $val31+$val21
val7=$[rint($val31+$val21)]
!endif

!ifval $val21>$val7-1
val21=$[rint($val7-1)]
!endif

!ifval $val22>$val7-$val21
val22=$[rint($val7-$val21)]
!endif
tmp0=!shuffle $val30

val32=$(tmp0)
tmp=!translate internal $	$ to ; in $val15

tmp=!row $val32 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val33=$(tmp0)
!if $val22>0 
tmp=!translate internal $	$ to ; in $val16

tmp=!row 1 to $val22 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val34=$(tmp0);
tmp=!translate internal $	$ to ; in $val16

tmp=!row $val22+1 to $val31 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val35=$(tmp0)
!else
val22=$[rint(0)]
val34=
val35=$val16
!endif
tmp0=!shuffle $val31

val36=$(tmp0)
tmp=!translate internal $	$ to ; in $val35

tmp=!row $val36 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val35=$(tmp0)
tmp=!translate internal $	$ to ; in $val33

tmp=!row 1 to $val21 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
tmp=!translate internal $	$ to ; in $val35

tmp=!row 1 to $val7-$val21-$val22 of $tmp
tmp1=!translate internal $\
$ to ; in $tmp
val37=$(tmp0);$val34 $(tmp1)
tmp0=!makelist 1 for x=1 to $val21

tmp1=!makelist 0 for x=1 to $val7-$val21

val38=$(tmp0),$(tmp1)
