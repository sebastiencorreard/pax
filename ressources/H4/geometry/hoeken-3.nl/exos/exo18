#@Stel een vergelijking op van de lijn met onderstaande vectorvoorstelling
a=!randint -10,10
b=!randint 1,15
pm=!randitem -1,1
b=$[$pm*$b]
d=!randint 1,10
e=!randint 1,10
c=$[$e*$a-$d*$b]
f=$[gcd($e,$d)]
E=$[$e/$f]
D=$[$d/$f]

answer$n=$e*x-$d*y=$c
