!readproc $checkdir/coord.proc

!if $goback=0
 n=$counter
 !if $AAA = $empty
    AAA=-100,-100,-101,-101
 !endif
 !if $maxscore > 0.5
    k=green
 !else
    k=red
 !endif
 #var5=!append line arrow $(answer$n),8,green\
 #arrow $AAA,8,$k to $var5
 
 object$n=!exec canvasdraw\
 $var5\
 linewidth 1\
 arrow $(answer$n),8,green\
 arrow $AAA,8,$k
 zoom red

!endif

!exit
