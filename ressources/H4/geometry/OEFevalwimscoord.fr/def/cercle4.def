tmp0=!shuffle A,B,C,D,E,F,G,H,K,L,M,N,P

val6=$(tmp0)
val7=$(val6[1])
val8=$(val6[2])
val9=$(val6[3])
tmp0=!values v,-v for v=1 to 10

val10=$(tmp0)
tmp0=!shuffle $val10

val10=$(tmp0)
val11=$[rint($(val10[1]))]
val12=$[rint($(val10[2]))]
val13=$[rint($(val10[3]))]
val14=$[rint($(val10[4]))]
tmp=!translate ";': to $     $ in ($val11+$val13)/2

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val15=$(tmp0)
tmp=!translate ";': to $     $ in ($val12+$val14)/2

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val16=$(tmp0)
tmp=!translate ";': to $     $ in ($val13-$val11)^2+($val14-$val12)^2

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val17=sqrt($(tmp0))
val18=Les coordonnées de \($val7\) sont ($val11 ; $val12) et celles de \($val8\) sont ($val13 ; $val14).	 <p>Quelle est la mesure du diamčtre de ce cercle&nbsp;
val19=Le diamčtre mesure 
!readproc oef/draw.phtml 200,200 \
xrange -100,100	yrange -100,100	circle 0,0,128,black	text blue,-75,0,medium , $val7	text blue,70,0,medium , $val8	crosshair 64,0,blue	text red,0,20,medium , $val9	crosshair 0,0,red	crosshair -64,0,blue	segment -64,0,64,0,blue	segment -36,-8,-34,8,blue	segment -33,-8,-31,8,blue	segment 36,8,34,-8,blue	segment 33,8,31,-8,blue	 
tmp0=$ins_url
