!set title=ParallÈlogramme 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fwguerima@free.fr
keywords=coordinates, parallelogram

ansorder=r,r
varcnt=35
prevarcnt=34
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!shuffle A,B,C,D,E,F,G,H,K,L,M,N,P

val6=$(tmp0)
val7=$(val6[1])
val8=$(val6[2])
val9=$(val6[3])
val10=$(val6[4])
tmp0=!values v,-v for v=1 to 10

val11=$(tmp0)
tmp0=!shuffle $val11

val11=$(tmp0)
val12=$[rint($(val11[1]))]
val13=$[rint($(val11[2]))]
val14=$[rint($(val11[3]))]
val15=$[rint($(val11[4]))]
val16=$[rint($(val11[5]))]
val17=$[rint($(val11[6]))]
val18=$[rint($val14*$val17-$val16*$val15)]
!if $val18=0 
val14=$[rint(3)]
val15=$[rint(1)]
val16=$[rint(4)]
val17=$[rint(-2)]
!endif
val19=$[rint($val12+$val14)]
val20=$[rint($val13+$val15)]
val21=$[rint($val12+$val16)]
val22=$[rint($val13+$val17)]
val23=Quelles sont les coordonnÈes du centre de ce parallÈlogramme
val24=les coordonnÈes du centre sont
val25=$[($val19+$val21)/2]
val26=$[($val20+$val22)/2]
!if $val2=2 
val27=[\left( reply1 ; reply2 \right)]
val28=\left( $val25 ; $val26 \right)
!else
val27=[\begin{pmatrix} reply1 \\ reply2 \end{pmatrix}]
val28=\begin{pmatrix} $val25 \\ $val26 \end{pmatrix}
!endif

!ifval $val21<0
val29= ($val21)
!else
val29=$val21
!endif

!ifval $val22<0
val30= ($val22)
!else
val30=$val22
!endif
val31=$[rint($val19+$val21)]
val32=$[rint($val20+$val22)]
replytype1=numexp
replyname1=Abscisse
replygood1=$val25
replytype2=numexp
replyname2=OrdonnÈe
replygood2=$val26
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	   Le plan est muni d'un repËre 
!insmath (O,I,J)
$() et	
!insmath $val7 $val8 $val9 $val10
$() est un parallÈlogramme tel que :	<div class="wimscenter"> 
!insmath $val7 ($val12 ; $val13)
$(), 
!insmath $val8 ($val19 ; $val20)
$(),  
!insmath $val10 ($val21 ; $val22)
$()</div>	<p>$val23 ?</p>	<div class="spacer">	  <b>Votre rÈponse</b> :	$val24 <div class="wimscenter"> 
!read oef/special.phtml mathmlinput $val27,5,noanswer	reply1,,color:blue;text-align:center;	reply2,,color:blue;text-align:center;	 
$()	.</div>	</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()<p>Dans la suite, les coordonnÈes d'un point 
!insmath A
$() se noteront 
!insmath (x_A;y_A)
$().</p>		<p>Puisque 
!insmath $val7 $val8 $val9 $val10
$() est un parallÈlogramme, le centre est le milieu de 
!insmath [$val8\,$val10]
$().</p>	<p> Calculons les coordonnÈes du milieu de ce segment :</p>	<ul><li>Son abscisse : 
!insmath x=\frac{x_$val8+x_$val10}{2}=\frac{$val19+$val29}{2}=$val25
$().</li>	<li>Son ordonnÈe : 
!insmath y=\frac{y_$val8+y_$val10}{2}=\frac{$val20+$val30}{2}=$val26
$().<//li></ul>		
$()
