tmp=!translate ";': to $     $ in ($val11+$val10)/2

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val14=$(tmp0)
tmp=!translate ";': to $     $ in ($val13+$val12)/2

