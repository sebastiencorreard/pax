!set title=Longueur d'un segment (graphique) 5
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fwguerima@free.fr
keywords=length

ansorder=r
varcnt=23
prevarcnt=22
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!shuffle A,B,C,D,E,F,G,H,K,L,M,N,P

val6=$(tmp0)
val7=$(val6[1])
val8=$(val6[2])
tmp0=!shuffle 2,3,4,5

val9=$(tmp0)
tmp=!nonempty items 2,3

tmp0=!randitem $tmp
val10=$[rint($(tmp0))]
val11=$[rint($(val9[1])*$val10)]
val12=$[rint($(val9[2])*$val10)]
tmp=!nonempty items 1,-1

tmp0=!randitem $tmp
val13=$[rint($(tmp0))]
tmp=!nonempty items 1,-1

tmp0=!randitem $tmp
val14=$[rint($(tmp0))]
tmp0=!randint 1, 6

val15=$[rint($val13*$(tmp0))]
tmp0=!randint 1, 6

val16=$[rint($val14*$(tmp0))]
val17=$[rint($val15-$val13*$val11)]
val18=$[rint($val16)]
val19=$[rint($val15)]
val20=$[rint($val16-$val14*$val12)]
val21=$[rint(300)]
val22=$[rint(max(abs($val17),abs($val19)))]
val23=$[rint(max(abs($val18),abs($val20)))]
val24=$[rint(max($val22,$val23)+1)]
val25=range -$val24,$val24,-$val24,$val24	parallel -$val24,-$val24,$val24,-$val24,0,1,2*$val24+1,grey	parallel -$val24,-$val24,-$val24,$val24,1,0,2*$val24+1,grey	arrow -$val24,0,$val24,0,20,black	arrow 0,-$val24,0,$val24,20,black	text black,-0.4,0,medium,0	text black,$val24-0.5,0,medium,X	text black,-0.5,$val24,medium,Y	text black,-0.4,1.2,medium,1	text black,1,0,medium,1	circle $val17,$val18,5,red	circle $val19,$val20,5,red	text red,$val17,$val18-0.1,medium,$val7	text red,$val19,$val20-0.1,medium,$val8
!readproc oef/draw.phtml $val21,$val21 \
$val25 
tmp0=$ins_url
val26=$(tmp0)
tmp=!translate ";': to $     $ in ($val19-$val17)^2+($val20-$val18)^2

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val27=sqrt($(tmp0))
replytype1=algexp
replyname1=$val7 $val8
replygood1=$val27
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="grid-x grid-margin-x">	  <div class="cell medium-6 small-12  flex-dir-column">	    <div class="flex-child-auto">	      Soient 
!insmath $val7
$() et 
!insmath $val8
$() deux points du plan muni d'un repčre orthonormé 
!insmath (O,I,J)
$().	<p>Quelle est la mesure de la longueur du segment 
!insmath [$val7\,$val8]
$() ?</p>	    </div>	    <div class="flex-child-auto">	        <b>Votre réponse</b> :	          <label for="reply1">
!insmath $val7 $val8 =
$()</label> 
!read oef/embed.phtml r1,9 
$() unités.	         <div class="wims_instruction">Tapez <span class="tt">sqrt(2)</span> pour 
!insmath \sqrt{2}
$().</div>	    </div>	  </div>	  <div class="cell medium-6 small-12">	     <div class="unbreakable"><img src="$val26" alt=""></div>	  </div>	</div>	
$()
!exit

