val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!shuffle A,B,C,D,E,F,G,H,K,L,M,N,P

val6=$(tmp0)
val7=$(val6[1])
val8=$(val6[2])
tmp=!nonempty items 1,-1

tmp0=!randitem $tmp
tmp=!nonempty items 1,3,5

tmp1=!randitem $tmp
val9=$[rint($(tmp0)*$(tmp1))]
tmp=!nonempty items 2,4,6

tmp0=!randitem $tmp
tmp=!nonempty items -1,1

tmp1=!randitem $tmp
val10=$[rint($val9+$(tmp0)*$(tmp1))]
tmp=!nonempty items 1,-1

tmp0=!randitem $tmp
tmp=!nonempty items 1,3,5

tmp1=!randitem $tmp
val11=$[rint($(tmp0)*$(tmp1))]
tmp=!nonempty items 2,4,6

tmp0=!randitem $tmp
tmp=!nonempty items -1,1

tmp1=!randitem $tmp
val12=$[rint($val11+$(tmp0)*$(tmp1))]
!if $val2=2 
val13=[\left( reply1 ; reply2 \right)]
!else
val13=[\begin{pmatrix} reply1 \\ reply2 \end{pmatrix}]
!endif
val14=$[rint(300)]
val15=$[rint(max(abs($val11),abs($val12))+1)]
val16=$[rint(max(abs($val9),abs($val10))+1)]
val17=range -$val15,$val15,-$val16,$val16	parallel -$val15,-$val16,$val15,-$val16,0,1,2*$val16+1,grey	parallel -$val15,-$val16,-$val15,$val16,1,0,2*$val15+1,grey	arrow -$val15,0,$val15,0,20,black	arrow 0,-$val16,0,$val16,20,black	text black,-0.4,0,medium,0	text black,$val15-0.5,0,medium,X	text black,-0.5,$val16,medium,Y	text black,-0.4,1.2,medium,1	text black,1,0,medium,1	circle $val11,$val9,5,red	circle $val12,$val10,5,red	text red,$val11,$val9-0.1,medium,$val7	text red,$val12,$val10-0.1,medium,$val8
!readproc oef/draw.phtml $val14,$val14 \
$val17 
tmp0=$ins_url
val18=$(tmp0)
tmp=!translate ";': to $     $ in ($val11+$val12)/2

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val19=$(tmp0)
tmp=!translate ";': to $     $ in ($val9+$val10)/2

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val20=$(tmp0)
replytype1=numexp
replyname1=Abscisse
replygood1=$val19
replytype2=numexp
replyname2=Ordonnťe
