!set title=Longueur d'un segment (graphique) 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fwguerima@free.fr
keywords=length

ansorder=r
varcnt=21
prevarcnt=20
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!shuffle A,B,C,D,E,F,G,H,K,L,M,N,P

val6=$(tmp0)
val7=$(val6[1])
val8=$(val6[2])
tmp=!translate internal $	$ to ; in 3,4	6,8

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val9=$(tmp0)
tmp0=!shuffle $val9

val9=$(tmp0)
tmp=!nonempty items 1,-1

tmp0=!randitem $tmp
val10=$[rint($(tmp0))]
tmp=!nonempty items 1,-1

tmp0=!randitem $tmp
val11=$[rint($(tmp0))]
tmp0=!randint 1, 6

val12=$[rint($val10*$(tmp0))]
tmp0=!randint 1, 6

val13=$[rint($val11*$(tmp0))]
val14=$[rint($val12-$val10*$(val9[1]))]
val15=$[rint($val13)]
val16=$[rint($val12)]
val17=$[rint($val13-$val11*$(val9[2]))]
val18=$[rint(300)]
val19=$[rint(max(abs($val14),abs($val16)))]
val20=$[rint(max(abs($val15),abs($val17)))]
val21=$[rint(max($val19,$val20)+1)]
val22=range -$val21,$val21,-$val21,$val21	parallel -$val21,-$val21,$val21,-$val21,0,1,2*$val21+1,grey	parallel -$val21,-$val21,-$val21,$val21,1,0,2*$val21+1,grey	arrow -$val21,0,$val21,0,20,black	arrow 0,-$val21,0,$val21,20,black	text black,-0.4,0,medium,0	text black,$val21-0.5,0,medium,X	text black,-0.5,$val21,medium,Y	text black,-0.4,1.2,medium,1	text black,1,0,medium,1	circle $val14,$val15,5,red	circle $val16,$val17,5,red	text red,$val14,$val15-0.1,medium,$val7	text red,$val16,$val17-0.1,medium,$val8
!readproc oef/draw.phtml $val18,$val18 \
$val22 
tmp0=$ins_url
val23=$(tmp0)
tmp=!translate ";': to $     $ in ($val16-$val14)^2+($val17-$val15)^2

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val24=sqrt($(tmp0))
replytype1=algexp
replyname1=$val7 $val8
replygood1=$val24
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="grid-x grid-margin-x">	  <div class="cell medium-6 small-12  flex-dir-column">	    <div class="flex-child-auto">	      Soient 
!insmath $val7
$() et 
!insmath $val8
$() deux points du plan muni d'un repčre orthonormé 
!insmath (O,I,J)
$().	<p>Quelle est la mesure de la longueur du segment 
!insmath [$val7\,$val8]
$() ?</p>	    </div>	    <div class="flex-child-auto">	        <b>Votre réponse</b> :	          <label for="reply1">
!insmath $val7 $val8 =
$()</label> 
!read oef/embed.phtml r1,9 
$() unités.	         <div class="wims_instruction">Tapez <span class="tt">sqrt(2)</span> pour 
!insmath \sqrt{2}
$().</div>	    </div>	  </div>	  <div class="cell medium-6 small-12">	     <div class="unbreakable"><img src="$val23" alt=""></div>	  </div>	</div>	
$()
!exit

