!read language lang/names

!set wims_backslash_insmath=yes

!header
!read present.phtml

!if $error!=$empty
  <div class="wims_msg alert">
  !read msg.phtml
  </div>
!endif

!if $status=waiting
 !read form.phtml
 <p>
 !if $repeat>1
  !set wims_ref_class=wims_button wims_secondary_button
  !href cmd=renew&worksheet=$worksheet&$module_init_parm $name_giveup
 $
 !else
  !set wims_ref_class=wims_button wims_secondary_button
  !href exo_Renew
 $
 !endif
 </p>
!else
 !read answer.phtml
 <p>
 !if $repeat>1
  !if $status=next
   !set wims_ref_class=wims_button wims_secondary_button
   !href cmd=renew&worksheet=$worksheet&$module_init_parm $name_giveup
 $
  !else
   !set wims_ref_class=wims_button
   !href exo_Again
 $
  !endif
 !else
  !set wims_ref_class=wims_button
  !href exo_Again
 $
 !endif
 !if $worksheet=$empty
  !set wims_ref_class=wims_button
  !href exo_Intro
 $
 !endif
 </p>
!endif

!tail
