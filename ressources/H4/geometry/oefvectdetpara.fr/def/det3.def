ansorder=r,r
varcnt=16
prevarcnt=15
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 20

val6=$[rint($(tmp0))]
tmp0=!randint -10, 10

val7=$[rint($(tmp0))]
tmp0=!randint 1, 20

tmp1=!randitem -1,1

val8=$[rint($val6+$(tmp0)*$(tmp1))]
tmp0=!randint -10, 10

val9=$[rint($(tmp0))]
tmp0=!randint -30, -10

val10=$[$(tmp0)/10]
tmp0=!randint 10, 35

tmp1=!randitem -1,1

val11=$[$val9+$(tmp0)*0.1*$(tmp1)]
val12=$[rint($val8-$val6)]
val13=$[rint($val9-$val7)]
tmp0=!randitem 1,2,2

val14=$[rint($(tmp0))]
tmp0=!randitem -1,1

tmp1=!randint 11, 35

val15=$[$(tmp0)*$(tmp1)/10]
val16=$[$val10+$val12*$val15]

!ifval ($val14=1)
val17=$[ $val11+$val13*$val15]
!else
tmp0=!randint 10, 30

val17=$[$val11+$val13*$val15+$(tmp0)/10]
!endif
val18=$[$val16-$val10]
val19=$[$val17-$val11]
val20=$[$val12*$val19-$val18*$val13]
replytype1=numeric
replyname1=
replygood1=$[$val20]
replytype2=radio
replyname2=
replygood2=$val14;Oui, Non, Je ne sais pas
