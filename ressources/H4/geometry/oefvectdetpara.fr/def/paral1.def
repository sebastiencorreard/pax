tmp0=!randint -10, 10

val8=$[rint($(tmp0))]
tmp0=!randint -10, 10

val9=$[rint($(tmp0))]
tmp0=!randint -5, 5

val10=$[rint($(tmp0))]
val11=$[rint($val7*$val10+$val8)]
tmp0=!randitem -1,1

val12=$[rint($(tmp0))]

!ifval ($val6=1)
val13=$[rint( $val10)]
!else
tmp0=!randint 1, 5

val13=$[rint($val10+$val12*$(tmp0))]
!endif

!ifval ($val6=1)
tmp0=!randint 1, 5

val14=$[rint( $val11+$val12*$(tmp0))]
!else
val14=$[rint($val7*$val13+$val8)]
!endif
tmp0=!randint 1, 5

val15=$[rint($val10-$val12*$(tmp0))]
val16=$[rint($val7*$val15+$val9)]

!ifval ($val6=1)
val17=$[rint( $val15)]
!else
tmp0=!randint 1, 5

val17=$[rint($val15-$val12*$(tmp0))]
!endif

!ifval ($val6=1)
tmp0=!randitem -1,1

tmp1=!randint 1, 5

val18=$[rint( $val16+$(tmp0)*$(tmp1))]
!else
tmp2=!randint 1, 3

tmp3=!randitem -1,1

tmp=!nonempty items 0,$(tmp2)*$(tmp3)

tmp4=!randitem $tmp
val18=$[rint(($val7*$val17+$val9)+$(tmp4))]
!endif
val19=$[rint($val13-$val10)]
val20=$[rint($val14-$val11)]
val21=$[rint($val17-$val15)]
val22=$[rint($val18-$val16)]
val23=$[rint(($val19*$val22)-($val21*$val20))]

!ifval ($val23=0)
val24=$[rint( 1)]
!else
val24=$[rint(2)]
!endif
val25=A,B,C,D,E,F,H,K,L,N
tmp0=!shuffle $val25

val25=$(tmp0)
