:solution
$()Le vecteur 
!insmath \overrightarrow{$val26 $val27}
$() a pour coordonnées  
!insmath [$val13-($val10);$val14-($val11)]=[$val19;$val20]
$() et le vecteur	
!insmath \overrightarrow{$val28 $val29}
$() a pour coordonnées  
!insmath [$val21;$val22]
$() .	<br />	Le déterminant de 
!insmath \overrightarrow{$val26 $val27}
$() et 
!insmath \overrightarrow{$val28 $val29}
$() est 
!insmath $val19\times($val22)-($val21)\times($val20)=$val23
$()
!if $val23!=0 
$()
!insmath \neq 0
$() 
!endif
$()	<br />Le déterminant est 
!if $val23=0 
$()nul 
!else
$() non nul 
!endif
$().	<br />Donc ces vecteurs 
!if $val23=0 
$()sont 
!else
$() ne sont pas 
!endif
$() colinéaires et les droites 
!insmath ($val26 $val27)
$() et 
!insmath ($val28 $val29)
$()  
!if $val23=0 
$()sont 
!else
$() ne sont pas 
!endif
$() parallčles.
$()
