!set title=Droites parallèles ? (direct) 
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
keywords=parallel,vectors,line
oefdescription=Déterminer si des droites sont parallèles en utilisant les vecteurs
computeanswer=no

ansorder=r
varcnt=27
prevarcnt=26
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 7

val6=$[rint($(tmp0))]
tmp0=!randint -7, 7

val7=$[rint($(tmp0))]
tmp0=!randint -10, 10

val8=$[rint($(tmp0))]
tmp0=!randint -10, 10

val9=$[rint($(tmp0))]
tmp0=!randint -5, 5

val10=$[rint($(tmp0))]
val11=$[rint($val7*$val10+$val8)]
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
val12=$[rint($(tmp0))]

!ifval ($val6=1)
val13=$[rint( $val10)]
!else
tmp0=!randint 1, 5

val13=$[rint($val10+$val12*$(tmp0))]
!endif

!ifval ($val6=1)
tmp0=!randint 1, 5

val14=$[rint( $val11+$val12*$(tmp0))]
!else
val14=$[rint($val7*$val13+$val8)]
!endif
tmp0=!randint 1, 5

val15=$[rint($val10-$val12*$(tmp0))]
val16=$[rint($val7*$val15+$val9)]

!ifval ($val6=1)
val17=$[rint( $val15)]
!else
tmp0=!randint 1, 5

val17=$[rint($val15-$val12*$(tmp0))]
!endif

!ifval ($val6=1)
tmp0=!randitem -1,1

tmp1=!randint 1, 5

val18=$[rint( $val16+$(tmp0)*$(tmp1))]
!else
tmp2=!randint 1, 3

tmp3=!randitem -1,1

tmp=!nonempty items 0,$(tmp2)*$(tmp3)

tmp4=!randitem $tmp
val18=$[rint(($val7*$val17+$val9)+$(tmp4))]
!endif
val19=$[rint($val13-$val10)]
val20=$[rint($val14-$val11)]
val21=$[rint($val17-$val15)]
val22=$[rint($val18-$val16)]
val23=$[rint(($val19*$val22)-($val21*$val20))]

!ifval ($val23=0)
val24=$[rint( 1)]
!else
val24=$[rint(2)]
!endif
val25=A,B,C,D,E,F,H,K,L,N
tmp0=!shuffle $val25

val25=$(tmp0)
tmp0=!sort item $(val25[1..4])

val25=$(tmp0)
val26=$(val25[1])
val27=$(val25[2])
val28=$(val25[3])
val29=$(val25[4])
replytype1=radio
replyname1=Droites parallèles?
replygood1=$val24;Oui,Non,Je ne sais pas
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<p>Dans le plan muni d'un repère, on donne 
!insmath $val26($val10 ; $val11) 
$(), 
!insmath $val27($val13 ; $val14) 
$()	, 
!insmath $val28($val15 ; $val16) 
$() et 
!insmath $val29($val17 ; $val18) 
$().</p>	<div class="wims_question">Les droites 
!insmath ($val26 $val27)
$() et 
!insmath ($val28 $val29)
$() sont-elles parallèles ? </div>	 
!read oef/embed.phtml reply 1 
$()
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()Le vecteur 
!insmath \overrightarrow{$val26 $val27}
$() a pour coordonnées  
!insmath [$val13-($val10);$val14-($val11)]=[$val19;$val20]
$() et le vecteur	
!insmath \overrightarrow{$val28 $val29}
$() a pour coordonnées  
!insmath [$val21;$val22]
$() .	<br>	Le déterminant de 
!insmath \overrightarrow{$val26 $val27}
$() et 
!insmath \overrightarrow{$val28 $val29}
$() est 
!insmath $val19\times($val22)-($val21)\times($val20)=$val23
$()
!if $val23!=0 
$()
!insmath \neq 0
$() 
!endif
$()<br>	<br/>Le déterminant est 
!if $val23=0 
$()nul 
!else
$() non nul 
!endif
$().	<br/>Donc ces vecteurs <b>
!if $val23=0 
$()sont 
!else
$() ne sont pas 
!endif
$() colinéaires</b>	et les droites 
!insmath ($val26 $val27)
$() et 
!insmath ($val28 $val29)
$()  <b>
!if $val23=0 
$()sont 
!else
$() ne sont pas 
!endif
$() parallèles</b>. 
!if $val6=1 
$()On peut remarquer également que les droites 
!insmath ($val26 $val27)
$() et 
!insmath ($val28 $val29)
$() sont verticales (car 
!insmath x_{$val26}=x_{$val27}
$() et	
!insmath x_{$val28}=x_{$val29}
$()) donc elles sont parallèles. 
!endif
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

