!set title=Norme de vecteur 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
computeanswer=yes

ansorder=r
varcnt=6
prevarcnt=5
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 20

tmp1=!randitem -1,1

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -20, 20

val7=$[rint($(tmp0))]
val8=$[($val6)*($val6)+($val7)*($val7)]
val9=$[sqrt(($val6)*($val6)+($val7)*($val7))]
!readproc slib/utilities/mathcalc 
tmp0=$slib_out
val10=$(tmp0)
replytype1=numeric
replyoption1=noanalyzeprint 
replyname1=\(\|| \overrightarrow{u}\||)
replygood1=$[$val9]
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Calculer la norme du vecteur 
!insmath \overrightarrow{u} \left ( \begin{array}{c}	$val6\\	$val7	\end{array}\right )
$().	<div class="wims_instruction">Pour avoir &radic;(...), taper sqrt(...).	Calculatrice disponible en cliquant sur l'image: $val10.</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()La norme de 
!insmath \overrightarrow{u}
$() est 
!insmath \sqrt{($val6)^2+($val7)^2}=\sqrt{$val8}
$().
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,10
embedcnt=0
