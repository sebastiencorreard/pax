replytype7=menu
replyname7=
replygood7=$val21;sont,ne sont pas
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<b>Cet exercice comporte plusieurs étapes.</b>	<p>Dans le plan muni d'un repčre, on donne 
!insmath $val23($val9 ; $val10)
$(), 
!insmath $val24($val12 ; $val13)
$() et 
!insmath $val25($val14 ; $val15)
$().</p>	Les points 
!insmath $val23
$(), 
!insmath $val24
$() et 
!insmath $val25
$() sont-ils alignés ?<br />	Il suffit de vérifier si les vecteurs 
!insmath \overrightarrow{$val23 $val24}
$() et 
!insmath \overrightarrow{$val23 $val25}
$() sont colinéaires.<br />	
!if $m_step=1 
$()
!insmath \overrightarrow{$val23 $val24}
$() a pour coordonnées:	 
!read oef/special.phtml mathmlinput [\left ( \begin{array}{c}reply1\\reply2\end{array} \right )],2##	reply1, 12	reply2, 12 
$()	 
!endif
$()	
!if $m_step=2 
$()
!if $m_sc_reply1=1 and $m_sc_reply2=1 
$()<span class = "oef_indgood">Correct :</span> 
!else
$()	 <span class = "oef_indbad">Erreur : vous avez répondu que les coordonnées de 
!insmath \overrightarrow{$val23 $val24}
$() sont ($m_reply1 ; $m_reply2).<br />			</span>  
!endif
$()	<span class = "oef_indgood"> Les coordonnées exactes de 
!insmath \overrightarrow{$val23 $val24}
$()	sont : 
!insmath [$val16 ; $val17]
$() </span>		<div>	
!insmath \overrightarrow{$val23 $val25}
$() a pour coordonnées:	 
!read oef/special.phtml mathmlinput [\left ( \begin{array}{c}reply3\\reply4\end{array} \right )],2	reply3, 12	reply4, 12 
$()	</div>	 
!endif
$()	
!if $m_step=3 
$()Les coordonnées exactes de 
!insmath \overrightarrow{$val23 $val24}
$()	  sont : 
!insmath [$val16 ; $val17]
$() .<br />		
!if $m_sc_reply3=1 and $m_sc_reply4=1 
$()<span class = "oef_indgood">Correct :</span> 
!else
$()	 <span class = "oef_indbad">Erreur : vous avez répondu que les coordonnées de 
!insmath \overrightarrow{$val23 $val25}
$() sont ($m_reply3 ; $m_reply4).<br />	  
!endif
$()</span>	<span class = "oef_indgood"> Les coordonnées exactes de 
!insmath \overrightarrow{$val23 $val25}
$()	  sont : 
!insmath [$val18 ; $val19]
$() </span>		<p>	
!insmath \overrightarrow{$val23$val24}
$() a pour coordonnées 
!insmath \left ( \begin{array}{c}$val16\\$val17\end{array} \right )
$() et	 
!insmath \overrightarrow{$val23$val25}
$() a pour coordonnées 
!insmath \left ( \begin{array}{c}$val18\\$val19\end{array} \right )
$().	 </p>	 Le déterminant de 
!insmath \overrightarrow{$val23$val24}
$() et 
!insmath \overrightarrow{$val23$val25}
$() est égal ŕ  
!read oef/embed.phtml r5,3 
$(),	 <br />	donc ces vecteurs  
!read oef/embed.phtml r6,4 
$() colinéaires et les points 
!insmath $val23
$(), 
!insmath $val24
$() et 
!insmath $val25
$()  
!read oef/embed.phtml r7,4 
$() alignés. 
!endif
$()	
$()
!exit

