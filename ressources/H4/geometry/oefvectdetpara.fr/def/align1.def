!set title=Points alignés ? (par étapes)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
keywords=parallel,vectors,line
oefdescription=Déterminer si des points sont alignés en utilisant les vecteurs
computeanswer=no

ansorder=r,r,r,r,r,r,r
varcnt=24
prevarcnt=23
postvarcnt=0
replycnt=7
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 7

val6=$[rint($(tmp0))]
tmp0=!randint -7, 7

val7=$[rint($(tmp0))]
tmp0=!randint -12, 12

val8=$[rint($(tmp0))]
tmp0=!randint -5, 5

val9=$[rint($(tmp0))]
val10=$[rint($val7*$val9+$val8)]
tmp0=!randitem -1,1

val11=$[rint($(tmp0))]

!ifval ($val6=1)
val12=$[rint( $val9)]
!else
tmp0=!randint 1, 5

val12=$[rint($val9+$val11*$(tmp0))]
!endif

!ifval ($val6=1)
tmp0=!randint 1, 5

val13=$[rint( $val10+$val11*$(tmp0))]
!else
val13=$[rint($val7*$val12+$val8)]
!endif

!ifval ($val6=1)
val14=$[rint( $val9)]
!else
tmp0=!randint 1, 5

val14=$[rint($val9-$val11*$(tmp0))]
!endif

!ifval ($val6=1)
tmp0=!randint 1, 5

val15=$[rint( $val10-$val11*$(tmp0))]
!else
tmp1=!randint 1, 3

tmp2=!randitem -1,1

tmp=!nonempty items 0,$(tmp1)*$(tmp2)

tmp3=!randitem $tmp
val15=$[rint(($val7*$val14+$val8)+$(tmp3))]
!endif
val16=$[rint($val12-$val9)]
val17=$[rint($val13-$val10)]
val18=$[rint($val14-$val9)]
val19=$[rint($val15-$val10)]
val20=$[rint(($val16*$val19)-($val18*$val17))]

!ifval ($val20=0)
val21=$[rint( 1)]
!else
val21=$[rint(2)]
!endif
val22=A,B,C,D,E,F,H,K
tmp0=!shuffle $val22

val22=$(tmp0)
tmp0=!sort item $(val22[1..3])

val22=$(tmp0)
val23=$(val22[1])
val24=$(val22[2])
val25=$(val22[3])
val26=r1,r2	r3,r4	r5,r6,r7
oefsteps=$val26 
nextstep=!nosubst $val26 
!readproc oef/steps.proc
replytype1=formal
replyoption1=nonstop 
replyweight1=12 
replyname1=
replygood1=$val16
