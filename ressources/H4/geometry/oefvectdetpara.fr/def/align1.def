:solution
$()
!insmath \overrightarrow{$val23 $val24}
$() a pour coordonnées	
!insmath \left ( \begin{array}{c}$val12-($val9)\\$val13-($val10)\end{array} \right )=\left ( \begin{array}{c}$val16\\$val17\end{array} \right )
$() et le vecteur	
!insmath \overrightarrow{$val23 $val25}
$() a pour coordonnées	
!insmath \left ( \begin{array}{c}$val18\\$val19\end{array} \right )
$() .	Le déterminant de 
!insmath \overrightarrow{$val23 $val24}
$() et 
!insmath \overrightarrow{$val23 $val25}
$() est 
!insmath $val16 \times ($val19)-($val18)\times ($val17)=$val20
$() 
!if $val20!=0 
$()
!insmath &ne;0
$() 
!endif
$()	donc ces vecteurs 
!if $val20=0 
$()sont 
!else
$() ne sont pas 
!endif
$() colinéaires et les points 
!insmath $val23
$(), 
!insmath $val24
$() et 
!insmath $val25
$() 
!if $val20=0 
$()sont 
!else
$() ne sont pas 
!endif
$() alignés.
$()
!exit

