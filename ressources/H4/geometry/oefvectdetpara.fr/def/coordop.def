!set title=Calcul des coordonnées de vecteurs avec opérations
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
computeanswer=no

ansorder=r,r
varcnt=24
prevarcnt=23
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=A,B,C,E,F,M,P
val7=B,C,D,F,G,N,R
val8=C,D,E,G,H,P,N
tmp0=!randint 1, 7

val9=$[rint($(tmp0))]
tmp0=!randint -10, 10

val10=$[rint($(tmp0))]
tmp0=!randint 1, 8

tmp=!nonempty items -1,1

tmp1=!randitem $tmp
val11=$[rint($val10+$(tmp0)*$(tmp1))]
tmp0=!randint -10, 10

val12=$[rint($(tmp0))]
tmp0=!randint -10, 10

val13=$[rint($(tmp0))]
tmp0=!randint -10, 10

val14=$[rint($(tmp0))]
tmp0=!randint 1, 8

tmp=!nonempty items -1,1

tmp1=!randitem $tmp
val15=$[rint($val13+$(tmp0)*$(tmp1))]
tmp=!nonempty items 1,1,1,2,3

tmp0=!randitem $tmp
val16=$[rint($(tmp0))]
tmp0=!randint 2, 5

tmp=!nonempty items -1,1

tmp1=!randitem $tmp
val17=$[rint($(tmp0)*$(tmp1))]
val18=$[rint($val16*($val11-$val10)+$val17*($val12-$val10))]
val19=$[rint($val16*($val14-$val13)+$val17*($val15-$val13))]
val20=$[rint(($val11-$val10))]
val21=$[rint(($val14-$val13))]
val22=$[rint($val16*($val11-$val10))]
val23=$[rint($val16*($val14-$val13))]
val24=$[rint(($val12-$val10))]
val25=$[rint(($val15-$val13))]
val26=$[rint(abs($val17))]
val27=$[rint($val26*($val12-$val10))]
val28=$[rint($val26*($val15-$val13))]
replytype1=formal
replyname1=
replygood1=$val18
replytype2=formal
replyname2=
replygood2=$val19
question=__EXECUTED_1692754_EXERCISE__
help=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="wims_question">	Calculer les coordonnées du vecteur	
!if $val16>1 
$()
!insmath $val16
$() 
!endif
$()
!insmath \overrightarrow{$(val6[$val9]) $(val7[$val9])}
$()
!if $val17>0 
$()
!insmath {}+$val17 
$() 
!else
$() 
!insmath $val17
$() 
!endif
$()
!insmath  \overrightarrow{$(val6[$val9]) $(val8[$val9])}
$() avec 
!insmath $(val6[$val9])($val10; $val13) 
$(), 
!insmath $(val7[$val9])($val11; $val14) 
$() et 
!insmath $(val8[$val9])($val12; $val15) 
$().	</div>	
!if $val16>1 
$()
!insmath $val16
$() 
!endif
$()
!insmath \overrightarrow{$(val6[$val9]) $(val7[$val9])}
$()
!if $val17>0 
$()
!insmath {}+$val17 
$() 
!else
$() 
!insmath $val17
$() 
!endif
$()
!insmath \overrightarrow{$(val6[$val9]) $(val8[$val9])}
$()	a pour coordonnées  
!read oef/special.phtml mathmlinput [\left ( \begin{array}{c}	reply1\\	reply2	\end{array} \right )],2	reply1,10	reply2,10	 
$()	
$()
!exit

:hint
$()
$()
!exit

:help
$()Les coordonnées d'un vecteur 
!insmath \overrightarrow{A B}
$() sont 
!insmath \left ( \begin{array}{c}x_B-x_A\\ y_B-y_A \end{array}\right )
$().<br/> Les opérations (somme, produit par un réel) sur les vecteurs s'appliquent aussi ŕ leurs coordonnées.
$()
!exit

:solution
$()Les coordonnées du vecteur 
!insmath \overrightarrow{$(val6[$val9]) $(val7[$val9])}
$() sont 
!insmath \left ( \begin{array}{c}	$val11-($val10)\\	$val14-($val13)	\end{array} \right )=\left ( \begin{array}{c}	$val20\\	$val21	\end{array} \right )
$()	
!if $val16>1 
$()donc les coordonnées de 
!insmath $val16 \overrightarrow{$(val6[$val9]) $(val7[$val9])}
$() sont	
!insmath \left ( \begin{array}{c}	$val22\\	$val23	\end{array} \right )
$() 
!endif
$().<br />	Les coordonnées du vecteur 
!insmath \overrightarrow{$(val6[$val9]) $(val8[$val9])}
$() sont	
!insmath \left ( \begin{array}{c}	$val24\\	$val25	\end{array} \right )
$()	 donc les coordonnées de 
!insmath $val26 \overrightarrow{$(val6[$val9]) $(val8[$val9])}
$() sont	 
!insmath \left ( \begin{array}{c}	$val27\\	$val28	\end{array} \right )
$().<br />	D'oů, les coordonnées de 
!if $val16>1 
$()
!insmath $val16
$() 
!endif
$()
!insmath \overrightarrow{$(val6[$val9]) $(val7[$val9])}
$()
!if $val17>0 
$()
!insmath {}+{}
$() 
!endif
$()	
!insmath $val17 \overrightarrow{$(val6[$val9]) $(val8[$val9])}
$() sont	
!insmath \left ( \begin{array}{c}	$val18\\	$val19	\end{array} \right )
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

