val10=!rawmath $(tmp0)
t_=!rawmath $val8/$val9
val11=!exec pari print($t_)
t_=!rawmath $val7-$val6*$val8/$val9
val12=!exec pari print($t_)
t_=!replace internal \( by ( in y=($val11)*x+$val12
tmp0=!exec maxima $t_

val13=!rawmath $(tmp0)
