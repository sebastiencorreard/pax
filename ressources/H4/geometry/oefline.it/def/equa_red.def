!set title=Equazioni esplicite e implicita
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22

ansorder=r
varcnt=17
prevarcnt=16
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=a
val7=a
!for val8 =1 to 3 
tmp0=!randitem -1,1

tmp1=!randint 1, 10

val9=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 1, 10

val10=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 1, 10

val11=$[rint($(tmp0)*$(tmp1))]
t_=!replace internal \( by ( in $val9*x+$val10*y+$val11
tmp0=!exec maxima $t_

val12=!rawmath $(tmp0)
t_=!replace internal \( by ( in -$val9*x/$val10-$val11/$val10
tmp0=!exec maxima $t_

val13=!rawmath $(tmp0)
val6=$val6,	\($val12 &#61; 0)	
val7=$val7,	\(y &#61; $val13)	
t_=!replace internal \( by ( in -$val9*x+$val10*y+$val11
tmp0=!exec maxima $t_

val12=!rawmath $(tmp0)
t_=!replace internal \( by ( in $val9*x/$val10-$val11/$val10
tmp0=!exec maxima $t_

val13=!rawmath $(tmp0)
val6=$val6,	\($val12 &#61; 0)	
val7=$val7,	\(y &#61; $val13)	
!next
tmp0=!item 2 to 7 of $val6

val6=$(tmp0)
tmp0=!item 2 to 7 of $val7

val7=$(tmp0)
replytype1=correspond
replyoption1=shuffle 
replyname1=
replygood1=$val6;$val7
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Associare le equazioni che corrispondono alla stessa retta:	 
!read oef/embed.phtml reply 1 
$()<br/>		
$()
!exit

