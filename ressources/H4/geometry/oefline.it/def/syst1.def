!set title=Sistema 2x2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=it
leftrange=-5.000000
rightrange=5.000000
author=FrÈdÈric, PITOUN
email=lva.pitoun@free.fr
computeanswer=yes
precision=10000

ansorder=r,r
varcnt=20
prevarcnt=19
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 3

val6=$[rint($(tmp0))]
tmp0=!randint 1, 3

val7=$[rint($(tmp0))]
tmp0=!randint 1, 5

val8=$[rint($(tmp0))]
tmp0=!randint 1, 5

val9=$[rint($(tmp0))]
tmp0=!randint 1, 2

val10=$[rint($(tmp0))]
tmp0=!randint 1, 2

val11=$[rint($(tmp0))]
val12=$[rint($val6)]
val13=$[rint($val6*$val8*(-1)^($val10))]
val14=$[rint($val6*$val9*(-1)^($val11))]
val15=$[rint($val7+$val6*$val8*$val9*(-1)^($val10+$val11))]
val16=$[rint($val12*$val15-$val13*$val14)]
t_=!replace internal \( by ( in $val12*x+$val13*y
tmp0=!exec pari $t_

val17=!rawmath $(tmp0)
t_=!replace internal \( by ( in $val14*x+$val15*y
tmp0=!exec pari $t_

val18=!rawmath $(tmp0)
tmp0=!texmath $val17

val19=$(tmp0)
tmp0=!texmath $val18

val20=$(tmp0)
tmp0=!randint -10, 10

val21=$[rint($(tmp0))]
tmp0=!randint -10, 10

val22=$[rint($(tmp0))]
t_=!rawmath (($val21)*($val15)-($val22)*($val13))/($val16)
val23=!exec pari print($t_)
t_=!rawmath ($val12*($val22)-($val21)*($val14))/($val16)
val24=!exec pari print($t_)
replytype1=default
replyname1=Valore di \(x)
replygood1=$val23
replytype2=default
replyname2=Valore di \(y)
replygood2=$val24
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Risolvere il sistema seguente: 
!insmath \left\lbrace \begin{array}{ccc} $val19 & = & $val21 \\ $val20 & = & $val22 \end{array} \right.
$()
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()Le soluzioni sono 
!insmath x = $val23
$() e 
!insmath y = $val24
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
