!set title=Parallela ad una retta
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=it
leftrange=-5.000000
rightrange=5.000000
author=Frédéric, PITOUN
email=lva.pitoun@free.fr
computeanswer=yes
precision=10000

ansorder=r,r
varcnt=17
prevarcnt=16
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem -1,1

tmp1=!randint 1, 10

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -10, 10

val7=$[rint($(tmp0))]
tmp0=!randint -10, 10

val8=$[rint($(tmp0))]
tmp0=!randint 1, 6

val9=$[rint($(tmp0))]
tmp0=!randint 1, 2

val10=$[rint($(tmp0))]
val11=$[rint($val6*$val8+$val9*(-1)^$val10)]
t_=!rawmath $val11-$val6*$val8
val12=!exec pari print($t_)
tmp=!translate ";': to $     $ in $val6*x+$val7

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!replace internal \( by ( in expand($(tmp0))
tmp1=!exec maxima $t_

val13=!rawmath $(tmp1)
tmp=!translate ";': to $     $ in $val6*x+$val12

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!replace internal \( by ( in expand($(tmp0))
tmp1=!exec maxima $t_

val14=!rawmath $(tmp1)
tmp0=!texmath $val13

val15=$(tmp0)
tmp0=!texmath $val14

val16=$(tmp0)
tmp0=!randitem ascisse,ordinate

val17=$(tmp0)
!if $val17=ascisse 
t_=!rawmath -$val12/$val6
val18=!exec pari print($t_)
t_=!rawmath 0
val19=!exec pari print($t_)
!endif
!if $val17=ordinate 
t_=!rawmath 0
val18=!exec pari print($t_)
t_=!rawmath $val12
val19=!exec pari print($t_)
!endif
replytype1=default
replyname1=Coefficiente angolare
replygood1=$val18
replytype2=default
replyname2=Ordinata nell'origine
replygood2=$val19
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

