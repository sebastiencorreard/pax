!set title=Equazione esplicita
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=it
leftrange=-5.000000
rightrange=5.000000
author=Frťdťric, PITOUN
email=lva.pitoun@free.fr
computeanswer=yes
precision=10000

ansorder=r,r
varcnt=12
prevarcnt=11
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint -15, 15

val6=$[rint($(tmp0))]
tmp0=!randint 1, 10

val7=$[rint($(tmp0))]
tmp0=!randint 1, 2

val8=$[rint($(tmp0))]
val9=$[rint($val7*(-1)^$val8)]
tmp0=!randint -10, 10

val10=$[rint($(tmp0))]
tmp=!translate ";': to $     $ in $val6*x + $val9*y + $val10

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!replace internal \( by ( in expand($(tmp0))
tmp1=!exec maxima $t_

val11=!rawmath $(tmp1)
tmp0=!texmath $val11

val12=$(tmp0)
tmp=!translate ";': to $     $ in (-1)*$val6/$val9

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val13=!rawmath $(tmp0)
tmp=!translate ";': to $     $ in (-1)*$val10/$val9

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val14=!rawmath $(tmp0)
tmp=!translate ";': to $     $ in $val13*x+$val14

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!replace internal \( by ( in expand($(tmp0))
tmp1=!exec maxima $t_

val15=!rawmath $(tmp1)
tmp0=!texmath $val15

val16=$(tmp0)
replytype1=default
replyname1=Coefficiente angolare
replygood1=$val13
replytype2=default
replyname2=Ordinata nell'origine
replygood2=$val14
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

