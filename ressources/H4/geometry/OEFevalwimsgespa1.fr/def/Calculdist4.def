val11=Calculer le volume du solide \(A B C D S T U V\).
val12=Volume
val13=\(\frac{1}{8}V),\(\frac{1}{2}V),\(\frac{1}{4}V),\(\frac{1}{16}V)
val14=\(\frac{1}{3}x y z),\(\frac{1}{6}x y z),\(\frac{1}{2}x y z),\(\frac{z}{3}\sqrt{x^2+y^2})
val15=\(\frac{7}{24}x y z),\(\frac{z}{12}\sqrt{x^2+y^2}),\(\frac{1}{6}x y z),\(\frac{1}{4}x y z)
