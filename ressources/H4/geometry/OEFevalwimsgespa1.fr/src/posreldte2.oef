SetColor[aa,red]
ShowLabel[aa, false]
bb=Segment(\pt3,\pt4)
SetColor[bb,blue]
ShowLabel[bb, false]}
  \text{listlab=a,b,c,d,e,f,g,h,i,j,k,l}
