!set title=Equations de droites - vocabulaire
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Nicolas, Segarra
email=Nicolas.Segarra@ac-versailles.fr
keywords=line_equation
language=fr
computeanswer=no
leftrange=-5.000000
rightrange=5.000000
precision=10000
title_it=Equazione della retta - vocabolario

ansorder=r,r
varcnt=19
prevarcnt=18
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=\mathcal{d}
tmp0=!randint -10, 10

val8=$[rint($(tmp0))]
tmp0=!randint -10, 10

val9=$[rint($(tmp0))]
tmp=!translate ";': to $     $ in $val8*x +$val9

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val10=$(tmp0)
tmp0=!texmath $val10

val10=$(tmp0)
val11=Le plan est rapporté à un repère orthonormal
val12=Soit \(($val7) \) la droite d'équation&nbsp;
val13=Déterminer le coefficient directeur de la droite \( ($val7)\) et son ordonnée à l'origine
val14=Coefficient directeur de
val15=Ordonnée à l'origine  de
val16=Attention, vous confondez le coefficient directeur et l'ordonnée à l'origine&nbsp;
!if $val6=it 
val11=Il piano è descritto da un sistema di riferimento cartesiano ortonormale
val12=Sia \(($val7) \) la retta di equazione
val13=Determinare il coefficiente angolare della retta \( ($val7)\) e la sua ordinata nell'origine
val14=Coefficiente angolare di
val15=Ordinata nell'origine di
val16=Attenzione: avete confuso il coefficiente angolare con l'ordinata nell'origine
!endif
replytype1=default
replyname1=$val14 \(($val7) \)
replygood1=$val8
replytype2=default
replyname2=$val15 \(($val7) \)
replygood2=$val9
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$() $val11 
!insmath  (O;I;J) 
$().	$val12: 
!insmath  y=$val10 
$().	<p>	$val13.	</p>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback
!ifval $m_reply1=$val9 and $m_reply2=$val8
 <div class='oef_feedbacks'>	<span class="oef_indbad">$val16!</span>
$()</div>
!endif

!exit

:test

!exit

:stat
vsavelist=8,9,10,11,12,13,16
embedcnt=0
