!set title=Trouver l'ordonnée d'un point
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Nicolas, Segarra
email=Nicolas.Segarra@ac-versailles.fr
language=fr
computeanswer=no
leftrange=-5.000000
rightrange=5.000000
precision=10000
title_it=Trovare l'ordinata di un punto

ansorder=r
varcnt=18
prevarcnt=17
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=\mathcal{d}
tmp0=!randint -10, 10

val8=$[rint($(tmp0))]
tmp0=!randint -10, 10

val9=$[rint($(tmp0))]
tmp0=!randint -10, 10

val10=$[rint($(tmp0))]
t_=!replace internal \( by ( in expand($val8*x+$val9)
tmp0=!exec maxima $t_

val11=$(tmp0)
tmp0=!texmath $val11

val11=$(tmp0)
val12=et
val13=est
val14=Le plan est rapporté à un repère orthonormal,Soient,la droite d'équation,le point d'abscisse
val15=Déterminer l'ordonnée \( y_A \) du point \( A \) dans le repère.
val16=L'ordonnée de
!if $val6=it 
val12=e
val13=è
val14=Il piano è descritto da un sistema di riferimento cartesiano ortonormale,Sia,la retta di equazione,il punto di ascissa
val15=Determinare l'ordinata \( y_A \) del punto \( A \) nel sistema di riferimento.
val16=L'ordinata di
!endif
replytype1=numeric
replyname1=$val16 \( A \) $val13 \( y_A \)
replygood1=$[$val8*$val10+$val9]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()$(val14[1]).	$(val14[2]) 
!insmath  ($val7) 
$() $(val14[3]) 
!insmath  y=$val11 
$()	$val12 
!insmath  A 
$() $(val14[4]) 
!insmath  $val10 
$().	<div class="wimscenter">	$val15	</div>
$()
!exit

