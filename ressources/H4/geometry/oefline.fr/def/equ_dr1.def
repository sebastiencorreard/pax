!set title=Equation de droites et vecteur directeur
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Frédéric, Pitoun
email=frederic.pitoun@free.fr
keywords=line_equation
language=fr
computeanswer=yes
leftrange=-5.000000
rightrange=5.000000
precision=10000
title_it=Equazione di rette e vettori direttori

ansorder=r,r,r,r,r
varcnt=29
prevarcnt=28
postvarcnt=0
replycnt=5
choicecnt=0
conditioncnt=2
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=\mathcal{d}
tmp0=!randint -10, 10

val8=$[rint($(tmp0))]
tmp0=!randint -10, 10

val9=$[rint($(tmp0))]
tmp0=!randint -10, 10

val10=$[rint($(tmp0))]
tmp0=!randitem -1,1

tmp1=!randint 1, 5

val11=$[rint($(tmp0)*$(tmp1))]
t_=!replace internal \( by ( in expand((x-$val8)*$val10-(y-$val9)*$val11 = 0)
tmp0=!exec maxima $t_

val12=!rawmath $(tmp0)
t_=!rawmath $val10/$val11
val13=!exec pari print($t_)
t_=!rawmath $val9-$val8*$val10/$val11
val14=!exec pari print($t_)
t_=!replace internal \( by ( in y=($val13)*x+$val14
tmp0=!exec maxima $t_

val15=!rawmath $(tmp0)
val16=et
val17=est
tmp=!trim Dans le plan muni d'un repčre, on considčre la droite ; passant par le point ; de coordonnées ; et dirigée par le vecteur ; de coordonnées ; Déterminer une équation de la droite ; Une équation de ; son équation réduite est&nbsp;
val18=!translate internal $	\
$ to ;; in $tmp
val19=Le petit
val20=Le coefficient directeur de
val21=L'ordonnée ŕ l'origine de
val22=est un vecteur directeur de cette droite
val23=Le point,est situé sur cette droite
val24=Une équation de la droite,son équation réduite est
!if $val6=it 
val16=e
val17=č
tmp=!trim Nel piano descritto da un sistema di riferimento cartesiano, consideriamo la retta ; passante per il punto ; di coordinate ; e diretta secondo il vettore ; di coordinate ; Determinare una equazione della retta ; Una possibile equazione della retta ; la sua equazione in forma esplicita č
val18=!translate internal $	\
$ to ;; in $tmp
val19=Coefficiente
val20=Il coefficiente angolare della retta 
val21=L'ordinata nell'origine della retta 
val22=č un vettore direttore corretto di questa retta
val23=Il punto,si trova su questa retta
val24=Una possibile equazione della retta č,la sua equazione in forma esplicita č
!endif
oefsteps=reply1,reply2,reply3	reply4,reply5 
nextstep=!nosubst reply1,reply2,reply3	reply4,reply5 
!readproc oef/steps.proc
replytype1=rational

replyname1=$val19 \(a\)
replygood1=?analyze 25
replytype2=rational

replyname2=$val19 \(b\)
replygood2=?analyze 26
replytype3=rational

replyname3=$val19 \(c\)
replygood3=?analyze 27
