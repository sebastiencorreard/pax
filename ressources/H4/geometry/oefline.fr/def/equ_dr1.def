$() $(val18[4;])	    
!insmath \overrightarrow{u}
$() $(val18[5;]) 
!insmath ($val11,$val10)
$().	
!if $m_step=1 
$()<p>	 $(val18[6;]) 
!insmath $val7
$() :	</p>	<div class="wimscenter">	 
!read oef/embed.phtml reply 1,6 
$() x +  
!read oef/embed.phtml reply 2,6 
$() y +  
!read oef/embed.phtml reply 3,6 
$()=0	</div> 
!endif
$()	
!if $m_step=2 
$()	<p>	  $(val18[7;]) 
!insmath $val7
$() $val17 
!insmath $val12
$(), $(val18[8;]):	</p>	<div class="wimscenter">	
!insmath y = 
$() 
