!set title=Equations rÈduites et correspondances
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
keywords=line_equation
language=fr
title_it=Equazioni esplicite e implicita

ansorder=r
varcnt=21
prevarcnt=20
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=\mathcal{d}
val8=a
val9=a
!for val10 =1 to 3 
tmp0=!randitem -1,1

tmp1=!randint 1, 10

val11=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 1, 10

val12=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 1, 10

val13=$[rint($(tmp0)*$(tmp1))]
t_=!replace internal \( by ( in $val11*x+$val12*y+$val13
tmp0=!exec maxima $t_

val14=!rawmath $(tmp0)
t_=!replace internal \( by ( in -$val11*x/$val12-$val13/$val12
tmp0=!exec maxima $t_

val15=!rawmath $(tmp0)
val8=$val8,	\($val14= 0\)	
val9=$val9,	\(y = $val15\)	
t_=!replace internal \( by ( in -$val11*x+$val12*y+$val13
tmp0=!exec maxima $t_

val14=!rawmath $(tmp0)
t_=!replace internal \( by ( in $val11*x/$val12-$val13/$val12
tmp0=!exec maxima $t_

val15=!rawmath $(tmp0)
val8=$val8,	\($val14 = 0\)	
val9=$val9,	\(y = $val15\)	
!next
tmp0=!item 2 to 7 of $val8

val8=$(tmp0)
tmp0=!item 2 to 7 of $val9

val9=$(tmp0)
val16=Mettez en relation les Èquations de droites se correspondant
!if $val6=it 
val16=Associare le equazioni che corrispondono alla stessa retta
!endif
replytype1=correspond
replyoption1=shuffle 
replyname1=
replygood1=$val8;$val9
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val16:	<div class="wimscenter"> 
!read oef/embed.phtml reply 1, 100 x 200 x 200 
$()</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=16
embedcnt=1
