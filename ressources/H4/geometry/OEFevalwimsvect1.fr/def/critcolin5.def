!set title=Critčre de colinéarité V
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=28
prevarcnt=27
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=$[rint(8)]
val7=$[rint($val6*2)]
tmp0=!randint -$val6, $val6

val8=$[rint($(tmp0))]
tmp0=!randint -$val6, $val6

val9=$[rint($(tmp0))]
!if $val8=0 and $val9=0 
tmp0=!randint 1, $val7

tmp1=!randitem 1,-1

val8=$[rint($(tmp0)*$(tmp1))]
!endif
tmp0=!randitem 1,1,1,1,2,3,4,5

val10=$[rint($(tmp0))]
tmp0=!randitem $val10,1

t_=!rawmath $val8 / $(tmp0)
val8=!exec pari print($t_)
tmp0=!randitem $val10,1

t_=!rawmath $val9 / $(tmp0)
val9=!exec pari print($t_)
tmp0=!randint 2, 6

tmp1=!randitem -1,1

val11=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 2, 6

tmp1=!randitem -1,1

val12=$[rint($(tmp0)*$(tmp1))]

!ifval $val11=$val12
val12=$[rint(-$val12)]
!endif
t_=!rawmath $val11*$val8
val13=!exec pari print($t_)
t_=!rawmath $val11*$val9
val14=!exec pari print($t_)
t_=!rawmath $val12*$val8
val15=!exec pari print($t_)
t_=!rawmath $val12*$val9
val16=!exec pari print($t_)
tmp0=!texmath $val13

tmp1=!texmath $val15

tmp2=!texmath $val14

tmp3=!texmath $val16

val17=$(tmp0),$(tmp1),$(tmp2),$(tmp3)
val18=$val13,$val15,$val14,$val16
tmp0=!randint 1, 4

val19=$[rint($(tmp0))]
t_=!rawmath $(val18[$val19])
val20=!exec pari print($t_)
tmp0=!texmath $val11*t+$val12

val21=$(tmp0)
t_=!rawmath ($val20-($val12))/($val11)
val20=!exec pari print($t_)
tmp0=!replace item number $val19 by $val21 in $val17

val17=$(tmp0)
val22=$(val17[1])
val23=$(val17[2])
val24=$(val17[3])
val25=$(val17[4])
val26=$[rint($val13*$val16-$val14*$val15)]
replytype1=numeric
replyname1=Votre réponse
replygood1=$[$val20]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Dans un repčre 
!insmath (O,\vec{i},\vec{j})
$() du plan, on considčre les vecteurs	
!insmath \vec{u}
$()
!insmath \left(\begin{array}{c} $val22 \\ $val24 \end{array}\right)
$() et	
!insmath \vec{v}
$()
!insmath \left(\begin{array}{c} $val23 \\ $val25 \end{array}\right)
$().	<p>	  Déterminer la valeur de 
!insmath t
$() telle que les vecteurs 
!insmath \vec{u}
$() et 
!insmath \vec{v}
$() soient colinéaires.	</p>	<div class="wimscenter"><label for="reply1">Valeur de 
!insmath t
$():</label>  
!read oef/embed.phtml reply1,7 
$()	</div>	<div class="wims_instruction">	  Donner 
!insmath t
$() sous forme fractionnaire ou décimale avec deux décimales.	</div>	
$()
!exit

