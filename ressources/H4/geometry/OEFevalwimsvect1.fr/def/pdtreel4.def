val11=$val10
val12=$[rint($val6)]
val13=$[rint($val8)]
val14=$[rint($val6 + $val9 -($val8))]
val15=$[rint($val9)]
val16=$[rint($val6+4)]
val17=$[rint($val8)]
val18=$[rint($val16+$val9-$val8)]
