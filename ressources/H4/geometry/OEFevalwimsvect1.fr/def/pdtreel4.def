tmp2=!randint 6, 8

val20=$(tmp0),$(tmp1),$(tmp2)
val21=
!for val22 =1 to 3 
val23=$[rint($(val20[$val22])+4)]
tmp0=!append item $val23 to $val21

val21=$(tmp0)
!next
val24=Les droites portant les points \(A\), \(B\), \(C\) et \(E\), \(F\), \(G\) sont parallčles.
val25=A,B,C
val26=E,F,G
tmp0=!shuffle 3

val27=$(tmp0)
tmp0=!shuffle 3

val28=$(tmp0)
val29=\overrightarrow{$(val25[$(val27[1])]) $(val25[$(val27[2])])}
val30=\overrightarrow{$(val26[$(val28[1])]) $(val26[$(val28[2])])}
val31=\( $val30 )
val32=\( $val29 )
t_=!rawmath ($(val21[$(val28[2])])-$(val21[$(val28[1])]))/($(val10[$(val27[2])])-$(val10[$(val27[1])]))
val33=!exec pari print($t_)
t_=!rawmath 1/($val33)
val34=!exec pari print($t_)
!if $val33>1 or $val33<-1 
val35=c'est \($val30) qui a la plus grande norme

!ifval $val33>0
val35=$val35 et \($val30) et \($val29) sont de męme sens
!else
val35=$val35 et \($val30) et \($val29) sont de sens opposés
!endif

!ifval $val33>0
val36= Le coefficent doit donc ętre supérieur ŕ 1
!else
val36= Le coefficent doit donc ętre inférieur ŕ -1
!endif
!else
val35=c'est \($val29) qui a la plus grande norme

!ifval $val33>0
val35=$val35 et \($val30) et \($val29) sont de męme sens
!else
val35=$val35 et \($val30) et \($val29) sont de sens opposés
!endif

!ifval $val33>0
val36= Le coefficent doit donc ętre positif et inférieur ŕ 1
!else
val36= Le coefficent doit donc ętre négatif et supérieur ŕ -1
!endif
!endif
val37=lightblue
val38=400
val39=400
val40=linewidth 1	parallel 0,$val8,0,$val9,0.2,0,floor(5*($val7))+1,$val37	parallel 0,$val8,0,$val9,-0.2,0,floor(5*abs($val6))+1,$val37	parallel $val6,0,$val7,0,0,0.2,floor(5*($val9))+1,$val37	parallel $val6,0,$val7,0,0,-0.2,floor(5*abs($val8))+1,$val37	
val41=linewidth 1	parallel 0,$val8,0,$val9,1,0,floor($val7+1),$val37	parallel 0,$val8,0,$val9,-1,0,floor(abs($val6)+1),$val37	parallel $val6,0,$val7,0,0,1,floor($val9+1),$val37	parallel $val6,0,$val7,0,0,-1,floor(abs($val8)+1),$val37	
val42=linewidth 2	segment $val12,$val13,$val14,$val15,red	linewidth 5	points red,$(val10[1]),$(val11[1]),$(val10[2]),$(val11[2]),$(val10[3]),$(val11[3])	text red,$(val10[$(val27[1])])-0.5,$(val11[$(val27[1])])+0.5,medium,$(val25[$(val27[1])])	text red,$(val10[$(val27[2])])-0.5,$(val11[$(val27[2])])+0.5,medium,$(val25[$(val27[2])])	text red,$(val10[$(val27[3])])-0.5,$(val11[$(val27[3])])+0.5,medium,$(val25[$(val27[3])])	
val43=linewidth 2	segment $val16,$val17,$val18,$val19,blue	linewidth 5	points blue,$(val21[1]),$(val20[1]),$(val21[2]),$(val20[2]),$(val21[3]),$(val20[3])	text blue,$(val21[$(val28[1])])-0.5,$(val20[$(val28[1])])+0.5,medium,$(val26[$(val28[1])])	text blue,$(val21[$(val28[2])])-0.5,$(val20[$(val28[2])])+0.5,medium,$(val26[$(val28[2])])	text blue,$(val21[$(val28[3])])-0.5,$(val20[$(val28[3])])+0.5,medium,$(val26[$(val28[3])])	
val44=xrange $val6-1,$val7+1	yrange $val8-1,$val9+1	$val41	$val42	$val43	
val45=$val44	
