val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=$[rint(4)]
val7=$[rint($val6*2)]
tmp0=!randint -$val6, $val6-2

val8=$[rint(2*$(tmp0)+1)]
tmp0=!randint -$val6, $val6

val9=$[rint(2*$(tmp0))]
tmp0=!randint -$val7, $val7

val10=$[rint($(tmp0))]
tmp0=!randint -$val6, $val6-2

val11=$[rint(2*$(tmp0)+1)]
tmp0=!randint 2, $val7

tmp1=!randitem -1,1

val12=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 2, $val7

tmp1=!randitem -1,1

val13=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -$val7, $val7

val14=$[rint($(tmp0))]
tmp0=!randint -$val7, $val7

val15=$[rint($(tmp0))]
tmp0=!randint -$val7, $val7

val16=$[rint($(tmp0))]
tmp0=!randint -$val7, $val7

val17=$[rint($(tmp0))]
!if $val14=$val16 and $val15=$val17 
val14=$[rint($val14+1)]
val15=$[rint($val15-2)]
!endif
t_=!rawmath 4
val18=!exec pari print($t_)
val19=xrange -10,10	  yrange -10,10	  parallel -10-$val18/2,-10,-10+$val18/2,10,1,0,21,gray	  parallel -10,-10,10,-10,0,1,21,gray	
val20=linewidth 2	  arrow -10,0,10,0,10,black	  arrow 0-$val18/2,-10,0+$val18/2,10,10,black	  linewidth 3	  arrow 0,0,1,0,5,red	  arrow 0,0,$val18/20,1,5,red	  text red,0.2,-0.8,medium,i	  text red,-0.8,0.2,medium,j	  text red,-0.4,-0.4,medium,O	
!if $val12>0 
tmp0=!randint -$val7, $val7-$val12

val16=$[rint($(tmp0))]
!else
tmp0=!randint -$val7-($val12), $val7

val16=$[rint($(tmp0))]
!endif
!if $val13>0 
tmp0=!randint -$val7, $val7-$val13

val17=$[rint($(tmp0))]
!else
tmp0=!randint -$val7-($val13), $val7

val17=$[rint($(tmp0))]
!endif
t_=!rawmath $val16+$val17*$val18/20
val21=!exec pari print($t_)
t_=!rawmath $val16+$val12 +($val17+$val13)*$val18/20
val22=!exec pari print($t_)
val19=$val19	 $val20	 linewidth 5	 point $val14+$val15*$val18/20,$val15,orange	 linewidth 3	 text orange,$val14-0.5,$val15-0.5,medium,M	 arrow $val21,$val17,$val22,$val17+$val13,10,green	 text green,$val22-0.5,$val17+$val13-0.5,medium,u	
val23=$val14,$val15
val24=$val12,$val13
replytype1=vector
replyname1=Votre réponse
replygood1=$val23
replytype2=vector
replyname2=Votre réponse
replygood2=$val24
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

