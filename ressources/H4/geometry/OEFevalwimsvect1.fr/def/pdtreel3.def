val31=!exec pari print($t_)
t_=!rawmath 1/($val31)
val32=!exec pari print($t_)
!if $val31>1 or $val31<-1 
val33=c'est \($val28) qui a la plus grande norme

!ifval $val31>0
val33=$val33 et \($val28) et \($val27) sont de męme sens
!else
val33=$val33 et \($val28) et \($val27) sont de sens opposés
!endif

!ifval $val31>0
val34= Le coefficent doit donc ętre supérieur ŕ 1
