val35=lightblue
val36=400
val37=400
val38=linewidth 1	parallel 0,$val8,0,$val9,0.2,0,floor(5*($val7))+1,$val35	parallel 0,$val8,0,$val9,-0.2,0,floor(5*abs($val6))+1,$val35	parallel $val6,0,$val7,0,0,0.2,floor(5*($val9))+1,$val35	parallel $val6,0,$val7,0,0,-0.2,floor(5*abs($val8))+1,$val35	
val39=linewidth 1	parallel 0,$val8,0,$val9,1,0,floor($val7+1),$val35	parallel 0,$val8,0,$val9,-1,0,floor(abs($val6)+1),$val35	parallel $val6,0,$val7,0,0,1,floor($val9+1),$val35	parallel $val6,0,$val7,0,0,-1,floor(abs($val8)+1),$val35	
val40=linewidth 2	segment $val14,$val15,$val16,$val17,red	linewidth 5	points red,$(val10[1]),$(val11[1]),$(val10[2]),$(val11[2]),$(val10[3]),$(val11[3])	text red,$(val10[$(val25[1])])-0.5,$(val11[$(val25[1])])+0.5,medium,$(val23[$(val25[1])])	text red,$(val10[$(val25[2])])-0.5,$(val11[$(val25[2])])+0.5,medium,$(val23[$(val25[2])])	text red,$(val10[$(val25[3])])-0.5,$(val11[$(val25[3])])+0.5,medium,$(val23[$(val25[3])])	
val41=linewidth 2	segment $val18,$val19,$val20,$val21,blue	linewidth 5	points blue,$(val12[1]),$(val13[1]),$(val12[2]),$(val13[2]),$(val12[3]),$(val13[3])	text blue,$(val12[$(val26[1])])-0.5,$(val13[$(val26[1])])+0.5,medium,$(val24[$(val26[1])])	text blue,$(val12[$(val26[2])])-0.5,$(val13[$(val26[2])])+0.5,medium,$(val24[$(val26[2])])	text blue,$(val12[$(val26[3])])-0.5,$(val13[$(val26[3])])+0.5,medium,$(val24[$(val26[3])])	
val42=xrange $val6-1,$val7+1	yrange $val8-1,$val9+1	$val39	$val40	$val41	
