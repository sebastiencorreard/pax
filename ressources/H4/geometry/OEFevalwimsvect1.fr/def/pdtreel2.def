val6=-4
val7=12
val8=-4
val9=8
tmp0=!randint 0, 3

tmp1=!randint 4, 5

tmp2=!randint 6, 8

val10=$(tmp0),$(tmp1),$(tmp2)
val11=$val10
val12=$[rint($val6)]
val13=$[rint($val8)]
val14=$[rint($val6 + $val9 -($val8))]
val15=$[rint($val9)]
val16=$val10
val17=
val18=A,B,C
val19=1,2,3
val20=1,3,2
val21=A,B,C
val22=\overrightarrow{$(val18[$(val19[1])]) $(val18[$(val19[2])])}
val23=\overrightarrow{$(val21[$(val20[1])]) $(val21[$(val20[2])])}
val24=\( $val23 )
val25=\( $val22 )
t_=!rawmath ($(val16[$(val20[2])])-$(val16[$(val20[1])]))/($(val10[$(val19[2])])-$(val10[$(val19[1])]))
val26=!exec pari print($t_)
t_=!rawmath 1/($val26)
val27=!exec pari print($t_)
!if $val26>1 or $val26<-1 
val28=c'est \($val23) qui a la plus grande norme

!ifval $val26>0
val28=$val28 et \($val23) et \($val22) sont de męme sens
!else
val28=$val28 et \($val23) et \($val22) sont de sens opposés
!endif

!ifval $val26>0
val29= Le coefficent doit donc ętre supérieur ŕ 1
!else
val29= Le coefficent doit donc ętre inférieur ŕ -1
!endif
!else
val28=c'est \($val22) qui a la plus grande norme

!ifval $val26>0
val28=$val28 et \($val23) et \($val22) sont de męme sens
!else
val28=$val28 et \($val23) et \($val22) sont de sens opposés
!endif

!ifval $val26>0
val29= Le coefficent doit donc ętre positif et inférieur ŕ 1
!else
val29= Le coefficent doit donc ętre négatif et supérieur ŕ -1
!endif
!endif
val30=lightblue
val31=400
val32=400
val33=linewidth 1	parallel 0,$val8,0,$val9,0.2,0,floor(5*($val7))+1,$val30	parallel 0,$val8,0,$val9,-0.2,0,floor(5*abs($val6))+1,$val30	parallel $val6,0,$val7,0,0,0.2,floor(5*($val9))+1,$val30	parallel $val6,0,$val7,0,0,-0.2,floor(5*abs($val8))+1,$val30	
val34=linewidth 1	parallel 0,$val8,0,$val9,1,0,floor($val7+1),$val30	parallel 0,$val8,0,$val9,-1,0,floor(abs($val6)+1),$val30	parallel $val6,0,$val7,0,0,1,floor($val9+1),$val30	parallel $val6,0,$val7,0,0,-1,floor(abs($val8)+1),$val30	
val35=linewidth 2	segment $val12,$val13,$val14,$val15,red	linewidth 5	points red,$(val10[1]),$(val11[1]),$(val10[2]),$(val11[2]),$(val10[3]),$(val11[3])	text red,$(val10[$(val19[1])])-0.5,$(val11[$(val19[1])])+0.5,medium,$(val18[$(val19[1])])	text red,$(val10[$(val19[2])])-0.5,$(val11[$(val19[2])])+0.5,medium,$(val18[$(val19[2])])	text red,$(val10[$(val19[3])])-0.5,$(val11[$(val19[3])])+0.5,medium,$(val18[$(val19[3])])	
val36=linewidth 2	segment \debl2x,\debl2y,\finl2x,\finl2y,blue	linewidth 5	points blue,$(val16[1]),\y2[1],$(val16[2]),\y2[2],$(val16[3]),\y2[3]	text blue,$(val16[$(val20[1])])-0.5,\y2[$(val20[1])]+0.5,medium,$(val21[$(val20[1])])	text blue,$(val16[$(val20[2])])-0.5,\y2[$(val20[2])]+0.5,medium,$(val21[$(val20[2])])	text blue,$(val16[$(val20[3])])-0.5,\y2[$(val20[3])]+0.5,medium,$(val21[$(val20[3])])	
val36=
val37=xrange $val6-1,$val7+1	yrange $val8-1,$val9+1	$val34	$val35	$val36	
val38=$val37	
replytype1=numeric
replyname1=coeff
