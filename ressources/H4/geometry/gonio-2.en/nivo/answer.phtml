<table  bgcolor="$bgcolor2" cellpadding="15">
    !for q=1 to $aantal_sommen
	<td>
	    Question <b>$q</b>)
	</td>
	<td>    
	    <font color=$fontcolor2>
		!htmlmath $(letter$q)(x)=$(GOED$q)
    	    </font>
	</td>
	<td>
	    <font color=$fontcolor2>
		!htmlmath $(letter$q)(x)=$(ANT$q)
	    </font>
	</td>
	<td>
	    $(opmerking$q)
	</td>
	<tr>	
    !next q
    </td>
</table>

