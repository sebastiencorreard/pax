!read language lang/names
!readproc defindex
!set titlist=!sort items $titlist
!set tlist=!items $wims_sort_order of $tlist
!header

<span class="wims_mod_title">$module_title</span> $name_intro

 !form new
 <input type="hidden" name="module" value="$module" />

 $name_jtype
 !default jtype=jsxgraph
 !formradio jtype list java,jsxgraph prompt Java, Jsxgraph

<p>$name_config</p>

 <ul>
 <li>$name_type:
 !set n=!itemcnt $tlist
 <p class="wimscenter">
 !set wims_formselect_switch=multiple size=$[min($n,6)]
 !formselect listype list $tlist prompt $titlist
 </p>
 </li><li>
  $name_numberdraw:
  !default repeat=1
  !formradio repeat from 1 to 8
  ($name_score)
</li><li>
 $name_level:
  !default level=2
  !formradio level from 1 to 10
 </li>
 </ul>
 <p class="wimscenter wimsform">
 <input type="submit" value="$wims_name_work" />
 </p>
!formend

!set keyw=!getdef keywords in INDEX

!read related.phtml $keyw

!tail
