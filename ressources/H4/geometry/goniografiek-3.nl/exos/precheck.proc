!if $(reply$n)=?
    remark$n=$NOK
    maxscore=0
    goback=0
    !exit
!endif
math=0
!readproc $checkdir/coord.proc

!if $goback=0
    !if $maxscore>0.5
	k=green
    !else
	k=red
    !endif
    tmpdata=linewidth 8\
    points $AAA,$k
        
    !appendfile getfile/$counter.data $tmpdata
!endif
!exit
