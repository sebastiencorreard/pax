# Rekenen met gonioformules II
# var4 is aantal uniek antwoorden
# hmmm var5 is periode "2*k*pi" ofzo

n=$counter
!if $level=0
    R=$counter
!else
    R=$level
!endif
!if $rounding=-1
    rounding=0
    !readproc $remarkdir/rounding.$taal
!endif
image=0
applet=0
plot=0
draw=0
mathview=0
embed=1
cols=30
rows=4
checkfile=exos/checkfile2.proc
join=!record 28 of lang/remarks.$taal
!if $R=1
    k=!randint 1,28
    b=!randint 2,9
    #tussen=!randfile exos/exo8.lijst
    tussen=!record $k of exos/exo8.lijst
    formula$n=!line 1 of $tussen
    answer$n=!line 2 of $tussen
    var4=!line 3 of $tussen
    var5=!line 4 of $tussen
    tex1=!line 5 of $tussen
    tex2=!line 6 of $tussen
    tex3=!line 7 of $tussen
!else
    k=!randint 1,24
    b=!randint 3,9
    tussen=!record $k of exos/exo8b.lijst
    #tussen=!record 24 of exos/exo8b.lijst
    formula$n=!line 1 of $tussen
    answer$n=!line 2 of $tussen
    var4=!line 3 of $tussen
    var5=!line 4 of $tussen
    texanswer$n=!line 5 of $tussen
    tex1=!line 5 of $tussen
    tex2=!line 6 of $tussen
    tex3=!line 7 of $tussen
!endif
inputs=1
embed=1
textanswer$n=(debug:$k)
helptext=<textarea cols=\'20\' rows=\'3\' class=\'schaersvoorde_textarea\'> x1 = k*pi \n x2 = pi/7+k*pi \n x3 = 2/7pi + k*pi</textarea>
ss=!record 26 of lang/remarks.$taal
#@Los de onderstaande vergelijking exact op.
question$n=<a onmouseover="return escape('$helptext')">$ss</a>
texanswer$n=\begin{array}{l} \color{red} $tex3 \\ \color{blue} $(formula$n) \rightarrow $tex1 \\ \rightarrow  $tex2 \end{array}
description=$youranwer

!exit

