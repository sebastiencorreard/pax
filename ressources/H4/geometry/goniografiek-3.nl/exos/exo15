	    !endif
	!else
	    f=$a $pm $b*sin($c*x - $d)
	    arg=sin\left($breuk \pi \cdot x - $d_tex \pi\right)=sin\left( $breuk \pi \left( x-$verschuiving \right) \right) \rightarrow \textrm{de verschuiving is: } $verschuiving
	    !if $mp=+
	     tabel=\begin{array}{c|c|c|c|c|c-.} x & $verschuiving & $verschuiving + \frac{1}{4} \cdot $p & $verschuiving + \frac{2}{4} \cdot $p & $verschuiving + \frac{3}{4} \cdot $p & $verschuiving + $p  \\  y & $a & $[$a+$b] & $a & $[$a-$b] & $a \end{array}
	    !else
	     tabel=\begin{array}{c|c|c|c|c|c-.} x & 0 & \frac{1}{4} \cdot $p & \frac{2}{4} \cdot $p & \frac{3}{4} \cdot $p & $p  \\  y & $a & $[$a-$b] & $a & $[$a+$b] & $a \end{array}
	    !endif
	    
	!endif
    !else
	# cos
	
#	e=!exec pari ((2*$x1/$p)-1/2)

	tot2=!exec pari A=((2*$x1/$p)-1/2)\
	    printtex(A)\
	    B=(2*$x1/($p*$br)-1/(2*$br))\
	    printtex(B)\
	    C=(1/2-(2*$x1/$p))\
	    printtex(C)\
	    D=(-1*(2*$x1/($p*$br)-1/(2*$br)))\
	    printtex(D)
	    
	    e=!line 1 of $tot2
	    
	    verschuiving=!line 4 of $tot2
	    verschuif=!line 8 of $tot2
	    
	    !if $e <0
		e_tex=!line 6 of $tot2
		e_tex= + $e_tex
		versch=+ $verschuif
	    !else
		e_tex=!line 2 of $tot2
		e_tex=- $e_tex
		versch=-$verschuiving
	    !endif
	    

	e=$e*pi
	!if $e=0*pi
	    f=$a $pm $b*cos($c*x)
	    arg=
	    !if $mp=+
	     tabel=\begin{array}{c|c|c|c|c|c-.} x & 0 & \frac{1}{4} \cdot $p & \frac{2}{4} \cdot $p & \frac{3}{4} \cdot $p & $p  \\  y & $[$a+$b] & $a & $[$a-$b] & $a & $[$a+$b] \end{array}
	    !else
	     tabel=\begin{array}{c|c|c|c|c|c-.} x & 0 & \frac{1}{4} \cdot $p & \frac{2}{4} \cdot $p & \frac{3}{4} \cdot $p & $p  \\  y & $[$a-$b] & $a & $[$a+$b] & $a & $[$a-$b] \end{array}
	    !endif
	!else
	    f=$a $pm $b*cos($c*x - $e)
	    arg=cos\left($breuk \pi \cdot x $e_tex \pi\right)=cos\left( $breuk \pi \left( x $versch \right) \right) \rightarrow \textrm{de verschuiving is: } $verschuiving
	    !if $pm=+
	     tabel=\begin{array}{c|c|c|c|c|c-.} x & $verschuiving & $verschuiving + \frac{1}{4} \cdot $p & $verschuiving + \frac{2}{4} \cdot $p & $verschuiving + \frac{3}{4} \cdot $p & $verschuiving + $p  \\  y & $[$a+$b] & $a  & $[$a-$b] & $a & $[$a+$b] \end{array}
	    !else
	     tabel=\begin{array}{c|c|c|c|c|c-.} x & $verschuiving & $verschuiving + \frac{1}{4} \cdot $verschuiving + $p & \frac{2}{4} \cdot $p & $verschuiving + frac{3}{4} \cdot $p & $verschuiving + $p  \\  y & $[$a-$b] & $a & $[$a+$b] & $a & $[$a-$b] \end{array}
	    !endif
	!endif
    !endif
    functie=!texmath $letter(x)=$f
    y=$a
!endif


