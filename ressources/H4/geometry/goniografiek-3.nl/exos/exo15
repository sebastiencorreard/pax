	arg=
	!if $mp=+
	 tabel=\begin{array}{c|c|c|c|c|c-.} x & 0 & \frac{1}{4} \cdot $p & \frac{2}{4} \cdot $p & \frac{3}{4} \cdot $p & $p  \\  y & $a & $[$a+$b] & $a & $[$a-$b] & $a \end{array}
	!else
	 tabel=\begin{array}{c|c|c|c|c|c-.} x & 0 & \frac{1}{4} \cdot $p & \frac{2}{4} \cdot $p & \frac{3}{4} \cdot $p & $p  \\  y & $a & $[$a-$b] & $a & $[$a+$b] & $a \end{array}
	!endif
    !else
	tot=!exec pari A=$p/4\
	A+$p/2
	x1=!line 1 of $tot
	x2=!line 2 of $tot
	f=$a $mp $b*cos($c*x)
	arg=
	!if $mp=+
	 tabel=\begin{array}{c|c|c|c|c|c-.} x & 0 & \frac{1}{4} \cdot $p & \frac{2}{4} \cdot $p & \frac{3}{4} \cdot $p & $p  \\  y & $[$a+$b] & $a & $[$a-$b] & $a & $[$a+$b] \end{array}
	!else
	 tabel=\begin{array}{c|c|c|c|c|c-.} x & 0 & \frac{1}{4} \cdot $p & \frac{2}{4} \cdot $p & \frac{3}{4} \cdot $p & $p  \\  y & $[$a-$b] & $a & $[$a+$b] & $a & $[$a-$b] \end{array}
	!endif
    !endif
    functie=!texmath $letter(x)=$f
    y=$a
!else
    c=!randitem AA,AA/2,AA/4,AA/6,AA/8,AA/10,AA/12,AA/14,AA/16,AA/18
#    p=!exec pari 2*AA/($c)

    br=!replace internal AA by 1 in $c
    
    tot=!exec pari 2*AA/($c)\
    printtex($br)
    
    p=!line 1 of $tot
    breuk=!line 2 of $tot
    
    c=!replace AA by pi in $c
    p=!replace AA by pi in $p
    a=!randitem -4,-3,-2,-1,1,2,3,4
    b=!randint 1,5
    x=!randint 0,$p
    tot=!exec pari A=$x/2\
    A + $p/2
    x1=!line 1 of $tot
    x2=!line 2 of $tot
    
    
    !if $keuze=1
	tot2=!exec pari A=(2*$x1/$p)\
	    printtex(A)\
	    B=(2*$x1/($p*$br))\
	    printtex(B)
	    
	    d=!line 1 of $tot2
	    d_tex=!line 2 of $tot2
	    verschuiving=!line 4 of $tot2
	d=$d*pi
	!if $d=0*pi
	    f=$a $pm $b*sin($c*x)
	    arg=sin($c*x)
	    !if $mp=+
	     tabel=\begin{array}{c|c|c|c|c|c-.} x & 0 & \frac{1}{4} \cdot $p & \frac{2}{4} \cdot $p & \frac{3}{4} \cdot $p & $p  \\  y & $a & $[$a+$b] & $a & $[$a-$b] & $a \end{array}
