    breuk=!replace internal AA by 1 in $c
    tot=!exec pari 2*AA/($c)\
	printtex($breuk)
    
    p=!line 1 of $tot
    breuk=!line 2 of $tot

    c=!replace AA by pi in $c
    p=!replace AA by pi in $p
    a=!randitem -4,-3,-2,-1,1,2,3,4
    b=!randint 1,5
    !if $keuze=1
	x1=0
	x2=!exec pari $p/2
