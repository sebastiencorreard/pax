\left[ \begin{array}{lll} x_{1} & = & \frac{-1}{6} \pi + 2k\pi \\ x_{2} & = & \frac{7}{6} \pi + 2k\pi \\ x_{3} & = & \frac{1}{2} \pi + 2k\pi \end{array} \right.
\sin^{2}(x)+\cos^{2}(x)=1 \rightarrow \cos^{2}(x)=1-\sin^{2}(x)

