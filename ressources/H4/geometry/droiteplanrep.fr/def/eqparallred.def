!set title=Equation droite parallèle (eq réduite)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez;Bruno,Mifsud
email=cyrille.douriez@ac-amiens.fr;communaute.mutuwims@laposte.net
keywords=line,equations,parallel
computeanswer=yes
precision=100000000

ansorder=r
varcnt=14
prevarcnt=13
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!itemcnt $val2


!ifval $(tmp0)=0 
val2=1
!else
val2=$val2
!endif
tmp0=!randitem 1,2

val6=$[rint($(tmp0))]
tmp0=!randint 2, 10

tmp1=!randitem -1,1

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 10, 20

tmp1=!randitem -1,1

val8=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -8, 8

val9=$[rint($(tmp0))]
tmp0=!randint 1, 7

tmp1=!randitem -1,1

val10=$[rint($val7*$val9+$val8+$(tmp0)*$(tmp1))]
val11=$[rint($val10-$val7*$val9)]
t_=!replace internal \( by ( in $val7*x+$val8
tmp0=!exec maxima $t_

val12=!rawmath $(tmp0)
val13=!rawmath $val7*x+$val11
!if $val2=1 
val14=xrange -50,50	yrange -50,50	hline 0,0,black	vline 0,0,black	parallel -30,-1,-30,1,60,0,2,black	parallel -1,-30,1,-30,0,60,2,black	text black , 30,-0.5,small , 30	text black , -30,-0.5,small , -30	text black , 0.3,-30,small , -30	text black , 1,30,small , 30	text black , 1,-1,small , O	linewidth 1.5
!readproc oef/draw.phtml 100,100 \
$val14	plot blue, $val12	crosshairs red,$val9,$val10	 
tmp0=$ins_url
val15=$(tmp0)
val16=<img src="$val15" alt="représentation graphique" style="float:right;margin-top:-0.5em;">
!endif

!ifval $val9>0
val17=$val9
!else
val17=($val9)
!endif
replytype1=function
replyname1=
replygood1=!rawmath $val13
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div class=wims_question>$val16	Déterminer l'équation de la droite 
!insmath (d')
$() parallèle à la droite 
!insmath (d)
$() d'équation 
!insmath y=$val12
$() et passant par 
!insmath A($val9; $val10)
$().	<br>La droite 
!insmath (d')
$() a pour équation : 
!insmath y=
$() 
!read oef/embed.phtml r1,10 
$().</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()<ul><li>
!insmath (d)
$() n'est pas verticale donc 
!insmath (d')
$() non plus et son équation est donc de la forme 
!insmath y=mx+p
$() <em>(les valeurs de 
!insmath m
$() et 
!insmath p
$() sont à déterminer)</em>.	</li><li>
!insmath (d)
$() et 
!insmath (d')
$() sont parallèles donc elles ont le même coefficient directeur : 
!insmath m=$val7
$().	</li><li>
!insmath A($val9; $val10)
$() appartient à 
!insmath (d')
$() donc ses coordonnées vérifient l'équation de 
!insmath (d')
$() :	
!insmath y_A={m}\times {x_A}+p
$() &hArr;	
!insmath $val10={$val7}\times {$val17}+p
$(). Cette équation a pour solution 
!insmath p=$val11
$()</li>	<li>L'équation réduite de 
!insmath (d')
$() est 
!insmath y=$val7 x+$val11
$().	</li></ul>
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,9,10,11,12,16,17
embedcnt=1
