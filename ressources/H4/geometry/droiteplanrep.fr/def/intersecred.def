 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!itemcnt $val2


!ifval $(tmp0)=0 
val2= 1
!else
val2=$val2
!endif
tmp0=!randint -5, 8

val6=$[rint($(tmp0))]
tmp0=!randint -15, 15

val7=$[rint($(tmp0))]
tmp0=!randint 2, 8

val8=$[rint($(tmp0))]
val9=$[rint($val7-$val8*$val6)]
tmp0=!randint -10, -1

val10=$[rint($(tmp0))]
val11=$[rint($val7-$val10*$val6)]
t_=!replace internal \( by ( in $val8*x+$val9
tmp0=!exec maxima $t_

val12=!rawmath $(tmp0)
t_=!replace internal \( by ( in $val10*x+$val11
tmp0=!exec maxima $t_

val13=!rawmath $(tmp0)
val14=$[rint($val8-$val10)]
val15=$[rint($val11-$val9)]
!if $val2=1 
val16=xrange -20,20	yrange -20,20	hline 0,0,black	vline 0,0,black	parallel -10,-0.5,-10,0.5,20,0,2,black	parallel -0.5,-10,0.5,-10,0,20,2,black	text black , 10,-0.5,small , 10	text black , 1,10,small , 10	text black , 1,-1,small , O	linewidth 1.5
!readproc oef/draw.phtml 100,100 \
$val16	plot blue, $val12	plot blue, $val13	 
tmp0=$ins_url
val17=$(tmp0)
val18=plot blue, $val12,$val13
val19=<img src="$val17" alt="représentation graphique" style="float:right;margin-left:0.5em;margin-right:0.2em;">
!readproc oef/draw.phtml 100,100 \
$val16	crosshair $val6,$val7, red	plot blue, $val12	plot blue, $val13	 
tmp0=$ins_url
val20=$(tmp0)
val21=<img src="$val20" alt="représentation graphique" style="float:right;margin-left:0.5em;margin-right:0.2em;">
!endif
!if $val8=1 
val22=x
!else
!if $val8=-1 
val22=-x
!else
val22=$val8 x
!endif
!endif
!if $val9=0 
val23=
!else
!if $val9>0 
val23=+$val9
!else
val23=$val9
!endif
!endif
val24=$val22 $val23
!if $val10=1 
val25=x
!else
!if $val10=-1 
val25=-x
!else
val25=$val10 x
!endif
!endif
!if $val11=0 
val26=
