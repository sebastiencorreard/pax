!set title=Equation réduite 
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille,Douriez;Bruno,Mifsud
email=cyrille.douriez@ac-amiens.fr;communaute.mutuwims@mlaposte.net
keywords=line,equations
computeanswer=no

ansorder=r,r
varcnt=21
prevarcnt=20
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!itemcnt $val2


!ifval $(tmp0)=0 
val2= 1
!else
val2=$val2
!endif
tmp0=!randint 1, 8

tmp1=!randitem -1,1

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -15, 15

val7=$[rint($(tmp0))]
tmp0=!randint -10, 10

val8=$[rint($(tmp0))]
val9=$[rint($val6*$val8+$val7)]
tmp0=!randitem 1,2,2,2

val10=$[rint($(tmp0))]

!ifval ($val10=1)
val11=$[rint( $val8)]
!else
tmp0=!randint 1, 10

tmp1=!randitem -1,1

val11=$[rint($val8+($(tmp0)*$(tmp1)))]
!endif

!ifval ($val10=1)
tmp0=!randint 1, 10

tmp1=!randitem -1,1

val12=$[rint( $val9+($(tmp0)*$(tmp1)))]
!else
val12=$[rint($val6*$val11+$val7)]
!endif

!ifval ($val10=1)
val13=!rawmath  $val8
!else
val13=!rawmath $val6 x+$val7
!endif

!ifval ($val10=1)
val14=$[rint( 1)]
!else
val14=$[rint(2)]
!endif
!if $val2=1 
val15=xrange -100,100	yrange -100,100	hline 0,0,black	vline 0,0,black	parallel -50,-2,-50,2,100,0,2,black	parallel -2,-50,2,-50,0,100,2,black	text black , 50,-0.5,small , 50	text black , 1,50,small , 50	text black , 1,-1,small , O	linewidth 1.5
!readproc oef/draw.phtml 100,100 \
$val15	crosshairs red,$val8,$val9,$val11,$val12	 
tmp0=$ins_url
val16=$(tmp0)

!ifval $val10=1
val17=vline $val8,0,blue
!else
val17=plot blue, $val13
!endif
val18=-0.5em
val19=<img src="$val16" alt="représentation graphique" style="float:right;margin-top:$val18;">
!readproc oef/draw.phtml 100,100 \
$val15	crosshairs red,$val8,$val9,$val11,$val12	$val17 
tmp0=$ins_url
val20=$(tmp0)
val21=<img src="$val20" alt="représentation graphique" style="float:right;margin-top:-0.5em;">
!endif

!ifval ($val8<0)
val22= $val11-($val8)
!else
val22=$val11-$val8
!endif

!ifval ($val9<0)
val23= $val12-($val9)
!else
val23=$val12-$val9
!endif
val24=$[rint($val6*$val8)]
replytype1=menu
replyname1=
replygood1=$val14;x=,y=
replytype2=function
replyname2=
replygood2=!rawmath $val13
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class=wims_question>$val19 Déterminer l'équation réduite de la droite 
!insmath (AB)
$() avec 
!insmath A($val8; $val9)
$() et 
!insmath B($val11; $val12)
$().	<br >L'équation est  
!read oef/embed.phtml r1 
$() 
!read oef/embed.phtml r2,10 
$()</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()	$val21	
!if $val10=1 
$()
!insmath A
$() et 
!insmath B
$() ont la męme abscisse 
!insmath $val8
$() donc la droite 
!insmath (AB)
$() est parallčle ŕ l'axe des ordonnées et son équation est 
!insmath x=$val8
$(). 
!else
$()	 <p>
!insmath A
$() et 
!insmath B
$() n'ont pas la męme abscisse donc la droite 
!insmath (AB)
$() n'est pas parallčle ŕ l'axe des ordonnées et son équation réduite est de la forme 
!insmath y=mx+p
$().</p>	<p> Il reste ŕ déterminer les valeurs de 
!insmath m
$() et 
!insmath p
$()	<ul><li>Le coefficient directeur 
!insmath m
$() est égal ŕ 
!insmath \frac{y_B-y_A}{x_B-x_1}=\frac{$val23}{$val22}=$val6
$().</li>	<li class="wims_nopuce">L'équation réduite de 
!insmath (AB)
$() est donc de la forme 
!insmath y=$val6 x+p
$().</li>	<li>Pour déterminer la valeur de 
!insmath p
$(), on remplace 
!insmath x
$() et 
!insmath y
$() dans l'équation par les coordonnées d'un point de la droite.</li>	<li class="wims_nopuce">En prenant par exemple 
!insmath A($val8; $val9)
$(), on obtient 
!if $val8<0 
$()
!insmath $val9=$val6 \times ($val8)+p
$() 
!else
$() 
!insmath $val9=$val6 \times $val8+p
$() 
!endif
$() c'est ŕ dire 
!insmath $val9=$val24+p
$().</li>	<li class="wims_nopuce">On en déduit que 
!if $val24<0 
$()
!insmath p=$val9-($val24)=$val7
$() 
!else
$() 
!insmath p=$val9-$val24=$val7
$() 
!endif
$() </li>	</ul>	<p> Conclusion : l'équation réduite de la droite 
!insmath (AB)
$() est 
!if $val7<0 
$()
!insmath y=$val6 x$val7
$() 
!else
$() 
!insmath y=$val6 x+$val7
$() 
!endif
$(). </p>	 
!endif
$()	
$()
!exit

