 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 5

val6=$[rint($(tmp0))]
tmp0=!randint 1, 3

val7=$[rint($(tmp0))]
tmp0=!randint 2, 7

val8=$[rint($(tmp0))]
tmp0=!randint -15, 15

val9=$[rint($(tmp0))]

!ifval ($val7=1)
val10=$[rint( -$val8)]
!else
tmp0=!randint 1, 6

val10=$[rint($val8+$(tmp0))]
!endif
tmp0=!randint 1, 4

tmp1=!randitem -1,1

val11=$[rint($val9+$(tmp0)*$(tmp1))]

!ifval ($val7=1)
val12=$[rint( 1)]
!else
val12=$[rint(2)]
!endif

!ifval ($val6<3)
val12=$[rint( $val6)]
!else
val12=$[rint( $val12)]
!endif

!ifval ($val7=1)
t_=!replace internal \( by ( in -$val8*x+$val9
tmp0=!exec maxima $t_

val13=!rawmath  $(tmp0)
!else
t_=!replace internal \( by ( in $val8*x+$val9
tmp1=!exec maxima $t_

val13=!rawmath $(tmp1)
!endif

!ifval ($val6<3)
val13=!rawmath  $val8
!else
val13=!rawmath $val13
!endif
t_=!replace internal \( by ( in $val10*x+$val11
tmp0=!exec maxima $t_

val14=!rawmath $(tmp0)

!ifval ($val6=1)
val14=!rawmath $val10
!else
val14=!rawmath $val14
!endif

!ifval $val6<3
val15=x=$val13
!else
val15=y=$val13
!endif

!ifval $val6=1
val16=x=$val14
!else
val16=y=$val14
!endif
replytype1=radio
replyname1=Droites parallèles?
replygood1=$val12;Oui,Non
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

