$()
!if $val6=1 
$()
!insmath (d_1)
$() et 
!insmath (d_2)
$() sont verticales donc parallèles. 
!endif
$()	
!if $val6=2 
$()
!insmath (d_1)
$() est verticale mais pas 
!insmath (d_2)
$() donc elles ne sont pas parallèles. 
