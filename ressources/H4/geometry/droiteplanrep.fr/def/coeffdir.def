!set title=Calcul du coefficient directeur
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez;Bruno,Mifsud
email=cyrille.douriez@ac-amiens.fr;communaute.mutuwims@laposte.net
computeanswer=no

ansorder=r
varcnt=19
prevarcnt=18
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!itemcnt $val2


!ifval $(tmp0)=0 
val2=1
!else
val2=$val2
!endif
tmp0=!randint 1, 10

tmp1=!randitem -1,1

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 8

val7=$[rint($val6+$(tmp0))]
tmp0=!randint 0, 15

tmp1=!randitem -1,1

val8=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 15

tmp1=!randitem -1,1

val9=$[rint($(tmp0)*$(tmp1))]
t_=!rawmath ($val9-$val8)/($val7-$val6)
val10=!exec pari print($t_)
tmp0=!randint 1, 6

val11=$[rint($(tmp0))]
tmp=!trim AB,A,B	CD,C,D	EF,E,F	GH,G,H	MN,M,N	RT,R,T
val12=!translate internal $	\
$ to ;; in $tmp
!if $val2=1 
t_=!replace internal \( by ( in $val10*x+$val9-$val10*$val7
tmp0=!exec maxima $t_

val13=!rawmath $(tmp0)
val14=xrange -16,16	yrange -16,16	hline 0,0,black	vline 0,0,black	parallel -10,-0.3,-10,0.3,20,0,2,black	parallel -0.3,-10,0.3,-10,0,20,2,black	text black , 10,-0.5,small , 10	text black , -10,-0.5,small , -10	text black , 0.3,-10,small , -10	text black , 1,10,small , 10	text black , 1,-1,small , O	linewidth 1.5
!readproc oef/draw.phtml 100,100 \
$val14	plot blue, $val13	crosshairs red,$val6,$val8,$val7,$val9	 
tmp0=$ins_url
val15=$(tmp0)
val16=<img src="$val15" alt="représentation graphique" style="float:right;margin-top:-0.5em;">
!endif

!ifval ($val8<0)
val17= $val9-($val8)
!else
val17=$val9-$val8
!endif

!ifval ($val6<0)
val18= $val7-($val6)
!else
val18=$val7-$val6
!endif
val19=$[rint($val9-$val8)]
val20=$[rint($val7-$val6)]
t_=!replace internal \( by ( in $val19/gcd($val19,$val20)
tmp0=!exec maxima $t_

val21=$[rint($(tmp0))]
t_=!replace internal \( by ( in $val20/gcd($val19,$val20)
tmp0=!exec maxima $t_

val22=$[rint($(tmp0))]
replytype1=formal
replyname1=m
replygood1=$val10
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class=wims_question>$val16 Calculer le coefficient directeur de la droite 
!insmath ($(val12[$val11;1]))
$() avec 
!insmath $(val12[$val11;2])( $val6 ; $val8 )
$() et 
!insmath $(val12[$val11;3])( $val7 ; $val9 )
$().	<br >	Votre réponse :  
!read oef/embed.phtml r1,12 
$()</div>	<div class=wims_instruction>Donner la valeur exacte.</div>	
$()
!exit

:hint
$()Le coefficent directeur de la droite 
!insmath ($(val12[$val11;1]))
$() se calcule ainsi :	<div class=wimscenter> 
!insmath (y_$(val12[$val11;3])-y_$(val12[$val11;2]))/(x_$(val12[$val11;3])-x_$(val12[$val11;2]))
$()</div>
$()
!exit

:help
$()
$()
!exit

:solution
$()$val16	Le coefficent directeur de la droite 
!insmath ($(val12[$val11;1]))
$() est égal ŕ 	
!insmath \frac{y_$(val12[$val11;3])-y_$(val12[$val11;2])}{x_$(val12[$val11;3])-x_$(val12[$val11;2])}=\frac{$val17}{$val18}	=\frac{$val19}{$val20}
$() 
!if $val22=1 
$()
!insmath =$val21
$() 
!endif
$().
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,11,12,16,17,18,19,20,21,22
embedcnt=1
