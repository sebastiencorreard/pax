\title{Equation droite parallĶle (eq rķduite)}
\author{Cyrille, Douriez;Bruno,Mifsud}
\email{cyrille.douriez@ac-amiens.fr;communaute.mutuwims@laposte.net}
\keywords{line,equations,parallel}
\computeanswer{yes}
\precision{100000000}

\text{confparm1= items(\confparm1)=0 ?1:\confparm1}
\integer{choix=randint(1,2)}
\integer{m=randint(2..10)*randint(-1,1)}
\integer{p=randint(10..20)*randint(-1,1)}
\integer{x=randint(-8..8)}
\integer{y=\m*\x+\p+randint(1..7)*randint(-1,1)}
\integer{q=\y-\m*\x}
\function{f=maxima(\m*x+\p)}
\function{g=\m*x+\q}


