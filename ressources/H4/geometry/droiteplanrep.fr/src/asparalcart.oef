\title{Equation parallèle qui passe par A (eq cartésienne)}
\author{Cyrille, Douriez;Bruno,Mifsud}
\email{cyrille.douriez@ac-amiens.fr;communaute.mutuwims@laposte.net}

\text{confparm1= items(\confparm1)=0 ?1:\confparm1}
\text{pt=random(A,B,C,D,E)}
\integer{a=randint(2..15)*randint(-1,1)}
\integer{b=randint(2..15)*randint(-1,1)}
\integer{c=randint(2..15)*randint(-1,1)}
\integer{x=randint(-20..20)}
\integer{y=randint(-20..20)}
\integer{y=(\a*\x+\b*\y+\c=0)? \y+randint(1..6):\y}
\integer{c2=-\a*\x-\b*\y}
\function{equ=\a*x+\b*y+\c2}
\text{equenonce=\a x }
\text{equenonce=\b>0?\equenonce+\b y:\equenonce \b y}
\text{equenonce=\c>0?\equenonce+\c:\equenonce \c }

