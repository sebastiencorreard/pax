#########solution
\integer{bm=-\b}
\integer{xabs=abs(\x)}
\integer{yabs=abs(\y)}
\text{t1=(\x>0)? x-\x:x+\xabs}
\text{t2=(\y>0)? y-\y:y+\yabs}
##########end solution

\statement{<div class=wims_question>\img
Déterminer une équation de la droite \((d_2)) parallèle à la droite \((d_1)) d'équation
 \(\equenonce =0) et passant par \(\pt(\x ; \y)).
<br > L'équation de \((d_2)) est :
\embed{r1,50}
</div>
<div class=wims_instruction>Donner une équation de la forme a*x+b*y+c=0.</div>}
\answer{Equation de \(d_2)}{\equ=0}{type=equation}

\solution{
\img
<p>\(\pt(\x ; \y)) et \(\equenonce =0)</p>
<p>On a : \(\overrightarrow{u}\left ( \begin{array}{c}\bm \\ \a \end{array} \right )) est un vecteur directeur de \(d_1)
donc de \(d_2) puisque ces deux droites sont parallèles.</p>
<p>Ensuite : 
</p><p>\(M(x; y)) appartient à \(d_2) 
</p><p>&hArr;  \(\overrightarrow{u}) et \(\overrightarrow{\pt M}\left ( \begin{array}{c}\t1\\\t2\end{array} \right )) sont colinéaires 
</p><p>&hArr; leur déterminant est nul
</p><p>&hArr; \(\a(\t1))\if{\b>0}{\({}+{})}\(\b (\t2))=0 
</p><p>&hArr; \(\equ=0).</p>}
