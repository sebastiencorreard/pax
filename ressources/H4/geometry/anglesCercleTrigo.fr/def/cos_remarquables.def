!set title=Cosinus  des angles remarquables
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Véronique, Royer
email=royer.veronique@orange.fr
computeanswer=no
precision=100

ansorder=r
varcnt=18
prevarcnt=17
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 16

val6=$[rint($(tmp0))]
val7=0, {\pi}/6 , {\pi}/4,{\pi}/3,{\pi}/2, {2\pi}/3,{3\pi}/4, {5\pi}/6, pi, -{5\pi}/6, -{3\pi}/4, -{2\pi}/3, -{\pi}/2 , -{\pi}/3, -{\pi}/4, -{\pi}/6
tmp0=!item $val6 of $val7

val8=$(tmp0)
val9=$[3.14]
val10=0, $val9/6 , $val9/4,$val9/3,$val9/2, 2*$val9/3,3*$val9/4, 5*$val9/6, $val9, -5*$val9/6, -3*$val9/4, -2*$val9/3, -$val9/2 , -$val9/3, -$val9/4, -$val9/6
tmp0=!item $val6 of  $val10

val11=$[$(tmp0)]
val12=\(1), \(\frac{\sqrt{3}}{2}) ,  \(\frac{\sqrt{2}}{2}) , \(1/2) , \(0),\( -1/2) , \( -  \frac{\sqrt{2}}{2}) , \( - \frac{\sqrt{3}}{2}) , \(-1) 

!ifval $val6< 10 
val13=$[rint( $val6)]
!else
val13=$[rint( 18 - $val6 )]
!endif

!ifval $val6 < 10 
val14=$[rint(  1+ abs( $val6 - 5) )]
!endif

!ifval $val6 >= 10 
val14=$[rint(  9 - abs( $val6 - 13))]
!endif
val15=$[cos($val11)]
val16=$[sin($val11)]
val17=$val15,$val16
val18=$[cos(0.2)]
val19=$[sin(0.2)]
val20=var brd = JXG.JSXGraph.initBoard('jxgbox', {boundingbox:[-1.2,1.2,1.2,-1.2], axis:true, grid:true});	var pO = brd.create('point',[0,0], {name:'O',size: 2, face: 'o', fixed:true, color:'blue'});	var pI = brd.create('point',[1,0], {name:'I',size: 2,  face: 'o', fixed:true, color:'blue'});	var c = brd.create('circle', [pO,pI], {strokeWidth:2, strokeColor:'blue'}) ;	brd.create('line', [ [0,0], [1,1] ] ,{strokeWidth:1 , strokeColor:'black', fixed:true});	brd.create('line', [ [0,0], [1,-1] ] ,{strokeWidth:1 , strokeColor:'black', fixed:true});	brd.create('line', [ [0.5,0], [0.5,1] ] ,{strokeWidth:1 , strokeColor:'black', fixed:true});	brd.create('line', [ [-0.5,0], [-0.5,1] ] ,{strokeWidth:1 , strokeColor:'black', fixed:true});	brd.create('line', [ [0,0.5], [1,0.5] ] ,{strokeWidth:1 , strokeColor:'black', fixed:true});	brd.create('line', [ [0,-0.5], [1,-0.5] ] ,{strokeWidth:1 , strokeColor:'black', fixed:true});	var pA = brd.create('glider',[$val15,$val16,c],{name:'A',size:3, color:'blue', fixed:true});	brd.create('arrow',[pO,pA], { strokeWidth:2, strokeColor:'red'});	brd.create('angle', [pI,pO,pA], {name:'a',  type:'sector', orthoType:'sectordot', orthoSensitivity:2, radius:1});	brd.create('arrow',[pO,pI], {strokeWidth:2,strokeColor:'red'});	var aa = brd.create('arc',[pO,pI,pA], { strokeWidth:3 , strokeColor:'red'});		
!readproc slib/geo2D/jsxgraph  jxgbox, 300 x 300, $val20 
tmp0=$slib_out
val21=$(tmp0)
replytype1=radio
replyname1=cosinus
replygood1=$val13; $val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

