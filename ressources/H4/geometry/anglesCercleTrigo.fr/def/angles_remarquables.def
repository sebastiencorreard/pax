:postdef
tmp=!trim $m_reply1
val19=!translate internal $	\
$ to ;; in $tmp
tmp=!trim $val14
val20=!translate internal $	\
$ to ;; in $tmp
val21=$[abs(sqrt($(val19[1])^2 + $(val19[2])^2) -1) ]

!exit

:feedback
!ifval  abs($(val19[1]) - $(val20[1])) > 0.05 or   abs($(val19[2]) - $(val20[2])) > 0.05
 <div class='oef_feedbacks'> Le point A  du cercle trigonomťtrique qui reprťsente l'angle 
!insmath $val8
$() radians est le point A$val6.  
$()</div>
