!set title=Placer un angle remarquable sur le cercle
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Vťronique, Royer
email=royer.veronique@orange.fr
language=fr
computeanswer=no
precision=100

ansorder=r
varcnt=18
prevarcnt=14
postvarcnt=3
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 16

val6=$[rint($(tmp0))]
val7=0, {\pi}/6 , {\pi}/4,{\pi}/3,{\pi}/2, {2\pi}/3,{3\pi}/4, {5\pi}/6, pi, -{5\pi}/6, -{3\pi}/4, -{2\pi}/3, -{\pi}/2 , -{\pi}/3, -{\pi}/4, -{\pi}/6
tmp0=!item $val6 of $val7

val8=$(tmp0)
val9=$[3.14]
val10=0, $val9/6 , $val9/4,$val9/3,$val9/2, 2*$val9/3,3*$val9/4, 5*$val9/6, $val9, -5*$val9/6, -3*$val9/4, -2*$val9/3, -$val9/2 , -$val9/3, -$val9/4, -$val9/6
tmp0=!item $val6 of  $val10

val11=$[$(tmp0)]
val12=$[cos($val11)]
val13=$[sin($val11)]
val14=$val12,$val13
val15=$[cos(0.2)]
val16=$[sin(0.2)]
val17=var brd = JXG.JSXGraph.initBoard('jxgbox', {boundingbox:[-1.2,1.2,1.2,-1.2], axis:true, grid:true});	var pO = brd.create('point',[0,0], {name:'O',size: 2, face: 'o', fixed:true, color:'blue'});	var pI = brd.create('point',[1,0], {name:'I',size: 2,  face: 'o', fixed:true, color:'blue'});	var c = brd.create('circle', [pO,pI], {strokeWidth:2, strokeColor:'blue'}) ;	brd.create('line', [ [0,0], [1,1] ] ,{strokeWidth:1 , strokeColor:'black', fixed:true});	brd.create('line', [ [0,0], [1,-1] ] ,{strokeWidth:1 , strokeColor:'black', fixed:true});	brd.create('line', [ [0.5,0], [0.5,1] ] ,{strokeWidth:1 , strokeColor:'black', fixed:true});	brd.create('line', [ [-0.5,0], [-0.5,1] ] ,{strokeWidth:1 , strokeColor:'black', fixed:true});	brd.create('line', [ [0,0.5], [1,0.5] ] ,{strokeWidth:1 , strokeColor:'black', fixed:true});	brd.create('line', [ [0,-0.5], [1,-0.5] ] ,{strokeWidth:1 , strokeColor:'black', fixed:true});				  //// modif oct 2016 (mŗj jsxgraph ;  Julien Lyotard )	jxgbox_rep1=brd.create('glider',[jxgbox_var1[0], jxgbox_var1[1],c],{name:'A',color:'red'});				brd.create('arrow',[pO,jxgbox_rep1], { strokeWidth:2, strokeColor:'red'});	brd.create('angle', [pI,pO,jxgbox_rep1], {name:'a',  type:'sector', orthoType:'sectordot', orthoSensitivity:2, radius:1});	brd.create('arrow',[pO,pI], {strokeWidth:2,strokeColor:'red'});	var aa = brd.create('arc',[pO,pI,jxgbox_rep1], { strokeWidth:3 , strokeColor:'red'});	brd.create('text',[-1,1,function(){return 'x(A) = '  + jxgbox_rep1.X().toFixed(3);}], {color:'red', fixed:true});	brd.create('text',[0.5,1,function(){return 'y(A) = '  + jxgbox_rep1.Y().toFixed(3);}], {color:'red', fixed:true});	brd.update() ;	
!for val18  =1 to 16 
val17=$val17	brd.create('point',[function(){return Math.cos( $(val10[$val18]));}, function(){return Math.sin($(val10[$val18]) );}],{name:'A$val18', size: 2,  face: 'o', fixed:true, color:'blue'});	
!next
replytype1=jsxgraph

replyoption1=precision=20 
replyname1=
replygood1=$val14
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()			<p>Avec la prťcision permise par le graphique, placer  sur le cercle trigonomťtrique le point rouge A	tel que l'angle orientť 
!insmath \left( \vec{OI} , \vec{OA} \right) 
$() mesure 
!insmath $val8
$() radians. </p>			<br>	 
!read oef/embed.phtml reply1, 400x400	jxgbox brd	$val17	jxgbox_var1=[$val15,$val16,c];	 
$()			
$()
!exit

