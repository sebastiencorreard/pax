!set title=Associer un point du cercle trigonométrique ŕ un angle
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Véronique, Royer
email=royer.veronique@orange.fr
language=fr
computeanswer=no
precision=100

ansorder=r
varcnt=8
prevarcnt=5
postvarcnt=2
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!random -30, 30

t_=!replace internal \( by ( in 0.01*floor($(tmp0)*10)
tmp1=!exec pari $t_

val6=$[$(tmp1)]
t_=!replace internal \( by ( in 0.01*round(100*cos($val6))
tmp0=!exec pari $t_

val7=$[$(tmp0)]
t_=!replace internal \( by ( in 0.01*round(100*sin($val6))
tmp0=!exec pari $t_

val8=$[$(tmp0)]
val9=$val7,$val8
val10=var brd = JXG.JSXGraph.initBoard('jxgbox', {boundingbox:[-1.2,1.2,1.2,-1.2], axis:true, grid:true});	var pO = brd.create('point',[0,0], {name:'O',size: 2, face: 'o', fixed:true, color:'blue'});	var pI = brd.create('point',[1,0], {name:'I',size: 2,  face: 'o', fixed:true, color:'blue'});		var c = brd.create('circle', [pO,pI], {strokeWidth:2, strokeColor:'blue'}) ;	/// Modif. le 27/02 : jxgbox_rep1 = brd.create('glider', jxgbox_var1,{name:'A',size:3, color:'red'});	jxgbox_rep1 = brd.create('glider', [jxgbox_var1[0], jxgbox_var1[1],c],{name:'A',size:3, color:'red'})		brd.create('arrow',[pO,jxgbox_rep1], { strokeWidth:2, strokeColor:'red'});	brd.create('angle', [pI,pO,jxgbox_rep1], {name:'a',  type:'sector', orthoType:'sectordot', orthoSensitivity:2, radius:1});	brd.create('arrow',[pO,pI], {strokeWidth:2,strokeColor:'red'});	var aa = brd.create('arc',[pO,pI,jxgbox_rep1], { strokeWidth:3 , strokeColor:'red'});	brd.create('text',[-1,1,function(){return 'x(A) = '  + jxgbox_rep1.X().toFixed(3);}], {color:'red', fixed:true});	brd.create('text',[0.5,1,function(){return 'y(A) = '  + jxgbox_rep1.Y().toFixed(3);}], {color:'red', fixed:true});	brd.update() ;	
replytype1=jsxgraph

replyoption1=precision=20 
replyname1=
replygood1=$val9
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<p>Soit 
!insmath a = $val6
$() un réel. On donne :  
!insmath cos (a ) \simeq  $val7 
$()  et  
!insmath sin (a ) \simeq  $val8 
$()	(valeurs arrondies au centičme). </p>		<p>Avec la précision permise par le graphique, placer  sur le cercle trigonométrique le point A	tel que l'angle orienté 
!insmath \left( \vec{OI} , \vec{OA} \right) 
$() mesure 
!insmath a
$() radians. </p>			<br>	 
!read oef/embed.phtml reply1, 400x400	jxgbox brd	$val10	jxgbox_var1=[0,1,c];	 
$()			
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:postdef
tmp=!trim $m_reply1
val11=!translate internal $	\
$ to ;; in $tmp
tmp=!trim $val9
val12=!translate internal $	\
$ to ;; in $tmp

!exit

:feedback
!ifval  abs($(val11[1]) - $(val12[1])) > 0.1 or   abs($(val11[2]) - $(val12[2])) > 0.1
 <div class='oef_feedbacks'> Le point A  du cercle trigonométrique représente l'angle mesurant 
!insmath a
$() radians si et seulement si 
!insmath x_A =  cos(a)
$()   et  
!insmath y_A =  sin(a)
$().<br>		
$()</div>
!endif

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,10
embedcnt=1
