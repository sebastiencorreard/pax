!set title=2-Choix du coefficient 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Chantal, Causse
email=Chantal.Causse@noos.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=11
prevarcnt=8
postvarcnt=2
replycnt=1
choicecnt=0
conditioncnt=1
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 3, 80

val6=$[$(tmp0)/2]
tmp0=!randint 3, 80

val7=$[$(tmp0)/2]
tmp0=!randint 1, 15

val8=$[$val7 + $(tmp0)/10]
val9=$[$val7/$val6*100]
val10=$[rint(max(ceil($val9),25) )]
val11=$[$val8/$val6*100]
val12=$[rint(min(floor($val11),400) )]

!ifval $val9 > 400 or $val11 < 25 or ceil($val9) > floor($val11) 
val13= 0 
!else
val13=1 
!endif
replyname1=Coefficient en %
replygood1=?analyze 14
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	 
!read oef/special.phtml tooltip <b>Passer la souris ici pour afficher les caractéristiques du photocopieur</b>,[ABOVE,true,STICKY,true,CLOSEBTN,true] ,<ul><li>Formats de papier disponibles : A4 (21*29.7 cm) et A3 (29.7*42 cm)</li>	<li>Dimensions utiles de la vitre : A3</li>	<li>Coefficients disponibles pour les agrandissements et réductions : de 25% ŕ 400% en nombre entier</li></ul>	Dans tous ces exercices, on fait abstraction du problčme du positionnement de l'original sur la vitre du photocopieur<br>	(problčme pourtant non négligeable dans la pratique !)	 
$()		<p>	Je veux photocopier un motif de telle sorte qu'un segment de longueur $val6 cm sur l'original  donne sur la photocopie un segment de longueur comprise entre $val7 cm et $val8 cm  .	</p><p>	Quel coefficient d'agrandissement/réduction puis-je choisir pour cela ?</p>	<div class="wims_instruction">	Si vous pensez que ce n'est pas possible sur ce photocopieur, indiquez 0.</div>	
$()
!exit

:hint
$()Dimension finale = dimension initiale $m_times coefficient<br>	Dans cet exercice, il peut y avoir plusieurs réponses possibles ; il suffit de donner l'une d'elles.
$()
!exit

:help
$()
$()
!exit

:solution
$()Le coefficient doit ętre compris entre $val9 et $val11.<br>	De plus, d'aprčs les caractéristiques du photocopieur, il doit ętre entier	et compris entre 25 et 400.	<p>	
!if $val13 = 0 
$()Ce n'est donc pas possible. 
!else
$() Les réponses possibles sont donc tous les entiers compris entre $val10 et $val12. 
!endif
$()	</p>
$()
!exit

:latex
$()
$()
!exit

:postdef

!ifval $val13 = 0 and $val14 =0 
val15=$[rint( 1)]
!else
val15=$[rint(0 )]
!endif

!ifval $val14 >= $val9 and $val14 <= $val11  and floor($val14)=$val14 and $val14 >= 25 and $val14 <= 400 
val16=$[rint( 1)]
!else
val16=$[rint(0 )]
!endif

!exit

:feedback

!exit

:test

!ifval $val15 = 1 or $val16 = 1 
 condtest1=1
!else
 condtest1=0
!endif
condname1=Coefficient

!exit

:stat
vsavelist=6,7,8,9,10,11,12,13,14
embedcnt=1
