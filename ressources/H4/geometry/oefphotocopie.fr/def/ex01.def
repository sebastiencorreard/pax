!set title=1-Dimension après photocopie
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Chantal, Causse
email=Chantal.Causse@noos.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=6
prevarcnt=5
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 3, 40

val6=$[$(tmp0)/2]
val7=$[min(42/$val6*100,400)]
tmp0=!randint 25, 99

tmp1=!randint 101, $val7

tmp2=!randitem $(tmp0),$(tmp1)

val8=$[rint($(tmp2))]
val9=$[$val8/100]
val10=$[round($val8*$val6/10)/10]
replytype1=numexp
replyname1=Longueur en cm arrondie au mm
replygood1=$val10
question=__EXECUTED_1692754_EXERCISE__
help=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$() 
!read oef/special.phtml tooltip <b>Passer la souris ici pour afficher les caractéristiques du photocopieur</b>,[ABOVE,true,STICKY,true,CLOSEBTN,true] ,<ul><li>Formats de papier disponibles : A4 (21*29.7 cm) et A3 (29.7*42 cm)</li>	<li>Dimensions utiles de la vitre : A3</li>	<li>Coefficients disponibles pour les agrandissements et réductions : de 25% à 400% en nombre entier</li></ul>	Dans tous ces exercices, on fait abstraction du problème du positionnement de l'original sur la vitre du photocopieur<br>	(problème pourtant non négligeable dans la pratique !)	 
$()<p>		Je photocopie un motif de longueur $val6 cm en réglant le coefficient d'agrandissement/réduction du photocopieur sur $val8 %.	<br>Quelle sera la longueur du motif obtenu sur la photocopie ?	</p>		
$()
!exit

:hint
$()
$()
!exit

:help
$()Dimension finale = dimension initiale $m_times coefficient
$()
!exit

:solution
$()Dimension finale = dimension initiale $m_times coefficient<br>	Ce qui donne ici comme longueur après photocopie : 
!insmath $val6 \times $val8 \% = $val6 \times $val9 = $val10 cm
$() 
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,8,9,10
embedcnt=1
