!set title=5-Diagonale
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Chantal, Causse
email=Chantal.Causse@noos.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r,r,r
varcnt=14
prevarcnt=13
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 6, 20

val6=$[$(tmp0)/2]
tmp0=!randint 6, 20

val7=$[$val6 + $(tmp0)/2]
tmp0=!randitem 1,2

val8=$[rint($(tmp0))]
tmp0=!item $val8 of A4,A3

val9=$(tmp0)
tmp0=!item $val8 of 21,29.7

val10=$[$(tmp0)]
tmp0=!item $val8 of 29.7,42

val11=$[$(tmp0)]
val12=$[floor(100*min(400,min($val10/$val6,$val11/$val7)))]
val13=$[sqrt($val6^2 + $val7^2)]
tmp0=!random $val13*25, $val13*$val12

val14=$[floor($(tmp0)/10)/10]
val15=$[rint(round($val14/$val13*100))]
val16=$[round($val6*$val15/10)/10]
val17=$[round($val7*$val15/10)/10]
val18=xrange 1,300	yrange 1,200	linewidth 3	rect 50,50,250,150,red	linewidth 1	segment 40,50,40,150,blue	segment 50,40,250,40,green	textup blue,20,50,medium,Largeur = $val6 cm	text green,100,30,medium,Longueur = $val7 cm	
replytype1=numexp
replyname1=Coefficient en %
replygood1=$val15
replytype2=numexp
replyname2=Largeur en cm arrondie au mm
replygood2=$val16
replytype3=numexp
replyname3=Longueur en cm arrondie au mm
replygood3=$val17
question=__EXECUTED_1692754_EXERCISE__
hint=!nosubst Penser au théorème de Pythagore.


!goto stat

!exit

:question
$() 
!read oef/special.phtml tooltip <b>Passer la souris ici pour afficher les caractéristiques du photocopieur</b>,[ABOVE,true,STICKY,true,CLOSEBTN,true] ,<ul><li>Formats de papier disponibles : A4 (21*29.7 cm) et A3 (29.7*42 cm)</li>	<li>Dimensions utiles de la vitre : A3</li>	<li>Coefficients disponibles pour les agrandissements et réductions : de 25% à 400% en nombre entier</li></ul>	Dans tous ces exercices, on fait abstraction du problème du positionnement de l'original sur la vitre du photocopieur<br>	(problème pourtant non négligeable dans la pratique !)	 
$()<p>	 
!read oef/draw.phtml 300,200 \
$val18 
$()</p>	Je veux photocopier le rectangle ci-dessus de telle sorte que sa diagonale sur la photocopie mesure $val14 cm.		<p>Que dois-je choisir comme coefficient sur le photocopieur ? (arrondir au plus proche)	<br>Combien mesureront alors la largeur et la longueur ?	</p>		
$()
!exit

:hint
$()Penser au théorème de Pythagore.
$()
!exit

