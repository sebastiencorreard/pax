!set title=4-Agrandissement maximal 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Chantal, Causse
email=Chantal.Causse@noos.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=9
prevarcnt=8
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 6, 20

val6=$[$(tmp0)/2]
tmp0=!randint 6, 20

val7=$[$val6 + $(tmp0)/2]
tmp0=!randitem 1,2

val8=$[rint($(tmp0))]
tmp0=!item $val8 of A4,A3

val9=$(tmp0)
tmp0=!item $val8 of 21,29.7

val10=$[$(tmp0)]
tmp0=!item $val8 of 29.7,42

val11=$[$(tmp0)]
val12=$[floor(100*min(4,min($val10/$val6,$val11/$val7)))]
tmp0=!shuffle $val6,$val7

val13=$(tmp0)
replytype1=numexp
replyname1=Coefficient en %
replygood1=$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$() 
!read oef/special.phtml tooltip <b>Passer la souris ici pour afficher les caractķristiques du photocopieur</b>,[ABOVE,true,STICKY,true,CLOSEBTN,true] ,<ul><li>Formats de papier disponibles : A4 (21*29.7 cm) et A3 (29.7*42 cm)</li>	<li>Dimensions utiles de la vitre : A3</li>	<li>Coefficients disponibles pour les agrandissements et rķductions : de 25% Ó 400% en nombre entier</li></ul>	Dans tous ces exercices, on fait abstraction du problĶme du positionnement de l'original sur la vitre du photocopieur<br>	(problĶme pourtant non nķgligeable dans la pratique !)	 
$()	<p>	Je veux photocopier la reproduction d'un tableau que j'ai trouvķe dans un livre. <br>	Celle-ci mesure $(val13[1]) cm sur $(val13[2]) cm.</p>			Je souhaite l'agrandir<b> au maximum</b> pour qu'elle tienne sur une feuille de format	$val9, en fixant comme impķratif que les c¶tķs du tableau soient parallĶles aux	bords de la feuille sur la photocopie.<p>	Que dois-je choisir comme coefficient sur le photocopieur ?	</p>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback
!ifval $m_reply1 = $val12 + 1
 <div class='oef_feedbacks'>Attention : comme il s'agit d'un maximum, il ne faut pas arrondir, mais prendre une valeur approchķe <b>par dķfaut</b> du coefficient trouvķ.
$()</div>
!endif

!exit

:test

!exit

:stat
vsavelist=9,12,13
embedcnt=1
