val7=$[rint($(tmp0))]
!if $val7=1 
val8=Le quadrilatère \(FACB) est un parallélogramme&#44; car ses côtés sont parallèles deux à deux.,	   Le quadrilatère \(AECB) est un parallélogramme&#44; car ses côtés sont parallèles deux à deux.,	\(FA=BC=AE),	   La médiatrice de \([FE]) passe par \(A). De même&#44; la médiatrice de \([ED]) passe par \(C) et celle de \([DF]) par \(B).,	   Comme les côtés de FED sont parallèles aux côtés de ABC&#44; les médiatrices de FED sont les hauteurs de ABC.,	   Comme les médiatrices d'un triangle sont concourantes&#44; les hauteurs de ABC sont concourantes.	
val9=$val8
val10=250x100x1
val11=xrange -6,6	 yrange -3,9	 linewidth 2	 poly black,-5,8,5,8,2,-2	 poly blue,0,8,-1.5,3,3.5,3	 segment 0,3,0,8,red	 segment -1.09,4.38,3.5,3,red	 segment 1.86,5.35,-1.5,3,red	 text black,0,8.5,medium,A	 text black,-2,3,medium,B	 text black,4,3,medium,C	 text black,2,-2.5,medium,D	 text black,5,8.5,medium,E	 text black,-5,8.5,medium,F	
!endif
!if $val7=2 
val8=La médiatrice d'un segment est l'ensemble des points du plan qui sont équidistants des extrémités du segment.,	   On trace les médiatrices de \([AB]) et de \([AC]) et on note O leur point commun.,	   Du fait que O est un point de la médiatrice de [AB]&#44; on a \(OA = OB).,	   Du fait que O est un point de la médiatrice de [AC]&#44; on a \(OA = OC).,	   On a donc l'égalité \(OB = OC).,	   Le point O appartient donc à la médiatrice de \([BC]).
val9=$val8
val10=250x100x1
val11=xrange -5,10	 yrange -5,10	 linewidth 2	 poly black,0,8,-4,-2,8,-2	 segment -2,3,2,1.4,red	 segment 4,3,2,1.4,red	 segment -4,-2,2,1.4,blue	 segment 0,8,2,1.4,blue	 segment 8,-2,2,1.4,blue	 text black,0,8.5,medium,A	 text black,-4,-2.8,medium,B	 text black,8,-2.8,medium,C	 text black,2,1,medium,O	
!endif
!if $val7=3 
val8=\(I) étant le milieu de \([HB]) et \(J) le milieu de \([AH])&#44; un théorème de la "droite des milieux"&#44; dans le triangle \(ABH)&#44; implique que \((IJ) \parallel (BA)).,	   Comme \((BA)) est perpendiculaire à \((AC))&#44; \((IJ)) est également perpendiculaire à \((AC)).,	   Donc le point \(J) appartient à la hauteur issue de \(I) du triangle \(AIC).,	   Le point \(J) appartient à la hauteur issue de \(A) du triangle \(AIC).,	   La droite \((CJ)) est une hauteur du triangle \(AIC)&#44; car les trois hauteurs d'un triangle sont concourantes.,	   Les droites \((CJ)) et \((AI)) sont perpendiculaires.	
val9=$val8
val10=350x100x1
val11=xrange -0.5,8.5	 yrange -2,7	 linewidth 2	 poly black,0,5,0,0,8,0	 segment 0,0,2.25,3.6,red	 linewidth 5	 points black,1.12,4.3,1.12,1.8,blue	 text black,0,-0.5,medium,A	 text black,0,5.5,medium,B	 text black,8,-0.8,medium,C	 text black,1,5,medium,I	 text black,1,2.5,medium,J	 text black,2,4.4,medium,H	
!endif
