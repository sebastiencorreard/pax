!set title=Raisonnement en géométrie 4
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr
computeanswer=no

ansorder=r,r,r,r,r
varcnt=13
prevarcnt=12
postvarcnt=0
replycnt=5
choicecnt=0
conditioncnt=1
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=350x100x1
tmp0=!randitem 1,2

val7=$[rint($(tmp0))]
val8=xrange -4,12	yrange -3,13	segment 0,-2,0,10,black	segment -2,9,12,2,black	text black,11,1,medium,d1	text black,-1,-1,medium,d2	text black,1,8.5,medium,S	linewidth 5	
!if $val7=1 
tmp0=!randint 1, 7

val9=$[rint($(tmp0))]
val8=$val8	point $val9,$val9/2,black	text black,$val9,$val9/2+0.7,medium,P	
val10=\(P) soit le milieu de \([U V])
val11=On trace par \(P) la parallèle à \(d_1) qui coupe \(d_2) en Y&#44; et la parallèle à \(d_2) qui coupe \(d_1) en \(X).,	\(S X P Y) est un parallélogramme. Soit \(Z) le milieu de \([X Y]) &#44; la droite \((S P)) passe par \(Z).,	La parallèle à  \((X Y)) passant par \(P) coupe \(d_1) en \(U) et \(d_2) en \(V).,	D'après le théorème de Thalès appliqué aux sécantes \(d_1)&#44;\(d_2) et \((S P)) et aux parallèles \(X Y) et \((U V)) &#44; on a \(\frac{Z X}{P U}=\frac{S Z}{S P}=\frac{Z Y}{P V}).,	Comme \(Z X=Z Y)&#44; il vient \(P U=P V) et \(P) est le milieu de \([U V]).	
!else
tmp0=!randint -1, 7

val12=$[rint($(tmp0))]
val8=$val8	point -2,$val12,black	text black,-2,$val12+0.7,medium,P	
val10=\(V) soit le milieu de \([P U])
val11=On trace la parallèle à \(d_1) passant par \(P) qui coupe \(d_2) en X.,	Soit \(V) le milieu de \([S X]).,	La droite \((V P)) coupe \(d_1) en \(U).,	D'après le théorème de Thalès appliqué aux sécantes \(d_2) et \((V P)) et aux parallèles \(d_1) et \((P X)) &#44; on a \(\frac{V P}{V U}=\frac{V X}{V S}).,	Comme \(V X=V S)&#44;  il vient \(V P=V U) et \(V) est le milieu de \([P U]).	
!endif
val13=$val11
replytype1=clickfill
replyname1=raisonnement
replygood1=$(val13[1]);$val11
replytype2=clickfill
replyname2=raisonnement
replygood2=?analyze 14;$val11
replytype3=clickfill
replyname3=étape 3
replygood3=?analyze 15;$val11
replytype4=clickfill
replyname4=étape 4
replygood4=$(val13[4]);$val11
replytype5=clickfill
replyname5=étape 5
replygood5=$(val13[5]);$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div class="float_right"> 
!read oef/draw.phtml 200,200 \
$val8 
$()</div>	Etant données deux droites 
!insmath d_1
$() et 
!insmath d_2
$() sécantes en 
!insmath S
$(),	et un un point 
!insmath P
$() non situé sur ces droites, déterminez deux points	
!insmath U
$() sur 
!insmath d_1
$() et 
!insmath V
$() sur 
!insmath d_2
$() tels que $val10.	<p>	Pour cela, ordonnez le raisonnement ci-dessous.	</p>	<br class="clearall">	<ul class="wims_nopuce"><li> 
!read oef/embed.phtml reply1,$val6 
$()  
!read oef/embed.phtml reply2,$val6 
$() </li>	<li> 
