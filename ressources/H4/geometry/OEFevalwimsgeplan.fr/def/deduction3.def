t_=!rawmath ($val19*$val11-$val20*$val13+$val14-$val12)/($val19-$val20)
val21=!exec pari print($t_)
t_=!rawmath $val19*$val21- $val19*$val11+$val12
val22=!exec pari print($t_)
t_=!rawmath $val22
val23=!exec pari print($t_)
t_=!rawmath $val22
val24=!exec pari print($t_)
t_=!rawmath $val11+($val23-$val12)/($val18-$val12)*($val17-$val11)
val25=!exec pari print($t_)
t_=!rawmath $val13+($val24-$val14)/($val16-$val14)*($val15-$val13)
val26=!exec pari print($t_)
