
!set cut=!item $askcnt of 0,0,0,3,4,4,46,47
<center>
!for i=1 to $askcnt
 !if $i isin $cut
  <p>
 !else
  !if $i>1
   &nbsp;&nbsp;
  !endif
 !endif
 !for t in ba,ca
  !set t$t=!item $i of $($(t)_list)
 !next t
 !set formula=!htmlmath $tba*x-$tca
 !if $status=waiting
  !href cmd=reply&good=$i y&nbsp;=&nbsp;$formula
 !else
  !if $i=$good
   <b>
  !endif
  !if $i=$real
   <font color=blue>
  !endif
  y&nbsp;=&nbsp;$formula
  !if $i=$good
   </b>
  !endif
  !if $i=$real
   </font>
  !endif
 !endif
!next i
</center>

