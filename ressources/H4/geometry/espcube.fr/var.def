# Variable declaration file.
#
# Only those variables with possible user inputs or requiring inter-request
# savings need to be declared in this file.
#
#Each non-comment line defines a variable. Format of the line:
#
#name	allow
#
#Or the condensed format
#
#allow: name name name ...
#
#name: name of the variable
#allow: when allow the user to override the defined value.
#       it maybe any, deny, init, config, reply.
#
#
#name	allow

status	deny

init: mode niv selplan ceplan colblue colrose
reply: ract rpt1 rpt2 rdte user rptp rseg1 rseg2 rseg choix1 choix2 raux
deny: listexos exotitles listactcube listacttetr
deny: note step verygoodmsg forms nbsteps actcnt cnt
deny: plan tplan cadre numpoint listpoint ptcoplan
deny: bary_x bary_y
deny: ptA ptB ptC ptD ptE ptF ptG ptH ptI ptJ ptK ptL
deny: ptM ptN ptO ptP ptQ ptR ptS ptT
deny: ptU[8] ptV[8] ptW[1] ptX[8] ptY[8] ptZ[8] ptI[6] ptJ[6]
deny: substpt
deny: ptK[6]  ptL[6] ptM[6] ptN[6] ptO[6] ptP[6] ptQ[6] ptR[6] ptS[6] ptT[6]
deny: ptA[6] ptB[6] ptC[6] ptE[6] ptF[6] ptG[6] ptH[6]

deny: faceA faceB faceC faceD faceE faceF faceG faceH
deny: faceI faceJ faceK faceL faceM faceN faceO faceP
deny: faceQ faceR faceS faceT
deny: faceU[8] faceV[8] faceW[8] faceX[8] faceY[8] faceZ[8]

deny: dteA dteB dteC dteD dteE dteF dteG dteH
deny: dteI dteJ dteK dteL dteM dteN dteO dteP
deny: dteQ dteR dteS dteT
deny: dte[12]
deny: sommet[6]
deny: milieu[6]
deny: aux[8] auxpt
deny: prol[24]

deny: colorA colorB colorC colorD
deny: colorE colorF colorG colorH
deny: colorI colorJ colorK colorL
deny: colorM colorN colorO colorP
deny: colorQ colorR colorS colorT
deny: relieX[8] relieY[8] relieZ[8] relieU[8] relieV[8] relieW[8]
deny: ptsplan segsplan
deny: lstface lstfac2 indlst2 ladte segpar cettepar typestep
deny: lstsegs sortpts segpoly flpoly errcnt segscube segsprol
deny: xmax xmaxmax xmaxdef xmin xminmin xmindef cube
deny: ymax ymaxmax ymaxdef ymin yminmin ymindef
deny: pt1 pt2 pt3 pt4 dessindte goodrep1 goodrep2 posrel1 posrel2
deny: marep1 marep2 colorrep1 colorrep2 posrel3 posrel4 posrel5 nattriangle
deny: lstplanaux segsaux

!read listeprol.def
