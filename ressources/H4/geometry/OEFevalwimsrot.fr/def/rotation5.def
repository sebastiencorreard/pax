!set title=Identifier une rotation 5
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr

ansorder=c
varcnt=19
prevarcnt=18
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=red,blue,yellow,green,purple
val7=rouge,bleu,jaune,vert,violet
tmp0=!values v for v=1 to 9

val8=$(tmp0)
tmp0=!shuffle $val8

val8=$(tmp0)
tmp0=!item $val8 of $val6

val6=$(tmp0)
tmp0=!item $val8 of $val7

val7=$(tmp0)
val9=$[rint(150)]
val10=$[rint(150)]
tmp0=!randint 40, 70

val11=$[rint($(tmp0))]
tmp0=!randint 110, 140

val12=$[rint($(tmp0))]
tmp0=!random -pi, pi

val13=$[$(tmp0)]
tmp0=!randitem 1,-1

tmp1=!random pi/3, 2*pi/3

val14=$[$(tmp0)*$(tmp1)]
val15=$[rint(1)]
tmp0=!shuffle $val11,$val12

val16=$(tmp0)
!readproc oef/draw.phtml 300,300 \
circle $val9,$val10,2*$val11,black	circle $val9,$val10,2*$val12,black	fcircle $val9+$(val16[1])*cos($val13),$val9+$(val16[1])*sin($val13),10,$(val6[1])	fcircle $val9+$(val16[2])*cos($val13+$val14),$val9+$(val16[2])*sin($val13+$val14),10,$(val6[2]) 
tmp0=$ins_url
val17=$(tmp0)
val18=Existe-il une rotation telle que l'image du point $(val7[1]) soit le point $(val7[2])
val19=Oui,Non
tmp0=!item $val15 of $val19

val20=$(tmp0)
choicename1=
choicegood1=$val20
choicebad1=Oui,Non
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()$val18 ?	<div class="wimscenter"> <img src="$val17" alt=""></div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=17,18
embedcnt=0
