!set title=Identifier une rotation 4
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr

ansorder=c
varcnt=37
prevarcnt=36
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=red,blue,yellow,green,purple
val7=rouge,bleue,jaune,verte,violette
tmp0=!values v for v=1 to 9

val8=$(tmp0)
tmp0=!shuffle $val8

val8=$(tmp0)
tmp0=!item $val8 of $val6

val6=$(tmp0)
tmp0=!item $val8 of $val7

val7=$(tmp0)
val9=0,0,0,30,20,30,20,-30,-30,-30
tmp0=!randint 140, 160

val10=$[rint($(tmp0))]
tmp0=!randint 140, 160

val11=$[rint($(tmp0))]
tmp0=!randint 60, 70

val12=$[rint($(tmp0))]
tmp0=!itemcnt $val9

val13=$[rint($(tmp0)/2)]
tmp0=!random -pi, pi

val14=$[$(tmp0)]
tmp0=!random -pi, pi

val15=$[$(tmp0)]
val16=$[pi]
val17=
val18=
tmp=!nonempty items 1,2,2,2

tmp0=!randitem $tmp
val19=$[rint($(tmp0))]
tmp0=!randint 4, 7

val20=$[1+($val19-1)*$(tmp0)/10]
!for val21 =1 to $val13 
val22=$[sqrt(($(val9[2*$val21-1]))^2+($(val9[2*$val21]))^2)]
!if $val22!=0 
val23=$[arccos($(val9[2*$val21-1])/$val22)]

!ifval $(val9[2*$val21])<0
val23=$[-$val23]
!endif
val24=$[$val10+$val12*cos($val15)+$val22*cos($val23+$val14+$val15)]
val25=$[$val11+$val12*sin($val15)+$val22*sin($val23+$val14+$val15)]
val26=$[$val10+$val12*cos($val15+$val16)+$val20*$val22*cos($val23+$val14+$val15+$val16)]
val27=$[$val11+$val12*sin($val15+$val16)+$val20*$val22*sin($val23+$val14+$val15+$val16)]
!else
val24=$[$val10+$val12*cos($val15)]
val25=$[$val11+$val12*sin($val15)]
val26=$[$val10+$val12*cos($val15+$val16)]
val27=$[$val11+$val12*sin($val15+$val16)]
!endif
tmp0=!append item $val24,$val25 to $val17

val17=$(tmp0)
tmp0=!append item $val26,$val27 to $val18

val18=$(tmp0)
!next
!readproc oef/draw.phtml 300,300 \
poly $(val6[1]),$val17	poly $(val6[2]),$val18 
tmp0=$ins_url
val28=$(tmp0)
val29=Existe-il une rotation telle que l'image de la figure $(val7[1]) soit la figure $(val7[2])
val30=Oui,Non
tmp0=!item $val19 of $val30

val31=$(tmp0)
choicename1=
choicegood1=$val31
choicebad1=Oui,Non
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()$val29 ?	<div class="wimscenter"> <img src="$val28" alt=""></div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=28,29
embedcnt=0
