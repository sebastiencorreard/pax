!set title=Point sur la droite ?
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Thomas Charon
email=thomas.charon@ac-lyon.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=yes
precision=10000

ansorder=r
varcnt=17
prevarcnt=16
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem 1,2,3,3,3

val6=$[rint($(tmp0))]
tmp0=!randitem 1,2

val7=$[rint($(tmp0))]
tmp0=!randint -10, 10

val8=$[rint($(tmp0))]
tmp0=!randint -10, 10

val9=$[rint($(tmp0))]
tmp0=!randint 1, 10

tmp1=!randitem -1,1

val10=$[rint($(tmp0)*$(tmp1))]

!ifval $val9<0
val11=$val9
!else
val11=+$val9
!endif

!ifval $val10=-1
val12=-x
!else
val12=$val10 x
!endif

!ifval $val10=1
val12=x
!endif

!ifval $val9=0
val13=$val12
!else
val13=$val12 $val11
!endif
tmp0=!item $val6 of x=$val8,y=$val9,y=$val13

val14=$(tmp0)
tmp0=!randint -10, 10

tmp1=!randint -10, 10

tmp2=!item $val6 of $val8,$(tmp0),$(tmp1)

val15=$[rint($(tmp2))]
tmp0=!randint -10, 10

tmp1=!item $val6 of $(tmp0),$val9,$val10*$val15+$val9

val16=$[rint($(tmp1))]
tmp0=!randint 1, 10

tmp1=!randitem -1,1

val17=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -10, 10

tmp1=!randint -10, 10

tmp2=!item $val6 of $val8+$val17,$(tmp0),$(tmp1)

val18=$[rint($(tmp2))]
tmp0=!randint -10, 10

tmp1=!item $val6 of $(tmp0),$val9+$val17,$val10*$val15+$val9

val19=$[rint($(tmp1))]
val20=appartient ,n'appartient pas
replytype1=menu
replyname1=
replygood1=$val7;$val20
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()		On considère la droite 
!insmath (d)
$() d'équation réduite 
!insmath $val14
$().<p>	Le point A 
!if $val7=1 
$()
!insmath ($val15;$val16)
$() 
!else
$() 
!insmath ($val18;$val19)
$() 
!endif
$()  
!read oef/embed.phtml reply 1 
$() à la droite 
!insmath (d)
$() </p>	
$()
!exit

