!set title=Tracer d'une droite ŗ partir de son ťquation rťduite
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Thomas Charon
email=thomas.charon@ac-lyon.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=yes
precision=1000

ansorder=r
varcnt=25
prevarcnt=21
postvarcnt=3
replycnt=1
choicecnt=0
conditioncnt=3
feedbackcnt=2
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items 1,2,3,3,3

tmp0=!randitem $tmp
val6=$[rint($(tmp0))]
val7=$[rint(0)]
tmp0=!randint 1, 5

tmp1=!randitem -1,1

val8=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -5, 5

val9=$[rint($(tmp0))]
tmp0=!randint -5, 5

val10=$[rint($(tmp0))]
!while  $val10=$val9   
tmp0=!randint -5, 5

val10=$[rint($(tmp0))]
!endwhile
val11=$[rint($val9)]
t_=!rawmath ($val10-$val9)/($val8-$val7)
val12=!exec pari print($t_)
tmp=!translate ";': to $     $ in $val12

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val12=!exec pari print($t_)
!if $val6=1 
tmp0=!randint -5, 5

val7=$[rint($(tmp0))]
val8=$[rint($val7)]
val13=$val7
val14=0*y+x-$val7	        
!endif
!if $val6=2 
val9=$[rint($val10)]
val13=$val9
val14=y+0*x-$val9
!endif
!if $val6=3 

!ifval $val11=0
val13=$val12*x
!else
val13=$val12*x+$val11
!endif
val14=y-($val13)
!endif
val15=var brd = JXG.JSXGraph.initBoard('jxgbox', {	 axis:true,boundingbox: [-6, 6, 6, -6], grid:true});	jxgbox_rep1 = brd.create('point',jxgbox_var1 , {snapToGrid:true});	jxgbox_rep2 = brd.create('point',jxgbox_var2, {snapToGrid:true} );	d = brd.create('line',[jxgbox_rep1,jxgbox_rep2] );	
val16=var brd = JXG.JSXGraph.initBoard('jxgbox', {	 axis:true,boundingbox: [-6, 6, 6, -6], grid:true});	jxgbox_rep1 = brd.create('point',[$val7,$val9], {fixed:true});	jxgbox_rep2 = brd.create('point',[xb,yb], {fixed:true} );	d = brd.create('line',[[$val7,$val9],[xb,yb]] );	

!ifval $val6=3
val17=1 2 3
!else
val17=1 2
!endif
replytype1=jsxgraph

replyoption1=precision=10 
replyname1=
replygood1=?analyze 18
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

