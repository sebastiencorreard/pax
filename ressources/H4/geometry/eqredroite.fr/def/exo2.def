:postdef
evaltmp=$val14

evaltmp=!mathsubst x=($(val18[1;1])) in $evaltmp
evaltmp=!mathsubst y=($(val18[1;2])) in $evaltmp
tmp0=($evaltmp)
t_=!rawmath $(tmp0)
val19=!exec pari print($t_)
evaltmp=$val14

evaltmp=!mathsubst x=($(val18[2;1])) in $evaltmp
evaltmp=!mathsubst y=($(val18[2;2])) in $evaltmp
tmp0=($evaltmp)
t_=!rawmath $(tmp0)
val20=!exec pari print($t_)
val21=$[rint(($(val18[1;1])-$(val18[2;1]))^2+($(val18[1;2])-$(val18[2;2]))^2)]

!exit

:feedback
!ifval $val19!=1 or $val20!=0
 <div class='oef_feedbacks'><script>	rep=brd.create('line',[[$val7,$val9],[$val8,$val10]],{name:'Correction',Color:'green',fixed:'true'});	</script>	<p> La bonne rťponse est reprťsentťe en vert.</p>
$()</div>
!endif
!ifval $val21<=9 and   $val19=0 and $val20=0 and $val6=3
 <div class='oef_feedbacks'>Sur votre copie, vous auriez dŻ placer les points 	
!insmath A
$() et 
!insmath B
$() plus ťloignťs l'un de l'autre, afin d'avoir une prťcision satisfaisante sur votre graphique. 	Essayez d'en tenir compte la prochaine fois.
$()</div>
!endif

!exit

:test

condlist= 1 2

condlist=$val17
condweight1=5 

!ifval $val19=0 
 condtest1=1
!else
 condtest1=0
!endif
condname1=\(A \in (d)) ?
condweight2=5 

!ifval $val20=0 and $val21>0 
 condtest2=1
!else
 condtest2=0
!endif
condname2=\(B \in (d)) et \(B\neq A) ?
condweight3=1 

!ifval $val21 >= 16
 condtest3=1
!else
 condtest3=0
!endif
condname3=\(A) et \(B) suffisamment ťloignťs ?

!exit

:stat
vsavelist=6,7,8,9,10,13,14,15,17,18
embedcnt=1
