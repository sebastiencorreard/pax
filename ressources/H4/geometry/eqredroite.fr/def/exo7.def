!set title=Dťterminer la seconde coordonnťe d'un point.
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Thomas Charon
email=thomas.charon@ac-lyon.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=yes
precision=10000

ansorder=r
varcnt=9
prevarcnt=8
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem 1,2

val6=$[rint($(tmp0))]
tmp0=!randint -10, 10

val7=$[rint($(tmp0))]
tmp0=!randint -10, 10

val8=$[rint($(tmp0))]
tmp0=!randint 1, 10

tmp1=!randitem -1,1

val9=$[rint($(tmp0)*$(tmp1))]
t_=!rawmath $val9*$val7+$val8
val10=!exec pari print($t_)
t_=!rawmath ($val7-$val8)/$val9
val11=!exec pari print($t_)
tmp0=!item $val6 of $val10,$val11

t_=!rawmath $(tmp0)
val12=!exec pari print($t_)
tmp0=!item $val6 of ($val7;y),(x;$val7)

val13=$(tmp0)
replytype1=formal
replyname1=Coordonnťe manquante du point \(M)
replygood1=$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()		Soit 
!insmath M
$() de coordonnťes 
!insmath $val13
$() un point de la droite 
!insmath d:y=$val9 x+$val8
$().	Dťterminer la coordonnťe manquante.  	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
