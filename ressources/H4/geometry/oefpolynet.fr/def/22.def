!set title=Nombre de sommets
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Bernadette,Perrin-Riou
email=bernadette.m.riou@orange.fr
title_it=Numero di vertici

ansorder=r
varcnt=23
prevarcnt=19
postvarcnt=3
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=Le nom du polyčdre est
val8=Donner le nombre de sommets du polyčdre convexe dont le patron est le suivant
val9=Le nombre de sommets est
!if $val6=it 
val7=Il poliedro si chiama
val8=Individua il numero di vertici del poliedro il cui sviluppo č qui mostrato
val9=Il numero di vertici č
!endif

!ifval $val2=
val10=1
!else
val10=$val2
!endif

!ifval $val10=1
tmp=!translate internal $	$ to ; in 4,5	6,7	7,8	8	8,9	8,10

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val11=$(tmp0)
!endif

!ifval $val10=2
tmp=!translate internal $	$ to ; in 11	12	12,13	13,14	15,16	17	18	19

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val11=$(tmp0)
!endif

!ifval $val10=3
tmp=!translate internal $	$ to ; in 20,21	22	24	26	27,30	32

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val11=$(tmp0)
!endif

!ifval $val10=4
tmp=!translate internal $	$ to ; in 34,37	38,42	47,52	60	62

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val11=$(tmp0)
!endif
tmp0=!record 0 of data/polyedre_off/index2

val12=$(tmp0)
tmp0=!select $val12 where column 3 isitemof $val11

val13=$(tmp0)
tmp=!translate internal $	$ to ; in $val13

tmp0=!rowcnt $tmp
val14=$(tmp0)
tmp0=!shuffle $val14

val15=$(tmp0)
tmp=!translate internal $	$ to ; in $val13

tmp=!row 1 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val13=$(tmp0)
val16=$(val13[1;2])
!readproc slib/geo2D/polynet $(val13[1;1]),size=200 html 
tmp0=$slib_out
val17=$(tmp0)
replyname1=
replygood1=$val16
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val8	$val17	<label for="reply1">$val9</label>  
!read oef/embed.phtml r1,4 
$().	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:postdef
!readproc slib/geo3D/polyhedra $(val13[1;1]),300,300,show=[S,A,F] color=[black,green,yellow,blue] width=[6,2] id=0 
tmp0=$slib_out
val18=$(tmp0)
tmp0=!lookup $(val13[1;1]) in data/polyedre_off/index.$val6

val19=$(tmp0)
val19=$(val19[1])

!exit

:feedback
!ifval 1=1
 <div class='oef_feedbacks'>	  $val7 <strong>$val19</strong>.	  <div>$val18</div>	
$()</div>
!endif

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,13,17
embedcnt=1
