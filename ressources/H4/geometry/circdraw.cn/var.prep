
def=!randitem $list
!read language lang/names
!read defs/$def

!if $gtype=circle
 xt=$[($cx-$xrange1)*$size/($xrange2-$xrange1)]
 yt=$[($yrange2-($cy))*$size/($yrange2-$yrange1)]
 gdata=$xt,$yt,$radius
 gplot=circle $cx,$cy,$[$radius*2+1],$color2
!endif

drawsrc=xrange $xrange1,$xrange2\
yrange $yrange1,$yrange2\
fill 0,0,240,240,240\
$picture

status=waiting
!advance trycnt
