# Variable initialisation file.
# This file is read by wims for new sessions.

# contenu du fichier: initialisation du probleme.

style=!listintersect $style and 1,3,4,5
!read defaults

!if $askcnt=8
 miss=no
!endif

wims_module_log=$cmd: $repeat times $style
!distribute item next,0,0 into status,replycnt,goodcnt

