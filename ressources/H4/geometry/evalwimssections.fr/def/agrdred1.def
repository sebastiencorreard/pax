!set title=Agrandissement et réduction 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=c,r
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=1
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=un agrandissement,une réduction
tmp=!nonempty items 50,20,25,10

tmp0=!randitem $tmp
val7=1/$(tmp0)
tmp0=!texmath $val7

val8=$(tmp0)
!readproc slib/lang/fname fr,boy 
tmp0=$slib_out
val9=$(tmp0)
tmp=!nonempty items camion,bateau,avion

tmp0=!randitem $tmp
val10=$(tmp0)
val11=multiplie
tmp0=!item 2 of $val6

val12=$(tmp0)
replytype1=numeric
replyname1=Question 2
replygood1=$[$val7]
choicename1=Question 1
choicegood1=$val12
choicebad1=$val6
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val9 possède un modèle réduit d'un $val10 au 
!insmath $val8
$().	<ol>	 <li>Le modèle réduit est-il un agrandissement ou une réduction du véritable $val10 ?</li>	 <li>Par quel coefficient faut-il multiplier les longueurs du modèle réel pour obtenir	 celle du modèle réduit ? </li>	</ol>	<p>	<strong>Votre réponse :</strong>	</p>	<ol>	 <li>c'est  
!read oef/embed.phtml c1 
$().</li>	 <li>Il faut multiplier les longueurs par  
!read oef/embed.phtml r1,10 
$().</li>	</ol>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=8,9,10
embedcnt=2
