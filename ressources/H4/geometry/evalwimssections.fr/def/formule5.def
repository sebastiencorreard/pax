!set title=Formule d'aire et volume 5
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=13
prevarcnt=12
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 20

val6=$[rint($(tmp0))]
val7=4*pi*$val6^2
val8=Quelle est la mesure de l'aire de la surface d'une sphère de rayon \($val6 cm)
val9=Son volume est de
val10=\(cm^2)
tmp0=!randint 1, 3

val11=$[rint($(tmp0))]
tmp=!trim au dixième,1	  au centième,2	  au milième,3	  à 0.1 près,1	  à 0.01 près,2	  à 0.001 près,3
val12=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val12

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val12=$(tmp0)
tmp0=!item 1 of $val12

val13=$(tmp0)
tmp0=!item 2 of $val12

val11=$[rint($(tmp0))]
val14=$[rint($val7*10^($val11))]
val7=$[$val14/10^($val11)]
replytype1=numexp
replyname1=Réponse
replygood1=$val7
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val8 ?	<div>	<strong>Votre réponse :</strong>	$val9  
!read oef/embed.phtml r1,12 
$() $val10.	</div>	<div class="wims_instruction">	  Vous arrondirez, si nécessaire, votre résultat $val13.	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=8,9,10,13
embedcnt=1
