!set title=Formule d'aire et volume 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=14
prevarcnt=13
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 15

val6=$[rint($(tmp0))]
tmp0=!randint 10, 50

val7=$[rint($(tmp0))]
val8=$val6^2*$val7/3
val9=Quelle est la mesure du volume d'une pyramide dont la base est un carré dont les côtés mesurent \($val6 cm) et dont la hauteur mesure \($val7 cm)
val10=Son volume est de
val11=\(cm^3)
tmp0=!randint 1, 3

val12=$[rint($(tmp0))]
tmp=!trim au dixième,1	  au centième,2	  au milième,3	  à 0.1 près,1	  à 0.01 près,2	  à 0.001 près,3
val13=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val13

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val13=$(tmp0)
tmp0=!item 1 of $val13

val14=$(tmp0)
tmp0=!item 2 of $val13

val12=$[rint($(tmp0))]
val15=$[rint($val8*10^($val12))]
val8=$[$val15/10^($val12)]
replytype1=numexp
replyname1=Réponse
replygood1=$val8
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val9 ?	<div>	<strong>Votre réponse :</strong>	$val10  
!read oef/embed.phtml r1,12 
$() $val11.	</div>	<div class="wims_instruction">	  Vous arrondirez, si nécessaire, votre résultat $val14.	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=9,10,11,14
embedcnt=1
