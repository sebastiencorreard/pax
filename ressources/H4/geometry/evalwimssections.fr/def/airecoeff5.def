!set title=Agrandissement réduction et aire 5
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r,r
varcnt=7
prevarcnt=6
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items 1000,2000,5000

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!texmath 1/$val6

val7=$(tmp0)
!readproc slib/lang/fname fr,girl 
tmp0=$slib_out
val8=$(tmp0)
tmp0=!randint 10, 300

val9=$[$(tmp0)/100]
val10=$[$val9*$val6^2]
val11=$[$val10/10000]
replytype1=numeric
replyname1=mesure en \(\cm^2)
replygood1=$[$val10]
replytype2=numeric
replyname2=mesure en \(\m^2)
replygood2=$[$val11]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Sur une carte au 
!insmath $val7
$(), $val8 a calculé la mesure de l'aire d'un terrain.	Elle a trouvé 
!insmath $val9 cm^2
$().<br>	Quelle est la mesure de l'aire réelle en 
!insmath cm^2
$() puis en 
!insmath m^2
$() du terrain ?	<p>	<strong>Votre réponse :</strong>	</p>	L'aire du terrain mesure  
!read oef/embed.phtml r1,12 
$() 
!insmath cm^2
$() soit  
!read oef/embed.phtml r2,12 
$() 
!insmath m^2
$().	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,8,9
embedcnt=2
