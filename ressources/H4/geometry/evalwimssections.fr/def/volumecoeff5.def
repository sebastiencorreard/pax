!set title=Agrandissement réduction et volume 5
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=1000000

ansorder=r,r
varcnt=7
prevarcnt=6
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items 10,20,50

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!texmath 1/$val6

val7=$(tmp0)
!readproc slib/lang/fname fr,girl 
tmp0=$slib_out
val8=$(tmp0)
tmp0=!randint 10, 300

val9=$[$(tmp0)]
val10=$[$val9*$val6^3]
val11=$[$val10/1000000]
replytype1=litexp
replyname1=mesure en \(\cm^3)
replygood1=$val10
replytype2=litexp
replyname2=mesure en \(\m^3)
replygood2=$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Un forgeron dispose d'une maquette au 
!insmath $val7
$() d'une statue	 qu'il doit réaliser. Le modèle réduit est constitué du même alliage de métal 	 que la véritable statue. Le volume de métal utilisée pour la maquette est de 	 
!insmath $val9 cm^3
$().	 <p>	Quel volume de métal devra-t-il utiliser pour fabriquer la véritable statue ?	Vous donnerez votre résultat en 
!insmath cm^3
$() puis en 
!insmath m^3
$().	</p>		<p>	<strong>Votre réponse :</strong>	</p>	Le forgeron aura besoin de  
!read oef/embed.phtml r1,12 
$() 
!insmath cm^3
$() de métal soit  
!read oef/embed.phtml r2,12 
$() 
!insmath m^3
$().	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,9
embedcnt=2
