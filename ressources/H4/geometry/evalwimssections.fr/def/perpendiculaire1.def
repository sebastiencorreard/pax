!set title=Section plane perpendiculaire
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=c
varcnt=18
prevarcnt=17
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=$[rint(1)]
tmp=!trim pave,cube,100,100,50,,,une face,2,	pave,cube,100,100,50,,,une arête,1,	pave,parallélépipède rectangle,75,125,25,,,une face,2,	pave,parallélépipède rectangle,75,125,25,,,une arête,2,	cone,cône de révolution,75,125,25,,,sa base,4,	cone,cône de révolution,75,125,25,,,son axe de révolution,3,	cylindre,cylindre de révolution,75,125,25,,,sa base,2,	cylindre,cylindre de révolution,75,125,25,,,son axe de révolution,3,
val7=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val7

tmp=!row $val6 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val8=$(tmp0)
val9=carré,rectangle,cercle,triangle,parallélogramme,cube,parallélépipède rectangle,cône de révolution,pyramide,cylindre
tmp0=!item 1 of $val8

val10=$(tmp0)
tmp0=!item 2 of $val8

val11=$(tmp0)
tmp0=!item 3 to 7 of $val8

val12=$(tmp0)
tmp0=!item 8 of $val8

val13=$(tmp0)
tmp0=!item 9 of $val8

val14=$[rint($(tmp0))]
tmp0=!item $val14 of $val9

val14=$(tmp0)
tmp0=!item 10 of $val8

val15=$(tmp0)
val16=$[rint(0.5)]
!readproc slib/local/solide $val10,$val16,$val12 
tmp0=$slib_out
val17=$(tmp0)
tmp0=!line 1 of $val17

val18=$(tmp0)
tmp0=!line 2 to -1 of $val17

val17=$(tmp0)
tmp0=!item 1 of $val18

val19=$[rint($(tmp0))]
tmp0=!item 2 of $val18

val20=$[rint($(tmp0))]
choicename1=Réponse
choicegood1=$val14
choicebad1=$val9
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  On coupe le $val11 ci-dessous perpendiculairement à $val13.	  Quelle sera la nature de la section plane obtenue ?	<div class="wimscenter">	 
!read oef/draw.phtml $val19,$val20 \
$val17 
$()	</div>	<strong>Votre réponse :</strong>	  C'est  
!read oef/embed.phtml c1 
$().	
$()
!exit

