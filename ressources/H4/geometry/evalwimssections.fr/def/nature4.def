!set title=Nature d'un solide
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=c
varcnt=17
prevarcnt=16
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=$[rint(4)]
val7=$[rint(120)]
val8=$[rint(150)]
val9=$[rint(80)]
val10=$[rint(100)]
tmp0=!randint 50, 70

val11=$[rint($(tmp0))]
tmp=!nonempty items tetraedre,pyramide

tmp0=!randitem $tmp
val12=$(tmp0)
val13=un parallélépipède rectangle,un cube,un cône,une pyramide,une sphère,un cylindre,un carré, un cercle, un rectangle, un triangle
tmp0=!item $val6 of $val13

val14=$(tmp0)
val15=$[rint(0.5)]
!readproc slib/local/solide $val12,$val15,$val7,$val8,$val9,$val10,$val11 
tmp0=$slib_out
val16=$(tmp0)
val17=$val16
tmp0=!line 1 of $val16

val18=$(tmp0)
tmp0=!line 2 to -1 of $val16

val16=$(tmp0)
tmp0=!item 1 of $val18

val19=$[rint($(tmp0))]
tmp0=!item 2 of $val18

val20=$[rint($(tmp0))]
choicename1=Réponse
choicegood1=$val14
choicebad1=$val13
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

