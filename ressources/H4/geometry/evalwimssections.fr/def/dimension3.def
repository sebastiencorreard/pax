val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!shuffle A,B,C,D,E,F,G,H,I,K,L,M,N,O,P,Q,R,S,T,U,V,W,X,Y,Z

val6=$(tmp0)
tmp0=!item 1 of $val6

val7=$(tmp0)
tmp0=!item 2 of $val6

val8=$(tmp0)
tmp0=!item 3 of $val6

val9=$(tmp0)
tmp0=!item 4 of $val6

val10=$(tmp0)
tmp0=!values v for v=5 to 13

val11=$(tmp0)
tmp0=!shuffle $val11

val11=$(tmp0)
val12=$[rint(max($(val11[1]),$(val11[4])))]
val13=$[rint($(val11[2]))]
val14=$[rint(min($(val11[1]),$(val11[4])))]
val15=$[rint($val12*$(val11[3]))]
val16=$[rint($val13*$val14)]
val17=$[rint($val12*$val13)]
val18=$[rint($val15*$val16/$val17)]
tmp=!nonempty items parallèle à sa base,perpendiculaire à son axe de révolution

tmp0=!randitem $tmp
val19=$(tmp0)
val20=\(\mathcal{C}) est un cône de sommet \($val7) dont la base est un disque de rayon \($val15 cm). \($val8) est le point de l'axe de révolution de \(\mathcal{C}) tel que \($val7$val8 = $val16 cm). On coupe le cône par un plan $val19 et passant par le point \($val8). La section plane obtenue est un cercle. Sachant que la hauteur du cône est de \($val17 cm), quel est le rayon du cercle obtenu
val21=$[rint($val18)]
val22=Le rayon de la section plane mesure
replytype1=numexp
replyname1=réponse
replygood1=$val21
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

