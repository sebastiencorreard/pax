!set title=Agrandissement réduction et aire 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=12
prevarcnt=11
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items C,D,E,R

tmp0=!randitem $tmp
val6=$(tmp0)
tmp=!nonempty items disque,triangle,carré,losange,parallélogramme,pentagone

tmp0=!randitem $tmp
val7=$(tmp0)
tmp0=!randint 10, 100

val8=$[$(tmp0)/10]
tmp0=!randint 1, 9

tmp1=!randint 11, 99

tmp=!nonempty items $(tmp0)/10,$(tmp1)/10

tmp2=!randitem $tmp
val9=$[$(tmp2)]
val10=$[$val8*$val9^2]
val11=\mathcal{$val6}
val12=\mathcal{$val6}'
val13=$val8
val14=$val10

!ifval $val9<1
val15=une réduction
!else
val15=un agrandissement
!endif
val16=\(\mathcal{$val6}) est un $val7 obtenu à partir d'un $val7 \(\mathcal{$val6}') par $val15 de coefficient \($val9)
replytype1=litexp
replyname1=réponse
replygood1=$val14
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val16.<br>	  Quelle est la mesure de l'aire de 
!insmath $val11
$() sachant que l'aire de 
!insmath $val12
$() mesure 
!insmath $val13 cm^2
$() ?	<p>	<strong>Votre réponse :</strong>	</p>	  L'aire de 
!insmath $val11
$() mesure  
!read oef/embed.phtml r1,12 
$() 
!insmath cm^2
$().	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=11,12,13,16
embedcnt=1
