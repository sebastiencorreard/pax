!ifval ($(val32[3])-$(val32[1])=$val14*$val10+$val15*$val13 and $(val32[4])-$(val32[2])=$val14*$val6+$val15*$val7)	or ($(val32[7])-$(val32[5])=$val14*$val10+$val15*$val13 and $(val32[8])-$(val32[6])=$val14*$val6+$val15*$val7)	or ($(val32[11])-$(val32[9])=$val14*$val10+$val15*$val13 and $(val32[12])-$(val32[10])=$val14*$val6+$val15*$val7) and $val33<13
 condtest1=1
