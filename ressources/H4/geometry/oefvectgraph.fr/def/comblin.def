tmp0=!randitem -3,-2,-1,1,2,3

val6=$[rint($(tmp0))]
tmp0=!randitem -3,-2,-1,1,2,3

val7=$[rint($(tmp0))]
tmp0=!randitem -4,4

val8=$[rint($(tmp0))]
tmp0=!randitem -1,1

val9=$[rint($(tmp0))]
tmp0=!randitem -3,-2,-1,1,2,3

val10=$[rint($(tmp0))]
tmp0=!randitem -4,4

val11=$[rint($(tmp0))]

!ifval abs($val11-$val8)<4 
val11=$[rint( -$val11)]
!endif
tmp0=!randitem -1,1

val12=$[rint($(tmp0))]
tmp0=!randitem -3,-2,-1,1,2,3

val13=$[rint($(tmp0))]
tmp0=!randitem -2,-1,1,2

tmp1=!randitem 1,2

val14=$[$(tmp0)/$(tmp1)]
tmp0=!randitem 1,2,3

tmp1=!randitem 1,2

val15=$[$(tmp0)/$(tmp1)]

!ifval $val14=1 and ($val15=1 or $val15=-1) 
val14=$[ -0.5]
!endif
t_=!replace internal \( by ( in $val14*u+$val15*v
tmp0=!exec pari $t_

val16=$(tmp0)
tmp0=!replace internal v by \vec{v} in $val16

val16=$(tmp0)
tmp0=!replace internal u by \vec{u} in $val16

val16=$(tmp0)
tmp0=!replace internal * by in $val16

val16=$(tmp0)
val17=xrange -10,10	  yrange -6,6	  opacity 255,255	  hline 0,0,black	  vline 0,0,black	  linewidth 2	  fontfamily 18px Arial	  arrow 0,0,1,0,6,#EE0700	  latex 0.5,0,\vec{i}	  arrow 0,0,0,1,6,#EE0700	  latex -0.3,0.7,\vec{j}	  arrow $val8,$val9,$val8+$val10,$val9+$val6,10,#EE0700	  latex $val8+$val10/2,$val9+$val6/2,\vec{u}	  arrow $val11,$val12,$val11+$val13,$val12+$val7,10,#EE0700	  latex $val11+$val13/2,$val12+$val7/2,\vec{v}	  point $val8,$val9,black	  point $val11,$val12,black	  precision 10	  opacity 155,155	  linewidth 1	  parallel -10,-6,-10,6,1,0,21,grey	  parallel -10,-6,10,-6,0,1,13,grey	  opacity 0,0	  grid 0.5,0.5,white	  opacity 255,255	  linewidth 2	  snaptogrid	

!ifval $val6>0 
val18=$[rint( 1 )]
!else
val18=$[rint( 3)]
!endif
val19=500x300

!ifval $val7>0 
val20=$[rint( -3 )]
!else
val20=$[rint( -1)]
!endif

!ifval ($val14*$val10+$val15*$val13)>0 
val21=$[rint( 2 )]
!else
val21=$[rint( 8)]
!endif

!ifval ($val14*$val6+$val15*$val7)>0 
val22=$[rint( -3 )]
!else
val22=$[rint( 3)]
!endif

!ifval $val6=0 
val23=$[rint( 0 )]
!else
val23=$[rint( 2)]
!endif

!ifval $val23=0 
val24=$[rint( 2 )]
!else
val24=$[rint( 0)]
!endif

!ifval $val7=0 
val25=$[rint( 0 )]
!else
val25=$[rint( 2)]
!endif

!ifval $val25=0 
val26=$[rint( 2 )]
!else
val26=$[rint( 0)]
!endif

!ifval $val14=1 
val27= 
!else
val27=	  dashed	  darrow -5+$val23,$val18+$val24,-5+$val23+$val14*$val10,$val18+$val24+$val14*$val6,10,blue	  latex -5+$val23+$val14*$val10/2-0.3,$val18+$val24+$val14*$val6/2,$val14\vec{u}	
!endif

!ifval $val15=1 
val28= 
!else
val28=	  dashed	  darrow -5+$val25,$val20+$val26,-5+$val25+$val15*$val13,$val20+$val26+$val15*$val7,10,blue	  latex -5+$val25+$val15*$val13/2-0.3,$val20+$val26+$val15*$val7/2,$val15\vec{v}	
!endif
tmp0=!exec canvasdraw	  size 750,450	  xrange -15,15	  yrange -9,9	  opacity 155,155	  linewidth 1	  grid 1,1,grey	  opacity 255,255	  linewidth 2	  fontfamily 18px Arial	  arrow -5,$val18,-5+$val10,$val18+$val6,10,#EE0700	  latex -5+$val10/2-0.3,$val18+$val6/2,\vec{u}	  arrow -5,$val20,-5+$val13,$val20+$val7,10,#EE0700	  latex -5+$val13/2-0.3,$val20+$val7/2,\vec{v}	  point -5,$val18,black	  point -5,$val20,black	  $val27 $val28 arrow $val21,$val22,$val21+$val14*$val10,$val22+$val14*$val6,6,blue	  arrow $val21+$val14*$val10,$val22+$val14*$val6,$val21+$val14*$val10+$val15*$val13,$val22+$val14*$val6+$val15*$val7,6,blue	  arrow $val21,$val22,$val21+$val14*$val10+$val15*$val13,$val22+$val14*$val6+$val15*$val7,10,green	  latex $val21+($val14*$val10+$val15*$val13)/2,$val22+($val14*$val6+$val15*$val7)/2,$val16	  

val29=$(tmp0)
val30=Dessiner un reprÈsentant de \($val16).
val31=Vous pouvez dessiner autant de vecteurs que vous voulez, mais seuls les trois premiers que vous	construisez seront analysÈs.<br>Si \($val16) est le vecteur nul, cliquez deux fois au mÍme endroit !
