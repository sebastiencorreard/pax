!!!! This file can contain contents which go after the exercise list in the intro.
!!Model for some configuration parameters. Uncomment if necessary
!!and replace no by yes in the following line.
!set introhook_exists=yes
!set introhook_tableless=yes


<div class="field box">
!if $lang iswordof fr
<strong>Afficher la relation vectorielle dans l'analyse&nbsp;:</strong>
!endif
<ul class="wims_nopuce">
<li>
!set wims_ref_id=confparm1_1
!formradio confparm1 list 1 prompt $wims_name_yes (par défaut)
</li>
<li>
!set wims_ref_id=confparm1_2
!formradio confparm1 list 2 prompt $wims_name_no
</li>
</ul>
</div>


<div class="field box">
!if $lang iswordof fr
<strong>Pour tous les exercices sauf le 06, utiliser dans les énoncés l'expression&nbsp;:</strong>
!set wims_html_mode=li
<ul class="wims_nopuce">
!formcheckbox confparm2 list 1,2 prompt vecteurs de męme direction (par défaut),vecteurs colinéaires
</ul>
<p>Si vous cochez les deux, le serveur choisira aléatoirement l'une des deux pour chaque génération d'exercice.</p>
!endif
</div>

<div class="field box">
!if $lang iswordof fr
<strong>Pour tous les exercices sauf le 06 et le 07, matérialiser en pointillés les directions des vecteurs lors de la construction&nbsp;:</strong>
!endif
<ul class="wims_nopuce">
<li>
!set wims_ref_id=confparm3_1
!formradio confparm3 list 1 prompt $wims_name_yes
</li>
<li>
!set wims_ref_id=confparm3_2
!formradio confparm3 list 2 prompt $wims_name_no (par défaut)
</li>
</ul>
</div>
