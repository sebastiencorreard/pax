 texanswer1= \left\{ \begin{array}{l} d(AB) = \sqrt{\left($x2 - $x1\right)^{2} + \left($y2 - $y1\right)^{2}} = \sqrt{$dx^{2}+$dy^{2}} \approx $ab \approx $rab \\ \textrm{gebruik de sinusregel} \\ \frac{d(AC)}{\sin($b^{o})} = \frac{d(AB)}{\sin($c^{o})} \\ d(AC) \approx \sin($b^{o}) \cdot \frac{$ab}{\sin($c^{o})} \approx $ac \approx $rac \\ \textrm{gebruik de sinusregel} \\ \frac{d(BC)}{\sin($a^{o})} =  \frac{d(AB)}{\sin($c^{o})} \\ d(BC) \approx  \sin($a^{o}) \cdot \frac{$ab}{\sin($c^{o})} \approx $bc \approx $rbc \end{array} \right.
  
 cad=$[$a+$gd]
