 rab=$[0.001*round(1000*$ab)]
 rbc=$[0.001*round(1000*$bc)]
 rac=$[0.001*round(1000*$ac)]
 d=$[atan(($dy)/($dx))]
 gd=$[$d*180/pi]
 x3=$[$x1+$ac*cos($a*pi/180+$d)]
 y3=$[$y1+$ac*sin($a*pi/180+$d)]
 x_max=$[max($x1,$x2)]
 x_max=$[max($x_max,$x3)]
 y_max=$[max($y1,$y2)]
 y_max=$[max($y_max,$y3)]
