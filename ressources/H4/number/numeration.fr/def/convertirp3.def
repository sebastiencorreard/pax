!set title=Convertir vers la base p 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fwguerima@free.fr
title_it=Convertire in base p 3

ansorder=r
varcnt=27
prevarcnt=26
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=20x25x
tmp=!translate internal $	$ to ; in $val5

tmp=!row 1 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$[rint($(tmp0))]
tmp=!translate internal $	$ to ; in $val5

tmp=!row 3 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val8=$(tmp0)
tmp0=!item 1 to $val7 of $val8

val8=$(tmp0)
tmp0=!randint 3, 5

val9=$(tmp0)
tmp0=!randint 1, $val7-1

val10=$(tmp0)
!for val11 =1 to $val9 
tmp0=!randint 1, $val7-1

val12=$[rint($(tmp0))]
val10=$val7*($val10)+$val12
!next
val13=$[rint($val10)]
tmp0=!texmath $val10

val14=$(tmp0)
!readproc slib/basep $val13,$val8 
tmp0=$slib_out
val12=$(tmp0)
!readproc slib/char2item $val12 
tmp0=$slib_out
val15=$(tmp0)
tmp0=!itemcnt $val15

val16=$[rint($(tmp0))]
val6=$val6$val16
!readproc slib/oef/env lang 
tmp0=$slib_out
val17=$(tmp0)
!if $val17=it 
val18=In questo esercizio si utilizza la base $val7.
val19=Base
val20=Base dieci
val21=Convertire il numero in tabella, scritto in base dieci, nella base $val7.
val22=numero
!else
val18=Dans cet exercice on utilise la base $val7.
val19=Base
val20=Base dix
val21=Convertir le nombre suivant, ťcrit en base dix, dans la base $val7 ?
val22=nombre
!endif
replytype1=clickfill
replyname1=
replygood1=$val15;$val8
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$val18<p>	$val21</p>	<table class="wimscenter wimsborder">	 <tr><th>$val20</th><th>$val19 $val7</th></tr>	 <tr><td>
!insmath $val14
$() </td><td>  
!read oef/embed.phtml r1,$val6 
$()</td></tr>	</table>	
$()
!exit

