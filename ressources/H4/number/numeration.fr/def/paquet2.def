ansorder=r
varcnt=40
prevarcnt=36
postvarcnt=3
replycnt=1
choicecnt=0
conditioncnt=1
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=20x25x
tmp=!translate internal $	$ to ; in $val5

tmp=!row 1 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val7=$[rint($(tmp0))]
tmp=!translate internal $	$ to ; in $val5

tmp=!row 3 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val8=$(tmp0)
tmp0=!item 1 to $val7 of $val8

val8=$(tmp0)
tmp=!nonempty items 4,5,6

tmp0=!randitem $tmp
val9=$[rint($(tmp0))]
tmp0=!randint 2, $val9-2

val10=$[rint($(tmp0))]
val6=$val6$val9
val11=$[rint(10^($val10))]
val12=
val13=
!for val14 =1 to $val9 

!ifval $val14=$val9
tmp0=!randint 2, $val7

val15=$[rint($(tmp0))]
!else
tmp1=!randint 1, $val7

val15=$[rint($(tmp1))]
!endif
val12=$(val8[$val15])$val12

!ifval $val14>$val10
val13=$(val8[$val15]),$val13
!endif
tmp0=!nonempty items $val13

val13=$(tmp0)
!next
!readproc slib/oef/env lang 
tmp0=$slib_out
val16=$(tmp0)
!if $val16=it 
val17=Quanti pacchetti di
val18=gettoni si possono realizzare quando si dispongono
val19=gettoni?
val20=Si possono realizzare
val21=pacchetti
val22=Vostra risposta
val23=Scrivere il numero di pacchetti in base $val7.
val24=risposta corretta
val25=La risposta corretta č
val26=numero
!else
val17=Combien de paquets de
val18=jetons peut-on réaliser lorsqu'on dispose de
val19=jetons ?
val20=On peut réaliser
val21=paquet(s).
val22=Votre réponse
val23=Ecrire le nombre de paquets en base $val7.
val24=réponse correcte 
val25=La bonne réponse est
val26=nombre
!endif
replytype1=clickfill
replyname1=$val26 1
replygood1=?analyze 27;$val8
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	$m_txtstatement1<p>	$val17 
!insmath \overline{$val11}^{$val7}
$() $val18 
!insmath \overline{$val12}^{$val7}
