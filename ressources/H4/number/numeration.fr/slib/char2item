!if $wims_read_parm!=slib_header
 !goto proc
!endif
slib_title=transforme un mot en liste de lettres
slib_parms=1\
Le mot

slib_author=Fabrice Guerimand 
slib_out=La liste des caract&egrave;res du mot
!exit

:proc
slib_input=!word 1 of $wims_read_parm
slib_n=!charcnt $slib_input
slib_out=$empty
!for slib_k=1 to $slib_n
 slib_t=!char $slib_k of $slib_input
 slib_out=!append item $slib_t to $slib_out
!next slib_k
