!if $wims_read_parm!=slib_header
 !goto proc
!endif
slib_title=add 0 at the begin
slib_parms=2\
line 1 number (list of digit)
line 2 lenght (add zero at the beginning)

slib_author=Fabrice Guerimand 
slib_out=add 0 at the beginning to have a correct lenght
!exit

:proc
slib_input=$wims_read_parm
slib_number=!row 1 of $slib_input
slib_l=!row 2 of $slib_input
slib_l0=!itemcnt $slib_number
!if $slib_l0>=$slib_l
    slib_out=$slib_number
!else
    slib_out=$slib_number
    !for slib_k=1 to $[$slib_l-$slib_l0]
     slib_number=0,$slib_number
     slib_out=$slib_out|$slib_number
    !next slib_k
!endif