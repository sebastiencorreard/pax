!if $wims_read_parm!=slib_header
 !goto proc
!endif
slib_title=delete 0 at the begin
slib_parms=1\
list of digit

slib_author=Fabrice Guerimand 
slib_out=list of digit without 0 at the begining
!exit

:proc
slib_input=$wims_read_parm
slib_n=!charcnt $slib_input
!if $slib_n=1
 slib_out=$slib_input
 !exit
!endif
slib_f=0
slib_k=1
!while $slib_k<$slib_n and $slib_f=0
 !if $(slib_input[$slib_k])!=0
  slib_f=1
 !else
  slib_k=$slib_k+1
 !endif
!endwhile
!if $slib_k<$slib_n
 slib_out=!nospace $(slib_input[$slib_k to $slib_n])
!else
 slib_out=0
!endif
