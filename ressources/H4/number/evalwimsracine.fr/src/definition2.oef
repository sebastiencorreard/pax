\title{Définition 2}
\language{fr}
\range{-5..5}
\author{Fabrice,Guerimand}
\email{fwguerima@free.fr}
\computeanswer{no}
\format{html}
\precision{10000}


\integer{a=randitem(3,5,7,9,11,13,15,17)}
\integer{a2=2*\a}
\integer{b=randitem(3,5,7,8)}
\integer{b2=\b^2}
\text{enonce=randitem(\sqrt{\a2}=\a,\sqrt{\b2}=\sqrt{\b})}

\statement{
L'égalité suivante est-elle vraie ?
<div class="center"> \(\enonce) </div>}
\choice{Réponse}{Non}{Oui}
