!set title=Calculette 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
leftrange=-5.000000
rightrange=5.000000
author=Fabrice,Guerimand
email=fwguerima@free.fr
computeanswer=no
precision=10000

ansorder=r
varcnt=16
prevarcnt=15
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!values v for v=11 to 99

val6=$(tmp0)
tmp0=!shuffle $val6

val6=$(tmp0)
val7=$[rint(sqrt($(val6[1]))+sqrt($(val6[2])))]

!ifval sqrt($(val6[1]))+sqrt($(val6[2]))=$val7
val8=$[rint($(val6[1])+1)]
!else
val8=$[rint($(val6[1]))]
!endif
val9=sqrt($val8+$(val6[2]))
tmp0=!randint 1, 3

val10=$[rint($(tmp0))]
val11=$[rint(($val9)*10^($val10))]
val11=$[$val11/10^($val10)]
tmp0=!texmath $val9

val9=$(tmp0)
val12=dixième,centième,millième
tmp0=!item $val10 of $val12

val13=$(tmp0)
val13=au $val13
val14=$[10^(-$val10)]
val14=à \($val14) près
tmp0=!randitem $val13,$val14

val15=$(tmp0)
replytype1=litexp
replyname1=Réponse
replygood1=$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Quel est l'arrondi $val15 de 
!insmath $val9
$() ? 
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=9,15
embedcnt=0
