!set title=Quotient 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
leftrange=-5.000000
rightrange=5.000000
author=Fabrice,Guerimand
email=fwguerima@free.fr
computeanswer=no
precision=10000

ansorder=c
varcnt=5
prevarcnt=4
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!trim a,b	x,y	u,v
val6=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val6

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val6=$(tmp0)
tmp0=!item 1 of $val6

val7=$(tmp0)
tmp0=!item 2 of $val6

val8=$(tmp0)
choicename1=RÈponse
choicegood1=Non
choicebad1=Oui
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	L'ÈgalitÈ suivante est-elle vraie pour toutes les valeurs de 
!insmath $val7
$() et  toutes les valeurs de 
!insmath $val8
$() non nulles ?	<div class="center">
!insmath \sqrt{\frac{$val7}{$val8}} = \frac{\sqrt{$val7}}{\sqrt{$val8}}
$()</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()Attention si 
!insmath $val7
$() et 
!insmath $val8
$() sont deux nombres nÈgatifs, avec 
!insmath $val8
$() non nul, leur quotient 
!insmath \frac{$val7}{$val8}
$() est positif donc 
!insmath \sqrt{\frac{$val7}{$val8}}
$() existe mais 
!insmath \sqrt{$val7}
$() et 
!insmath \sqrt{$val8}
$() n'existent pas. Donc on ne peut pas Ècrire 
!insmath \sqrt{\frac{$val7}{$val8}} = \frac{\sqrt{$val7}}{\sqrt{$val8}}
$()  pour toutes les valeurs de 
!insmath $val7
$() et 
!insmath $val8
$().
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,8
embedcnt=0
