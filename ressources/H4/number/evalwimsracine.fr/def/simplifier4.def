!set title=Simplifier 4
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice,Guerimand
email=fwguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=9
prevarcnt=8
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=4
tmp=!nonempty items 2,3,5,6,7,10,11,13

tmp0=!randitem $tmp
val7=$[rint($(tmp0))]
tmp0=!values v for v=2 to 20

val8=$(tmp0)
tmp0=!shuffle $val8

val8=$(tmp0)
val9=$[rint(0)]
val10=$[rint($val7*$(val8[2])^2)]
val11=$(val8[2])*sqrt($val7),sqrt($val7)*$(val8[2])
val12=\sqrt{$val10}
replytype1=litexp
replyname1=RÈponse 1
replygood1=$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Ecrire 
!insmath $val12
$() sous la forme 
!insmath a\sqrt{b}
$() o˘ 
!insmath b
$() est un entier positif le plus petit possible.	<div class="center">	
!if $val9=1 
$()	
!insmath $val12 =
$()  
!read oef/embed.phtml r1,$val6 
$() 
!insmath \times \sqrt{$val7}
$().	</div>	 
!else
$() 	
!insmath $val12 =
$()  
!read oef/embed.phtml r1,3*$val6 
$()	</div>	<small>(Taper sqrt(2) pour 
!insmath \sqrt{2}
$().)</small> 
!endif
$()	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,9,12
embedcnt=2
