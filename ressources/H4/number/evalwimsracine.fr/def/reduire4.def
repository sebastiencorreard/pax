val6=12
tmp=!nonempty items 2,3,5,6,7,10,11,13

tmp0=!randitem $tmp
val7=$[rint($(tmp0))]
tmp0=!values v for v=2 to 14

val8=$(tmp0)
tmp0=!shuffle $val8

val8=$(tmp0)
tmp0=!shuffle +,+,+,-,-,-

val9=$(tmp0)
val10=$[rint($val7*$(val8[1])^2)]
val11=$[rint($(val9[2])$(val8[2])*$(val8[1])$(val9[1]) $(val8[3]))]
val12=$(val9[2])$(val8[2])\sqrt{$val10},$(val9[1])$(val8[3])\sqrt{$val7}
tmp0=!shuffle $val12

val12=$(tmp0)
tmp0=!items2words $val12

val12=$(tmp0)
tmp0=!char 1 of $val12

val13=$(tmp0)
!if +=$val13 
tmp0=!char 2 to -1 of $val12

val12=$(tmp0)
!endif
val11=$val11*sqrt($val7),sqrt($val7)*$val11
replytype1=litexp
replyname1=RÈponse 1
replygood1=$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

