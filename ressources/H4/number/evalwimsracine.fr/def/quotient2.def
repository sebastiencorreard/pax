$()	
!if $m_affichage=1 
$()	 $m_base<sup> 
!read oef/embed.phtml r1,$val6 
$()</sup>	 
!else
$() 	  
!read oef/embed.phtml r1,$val6 
$()	 
!endif
$()</div>
$()
