!set title=Quotient 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
leftrange=-5.000000
rightrange=5.000000
author=Fabrice,Guerimand
email=fwguerima@free.fr
