prevarcnt=9
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=5
tmp0=!values v for v=2 to 10

val7=$(tmp0)
tmp0=!shuffle $val7

val7=$(tmp0)
val8=$[rint($(val7[1])*$(val7[2])^2)]
val9=$[rint($(val7[1]))]
tmp0=!shuffle $val8,$val9

val8=$(tmp0)
tmp=!translate ";': to $     $ in sqrt($(val8[1])/$(val8[2]))

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val10=$(tmp0)
val11=\frac{\sqrt{$(val8[1])}}{\sqrt{$(val8[2])}}
tmp=!translate ";': to $     $ in $val10

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val10=$(tmp0)
replytype1=numexp
replyname1=RÈponse 1
replygood1=$val10
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

