!set title=DÈfinition 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
leftrange=-5.000000
rightrange=5.000000
author=Fabrice,Guerimand
email=fwguerima@free.fr
computeanswer=no
precision=10000

ansorder=c
varcnt=6
prevarcnt=5
postvarcnt=0
replycnt=0
choicecnt=1
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items 3,5,7,9,11,13,15,17

tmp0=!randitem $tmp
val6=$[rint($(tmp0))]
val7=$[rint(2*$val6)]
tmp=!nonempty items 3,5,7,8

tmp0=!randitem $tmp
val8=$[rint($(tmp0))]
val9=$[rint($val8^2)]
tmp=!nonempty items \sqrt{$val7}=$val6,\sqrt{$val9}=\sqrt{$val8}

tmp0=!randitem $tmp
val10=$(tmp0)
choicename1=RÈponse
choicegood1=Non
choicebad1=Oui
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	L'ÈgalitÈ suivante est-elle vraie ?	<div class="center"> 
!insmath $val10
$() </div>
$()
!exit

