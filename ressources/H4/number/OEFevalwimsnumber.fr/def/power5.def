!set title= Calcul avec des puissances V
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=RÈgine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100000000

ansorder=r
varcnt=12
prevarcnt=11
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=Elever au carrÈ
tmp0=!randint 2, 9

val7=$[rint($(tmp0))]
tmp0=!randint 2, 8

val8=$[rint($(tmp0))]

!ifval $val7>3
tmp0=!randitem 1,2

val9=$[rint($(tmp0))]
!else
tmp1=!randint 1, 2

val9=$[rint($(tmp1))]
!endif
val10=$[rint(2*$val9)]

!ifval $val10<6
tmp0=!randitem 1,2

val11=$[rint($(tmp0))]
!else
val11=$[rint(1)]
!endif
val12=($val7 \times 10^{$val9})^2
val13=$val8 \times 10^{-$val11}
val14=\(\text{Effectuer}\; $val12 + $val13)
val15=$[($val7*10^$val9)^2+($val8*10^(-$val11))]
val16=$[rint(10^(2*$val9))]
replytype1=numeric
replyname1=
replygood1=$[$val15]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div class="warning">A faire sans calculatrice!</div>	<b>$val6</b> :	<div class="wimscenter">$val14</div>	  …crire la rÈponse sous forme dÈcimale $m_trep.	<div class="wimscenter"><label for="reply1">Votre solution</label>: 
!read oef/embed.phtml reply1 
$()	</div>	
$()
!exit

