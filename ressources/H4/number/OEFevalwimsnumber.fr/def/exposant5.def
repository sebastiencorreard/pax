val10=$[rint(2*$val8-1)]
val11=$[rint(2*$val8)]
val12=\frac{((8^{$val7}) \times (21^{$val8} \times x))^2}{(16^{$val7})\times 7 \times (x^{3})}
val13=\(\text{Simplifier}\; $val12) 
