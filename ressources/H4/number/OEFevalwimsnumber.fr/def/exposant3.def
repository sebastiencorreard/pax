!set title=Calcul avec des exposants III
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rťgine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r,r
varcnt=12
prevarcnt=10
postvarcnt=1
replycnt=2
choicecnt=0
conditioncnt=1
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=Calculatrice autorisťe
val6=A faire sans calculatrice!
tmp0=!randint 5, 11

val7=$[rint($(tmp0))]
tmp0=!randint 2, 5

val8=$[rint($(tmp0))]
val9=$[rint($val8*4)]
val10=$[rint(-2*$val7)]
val11=($val9^{$val7}) \times 2^{$val10}
val12=\(\text{Effectuer}\; $val11) 
val13=$[rint($val8^($val7))]
tmp0=!texmath $val8^$val7

val14=\($(tmp0))
replytype1=numeric
replyname1=
replygood1=?analyze 15
replytype2=numeric
replyname2=
replygood2=?analyze 16
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="wims_warning">$val6</div>	<div class="wimscenter">$val12</div>	<div class="wimscenter"><label for="reply1">Votre solution</label>: 
!read oef/embed.phtml reply1,3 
$()<sup> 
!read oef/embed.phtml reply2,3 
$()</sup>	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:postdef
val17=$[rint($m_reply1^$m_reply2)]

!exit

:feedback
!ifval $val17 <>$val13
 <div class='oef_feedbacks'>Il fallait rťpondre $val14
$()</div>
!endif

!exit

:test

!ifval $val17=$val13
 condtest1=1
!else
 condtest1=0
!endif
condname1=

!exit

:stat
vsavelist=6,12,13,14,15,16
embedcnt=2
