 !exit
!endif

tmp0=!randitem 2,3,5,6,7,8

val6=$[rint($(tmp0))]
tmp0=!randitem 3,6,7,9,12,14,15

val7=$[rint($(tmp0))]
val8=Le nombre \(\sqrt{$val6}) est irrationnel,1	  Tous les nombres \(\sqrt{a})&#44; a Ètant un entier naturel&#44; sont irrationnels,2	  L'inverse de \($val7) n'est pas dÈcimal,1	  Le nombre \(pi) est irrationnel,1	  Tous les inverses des nombres entiers sont des nombres dÈcimaux,2	  Aucun inverse de rationnal n'est un entier,2	
tmp0=!shuffle 3

val9=$(tmp0)
val10=$[rint($(val9[2])+3)]
val9=1,2,3,$val10
tmp0=!shuffle $val9

val9=$(tmp0)
tmp=!translate internal $	$ to ; in $val8

tmp=!row $(val9[1]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val11=$(tmp0)
tmp=!translate internal $	$ to ; in $val8

tmp=!row $(val9[2]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val12=$(tmp0)
tmp=!translate internal $	$ to ; in $val8

tmp=!row $(val9[3]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val13=$(tmp0)
tmp=!translate internal $	$ to ; in $val8

tmp=!row $(val9[4]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val14=$(tmp0)
val15=Vrai,Faux
replytype1=radio
replyname1=$(val11[1])
replygood1=$(val11[2]);$val15
replytype2=radio
replyname2=$(val12[1])
replygood2=$(val12[2]);$val15
replytype3=radio
replyname3=$(val13[1])
replygood3=$(val13[2]);$val15
replytype4=radio
replyname4=$(val14[1])
replygood4=$(val14[2]);$val15
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

