!set title=Calcul avec des fractions III
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=RÈgine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=12
prevarcnt=11
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=A faire sans calculatrice!
tmp0=!randint 2, 11

val7=$[rint($(tmp0))]
tmp0=!randint 2, 11

val8=$[rint($(tmp0))]
tmp0=!randint 2, 7

val9=$[rint($(tmp0))]
val10=$[rint($val7*$val8)]
tmp0=!randint 3, 8

val11=$[rint($(tmp0))]
tmp0=!randitem 1,2

val12=$[rint($(tmp0))]
!if $val12=1 
val13=$val10\times\frac{$val9}{$val8}
tmp=!translate ";': to $     $ in $val10*$val9/$val8

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val14=!exec pari print($t_)
!else
val13=\frac{$val9}{$val8}\times\frac{$val10}{$val11}
tmp=!translate ";': to $     $ in $val9/$val8*$val10/$val11

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val14=!exec pari print($t_)
!endif
replytype1=numexp
replyname1=
replygood1=$val14
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="wims_warning">$val6</div>	  Calculer :	<div class="wimscenter">
!insmath A=$val13
$()</div>	  Exprimer le rÈsultat sous forme d'une fraction irrÈductible.	<div class="wimscenter"><label for="reply1">Votre solution</label> :  
!read oef/embed.phtml reply1,5 
$()</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,13
embedcnt=1
