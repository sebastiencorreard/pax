!set title=Calcul avec des exposants II
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rťgine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=9
prevarcnt=8
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=Calculatrice autorisťe
val6=A faire sans calculatrice!
tmp0=!randint 4, 7

val7=$[rint($(tmp0))]
val8=$[rint($val7-1)]
val9=$[rint($val7-2)]
val10=(5^{$val7}) \times 2^{$val8}+10^{$val9}
val11=\(\text{Effectuer}\; $val10) 
val12=$[rint(5^$val7*2^$val8+10^$val9)]
replytype1=numeric
replyname1=
replygood1=$[$val12]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="wims_warning">$val6</div>	<div class="wimscenter">$val11</div>	<div class="wimscenter"><label for="reply1">Votre solution</label>: 
!read oef/embed.phtml reply1 
$()	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,11
embedcnt=1
