val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=80x300x200
tmp0=!randint 5, 20

val7=$[rint($(tmp0))]
tmp0=!randint 5, 20

val8=$[rint($(tmp0))]
tmp0=!randint 5, 20

val9=$[rint($(tmp0))]
tmp0=!randint 5, 20

val10=$[rint($(tmp0))]
tmp0=!randint 5, 20

val11=$[rint($(tmp0))]
val12=\(-$val7^2\times $val8 - \frac{$val11}{(-$val9)^3 + $val10}),	\(\frac{-$val7^2\times $val8 - $val11}{(-$val9)^3 + $val10}),	\((-$val7^2)\times \frac{$val8}{(-$val9)^3 + $val10}- $val11),	\((\frac{$val7}{(-$val9)^3})\times $val8 - \frac{$val11}{$val10})
val13=$[-$val7^2* $val8 - $val11/((-$val9)^3 + $val10)]
val14=$[(-$val7^2*$val8 - $val11)/((-$val9)^3 + $val10)]
val15=$[(-$val7^2)* $val8/((-$val9)^3 + $val10)- $val11]
val16=$[($val7/(-$val9)^3)* $val8 - $val11/$val10]
val17=$val13,$val14,$val15,$val16
replytype1=correspond
replyname1=Correspondance
replygood1=$val12;$val17
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

