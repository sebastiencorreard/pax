!set title=Calcul avec des fractions IV
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rťgine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=9
prevarcnt=8
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=A faire sans calculatrice!
tmp0=!randint 1, 4

val7=$[rint($(tmp0))]
tmp0=!randint 3, 7

val8=$[rint($(tmp0))]
tmp0=!randint 1, 5

val9=$[rint($(tmp0))]
tmp0=!randint 6, 9

val10=$[rint($(tmp0))]
tmp0=!randint 3, 6

val11=$[rint($(tmp0))]
val12=\frac{$val7}{$val8}-\frac{$val9}{$val10}+\frac{7 \times $val11}{7}
tmp=!translate ";': to $     $ in $val7/$val8- $val9 / $val10 + $val11

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val13=!exec pari print($t_)
replytype1=numexp
replyname1=
replygood1=$val13
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="wims_warning">$val6</div>	  Calculer :	<div class="wimscenter">
!insmath A=$val12
$()</div>	  Exprimer le rťsultat sous forme d'une fraction irrťductible.	<div class="wimscenter"><label for="reply1">Votre solution</label> :  
!read oef/embed.phtml reply1,5 
$()</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

