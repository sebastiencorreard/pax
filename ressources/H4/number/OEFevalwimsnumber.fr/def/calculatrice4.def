!set title=Utilisation de la calculatrice 4
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=RÈgine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=13
prevarcnt=12
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=$[rint(3)]
val7=defaut
val8=\(\pi -4)
tmp0=!randint 3, 8

val9=$[rint($(tmp0))]
tmp0=!randint 3, 8

val10=$[rint($(tmp0))]
tmp0=!randint 3, 8

val11=$[rint($(tmp0))]
val12=\(B=$val9 x - \frac{$val10}{x^2}+ $val11)
val13=B
val14=!rawmath $val9*(x)-$val10/(x)^2+$val11
evaltmp=$val14

evaltmp=!mathsubst x=(pi -4) in $evaltmp
tmp0=($evaltmp)
val15=$[$(tmp0)]
val16=$[rint(floor($val15*1000))]
val17=$[$val16/1000]
replytype1=numeric
replyname1=
replygood1=$[$val17]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Soit $val12;<p>	  A l'aide de la calculatrice, calculer $val13 en remplaÁant 
!insmath x
$() par $val8 et donner	  sa <label for="reply1">valeur approchÈe</label> par $val7 ‡ $val6 dÈcimales.	</p>	<div class="wimscenter"> 
!read oef/embed.phtml reply1 
$()</div>	
$()
!exit

