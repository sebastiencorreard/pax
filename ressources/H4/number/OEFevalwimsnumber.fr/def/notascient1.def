!set title=Notation scientifique I
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=RÈgine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 150000, 750000

val6=$[rint($(tmp0))]
tmp0=!randint 2, 4

val7=$[rint($(tmp0))]
val8=$[rint(10^$val7)]
val9=$[rint($val7-1)]
val10=$[$val6/10^5]
val11=$[$val6/10^$val7]
val12=\(\frac{$val6}{$val8}),\($val10 \times 10^$val9),\($val6 \times 10^{-$val7}),\($val11)
replytype1=radio
replyoption1=shuffle 
replyname1=
replygood1=2;$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

