!set title= Ordre de grandeur IV
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=yes
precision=10000

ansorder=r
varcnt=5
prevarcnt=4
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint -7, -5

val6=$[rint($(tmp0))]
tmp0=!randint 2, 5

val7=$[rint($(tmp0))]
val8=$[rint(10*$val7)]
val9=$[rint(24*$val7+$val6)]
replytype1=numeric
replyname1=
replygood1=$[$val9]
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  L'effectif d'une certaine population de bactéries est multiplié par 10 toutes les 10 heures.<br />	  Chacune de ces bactéries pèse 
!insmath 10^{$val6}
$() grammes.<br />	 Si elles se multipliaient ainsi durant $val8 jours, à partir d'une seule bactérie,	  quel serait l'ordre de grandeur de la masse bactérienne ?	<div class="wimscenter">Ordre de grandeur de la masse: 10<sup> 
!read oef/embed.phtml reply1,3 
$()</sup></div>	
$()
!exit

:hint
$()Si 
!insmath N=a \times 10^p
$() est un nombre réel écrit sous la forme scientifique,	 l'ordre de grandeur de 
!insmath N
$() est simplement 
!insmath a' \times 10^p
$(), où	
!insmath a'
$() est l'entier <u>arrondi</u> du décimal 
!insmath a
$().<br />	  L'entier 
!insmath a'
$() est inférieur au décimal 
!insmath a
$() si la première décimale de ce dernier est 0,1,2,3 ou 4,	  et supérieur si c'est 5,6,7,8 ou 9.	
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,8
embedcnt=1
