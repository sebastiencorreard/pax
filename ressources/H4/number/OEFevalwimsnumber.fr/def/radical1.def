tmp0=!randitem 2,3,5,6,7,8

val9=$[rint($(tmp0))]
val10=\(\sqrt{$val8}=$val7\; ou\; -$val7),2	\(\sqrt{-x}) existe si \(x \le 0),1	  Si \(x>0)&#44; \(\sqrt{1+x^2}=1+x),2	  Racine carrťe de 0 n'existe pas,2	\(\sqrt{\frac{1}{$val7}}=\frac{\sqrt{$val7}}{$val7}),1
tmp=!translate internal $	$ to ; in $val10

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
