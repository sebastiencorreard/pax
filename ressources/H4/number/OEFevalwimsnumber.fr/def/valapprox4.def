!set title=Valeur décimale IV
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r,r,r
varcnt=25
prevarcnt=24
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 10001, 99999

tmp1=!randint 101, 999

tmp2=!randint 10001, 99999

tmp3=!randint 1001, 9999

val6=$(tmp0)/10000,$(tmp1)/10000,-$(tmp2)/10000,$(tmp3)/1000
tmp=!nonempty items $val6

tmp0=!randitem $tmp
val7=$[$(tmp0)]
tmp0=!randitem 2.,3

val8=$[rint($(tmp0))]
val9=$[$val7*10^$val8]
tmp0=!randint 11, 40

val10=$[rint($(tmp0))]
tmp0=!randitem 3,7,11,13

val11=$[rint($(tmp0))]
val7=$[$val10/ $val11]
val12=\frac{$val10}{$val11}
tmp0=!randitem 2,3

val13=$[rint($(tmp0))]
tmp0=!randitem 2,3

val14=$[rint($(tmp0))]
tmp0=!randitem 2,3

val15=$[rint($(tmp0))]
tmp0=!randitem 1,2

val16=$[rint($(tmp0))]
val17=par excès, par défaut
val18=$(val17[$val16])
val9=$[$val7*10^$val13]
val19=$[rint($val9)]
val20=$[$val19/10^$val13]
val9=$[$val7*10^$val14]

!ifval $val16=1
val19=$[rint(ceil($val9))]
!else
val19=$[rint(floor($val9))]
!endif
val21=$[$val19/10^$val14]
val9=$[$val7*10^$val15]
val22=$val9
tmp0=!replace internal . by , in $val22

val22=$(tmp0)
val23=$[$(val22[1])/10^$val15]
replytype1=numeric
replyname1=arrondi
replygood1=$[$val20]
replytype2=numeric
replyname2=$val18
replygood2=$[$val21]
replytype3=numeric
replyname3=toncature
replygood3=$[$val23]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$() On considère le nombre réel 
!insmath n=$val12
$().	  A l'aide de la calculatrice, donner:	<ol>	<li>La <label for="reply1">valeur arrondie à $val13 décimales de 
!insmath n
$()</label>:  
!read oef/embed.phtml reply1 
$()</li>	<li>Une <label for="reply2">valeur approchée à 
!insmath 10^{-$val14}
$() près $val18 de 
!insmath n
$()</label>:  
!read oef/embed.phtml reply2 
$()</li>	<li>La <label for="reply3"></label>troncature à $val15 décimales de 
!insmath n
$()</label>:  
!read oef/embed.phtml reply3 
$()</li>	</ol>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=12,13,14,15,18
embedcnt=3
