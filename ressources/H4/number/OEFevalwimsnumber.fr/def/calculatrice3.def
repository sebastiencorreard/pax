!set title=Utilisation de la calculatrice 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=14
prevarcnt=13
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=$[rint(4)]
val7=excès
tmp0=!randint 3, 8

val8=$[rint($(tmp0))]
tmp0=!randint 3, 8

val9=$[rint($(tmp0))]
tmp0=!randint 3, 8

val10=$[rint($(tmp0))]
tmp0=!randitem 7,8,10,11,12,13,14,15,17,19

val11=$[rint($(tmp0))]
val12=\(A=$val8 x^2+ $val9 x +$val10)
val13=\(1+\sqrt{$val11})
val14=A
val15=!rawmath $val8*(x)^2+$val9*(x)+$val10
evaltmp=$val15

evaltmp=!mathsubst x=(1+sqrt($val11)) in $evaltmp
tmp0=($evaltmp)
val16=$[$(tmp0)]
val17=$[rint(ceil($val16*10000))]
val18=$[$val17/10000]
replytype1=numeric
replyname1=
replygood1=$[$val18]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Soit $val12;<p>	  A l'aide de la calculatrice, calculer $val14 en remplaçant 
!insmath x
$() par $val13 et donner	  sa <label for="reply1">valeur approchée</label> par $val7 à $val6 décimales.	</p>	<div class="wimscenter"> 
!read oef/embed.phtml reply1 
$()</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,12,13,14
embedcnt=1
