val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=Diviser
tmp0=!randitem 4,6,7,8,9

val7=$[rint($(tmp0))]
tmp0=!randint 9, 15

val8=$[rint($val7*$(tmp0))]
tmp0=!randitem 2,4,5,8

val9=$[rint($val7*$(tmp0))]
tmp0=!randint 11, 16

val10=$[rint($(tmp0))]
tmp0=!randitem 1,2

tmp1=!randitem 1,-1

val11=$[rint($val10+$(tmp0)*$(tmp1))]
val12=$val8 \times 10^{$val10}
val13=$val9 \times 10^{$val11}
val14=\(\text{Diviser}\;\; $val12 \;\text{par}\;\; $val13)
val15=en tronquant au centiŤme
val16=$[($val8*10^$val10)/($val9*10^($val11))*100]
val17=$[rint(floor($val16))]
val18=$[$val17/100]
val19=$[rint(10^($val10-$val11))]
replytype1=numeric
replyname1=
replygood1=$[$val18]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

