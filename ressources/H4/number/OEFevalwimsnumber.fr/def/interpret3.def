!set title=InterprÕter un rÕsultat 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=RÕgine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
precision=10000
leftrange=-5.000000
rightrange=5.000000
computeanswer=yes

ansorder=r
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
