 !exit
!endif

tmp0=!randint 10000000, 99999999

val6=$[rint($(tmp0))]
tmp0=!randint 10000000, 99999999

val7=$[rint($(tmp0))]

!ifval $val6=$val7
val7=$[rint($val6-1)]
!endif
tmp0=!randint 123, 999

val8=$[rint($(tmp0))]
val9=$[rint($val6*$val8+1)]
val10=$[rint($val7*$val8+1)]
val11=\(A=B),	  En faisant la soustraction&#44; je peux faire apparaitre les dÕcimales cachÕes. Si la calculatrice affiche 0 c'est que \(A=B),	  Pour õtre absolument certain&#44; je peux comparer le chiffre des unitÕs de \(a \times b') avec celui de \(a' \times b) et si c'est le mõme alors \(A=B),	  Si les tests 2 ou 3 Õchouent&#44; c'est que \(A) est diffÕrent de \(B)
replytype1=checkbox
replyname1=bonnes affirmations
replygood1=4;$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  On souhaite comparer 
!insmath A=\frac{a}{b}= \frac{$val6}{$val7}
$() et 
!insmath B=\frac{a'}{b'}=\frac{$val6 \times $val8+1}{$val7 \times $val8 + 1}
$().<p>	  La calculatrice affiche les mõmes chiffres.	</p>	  Quelles affirmations sont certainement vraies ?	<ol>	<li>  
!read oef/embed.phtml reply1,1 
$()</li>	<li>  
!read oef/embed.phtml reply1,2 
$()</li>	<li>  
!read oef/embed.phtml reply1,3 
$()</li>	<li>  
!read oef/embed.phtml reply1,4 
$()</li>	</ol>	
$()
