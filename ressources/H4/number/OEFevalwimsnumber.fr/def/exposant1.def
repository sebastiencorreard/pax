!set title=Calcul avec des exposants I
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rťgine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=9
prevarcnt=8
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=Calculatrice autorisťe
tmp0=!randint 4, 9

val7=$[rint($(tmp0))]
tmp0=!randint 3, 5

val8=$[rint($(tmp0))]
val9=$[rint(2^$val7)]
val10=$[rint(10^$val8)]
val11=2^{$val7}-10^{$val8}\times u
val12=\(\text{Effectuer}\; $val11) 
val13=$val9-$val10*u
replytype1=formal
replyname1=
replygood1=$val13
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="wims_warning">$val6</div>	<div class="wimscenter">$val12</div>	<div class="wimscenter"><label for="reply1">Votre solution</label>: 
!read oef/embed.phtml reply1 
$()	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,12
embedcnt=1
