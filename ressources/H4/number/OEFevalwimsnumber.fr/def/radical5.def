!set title= Calcul avec des radicaux V
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=6
prevarcnt=5
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=A faire sans calculatrice!
tmp0=!randint 1, 7

val7=$[rint($(tmp0))]
tmp0=!randitem 5,6,7,8,10,11,13

val8=$[rint($(tmp0))]
val9=$[rint($val8-2)]
val10=$val7*(sqrt($val8)+sqrt($val9))/2
replytype1=formal
replyname1=
replygood1=$val10
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="wims_warning">$val6</div>	  Rendre rationnel le dénominateur de :	 <div class="wimscenter">
!insmath \frac{$val7}{\sqrt{$val8}-\sqrt{$val9}}
$()</div>	<em>C'est-ŕ-dire écrire ce nombre sous la forme d'une fraction ne contenant	pas de racine carrée au dénominateur.</em>	<div class="wims_instruction">	Pour saisir une racine carrée, taper <span class="tt">sqrt(..)</span>,	exemple taper <span class="tt">sqrt(2)</span>	pour 
!insmath \sqrt{2}
$().</div>	<div class="wimscenter"> 
!read oef/embed.phtml reply1 
$()</div>	
$()
!exit

:hint
$()Regardez ces trois exemples:	<ol>	<li> 
!insmath \frac{1}{\sqrt{2}}=\frac{1 \times \sqrt{2}}{\sqrt{2} \times \sqrt{2}}=\frac{\sqrt{2}}{2}
$()</li>	<li> 
!insmath \frac{1}{1+\sqrt{2}}=\frac{1 \times (1 - \sqrt{2})}{(1+\sqrt{2})\times(1-\sqrt{2})}=\frac{1-\sqrt{2}}{1-2}=\sqrt{2}-1
$()</li>	<li> 
!insmath \frac{1}{\sqrt{5}-\sqrt{2}}=\frac{1 \times (\sqrt{5}+\sqrt{2})}{(\sqrt{5}-\sqrt{2})\times (\sqrt{5}+\sqrt{2})}=\frac{\sqrt{5}+\sqrt{2}}{5-2}=\frac{\sqrt{5}+\sqrt{2}}{3}
$()</li>	</ol>
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,9
embedcnt=1
