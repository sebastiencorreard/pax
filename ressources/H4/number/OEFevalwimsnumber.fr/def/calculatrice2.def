!set title=Utilisation de la calculatrice 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=9
prevarcnt=8
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 7, 19

val6=$[rint($(tmp0))]
tmp0=!randint 7, 19

val7=$[rint($(tmp0))]
tmp0=!randint 7, 19

val8=$[rint($(tmp0))]
val9=$[rint(4)]
val10=$[10000*(($val6/$val7)^2+sqrt($val6+$val7))/(1/$val7+1/($val8)^2)]
val11=\(\frac{(\frac{$val6}{$val7})^2 + \sqrt{$val6+$val7}}{\frac{1}{$val7}+\frac{1}{$val8^2}})
val12=$[rint(ceil($val10))]
val13=$[$val12/10000]
replytype1=numeric
replyname1=
replygood1=$[$val13]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Donner à l'aide de votre calculatrice, la valeur approchée à	 $val9 décimales par excès de:	<div class="wimscenter"><label for="reply1">$val11</label></div>	<div class="wimscenter"> 
!read oef/embed.phtml reply1 
$()</div>	
$()
!exit

