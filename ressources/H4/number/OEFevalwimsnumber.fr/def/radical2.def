!set title= Calcul avec des radicaux II
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=RÈgine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=A faire sans calculatrice!
tmp0=!randitem 2,3,5,7

val7=$[rint($(tmp0))]
tmp0=!randint 3, 7

val8=$[rint($(tmp0))]
val9=$[rint($val8+1)]
val10=$[rint($val8^2*$val7)]
val11=$[rint($val9^2*$val7)]
val12=($val8+$val9)*sqrt($val7)
replytype1=formal
replyname1=
replygood1=$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="wims_warning">$val6</div>	  …crire sous la forme 
!insmath a \sqrt{b}
$(), 
!insmath a
$() et 
!insmath b
$() entiers, 
!insmath a
$() le plus grand possible :	<div class="wimscenter"><label for="reply1">
!insmath \sqrt{$val10}+\sqrt{$val11}
$()</label></div>	<div class="wims_instruction">	 Pour saisir une racine carrÈe, taper <span class="tt">sqrt(..)</span>,	  exemple taper <span class="tt">sqrt(2)</span> pour 
!insmath \sqrt{2}
$()	</div>	<div class="wimscenter"> 
!read oef/embed.phtml reply1 
$()</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,10,11
embedcnt=1
