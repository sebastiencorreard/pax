!else
val13=$[rint(1)]
!endif
val14=$[rint(3-$val13)]
tmp0=!embraced randrow {$val8.$val10$val12<u>$val10$val12</u> n'est pas décimal,$val13;$val8.$val10$val12<u>$val10$val12</u> est décimal,$val14}

val15=$(tmp0)	  $val7.$val9$val11 est décimal,1	  Le nombre $val6 n'est pas premier,1	  Tout nombre réel est nombre décimal,2	  Tout entier naturel est un nombre décimal,1	  Tout nombre rationnel est un nombre décimal,2	  Le nombre 0 n'est pas décimal,2	
