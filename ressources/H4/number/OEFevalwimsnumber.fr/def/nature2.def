val19=$[rint($(val17[2])+2)]
val17=1,2,$val18,$val19
tmp0=!shuffle $val17

val17=$(tmp0)
tmp=!translate internal $	$ to ; in $val15

tmp=!row $(val17[1]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val20=$(tmp0)
tmp=!translate internal $	$ to ; in $val15

tmp=!row $(val17[2]) of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val21=$(tmp0)
