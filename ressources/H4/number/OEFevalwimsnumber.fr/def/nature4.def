val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 3

val6=$[rint($(tmp0))]
tmp0=!randint 2, 8

val7=$[rint($(tmp0))]
tmp0=!randitem 2,4,5,7,8

val8=$[rint($(tmp0))]
val9=
val10=\(\frac{$val7}{9}\times 2^$val6)
tmp0=!append item $val10 to $val9

val9=$(tmp0)
val10=\($val7 \times \frac{3}{3}\times 5^$val6)
tmp0=!append item $val10 to $val9

val9=$(tmp0)
val10=\(\frac{$val7^2}{7}\times 2^$val6)
tmp0=!append item $val10 to $val9

val9=$(tmp0)
val10=\(\frac{$val8}{3}\times 10^$val6)
tmp0=!append item $val10 to $val9

val9=$(tmp0)
val10=\(\frac{$val7}{2^$val6}\times 5^$val6)
tmp0=!append item $val10 to $val9

val9=$(tmp0)
val11=1,3,4
replytype1=checkbox
replyoption1=shuffle 
replyname1=
replygood1=$val11;$val9
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

