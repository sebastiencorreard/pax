!set title=Interpréter un résultat 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
precision=10000
leftrange=-5.000000
rightrange=5.000000
computeanswer=yes

ansorder=r
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem 2,3,5,6,7,8,10,11,12,13,14

val6=$[rint($(tmp0))]
val7=$[sqrt($val6)]
val8=$[$val7-10^-7]
val9=$[rint(5)]
val10=$val8$val9
val11=$val7$val9
val12=\(\sqrt{$val6}) = $val7, \(\sqrt{$val6} \ge $val7), \(\sqrt{$val6} \le $val7),\($val10 \le \sqrt{$val6} < $val11),\($val10 < \sqrt{$val6} \le $val11) 
replytype1=radio
replyoption1=shuffle 
replyname1=Déduction
replygood1=4;$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Je tape sur ma calculatrice 
!insmath \sqrt{$val6}
$() et la calculatrice m'affiche le nombre $val7.	<p>	  Que puis-je en déduire?	</p>	<ul>	<li> 
!read oef/embed.phtml reply1,1 
$()</li>	<li> 
!read oef/embed.phtml reply1,2 
$()</li>	<li> 
!read oef/embed.phtml reply1,3 
$()</li>	<li> 
!read oef/embed.phtml reply1,4 
$()</li>	<li> 
!read oef/embed.phtml reply1,5 
$()</li>	</ul>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7
embedcnt=5
