!set title=Valeur dÈcimale III
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=RÈgine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=16
prevarcnt=15
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem 2,3,5,6,7,8,10,11,12,13,14

val6=$[rint($(tmp0))]
val7=$[sqrt($val6)*100000]
val7=$[rint($val7)]
t_=!rawmath $val7/10000
val8=!exec pari print($t_)
t_=!rawmath $val8/100
val9=!exec pari print($t_)
t_=!rawmath -$val8
val10=!exec pari print($t_)
tmp0=!randint 1001, 9999

tmp1=!randint 1, 9

tmp2=!randint 101, 999

tmp3=!randint 1001, 9999

tmp4=!randint 1, 9

tmp5=!randint 1001, 9999

val11=($(tmp0)*10+$(tmp1))/10000,$(tmp2)/10000,-($(tmp3)*10+$(tmp4))/10000,$(tmp5)/1000
val11=$val8,$val9,$val10
tmp=!nonempty items $val11

tmp0=!randitem $tmp
val7=$[$(tmp0)]
tmp0=!randitem 2,3

val12=$[rint($(tmp0))]
val13=$[$val7*10^$val12]
val14=$val13
tmp0=!replace internal . by , in $val14

val14=$(tmp0)
val15=$[$(val14[1])/10^$val12]
val16=la toncature ‡ $val12 dÈcimales
replytype1=numeric
replyname1=
replygood1=$[$val15]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Donner un nombre dÈcimal qui soit $val16 de:	<div class="wimscenter">A=$val7 </div>	  <label for="reply1">Votre rÈponse</label>:	<div class="wimscenter"> 
!read oef/embed.phtml reply1,5 
$()	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,16
embedcnt=1
