!set title=Calcul avec des fractions V
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Rťgine, Mangeard; Jean-Pierre, Boudine
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=7
prevarcnt=6
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=A faire sans calculatrice!
tmp0=!randint 2, 6

val7=$[rint($(tmp0))]
tmp0=!randint 3, 11

val8=$[rint($(tmp0))]
tmp0=!randint 4, 13

val9=$[rint($(tmp0))]
val10=\frac{\frac{$val7}{-$val8}}{\frac{$val9}{$val7}}
tmp=!translate ";': to $     $ in ($val7/(-$val8))/ ( $val9 / $val7)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!rawmath $(tmp0)
val11=!exec pari print($t_)
replytype1=numexp
replyname1=
replygood1=$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="wims_warning">$val6</div>	  Calculer :	<div class="wimscenter">
!insmath A=$val10
$()</div>	  Exprimer le rťsultat sous forme d'une fraction irrťductible.	<div class="wimscenter"><label for="reply1">Votre solution</label> :  
!read oef/embed.phtml reply1,5 
$()</div>	
$()
!exit

