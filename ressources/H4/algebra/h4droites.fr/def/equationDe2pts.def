!set title=Equation par deux points
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Joachim Yaméogo
email=yameogo@unice.fr
language=fr
computeanswer=yes
precision=1000

ansorder=r
varcnt=33
prevarcnt=32
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=lightblue
val7=300
val8=300
val9=-4
val10=4
val11=-4
val12=4
val13=linewidth 1	parallel 0,$val11,0,$val12,0.2,0,floor(5*($val10))+1,$val6	parallel 0,$val11,0,$val12,-0.2,0,floor(5*abs($val9))+1,$val6	parallel $val9,0,$val10,0,0,0.2,floor(5*($val12))+1,$val6	parallel $val9,0,$val10,0,0,-0.2,floor(5*abs($val11))+1,$val6	
val14=linewidth 3	parallel 0,$val11,0,$val12,1,0,floor($val10+1),$val6	parallel 0,$val11,0,$val12,-1,0,floor(abs($val9)+1),$val6	parallel $val9,0,$val10,0,0,1,floor($val12+1),$val6	parallel $val9,0,$val10,0,0,-1,floor(abs($val11)+1),$val6	
val15=linewidth 2	vline 0,0,black	hline 0,0,black	arrow 0,0,1,0,10,magenta	arrow 0,0,0,1,10,magenta	text red,0.7,-0.1,medium,i	text red,-0.3,0.7,medium,j	text black,-0.3,-0.1,medium,O	arrow $val10-1,0,$val10,0,10,black	arrow 0,$val12-1,0,$val12,10,black	text black,$val10-0.3,-0.2,large,x	text black,-0.3,$val12-0.2,large,y	
val16=xrange $val9,$val10	yrange $val11,$val12	$val13	$val14	$val15	
tmp0=!randitem -1,1

tmp1=!randint 1, ($val10-1)

val17=$[rint($(tmp0)*$(tmp1))]
!if $val17>0 
tmp0=!randint ($val9+1), ($val17-1)

val18=$[rint($(tmp0))]
!else
tmp0=!randint ($val17+1), ($val10-1)

val18=$[rint($(tmp0))]
!endif
tmp0=!randitem -1,1

tmp1=!randint 1, ($val12-1)

val19=$[rint($(tmp0)*$(tmp1))]
!if $val19>0 
tmp0=!randint ($val11+1), ($val19-1)

val20=$[rint($(tmp0))]
!else
tmp0=!randint ($val19+1), ($val12-1)

val20=$[rint($(tmp0))]
!endif
val21=$[rint($val20-($val19))]
val22=$[rint($val17-($val18))]
val23=$[rint(($val17)*($val20-($val19))-($val19)*($val18-($val17)))]
val24=!rawmath ($val21)*x+($val22)*y
t_=!replace internal \( by ( in $val24-($val23);
tmp0=!exec maxima $t_

val25=$(tmp0)
val26=$val25=0
t_=!replace internal \( by ( in ((-$val21)*x+($val23))/($val22);
tmp0=!exec maxima $t_

val27=$(tmp0)
tmp0=!texmath $val25=0

val25=$(tmp0)
tmp0=!texmath $val24=$val23

val28=$(tmp0)
val29=$val25
val30=$[rint(-$val22)]
val31=$[rint($val21)]
tmp0=!texmath (x-$val17)*($val31)-(y-$val19)*($val30)=0

val32=$(tmp0)
tmp0=!shuffle red,blueviolet,green,brown

val33=$(tmp0)
val34=$val16	linewidth 2	plot $(val33[1]),$val27	text black,$val17-0.3,$val19-0.2,large,A	text black,$val18-0.3,$val20-0.2,large,B	linewidth 8	point $val17,$val19,$(val33[2])	point $val18,$val20,$(val33[3])	
replytype1=equation
replyname1=
replygood1=!rawmath $val26
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="affiche_pres">	  Dans le plan 
!insmath \RR^2
$() muni d'un repčre  
!insmath (O,i,j)
$(), on considčre	  la droite <b>D</b> passant par les deux points 
!insmath A($val17,$val19)
$() et 
!insmath B($val18,$val20)
$().	  <br>	  Donnez une équation de la droite <b>D</b>.	</div>	<div class="affiche_pres">	  <b>Votre réponse.</b> (sous l'une des formes 
!insmath a x + b y - c=0
$() ou 
!insmath a x + b y=c
$())	  <br>	  <span style="background-color:bisque;padding:4px;">	  Une équation  de la droite <b>D</b> est donnée par:  
!read oef/embed.phtml reply 1,20 6 
$().	  </span>	</div>	
$()
!exit

:hint
$()	  <p style="background-color:bisque;">	  Pour un point 
!insmath M(x,y)\in \RR^2
$(), écrire une relation de colinéarité entre	  le vecteur 
!insmath \vec{AM}(x-x_A,y-y_A)
$() et le vecteur 
!insmath \vec{AB}
$().	  </p>	
$()
!exit

:help
$()
$()
!exit

:solution
$()	  <b><span style="color:darkcyan;">exemple de r&eacute;daction</span></b> de la solution:	  <br>	   Un vecteur directeur de la droite <b>D</b> est donné par 
!insmath \vec{AB}($val30,$val31)
$().	   Pour un point 
!insmath M(x,y)\in \RR^2
$(), une relation de colinéarité entre	   
!insmath \vec{AM}(x-x_A,y-y_A)
$() et le vecteur	  
!insmath \vec{AB}
$() est donnée par l'équation 
!insmath $val32
$(). On en déduit facilement	  que la droite <b>D</b> admet pour équation 
!insmath $val29
$().		  <div class="affiche_pres" style="text-align:center;">	        Voici une représentation graphique de la droite <b>D</b>:	      <p>	         
!read oef/draw.phtml $val7,$val8 \
	   $val34	    
$()	      </p>	  </div>	
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,8,17,18,19,20,29,30,31,32,34
embedcnt=1
