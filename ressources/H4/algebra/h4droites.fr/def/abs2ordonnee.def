!set title=Avec l'ordonnée , trouver l'abscisse
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Joachim Yaméogo
email=yameogo@unice.fr
language=fr
computeanswer=yes
precision=1000

ansorder=r
varcnt=38
prevarcnt=37
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=lightblue
val7=300
val8=300
val9=-4
val10=4
val11=-4
val12=4
val13=linewidth 1	parallel 0,$val11,0,$val12,0.2,0,floor(5*($val10))+1,$val6	parallel 0,$val11,0,$val12,-0.2,0,floor(5*abs($val9))+1,$val6	parallel $val9,0,$val10,0,0,0.2,floor(5*($val12))+1,$val6	parallel $val9,0,$val10,0,0,-0.2,floor(5*abs($val11))+1,$val6	
val14=linewidth 3	parallel 0,$val11,0,$val12,1,0,floor($val10+1),$val6	parallel 0,$val11,0,$val12,-1,0,floor(abs($val9)+1),$val6	parallel $val9,0,$val10,0,0,1,floor($val12+1),$val6	parallel $val9,0,$val10,0,0,-1,floor(abs($val11)+1),$val6	
val15=linewidth 2	vline 0,0,black	hline 0,0,black	arrow 0,0,1,0,10,magenta	arrow 0,0,0,1,10,magenta	text red,0.7,-0.1,medium,i	text red,-0.3,0.7,medium,j	text black,-0.3,-0.1,medium,O	arrow $val10-1,0,$val10,0,10,black	arrow 0,$val12-1,0,$val12,10,black	text black,$val10-0.3,-0.2,large,x	text black,-0.3,$val12-0.2,large,y	
val16=xrange $val9,$val10	yrange $val11,$val12	$val13	$val14	$val15	
tmp0=!randitem -1,1

tmp1=!randint 1, ($val10-1)

val17=$[rint($(tmp0)*$(tmp1))]
!if $val17>0 
tmp0=!randint ($val9+1), ($val17-1)

val18=$[rint($(tmp0))]
!else
tmp0=!randint ($val17+1), ($val10-1)

val18=$[rint($(tmp0))]
!endif
tmp0=!randitem -1,1

tmp1=!randint 1, ($val12-1)

val19=$[rint($(tmp0)*$(tmp1))]
!if $val19>0 
tmp0=!randint ($val11+1), ($val19-1)

val20=$[rint($(tmp0))]
!else
tmp0=!randint ($val19+1), ($val12-1)

val20=$[rint($(tmp0))]
!endif
val21=$[rint($val20-($val19))]
val22=$[rint($val17-($val18))]
val23=$[rint(($val17)*($val20-($val19))-($val19)*($val18-($val17)))]
val24=!rawmath ($val21)*x+($val22)*y
t_=!replace internal \( by ( in $val24-($val23);
tmp0=!exec maxima $t_

val25=$(tmp0)
t_=!replace internal \( by ( in ((-$val21)*x+($val23))/($val22);
tmp0=!exec maxima $t_

val26=$(tmp0)
tmp0=!texmath $val25=0

val25=$(tmp0)
tmp0=!texmath $val24=$val23

val27=$(tmp0)
val28=$val25,$val27
tmp0=!randitem 1,2

val29=$[rint($(tmp0))]
val30=$(val28[$val29])
tmp0=!randitem -1,1

tmp1=!randitem 1/2,1,3/2,2,5/2,3,7/2

val31=$(tmp0)*$(tmp1)
t_=!replace internal \( by ( in ($val21)*x+($val22)*($val31)-($val23);
tmp0=!exec maxima $t_

tmp1=!texmath $(tmp0)=0

tmp2=!texmath ($val21)*x+($val22)*($val31)=$val23

val32=$(tmp1),$(tmp2)
val33=$[rint(-$val22)]
val34=$[rint($val21)]
t_=!replace internal \( by ( in (1/($val21))*((-$val22)*($val31)+($val23));
tmp0=!exec maxima $t_

val35=$(tmp0)
tmp0=!texmath $val35

val36=$(tmp0)
tmp0=!texmath $val31

val37=$(tmp0)
tmp0=!shuffle red,blueviolet,green,brown

val38=$(tmp0)
val39=$val16	linewidth 2	plot $(val38[1]),$val26	linewidth 8	point $val35,$val31,$(val38[2])	text $(val38[2]),$val35-0.3,$val31-0.3,giant,M	linewidth 2	dline $val9,$val31,$val10,$val31,$(val38[2])	
replyname1=
replygood1=$val35
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="affiche_pres">	  Le plan 
!insmath \RR^2
$() est muni d'un rep&egrave;re 
!insmath (O,i,j)
$().	  On consid&egrave;re la droite <b>D</b> dont une &eacute;quation est donn&eacute;e par	  &nbsp; 
!insmath $val30
$() .	  <br>	  Calculer l'abscisse 
!insmath x_{M}
$() du point 
!insmath M
$() de la droite <b>D</b>, dont l'ordonnée est	  
!insmath y_{M}=$val37
$().	  <hr>	  Votre r&eacute;ponse&nbsp;:	      <span style="background-color:antiquewhite;padding:4px">	        l'abscisse de 
!insmath M
$() est  
!read oef/embed.phtml reply 1,10 
$()	      </span>	</div>	
$()
!exit

:hint
$()	  <ul>	    <li>	      Noter pour commencer, que la droite <b>D</b> n'est pas parallčle ŕ la droite	      d'équation 
!insmath y=$val37
$(), car le coefficient de 
!insmath x
$() dans l'équation de	      <b>D</b> n'est pas nul.	    </li>	    <li>	      Remplacer 
!insmath y
$() par 
!insmath $val37
$() dans l'équation de la droite et résoudre	      l'équation correspondante en 
!insmath x
$().	    </li>	  </ul>	
$()
!exit

:help
$()
$()
!exit

:solution
$()	  Voici un	  <b><span style="color:darkcyan;">exemple de r&eacute;daction</span></b> de la solution&nbsp;:	  <br>	  Pour trouver l'abscisse du point 
!insmath M\in D
$() dont l'ordonnée est 
!insmath $val37
$(), nous	  remplaçons 
!insmath y
$() par 
!insmath $val37
$() dans l'équation &nbsp; 
!insmath $val30
$().	  On est donc amené	  ŕ résoudre l'équation suivante 
!insmath $(val32[$val29])
$() oů l'inconnue est 
!insmath x
$().	  On trouve alors la solution 
!insmath x=$val36
$(). La droite <b>D</b> rencontre donc	  la droite d'équation 
!insmath y=$val37
$() en 
!insmath M($val36,$val37)
$().	  <div class="affiche_pres" style="text-align:center;">	    Voici une représentation graphique de la droite <b>D</b>:	      <p>	         
!read oef/draw.phtml $val7,$val8 \
	   $val39	    
$()	      </p>	  </div>	
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,8,29,30,32,36,37,39
embedcnt=1
