!set title=Sélectionner un vecteur directeur II
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Marie-Claude, David;Joachim, Yaméogo
email=Marie-Claude.David@math.u-psud.fr,Yameogo@unice.fr
language=fr
computeanswer=yes
precision=1000

ansorder=r
varcnt=51
prevarcnt=50
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=lightblue
val7=300
val8=300
val9=-4
val10=4
val11=-4
val12=4
val13=linewidth 1	parallel 0,$val11,0,$val12,0.2,0,floor(5*($val10))+1,$val6	parallel 0,$val11,0,$val12,-0.2,0,floor(5*abs($val9))+1,$val6	parallel $val9,0,$val10,0,0,0.2,floor(5*($val12))+1,$val6	parallel $val9,0,$val10,0,0,-0.2,floor(5*abs($val11))+1,$val6	
val14=linewidth 3	parallel 0,$val11,0,$val12,1,0,floor($val10+1),$val6	parallel 0,$val11,0,$val12,-1,0,floor(abs($val9)+1),$val6	parallel $val9,0,$val10,0,0,1,floor($val12+1),$val6	parallel $val9,0,$val10,0,0,-1,floor(abs($val11)+1),$val6	
val15=linewidth 2	vline 0,0,black	hline 0,0,black	arrow 0,0,1,0,10,magenta	arrow 0,0,0,1,10,magenta	text red,0.7,-0.1,medium,i	text red,-0.3,0.7,medium,j	text black,-0.3,-0.1,medium,O	arrow $val10-1,0,$val10,0,10,black	arrow 0,$val12-1,0,$val12,10,black	text black,$val10-0.3,-0.2,large,x	text black,-0.3,$val12-0.2,large,y	
val16=xrange $val9,$val10	yrange $val11,$val12	$val13	$val14	$val15	
tmp0=!randitem -1,1

tmp1=!randint 1, ($val10-1)

val17=$[rint($(tmp0)*$(tmp1))]
!if $val17>0 
tmp0=!randint ($val9+1), ($val17-1)

val18=$[rint($(tmp0))]
!else
tmp0=!randint ($val17+1), ($val10-1)

val18=$[rint($(tmp0))]
!endif
tmp0=!randitem -1,1

tmp1=!randint 1, ($val12-1)

val19=$[rint($(tmp0)*$(tmp1))]
!if $val19>0 
tmp0=!randint ($val11+1), ($val19-1)

val20=$[rint($(tmp0))]
!else
tmp0=!randint ($val19+1), ($val12-1)

val20=$[rint($(tmp0))]
!endif
val21=$[rint($val20-($val19))]
val22=$[rint($val17-($val18))]
val23=$[rint(($val17)*($val20-($val19))-($val19)*($val18-($val17)))]
val24=!rawmath ($val21)*x+($val22)*y
t_=!replace internal \( by ( in $val24-($val23);
tmp0=!exec maxima $t_

val25=$(tmp0)
t_=!replace internal \( by ( in ((-$val21)*x+($val23))/($val22);
tmp0=!exec maxima $t_

val26=$(tmp0)
tmp0=!texmath $val25=0

val25=$(tmp0)
tmp0=!texmath $val24=$val23

val27=$(tmp0)
tmp0=!randitem $val25,$val27

val28=$(tmp0)
val29=$[rint(-$val22)]
val30=$[rint($val21)]
tmp0=!shuffle -5,-4,-3,3,4,5

val31=$(tmp0)
tmp0=!randitem -1,1

tmp1=!randitem 1,2,3

val32=$[rint($(tmp0)*$(tmp1))]
tmp=!trim 
val33=!translate internal $	\
$ to ;; in $tmp
!for val34 =1 to 3 
val35=$[rint($(val31[$val34])+($val32)*($val30))]
tmp=!trim $val33	              ($val29)*($val32),$val35	       
val33=!translate internal $	\
$ to ;; in $tmp
!next
tmp=!trim $val33	            $val29,$val30	     
val33=!translate internal $	\
$ to ;; in $tmp
val36=
!for val34 =1 to 4 
tmp0=!randitem -3,-2,-1,2,3

val37=$[rint($(tmp0))]
val38=$[rint(($val37)*($(val33[$val34;1])))]
val39=$[rint(($val37)*($(val33[$val34;2])))]
!if $val34=4 
val40=$[rint($val38)]
val41=$[rint($val39)]

!ifval $val37=-1
val42= - 
!else
val42= $val37
!endif
!endif
!if $val39<0 
tmp0=!texmath $val38\vec{i} $val39\vec{j}

val43=$(tmp0)
!else

!ifval $val39<>0
tmp0=!texmath $val38\vec{i}+$val39\vec{j}

val43=$(tmp0)
!else
tmp1=!texmath $val38\vec{i}

val43=$(tmp1)
!endif
!endif
tmp0=!append item $val43 to $val36

val36=$(tmp0)
!next
tmp0=!shuffle 4

val44=$(tmp0)
tmp0=!positionof item 4 in $val44

val45=$(tmp0)
tmp0=!shuffle red,blueviolet,green,brown

val46=$(tmp0)
val47=$val16	linewidth 2	plot $(val46[1]),$val26	
replytype1=radio
replyname1=
replygood1=$val45;1,2,3,4
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<p>	  Dans le plan 
!insmath \RR^2
$() est muni d'un repčre 
!insmath (O,i,j)
$(), on considčre	  la droite 
!insmath \mathcal{D}
$() dont une &eacute;quation est donn&eacute;e par	  &nbsp; 
!insmath $val28
$().	  <br>	  Dans la liste suivante, trouvez un vecteur directeur pour la droite 
!insmath \mathcal{D}
$().	</p>	<ul>	  <li> 
!read oef/embed.phtml reply1,1 
$() :  
!insmath $(val36[$(val44[1])])
$()</li>	  <li> 
!read oef/embed.phtml reply1,2 
$() :  
!insmath $(val36[$(val44[2])])
$()</li>	  <li> 
!read oef/embed.phtml reply1,3 
$() :  
!insmath $(val36[$(val44[3])])
$()</li>	  <li> 
!read oef/embed.phtml reply1,4 
$() :  
!insmath $(val36[$(val44[4])])
$()</li>	</ul>	
$()
!exit

:hint
$()	   Vous pouvez utiliser le th&eacute;or&egrave;me suivant:	  <p style="background-color:bisque;">	    <b>Th&eacute;or&egrave;me:</b> L'ensemble des points 
!insmath M\ (x,y)
$() tels que	    
!insmath a x + b y = c
$(), avec 
!insmath a
$() et 
!insmath b
$() non simultanément nuls, est une droite admettant	    le vecteur 
!insmath \vec{v}\ (-b,a)
$() pour vecteur directeur.	  </p>	
$()
!exit

:help
$()
$()
!exit

:solution
$()	   <p> Voici un	    <b><span style="color:darkcyan;">exemple de r&eacute;daction</span></b> de la solution.	  </p>	  <p>	  Pour trouver un vecteur directeur de la droite 
!insmath \mathcal{D}
$(), nous allons appliquer le	  th&eacute;or&egrave;me suivant:</p>	  <p style="background-color:bisque;">	  <b>Th&eacute;or&egrave;me:</b> L'ensemble des points 
!insmath M(x,y)
$() tels que 
!insmath a x + b y = c
$(),	  avec 
!insmath a
$() et 
!insmath b
$() non simultanément nuls, est une droite admettant le vecteur	  
!insmath \vec{v}(-b,a)
$() pour vecteur directeur.	  </p>	  Ici nous avons 
!insmath a=$val21
$() et 
!insmath b=$val22
$(). Un vecteur directeur de la droite 
!insmath \mathcal{D}
$() est	  donc le vecteur 
!insmath \vec{v}\ ($val29,$val30)
$(), qui est colinéaire au	  $val45<sup><small>&egrave;me</small></sup> vecteur non nul &nbsp;	  
!insmath \vec{w}\ ($val40,$val41)
$() &nbsp; de la liste propos&eacute;e. On vérifiera l'égalité :	  
!insmath \vec{w}\ ($val40,$val41)=$val42\vec{v}\ ($val29,$val30)
$().</p>	  <p class="wimscenter">	        Voici une représentation graphique de la droite 
!insmath \mathcal{D}
$().	      <br>	         
!read oef/draw.phtml $val7,$val8 \
	   $val47	    
$()	  </p>	
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,8,21,22,28,29,30,36,40,41,42,44,45,47
