!set title=Simplification de valeur absolue 2
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=David Doyen
email=david.doyen@u-pem.fr
language=fr

ansorder=r
varcnt=32
prevarcnt=31
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=-8,-7,-6,-5,-4,-3,-2,2,3,4,5,6,7,8,9
tmp0=!shuffle $val6

val6=$(tmp0)
val7=$(val6[1])
val8=$(val6[2])
tmp=!nonempty items -3,-2,-1

tmp0=!randitem $tmp
val9=$(tmp0)
tmp=!translate ";': to $     $ in -$val8/$val7

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val10=$(tmp0)
tmp0=!texmath $val10

val11=$(tmp0)
tmp=!nonempty items $val7*x+$val8,$val8+$val7*x

tmp0=!randitem $tmp
val12=$(tmp0)
t_=!replace internal \( by ( in $val12
tmp0=!exec pari $t_

val12=$(tmp0)
tmp0=!randint 1, 2

val13=$(tmp0)
!if $val13=1 
tmp0=!texmath $val12

val14=$(tmp0)
val15=abs($val12)
val16=$val9*$val15
!else
val12=$val9*($val12)
tmp0=!texmath $val12

val14=$(tmp0)
val15=abs($val12)
val16=$val15
!endif
tmp0=!randint 1, 2

val17=$(tmp0)
!if $val17=1 
val18=\({x \geq $val11}\)
t_=!rawmath $val10+1
val19=!exec pari print($t_)
!else
val18=\({x \leq $val11}\)
t_=!rawmath $val10-1
val19=!exec pari print($t_)
!endif
evaltmp=$val12

evaltmp=!mathsubst x=($val19) in $evaltmp
tmp0=($evaltmp)
t_=!rawmath $(tmp0)
val20=!exec pari print($t_)
!if $val20>0 
tmp=!translate ";': to $     $ in $val12

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val21=$(tmp0)
val22=\($val14 \geq 0\)
val23=\($val15= $val21\)
!else
tmp=!translate ";': to $     $ in -($val12)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val21=$(tmp0)
val22=\($val14 \leq 0\)
val23=\($val15= -($val12)= $val21\)
!endif
!if $val13=1 
tmp=!translate ";': to $     $ in $val9*($val21)

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val24=$(tmp0)
!else
val24=$val21
!endif
replytype1=formal
replyname1=
replygood1=$val24
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()On suppose $val18. Simplifier l'expression 
!insmath $val16
$() en une expression ne faisant pas intervenir de valeur absolue.<br class="spacer">	
!insmath $val16
$() 
!insmath =
$()  
!read oef/embed.phtml reply1,10 
$()	
$()
!exit

:hint
$()Etudier le signe de 
!insmath $val14
$() quand $val18.
$()
!exit

:help
$()
$()
!exit

:solution
$()Si $val18, alors $val22.<br>	D'oł, $val23.	
!if $val13=1 
$()<br> Finalement, 
!insmath $val16=$val24
$(). 
!endif
$()	
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=13,14,16,18,22,23,24
embedcnt=1
