!set title=InÈquations du type \({|a x+b|}\leq c\) (inÈgalitÈs)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=David Doyen
email=david.doyen@u-pem.fr
language=fr

ansorder=r,r,r,r
varcnt=12
prevarcnt=11
postvarcnt=0
replycnt=4
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 9

val6=$(tmp0)
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
tmp1=!randint 1, 9

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 9

val8=$(tmp0)
t_=!rawmath ($val8-$val7)/$val6
val9=!exec pari print($t_)
t_=!rawmath (-$val8-$val7)/$val6
val10=!exec pari print($t_)
!if $val7>0 
tmp=!nonempty items $val6*x+$val7,$val7+$val6*x

tmp0=!randitem $tmp
val11=$(tmp0)
!else
tmp=!nonempty items $val6*x+$val7,$val7+$val6*x,-$val6*x-$val7,-$val7-$val6*x

tmp0=!randitem $tmp
val11=$(tmp0)
!endif
tmp0=!texmath $val11

val11=$(tmp0)
tmp=!nonempty items <,\leq

tmp0=!randitem $tmp
val12=$(tmp0)
val13=\({$val12}\)
val14=\({<}\),\({\leq}\)
replytype1=numexp
replyname1=
replygood1=$val10
replytype2=clickfill
replyname2=
replygood2=$val13;$val14
replytype3=clickfill
replyname3=
replygood3=$val13;$val14
replytype4=numexp
replyname4=
replygood4=$val9
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div>DÈterminer l'ensemble des rÈels 
!insmath x
$() tels que 
!insmath {|$val11|} $val12 $val8
$().</div>	<div>Il s'agit de l'ensemble des rÈels 
!insmath x
$() vÈrifiant l'encadrement  
!read oef/embed.phtml reply1,3 
$()  
!read oef/embed.phtml reply2,25x25 
$() 
!insmath x
$() 
!read oef/embed.phtml reply3,25x25 
$()  
!read oef/embed.phtml reply4,3 
$()</div>	
$()
!exit

