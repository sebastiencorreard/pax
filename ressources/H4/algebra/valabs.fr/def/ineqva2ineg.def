!set title=InÈquations du type \({|a x+b|}\geq c\) (inÈgalitÈs)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=David Doyen
email=david.doyen@u-pem.fr
language=fr

ansorder=r,r,r,r
varcnt=15
prevarcnt=14
postvarcnt=0
replycnt=4
choicecnt=0
conditioncnt=1
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 9

val6=$(tmp0)
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
tmp1=!randint 1, 9

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 9

val8=$(tmp0)
t_=!rawmath ($val8-$val7)/$val6
val9=!exec pari print($t_)
t_=!rawmath (-$val8-$val7)/$val6
val10=!exec pari print($t_)
!if $val7>0 
tmp=!nonempty items $val6*x+$val7,$val7+$val6*x

tmp0=!randitem $tmp
val11=$(tmp0)
!else
tmp=!nonempty items $val6*x+$val7,$val7+$val6*x,-$val6*x-$val7,-$val7-$val6*x

tmp0=!randitem $tmp
val11=$(tmp0)
!endif
tmp0=!texmath $val11

val11=$(tmp0)
tmp=!nonempty items >,\geq

tmp0=!randitem $tmp
val12=$(tmp0)
val13=\({<}\),\({\leq}\),\({>}\),\({\geq}\)
!if $val12=\geq 
val14=\({\leq}\)
val15=\({\geq}\)
!else
val14=\({<}\)
val15=\({>}\)
!endif
replytype1=clickfill
replyname1=
replygood1=?analyze 16;$val13
replytype2=numexp
replyname2=
replygood2=?analyze 17
replytype3=clickfill
replyname3=
replygood3=?analyze 18;$val13
replytype4=numexp
replyname4=
replygood4=?analyze 19
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div>DÈterminer l'ensemble des rÈels 
!insmath x
$() tels que 
!insmath {|$val11|} $val12 $val8
$().</div>	<div>Il s'agit de l'ensemble des rÈels 
!insmath x
$()  
!read oef/embed.phtml reply1,25x25x1 
$()  
!read oef/embed.phtml reply2,3 
$() et des rÈels 
!insmath x
$()  
!read oef/embed.phtml reply3,25x25x1 
$()  
!read oef/embed.phtml reply4,3 
$()</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback
!ifval 1=1
 <div class='oef_feedbacks'>Il s'agit de l'ensemble des rÈels 
!insmath x
$() $val14 
!insmath $val10
$() et des rÈels 
!insmath x
$() $val15 
!insmath $val9
$()
$()</div>
!endif

!exit

:test

!ifval (($val16 issametext $val14) and ($val17=$val10) and ($val18 issametext $val15) and ($val19=$val9)) or (($val16 issametext $val15) and ($val17=$val9) and ($val18 issametext $val14) and ($val19=$val10))
 condtest1=1
!else
 condtest1=0
!endif
condname1=Bonne rÈponse

!exit

:stat
vsavelist=8,9,10,11,12,14,15,16,17,18,19
embedcnt=4
