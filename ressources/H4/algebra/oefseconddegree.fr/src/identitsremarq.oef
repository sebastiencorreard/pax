<tr><td style="text-align: center; ">\embed{r8}</td><td style="text-align: center; ">\if{\forme=1}{\(\fft)}{\if{\forme=2}{\((\babs-\aabs*x)^2) }{\if{\b>0}{\((\a*x+\babs)^2)}{\((\a*x-\babs)^2)}}}</td></tr>
</table>
}
