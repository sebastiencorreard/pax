<tr><td style="text-align: center; width: 20%;">\(a^2\)</td><td style="text-align: center; width: 20%;">\(a\)</td><td style="text-align: center; width: 20%;">\(b^2\)</td><td style="text-align: center; width: 20%;">\(b\)</td><td style="text-align: center; width: 20%;">&plusmn;\(2ab)</td></tr>
<tr><td style="text-align: center; ">\embed{r3,3}</td><td style="text-align: center;">\embed{r4,3}</td><td style="text-align: center;">\embed{r5,3}</td><td  style="text-align: center;">\embed{r6,3}</td><td style="text-align: center;">\embed{r7,3}</td></tr>
</table><br><br>
