<tr><td style="text-align: center; ">\embed{r3,3}</td><td style="text-align: center;">\embed{r4,3}</td><td style="text-align: center;">\embed{r5,3}</td><td  style="text-align: center;">\embed{r6,3}</td><td style="text-align: center;">\embed{r7,3}</td></tr>
</table><br><br>
<table class="wimsborder"><td style="text-align: center; width: 50%;">Formule factorisée</td><td style="text-align: center; width: 50%;">Expression factorisée</td></tr>
<tr><td style="text-align: center; ">\embed{r8}</td><td style="text-align: center; ">\embed{r9,12}</td></tr>
</table>
}
