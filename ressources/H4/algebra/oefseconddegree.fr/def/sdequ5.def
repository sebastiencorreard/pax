!set title=Equation 5 : ax≤+bx&#61;0
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
language=fr
computeanswer=yes
precision=1000

ansorder=r
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 10

tmp1=!randitem -1,1

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 30

tmp1=!randitem -1,1

val7=$[rint($(tmp0)*$(tmp1))]
t_=!replace internal \( by ( in $val6*x^2+$val7*x
tmp0=!exec maxima $t_

val8=!rawmath $(tmp0)
t_=!rawmath -$val7/$val6
val9=!exec pari print($t_)
val10=0,$val9
t_=!replace internal \( by ( in $val6*x+$val7
tmp0=!exec maxima $t_

val11=!rawmath $(tmp0)
val12=$[rint(-$val7)]
replytype1=fset
replyname1=Solutions
replygood1=$val10
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Rťsoudre dans 
!insmath \ \RR
$() l'ťquation :	<div class="wimscenter wims_emph">	
!insmath $val8=0
$()	</div>	S= 
!read oef/embed.phtml r1,8 
$()	<div class="wims_instruction">	Sťparer les solutions ťventuelles par une virgule.</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
!insmath $val8
$() n'ayant que des termes en x,	on peut factoriser par x:	<div class="spacer">	
!insmath $val8=0
$() &hArr; 
!insmath x($val11)=0
$() &hArr;
!insmath x=0
$() ou 
!insmath $val11=0
$() &hArr; 
!insmath x=0
$() ou 
!insmath x=\frac{$val12}{$val6}
$().	</div>
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,8,11,12
embedcnt=1
