!set title=Equation 4 : (ax+b)˛&#61;(cx+d)˛
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
language=fr
computeanswer=yes
precision=1000

ansorder=r
varcnt=21
prevarcnt=20
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 5

val6=$[rint($(tmp0))]
tmp0=!randint 1, 20

tmp1=!randitem -1,1

val7=$[rint($(tmp0)*$(tmp1))]
val8=!rawmath ($val6*x+$val7)^2
tmp0=!randint 1, 10

tmp1=!randitem -1,1

val9=$[rint($val6+$(tmp0)*$(tmp1))]

!ifval ($val9=0)
tmp0=!randint 6, 10

val9=$[rint( $(tmp0))]
!else
val9=$[rint($val9)]
!endif
tmp0=!randint 1, 20

tmp1=!randitem -1,1

val10=$[rint($(tmp0)*$(tmp1))]
val11=!rawmath ($val9*x+$val10)^2
t_=!rawmath ($val10-$val7)/($val6-$val9)
val12=!exec pari print($t_)

!ifval ($val6+$val9=0)
t_=!rawmath  -10000000
val13=!exec pari print($t_)
!else
t_=!rawmath (-$val10-$val7)/($val6+$val9)
val13=!exec pari print($t_)
!endif

!ifval ($val6+$val9=0)
val14= $val12
!else
val14=$val12,$val13
!endif
val15=\(\Leftrightarrow\)
val16=!rawmath $val6*x+$val7
val17=!rawmath $val9*x+$val10
t_=!replace internal \( by ( in ($val6-$val9)*x+($val7-$val10)
tmp0=!exec maxima $t_

val18=!rawmath $(tmp0)
t_=!replace internal \( by ( in expand(($val6+$val9)*x+($val7+$val10))
tmp0=!exec maxima $t_

val19=!rawmath $(tmp0)
t_=!replace internal \( by ( in expand(($val7+$val10)*(($val6-$val9)*x+($val7-$val10)))
tmp0=!exec maxima $t_

val20=!rawmath $(tmp0)
val21=$[rint($val6+$val9)]

!ifval ($val21=0)
val22=$[rint( -($val7+$val10)*($val7-$val10))]
!else
val22=$[rint($val10-$val7)]
!endif
val23=$[rint(-($val7+$val10))]

!ifval ($val21=0)
val24=$[rint( ($val7+$val10)*($val6-$val9))]
!else
val24=$[rint($val6-$val9)]
!endif
replytype1=fset
replyname1=Solutions
replygood1=$val14
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Résoudre dans 
!insmath \ \RR
$() l'équation 
!insmath $val8=$val11
$().	<br>L'ensemble des solutions est  <label for "reply1"> 
!read oef/embed.phtml r1,8 
$()</label>.	<div class="wims_instruction">	Séparer les éventuelles solutions par une virgule.	En cas d'absence de solution, écrire : aucune.</div>		
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
!insmath $val8=$val11
$() $val15 
!insmath $val8-$val11=0
$() 	<br>
!insmath $val8=$val11
$() $val15 
!insmath [$val16-($val17)][$val16+($val17)]=0
$() 	<br>
!insmath $val8=$val11
$() $val15 
!insmath ($val18)($val19)=0
$()	<br>
!insmath $val8=$val11
$() $val15 
!if $val21=0 
$()
!insmath $val20=0
$() 
!else
$() 
!insmath $val18=0
$() ou 
!insmath $val19=0
$() 
!endif
$()	<br>
!insmath $val8=$val11
$() $val15 
!insmath x=\frac{$val22}{$val24}
$() 
!if $val21<>0 
$()ou 
!insmath x=\frac{$val23}{$val21}
$() 
!endif
$().
$()
!exit

:latex
$()
$()
!exit

:feedback

