!set title=Inéquation 1: x˛>a
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
language=fr
computeanswer=yes
precision=1000

ansorder=r
varcnt=18
prevarcnt=17
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 10

tmp1=!randitem -1,1

val6=$[rint($(tmp0)*$(tmp1))]
val7=$[rint(-$val6)]
tmp0=!randint 1, 4

val8=$[rint($(tmp0))]
val9=&lt;,&le;,&ge;,&gt
val10=$[sqrt($val6)]

!ifval (floor($val10)=$val10)
val11= $val10
!else
val11=\(\sqrt{$val6})
!endif

!ifval (floor($val10)=$val10)
val12= -$val10
!else
val12=-\(\sqrt{$val6})
!endif

!ifval ($val6<0)
val13= 0,\(\sqrt{$val7}),-\(\sqrt{$val7}),&#93;,&#91;,U,&empty;
!else
val13=&empty;,0,U,+&infin;,-&infin;
!endif
!if $val6<0 
tmp=!trim &empty;	&empty;	&#93;,-&infin;,&#59;,+&infin;,&#91;	&#93;,-&infin;,&#59;,+&infin;,&#91;
val14=!translate internal $	\
$ to ;; in $tmp
!endif
!if $val6=0 
tmp=!trim &empty;	0	&#93;,-&infin;,&#59;,+&infin;,&#91;	&#93;,-&infin;,&#59;,0,&#91;,U,&#93;,0,+&infin;,&#91;
val14=!translate internal $	\
$ to ;; in $tmp
!endif
!if $val6>0 
tmp=!trim &#93;,$val12,&#59;,$val11,&#91;	&#91;,$val12,&#59;,$val11,&#93;	&#93;,-&infin;,&#59;,$val12,&#93;,U,&#91;,$val11,&#59;,+&infin;,&#91;	&#93;,-&infin;,&#59;,$val12,&#91;,U,&#93;,$val11,&#59;,+&infin;,&#91;
val14=!translate internal $	\
$ to ;; in $tmp
!endif
!if $val8<3 
!if $val6<=0 
val15=-10,-11,10,-11
!endif
!if $val6>0 
val15=-sqrt($val6),0,sqrt($val6),0
!endif
!else
!if $val6<=0 
val15=-10,0,10,0
!endif
!if $val6>0 
val15=-10,0,-sqrt($val6),0
!endif
!endif
!if $val6>0 and $val8>=3 
val16=10,0,sqrt($val6),0
!else
val16=-10,-11,10,-11
!endif
replytype1=clickfill
replyname1=Solutions
replygood1=$(val14[$val8;]);$val13
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Résoudre dans 
!insmath \ \RR
$() l'inéquation :	<div class="wimscenter wims_emph">	x<sup>2</sup>$(val9[$val8])$val6</div>	S= 
!read oef/embed.phtml r1,50x30x11 
$()	<div class="wims_instruction">	Faire glisser les élements afin de former l'ensemble des solutions.</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()L'équation 
!insmath x^2=$val6
$() 
!if $val6<0 
$()n'a pas de solution 
!else
$() 
!if $val6=0 
$()a une solution : 0 
!else
$() a deux solutions:	$val11 et $val12 
!endif
$() 
!endif
$().<br/>D'aprčs les variations de la fonction carré, on obtient (en orange) l'ensemble des solutions.	<div class="wimscenter">	 
!read oef/draw.phtml 300,300 \
	xrange -10,10	yrange -10,10	linewidth 2	segment -10,0,10,0, black	segment 0,-10,0,10, black	segment -10,$val6,10,$val6,green	segment 1,-0.3,1,0.3, black	segment -0.3,1,0.3,1, black	text black,-0.5,0,medium,O	text black,0.8,0,medium,I	text black,-0.7,1.3,medium,J	text blue,7,9.5,medium,y=x^2	segment -sqrt($val6),$val6,-sqrt($val6),0,green	segment sqrt($val6),$val6,sqrt($val6),0,green	text green,0.3,$val6,medium,$val6	segment $(val15[1]),$(val15[2]),$(val15[3]),$(val15[4]),orange	segment $(val16[1]),$(val16[2]),$(val16[3]),$(val16[4]),orange	plot blue,x^2 
$()	</div>
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

