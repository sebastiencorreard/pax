!set title=Equation 2 : ax≤+b&#61;c
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
language=fr
computeanswer=yes
precision=1000
computeanswer=yes

ansorder=r
varcnt=10
prevarcnt=9
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 10

tmp1=!randitem -1,1

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 20

tmp1=!randitem -1,1

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 0, 10

tmp1=!randitem -1,1

val8=$[rint($(tmp0)*$(tmp1))]
val9=$[rint($val8*$val6+$val7)]
t_=!replace internal \( by ( in $val6*x^2+$val7
tmp0=!exec maxima $t_

val10=!rawmath $(tmp0)
t_=!rawmath ($val9-$val7)/$val6
val11=!exec pari print($t_)

!ifval ($val11<0)
val12= aucune
!else
val12=sqrt($val11),-sqrt($val11)
!endif

!ifval ($val11=0)
val12= 0
!else
val12=$val12
!endif
val13=$[rint($val9-$val7)]
replytype1=fset
replyname1=Solutions
replygood1=$val12
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div class="wims_question">Rťsoudre dans 
!insmath \ \RR
$(), l'ťquation : 
!insmath $val10=$val9
$().</div>	L'ensemble des solutions est  
!read oef/embed.phtml r1,8 
$().	<div class="wims_instruction">	Pour 
!insmath \sqrt{5}
$() par exemple, ťcrire : <span class="tt">sqrt(5)</span>. Sťparer les solutions ťventuelles par une virgule.	En cas d'absence de solution, ťcrire : <span class="tt">aucune</span>.	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
!insmath $val10=$val9
$() &hArr; 
!insmath $val6 x^2=$val13
$() &hArr; 
!insmath x^2=$val11
$()	
!if $val11<0 
$(). 
!insmath x^2\geq 0
$() et 
!insmath $val11<0
$() donc pas de solution. 
!else
$() 
!if $val11>0 
$()&hArr; 
!insmath x=\sqrt{$val11}
$()	ou 
!insmath x=-\sqrt{$val11}
$(). 
!else
$() &hArr; 
!insmath x=0
$(). 
!endif
$() 
!endif
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,9,10,11,13
embedcnt=1
