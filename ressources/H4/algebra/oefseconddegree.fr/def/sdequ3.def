!set title=Equation 3 : (ax+b)˛&#61;c
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
language=fr
computeanswer=yes
precision=1000

ansorder=r
varcnt=20
prevarcnt=19
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items 1,2,3,3,3

tmp0=!randitem $tmp
val6=$[rint($(tmp0))]

!ifval ($val6=1)
tmp0=!randint -8, -1

val7=$[rint( $(tmp0))]
!else
tmp1=!randint 0, 10

val7=$[rint($(tmp1)^2)]
!endif

!ifval ($val6=2)
tmp0=!randint 2, 24

val7=$[rint( $(tmp0))]
!else
val7=$[rint($val7)]
!endif
tmp0=!randint 1, 5

val8=$[rint($(tmp0))]
tmp0=!randint 1, 20

tmp1=!randitem -1,1

val9=$[rint($(tmp0)*$(tmp1))]
t_=!replace internal \( by ( in ($val8*x+$val9)^2
tmp0=!exec maxima $t_

val10=!rawmath $(tmp0)
tmp0=!texmath $val10

val10=$(tmp0)
val11=(sqrt($val7)-($val9))/$val8
val12=(-sqrt($val7)-($val9))/$val8

!ifval ($val6=1)
val13= aucune
!else
val13=$val11,$val12
!endif

!ifval ($val7=0)
val13= $val11
!else
val13=$val13
!endif
val14=!rawmath $val8*x+$val9
tmp0=!texmath $val14

val14=$(tmp0)
val15=$[rint(sqrt($val7))]
val16=$[rint(sqrt($val7)-$val9)]
val17=$[rint(-sqrt($val7)-$val9)]
val18=$[rint(abs($val9))]
val19=!rawmath $val8*x
tmp0=!texmath $val19

val19=$(tmp0)
replytype1=fset
replyname1=Solutions
replygood1=$val13
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div class="wims_question">Résoudre dans 
!insmath \ \RR
$(), l'équation : 
!insmath $val10=$val7
$().</div>	L'ensemble des solutions est  
!read oef/embed.phtml r1,18 
$().	<div class="wims_instruction">	Pour 
!insmath \sqrt{5}
$() par exemple, écrire : <span class="tt">sqrt(5)</span>.	Séparer les éventuelles solutions par une virgule.	En cas d'absence de solution, écrire : <span class="tt">aucune</span>. Attention aux parenthčses si besoin.</div>		
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
!if $val6=1 
$()
!insmath $val10 \geq 0
$() pour tout nombre réel x et 
!insmath $val7<0
$() donc il n'y pas de solution. 
!else
$()	 
!insmath $val10=$val7
$() &hArr;	
!if $val6=2 
$()
!insmath $val14=\sqrt{$val7}
$() ou 
!insmath $val14=-\sqrt{$val7}
$() &hArr; 
!insmath $val8 x=
$()
!if $val9>0 
$()
!insmath {}-{}
$() 
!endif
$()
!insmath $val18+\sqrt{$val7}
$() ou 
!insmath $val8 x=
$()
!if $val9>0 
$()
!insmath {}-{}
$() 
!endif
$()
!insmath $val18-\sqrt{$val7}
$()	&hArr; 
!insmath \x=
$()
!if $val9>0 
$()
!insmath \frac{-$val18+\sqrt{$val7}}{$val8}
$() 
!else
$() 
!insmath \frac{$val18+\sqrt{$val7}}{$val8}
$() 
!endif
$() ou 
!insmath x=
$()
!if $val9>0 
$()
!insmath \frac{-$val18-\sqrt{$val7}}{$val8}
$() 
!else
$() 
!insmath \frac{$val18-\sqrt{$val7}}{$val8}
$() 
!endif
$() 
!else
$()	 
!insmath $val14=$val15
$() 
!if $val7>0 
$()ou 
!insmath $val14=-$val15
$() 
!endif
$() &hArr; 
!insmath $val19=$val16
$() 
!if $val7>0 
$()ou 
!insmath $val19=$val17
$() 
!endif
$() 
!if $val8>1 
$()&hArr; 
!insmath \x=\frac{$val16}{$val8}
$() 
!if $val7>0 
$()ou 
!insmath x=\frac{$val17}{$val8}
$() 
!endif
$() 
!endif
$(). 
!endif
$()	 
!endif
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,10,14,15,16,17,18,19
