!set title=Equation 1 : x≤&#61;a
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
language=fr
computeanswer=yes
precision=10000

ansorder=r
varcnt=4
prevarcnt=3
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint -10, 20

val6=$[rint($(tmp0))]

!ifval ($val6=0)
val7= 0
!else
val7=sqrt($val6),-sqrt($val6)
!endif

!ifval ($val6<0)
val7= aucune
!else
val7=$val7
!endif
replytype1=fset
replyname1=Solutions
replygood1=$val7
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div class="wims_question">Rťsoudre dans 
!insmath \ \RR
$(), l'ťquation : 
!insmath x^2=$val6
$().</div>	L'ensemble des solutions est  
!read oef/embed.phtml r1,8 
$().	<div class="wims_instruction">	Pour 
!insmath \sqrt{5}
$() par exemple, ťcrire : <span class="tt">sqrt(5)</span>. Sťparer les solutions ťventuelles par une virgule.	En cas d'absence de solution, ťcrire : <span class="tt">aucune</span>.	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()	  
!if $val6<0 
$()
!insmath x^2 \geq 0
$() et 
!insmath $val6<0
$() donc l'ťquation n'a pas de solution. 
!else
$()	     
!if $val6=0 
$()La solution est 0. 
!else
$() Les solutions sont 
!insmath \sqrt{$val6}
$() et 
!insmath -\sqrt{$val6}
$(). 
!endif
$()	   
!endif
$()	
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6
embedcnt=1
