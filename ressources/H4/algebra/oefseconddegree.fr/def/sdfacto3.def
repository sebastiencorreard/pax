!set title=Factorisation 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
language=fr
computeanswer=yes
precision=1000

ansorder=r
varcnt=20
prevarcnt=11
postvarcnt=8
replycnt=1
choicecnt=0
conditioncnt=1
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 6

tmp1=!randitem -1,1

val6=$[$(tmp0)*$(tmp1)]
tmp=!nonempty items -8,-7,-6,-5,-4,-3,-2,-1,1,2,3

tmp0=!randitem $tmp
val7=$[rint($(tmp0))]
tmp0=!randint 1, 7

val8=$[rint(abs($val7)+$(tmp0))]
t_=!replace internal \( by ( in $val6*(x-$val7)*(x-$val8)
tmp0=!exec maxima $t_

val9=!rawmath $(tmp0)
t_=!replace internal \( by ( in ($val6*x-$val6*$val7)*(x-$val8)
tmp0=!exec maxima $t_

val10=!rawmath $(tmp0)
t_=!replace internal \( by ( in ($val6*x-$val6*$val8)*(x-$val7)
tmp0=!exec maxima $t_

val11=!rawmath $(tmp0)
t_=!replace internal \( by ( in expand($val9)
tmp0=!exec maxima $t_

val12=!rawmath $(tmp0)
t_=!replace internal \( by ( in expand((x-$val7)*(x-$val8))
tmp0=!exec maxima $t_

val13=!rawmath $(tmp0)
t_=!replace internal \( by ( in x-$val7
tmp0=!exec maxima $t_

val14=!rawmath $(tmp0)
t_=!replace internal \( by ( in $val7*$val8
tmp0=!exec maxima $t_

val15=$[$(tmp0)]
replytype1=function
replyname1=\(f(x))
replygood1=?analyze 16
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Factoriser 
!insmath f(x)=$val12
$(), en produit de facteurs constants ou affines, sachant que 
!insmath $val7
$() et 
!insmath $val8
$() en sont les racines	.	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()Si 
!insmath x_1
$() et 
!insmath x_2
$() sont les racines de 
!insmath f(x)=ax^2+bx+c
$() alors 
!insmath f(x)=a(x-x_1)(x-x_2)
$()	 donc 
!insmath f(x)=$val9
$().  
$()
!exit

:latex
$()
$()
!exit

:postdef
val17=$val16

!ifval (^2 isin $val17)
val18=$[rint( 1)]
!else
val18=$[rint(0)]
!endif
t_=!replace internal \( by ( in $val16
tmp0=!exec maxima $t_

val19=!rawmath $(tmp0)
val20=$[rint(1)]
!for val21 =1 to 5 
evaltmp=$val19

evaltmp=!mathsubst x=($val21) in $evaltmp
tmp0=($evaltmp)
val22=$[rint($(tmp0))]
evaltmp=$val9

evaltmp=!mathsubst x=($val21) in $evaltmp
tmp0=($evaltmp)
val23=$[rint($(tmp0))]
!if $val22<>$val23 
val20=$[rint(0)]
!endif
!next

!exit

:feedback

!exit

:test

!ifval $val18=0 and $val20=1
 condtest1=1
!else
 condtest1=0
!endif
condname1=Forme factorisée conforme

!exit

:stat
vsavelist=7,8,9,12,16
embedcnt=0
