!set title=Factorisation 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
language=fr
computeanswer=yes
precision=1000

ansorder=r
varcnt=10
prevarcnt=9
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

t_=!replace internal \( by ( in x-\x1
tmp0=!exec maxima $t_

val6=!rawmath $(tmp0)
t_=!replace internal \( by ( in \x1*\x2
tmp0=!exec maxima $t_

val7=$[$(tmp0)]
val8=$[rint(1)]
tmp0=!randint -10, 10

val9=$[rint($(tmp0))]
tmp0=!randint 1, 15

tmp1=!randitem -1,1

val10=$[rint($val9+$(tmp0)*$(tmp1))]
t_=!replace internal \( by ( in $val8*(x-$val9)*(x-$val10)
tmp0=!exec maxima $t_

val11=!rawmath $(tmp0)
t_=!replace internal \( by ( in expand($val11)
tmp0=!exec maxima $t_

val12=!rawmath $(tmp0)
t_=!replace internal \( by ( in x-$val9
tmp0=!exec maxima $t_

val6=!rawmath $(tmp0)
t_=!replace internal \( by ( in $val9*$val10
tmp0=!exec maxima $t_

val7=$[$(tmp0)]
replytype1=algexp
replyname1=f(x)
replygood1=$val11
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Factoriser 
!insmath f(x)=$val12
$() sachant que 
!insmath $val9
$() en est une racine.	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$() 
!insmath $val9
$() est une racine de 
!insmath f(x)
$() donc 
!insmath f(x)=($val6)(x-x2)
$().	
!insmath $val9*x2=$val7
$() ssi 
!insmath x2=$val10
$() donc 
!insmath f(x)=$val11
$().
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,9,10,11,12
embedcnt=0
