!set title=Variations d'une fonction du second degré sous forme factorisée (ax+b)(cx+d)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=David, Rousseau
email=cyrille.douriez@ac-amiens.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r,r,r,r
varcnt=19
prevarcnt=18
postvarcnt=0
replycnt=4
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 6

val6=$[rint($(tmp0))]
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
val7=$[rint($(tmp0))]
val8=$[rint($val6*$val7)]

!ifval ($val7=-1)
val9=$[rint( 1)]
!else
val9=$[rint(2)]
!endif

!ifval ($val7=-1)
val10= 1
!else
val10=2
!endif

!ifval ($val7=-1)
val11= 2
!else
val11=1
!endif
tmp0=!randint 1, 6

val12=$[rint($(tmp0))]
tmp0=!randint 1, 6

tmp=!nonempty items -1,1

tmp1=!randitem $tmp
val13=$[rint(($val12+$(tmp0))*$(tmp1))]
tmp0=!randint 1, 6

tmp=!nonempty items -1,1

tmp1=!randitem $tmp
val12=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 2, 8

tmp=!nonempty items -1,1

tmp1=!randitem $tmp
val6=$[rint($(tmp0)*$(tmp1))]

!ifval ($val6*$val7>0)
tmp0=!randint 1, 8

val14=$[rint( $(tmp0))]
!else
tmp1=!randint -8, -1

val14=$[rint($(tmp1))]
!endif
val15=$[rint(-$val12*$val6)]
val16=$[rint(-$val13*$val14)]
val8=$[rint($val6*$val14)]
t_=!replace internal \( by ( in  ($val6*x+$val15)*($val14*x+$val16)
tmp0=!exec maxima $t_

val17=!rawmath $(tmp0)
t_=!rawmath ($val12+$val13)/2
val18=!exec pari print($t_)

!ifval ($val13>0)
val19= f(x)=(ax+b)(cx+d),\frac{x_1+x_2}{2},\frac{$val12+$val13}{2} =$val18
!else
val19=f(x)=(ax+b)(cx+d),\frac{x_1+x_2}{2},\frac{x_1+(x_2)}{2}=$val18
!endif
val20=r1	r2	r3,r4
oefsteps=$val20 
nextstep=!nosubst $val20 
!readproc oef/steps.proc
replytype1=auto

replyoption1=nonstop 
replyname1=réponse
replygood1=$val18
replytype2=menu
replyname2=son signe est
replygood2=$val9;négatif,positif
replytype3=menu
replyname3=
replygood3=$val10;croissante,décroissante
replytype4=menu
replyname4=
replygood4=$val11;croissante,décroissante
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()On considčre la fonction 
!insmath f
$() définie sur 
!insmath \mathbb{R}
$() par 
!insmath f(x)= $val17
$().<br>	
!if $m_step=1 
$()	Quelle est l'abscisse du sommet de la parabole représentant 
!insmath f
$() ?  
!read oef/embed.phtml r1,4 
$()	 
!endif
$()	
!if $m_step=2 
$()Quel le signe du terme de plus haut degré de 
!insmath f(x)
$() ?  
!read oef/embed.phtml r2 
$()  
!endif
$()	
!if $m_step=3 
$()
!insmath f
$() est d'abord  
!read oef/embed.phtml r3 
$() sur &#93;
!insmath -\infty ; $val18
$()&#93; puis  
!read oef/embed.phtml r4 
$() sur &#91;
!insmath  $val18; +\infty 
$()&#91;. 
!endif
$()	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()<p>Pour une fonction du second degré 
!insmath f
$() d'expression 
!insmath $(val19[1])
$(), le sommet de la parabole représentative a pour abscisse 
!insmath $(val19[2])
$()	avec 
!insmath x_1
$() et 
!insmath x_2
$() racines de 
!insmath f(x)
$()	.	Ici le sommet a donc pour abscisse 
!insmath $(val19[3])
$().	<p>Le coefficient de 
!insmath x^2
$() dans 
!insmath f(x)
$() est 
!insmath $val8
$(), il est donc 
!if $val8>0 
$()positif 
!else
$() négatif 
!endif
$(). On en déduit que 
!insmath f
$() est	
!if $val8>0 
$()décroissante 
!else
$() croissante 
!endif
$() sur &#93;
!insmath -\infty ; $val18
$()&#93; et 
!if $val8>0 
$()croissante 
!else
$() décroissante 
!endif
$() sur &#91;
!insmath  $val18; +\infty 
$()&#91; (parabole représentative orientée vers le 
!if $val8>0 
$()haut 
!else
$() bas 
!endif
$()). 
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
