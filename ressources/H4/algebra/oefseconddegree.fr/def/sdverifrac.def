language=fr
computeanswer=yes
precision=1000
computeanswer=yes

ansorder=r
varcnt=12
prevarcnt=11
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint -10, 10

val6=$[rint($(tmp0))]
val7=$[rint($val6+1)]
val8=$[rint($val6-1)]
val9=$val8,$val6,$val7
tmp0=!randint 1, 3

val10=$[rint($(tmp0))]
val11=$[rint($(val9[$val10]))]
val12=$[rint($val11*(-2))]
tmp0=!randint 1, 3

tmp1=!randitem -1,1

t_=!replace internal \( by ( in expand($(tmp0)*$(tmp1)*(x-$val11)*(x-$val12))
tmp2=!exec maxima $t_

val13=!rawmath $(tmp2)

!ifval ($val11>0)
tmp0=!replace internal x by $val11 in $val13

val14= $(tmp0)
!else
tmp1=!replace internal x by ($val11) in $val13

val14=$(tmp1)
!endif
tmp0=!texmath $val13

val13=$(tmp0)
tmp0=!texmath $val14

val14=$(tmp0)
replytype1=radio
replyname1=
replygood1=$val10;$val9
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<p>Parmi les valeurs suivantes, laquelle est une racine de 
!insmath $val13
$() ?</p>	 
!read oef/embed.phtml r1 
$()
$()
!exit

