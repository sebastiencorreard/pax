replyname2=
replygood2=$val16
replytype3=formal
replyname3=
replygood3=$val17
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Etudier l'extremum sur 
!insmath \mathbb{R}
$() de la fonction du second degré 
!insmath f
$() d'expression : 
!insmath f(x)=$val12
$().<br> 	
!insmath f
$() a un  
!read oef/embed.phtml r1 
$() atteint en x= 
!read oef/embed.phtml r2,3 
$() et égal ŕ  
!read oef/embed.phtml r3,3 
$().
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()Si on développe 
!insmath f(x)
$(), le coefficient de 
!insmath x^2
$() est 
!if $val10>0 
$()
!insmath $val8 \times $val10=$val15
$() 
!else
$() 
!insmath $val8 \times ($val10)=$val15
$() 
!endif
$(). Comme 
!if $val15>0 
$()
!insmath $val15>0
$() 
!else
$() 
!insmath $val15<0
$() 
!endif
$(), la fonction 
!insmath f
$() a un 	
!if $val15>0 
$()minimum 
!else
$() maximum 
!endif
$() sur 
!insmath \mathbb{R}
$(). <br>Les racines de 
!insmath f
$() sont 
!insmath $val6
$() et 
!insmath $val7
$(). En effet, 
!insmath f(x)=0
$() &hArr; 
!insmath $val13=0
$() ou 
!insmath $val14=0
$() &hArr; 
!insmath x=$val6
$() ou 
!insmath x=$val7
$(). 	<br>Donc ce 
!if $val15>0 
$()minimum 
!else
$() maximum 
!endif
$() est atteint pour 
!insmath x=
$()
!if $val7>0 
$()
!insmath \frac{$val6+$val7}{2}=$val16
$() 
!else
$() 
!insmath \frac{$val6+($val7)}{2}=$val16
$() 
!endif
$() et est égal ŕ  	
!insmath f($val16)=$val17
$().	
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

