val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint -9, 1

val6=$[rint($(tmp0))]
tmp0=!randint 1, 9

val7=$[rint($val6+$(tmp0))]
tmp0=!randint 1, 5

val8=$[rint($(tmp0))]
val9=$[rint(-$val8*$val6)]
tmp0=!randint 1, 5

tmp1=!randitem -1,1

val10=$[rint($(tmp0)*$(tmp1))]
val11=$[rint(-$val10*$val7)]
t_=!replace internal \( by ( in ($val8*x+$val9)*($val10*x+$val11)
tmp0=!exec maxima $t_

val12=!rawmath $(tmp0)
t_=!replace internal \( by ( in $val8*x+$val9
tmp0=!exec maxima $t_

val13=!rawmath $(tmp0)
t_=!replace internal \( by ( in $val10*x+$val11
tmp0=!exec maxima $t_

val14=!rawmath $(tmp0)
val15=$[rint($val8*$val10)]
t_=!replace internal \( by ( in ($val13)*($val14)
tmp0=!exec maxima $t_

val12=!rawmath $(tmp0)
t_=!rawmath ($val6+$val7)/2
val16=!exec pari print($t_)
evaltmp=$val12

evaltmp=!mathsubst x=($val16) in $evaltmp
tmp0=($evaltmp)
t_=!rawmath $(tmp0)
val17=!exec pari print($t_)
tmp0=!texmath $val12

val12=$(tmp0)

!ifval ($val15>0)
val18=$[rint( 2)]
!else
val18=$[rint(1)]
!endif
val19=$[abs($val16)]

!ifval ($val16>0)
val20= x-$val19
!else
val20=x+$val19
!endif
replytype1=menu
replyname1=
replygood1=?analyze 21;minimum,maximum
