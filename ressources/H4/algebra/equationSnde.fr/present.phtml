!!style="background-color:#FFCC66"
<div class="wims_question">
<p>$name_enonce: \($eqg = $eqd\).</p>
!if $[$etape]=1
  $(name_question[1;]) <span class="tt">$name_valid</span>:
!endif
!if $[$etape]=2
  $(name_question[2;]) <span class="tt">$name_valid</span>:
!endif
!if $[$etape]=3 and $[$repnbsol]=1
