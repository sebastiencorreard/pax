:postdef
tmp0=!lower $val21

val21=$(tmp0)
tmp0=!lower $val22

val22=$(tmp0)
!if $val21 isitemof $val12 and $val15=nvt 
val23=$[rint(1)]
val24=$[rint(1)]
!else
!if $val21 isitemof $val12 and $val15!=nvt 
val23=$[rint(0)]
val24=$[rint(0)]
!else
t_=!replace internal \( by ( in  if(((round(1000*($val15)))/1000) == ((round(1000*($val21)))/1000) ,1,0)
tmp0=!exec pari $t_

val23=$[rint($(tmp0))]
t_=!replace internal \( by ( in  if(((round(1000*($val16)))/1000) == ((round(1000*($val22)))/1000) ,1,0)
tmp0=!exec pari $t_

val24=$[rint($(tmp0))]
!endif
!endif

!exit

