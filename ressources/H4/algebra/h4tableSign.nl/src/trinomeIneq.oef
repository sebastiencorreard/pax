###############################################################################
## L'objet de l'exercice est de rťsoudre une inťgalitť de la forme f1*f2>0   ##
###############################################################################
\title{Ongelijkheid en Drieterm I}
\language{nl}
\computeanswer{yes}
\precision{1000}
\author{YAMEOGO Joachim}
\email{yameogo@math.unice.fr}
\format{html}

###### les deux racines distinctes du trinome ######
## borne pour la valeur absolue d'une des racines ##
\integer{singmax=20}

## ťcart maximale entre les racines ##
\integer{singdif=30}

## Choix des racines ##
\integer{sing1=random(-\singmax..\singmax)}
\integer{sing2=random(1..\singdif)+\sing1}

### le trinome et ses facteurs ###
## faisons en sorte que le coefficient de x^2 change de temps en temps ##
\integer{k1=random(-1,1)*random(1..25)}

## les facteurs f1 et f2 du trinome factorisť f ##
\text{f1=(\k1)*(x-(\sing1))}
\text{f2=(x-(\sing2))}
\text{f=texmath(maxima((\f1)*(\f2);))}
\text{f1=texmath(maxima((\f1);))}
\text{f2=texmath(maxima((\f2);))}

### fabrication d'un exemple qui servira d'indication ###
\integer{gsing1=(\sing1)-random(3,4)}
\integer{gsing2=(\sing1)-random(1,2)}
\text{g1=texmath(maxima((x-(\gsing1));))}
\text{g2=texmath(maxima((x-(\gsing2));))}
\text{g=texmath(maxima((x-(\gsing1))*(x-(\gsing2));))}

### fabrication des signes + et -  pour une ťventuelle table des signes ###
\text{posi=<font color=red size=+3><b>+</b></font>}
\text{nega=<font color=red size=+3><b>-</b></font>}

### la liste des objets que l'on peut cliquer pour rťsoudre l'exercice ###
\text{x1=\(\sing1)}
\text{x2=\(\sing2)}
\integer{x3=\sing1-random(1,5)}
\integer{x4=\sing2+random(1,5)}
\text{x3=\(\x3)}
\text{x4=\(\x4)}
\text{crocg=&#91;}
\text{crocd=&#93;}
\text{union=\(\cup)}
\text{infg=\(-\infty)}
\text{infd=\(+\infty)}
\text{virg=&#44;}

\text{permut=shuffle(\x1,\x2,\x3,\x4)}

\text{clicList=
\crocg,\virg,\crocd,\union,\infg,\infd,\permut[1],\permut[2],\permut[3],\permut[4]
}
## taille des symboles et des champs ŗ remplir par clic ##
\text{size=60x40x12}

### fabrication de la question et calcul de la bonne rťponse ###
\integer{sf=random(-1,1)}

\if{\sf=1}{
  \if{\k1>0}{
    \text{brep=\crocd,\infg,\virg,\x1,\crocg,\union,\crocd,\x2,\virg,\infd,\crocg |
    \crocd,\x2,\virg,\infd,\crocg,\union,\crocd,\infg,\virg,\x1,\crocg}
    \text{brepf=\crocd\infg\virg\x1\crocg\union\crocd\x2\virg\infd\crocg}
    }{
    \text{brep=\crocd,\x1,\virg,\x2,\crocg}
    \text{brepf=\crocd\x1\virg\x2\crocg}
    }
  \text{inequation=\f > 0}
  }{
  \if{\k1>0}{
    \text{brep=\crocd,\x1,\virg,\x2,\crocg}
    \text{brepf=\crocd\x1\virg\x2\crocg}
    }{
    \text{brep=\crocd,\infg,\virg,\x1,\crocg,\union,\crocd,\x2,\virg,\infd,\crocg |
    \crocd,\x2,\virg,\infd,\crocg,\union,\crocd,\infg,\virg,\x1,\crocg}
    \text{brepf=\crocd\infg\virg\x1\crocg\union\crocd\x2\virg\infd\crocg}
    }
  \text{inequation=\f <0}
}

### la liste des bons signes  pour une ťventuelle correction ###
\if{\k1>0}{
  \text{repList=\nega,\posi,\posi,\nega,\nega,\posi,\posi,\nega,\posi}
}

\if{\k1<0}{
  \text{repList=\posi,\nega,\nega,\nega,\nega,\posi,\nega,\posi,\nega}
}

### afin de faire des indications un peu variťes ###
\integer{sg=random(-1,1)}
\if{\sg=-1}{
  \text{inequationg=\g < 0}
  \text{brepg=\crocd\gsing1,\gsing2\crocg}
  }{
  \text{inequationg=\g > 0}
  \text{brepg=\crocd \(-\infty),\gsing1\crocg \(\cup) \crocd \gsing2,\(+\infty) \crocg}
}

### Maintenant, rťdigeons l'ťnoncť ###
