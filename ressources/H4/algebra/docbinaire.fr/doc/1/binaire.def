!set titb=Jouez avec l'ordinateur
!set keyw=
!set datm=20130711
!set prev=
!set next=
!set upbl=main
!set dat1=19000101
!set dat2=24000101

!if $wims_read_parm!=$empty
  !goto $wims_read_parm
!endif
!exit

:content

!set t_=!replace internal \( by ( in A = matrix(6,32) ; B =vector(6) ;	for(i = 1, 63, u = binary(i) ;	  for (j = 1 , 6,	       if ( j <= #u && u[#u + 1 - j] !=0,	          B[j] ++ ; A[j,B[j]] = i )	   )	) ;	for( j = 1, 6 , B[j] = matrix(4,8,n,m,A[j, 8*(n-1) + m])) ;print(B)	
!set tmp0=!exec pari $t_

!set m_carte=$(tmp0)

!set m_color=skyblue

!set tmp=!trim  
!set m_CARTE=!translate internal $	$ to ; in $tmp

 
!for m_j = 1 to 6  

  
!set m_Carte=$(m_carte[$m_j])

  
!set tmp0=!declosing $m_Carte

!set tmp=!trim $(tmp0) 
!set m_Carte=!translate internal $	$ to ; in $tmp

  
!set m_B=

    
!for m_h = 1 to 4 

    
!set m_B=$m_B <tr>

      
!for m_l = 1 to 8 

       
!set m_B=$m_B <td> $(m_Carte[$m_h;$m_l])</td>

      
!next

     
!set m_B=$m_B </tr>

   
!next

 
!set tmp=!trim $m_CARTE	 $m_B 
!set m_CARTE=!translate internal $	$ to ; in $tmp

!next

!ifval $m_parm2 !=  
!set m_a= $m_parm2 

!else
!set tmp0=!shuffle 6

!set m_a= $(tmp0)

!endif

!set m_p=$m_parm1

<div class ="question">
Pensez ŕ un nombre entre 1 et 63.
Puis cochez les cartes sur lesquelles ce nombre se trouve.
</div>

!set m_check=

 
!for m_r = 1 to 6 

!ifval $m_r isin $m_p  
!set m_check= $m_check, checked="checked" 

!else
!set m_check= $m_check,toto

!endif

!next

!set tmp0=!nonempty items $m_check

!set tmp1=!replace internal toto by in $(tmp0)

!set m_check=$(tmp1)

<br>

!read primitives.phtml 1, form, ., expform, Cochez les cartes puis cliquez sur <input type="submit" value="Envoyer">.	<table class="wimscenter wimsborder">	<tr><td>	 <table class="wimsnoborder" style="background-color:\color"><caption><input type="checkbox" name="parm1" value="\a[1]" id="cart1" \check[\a[1]]><label for="cart1">Carte 1</label></caption>	 \CARTE[\a[1];]</table>	 </td>	 <td>	 <table class="wimsnoborder" style="background-color:\color"><caption><input type="checkbox" name="parm1" value="\a[2]" id="cart2" \check[\a[2]]><label for="cart2">Carte 2</label></caption>	 \CARTE[\a[2];]</table>	 </td>	 <td>	 <table class="wimsnoborder" style="background-color:\color"><caption><input type="checkbox" name="parm1" value="\a[3]" id="cart3" \check[\a[3]]><label for="cart3">Carte 3</label></caption>	 \CARTE[\a[3];]</table>	 </td></tr><tr>	 <td>	 <table class="wimsnoborder" style="background-color:\color"><caption><input type="checkbox" name="parm1" value="\a[4]" id="cart4" \check[\a[4]]><label for="cart4">Carte 4</label></caption>	 \CARTE[\a[4];]</table>	 </td>	 <td>	 <table class="wimsnoborder" style="background-color:\color"><caption><input type="checkbox" name="parm1" value="\a[5]" id="cart5" \check[\a[5]]><label for="cart5">Carte 5</label></caption>	 \CARTE[\a[5];]</table>	 </td>	 <td>	 <table class="wimsnoborder" style="background-color:\color"><caption><input type="checkbox" name="parm1" value="\a[6]" id="cart6" \check[\a[6]]><label for="cart6">Carte 6</label></caption>	 \CARTE[\a[6];]</table>	 </td>	</tr>	</table>	<input type="hidden" name="parm2" value="\a">	 

!set m_N=$[rint(0)]

!set m_reponse=$[rint($m_parm1)]

 
!for m_a in $m_p 
 
!set m_N=$[rint($m_N + 2^($m_a-1))]
 
!next

 
!if $m_p != 

<div class ="reponse">
Vous avez pensé au nombre <span style="font-size&#58;20px">$m_N </span>.
</div>
!endif

