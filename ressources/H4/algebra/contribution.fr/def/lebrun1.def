val15=$(tmp1)
val8=$val8,$val15
tmp=!translate ";': to $     $ in $val12*$val14

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val16=$[$(tmp0)]
tmp=!translate ";': to $     $ in $val13*$val15

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val17=$[$(tmp0)]
val9=$val9,$val16,$val17
val10=$val10,$val14,$val15
!next
val6=$(val6[2..-1])
val7=$(val7[2.. -1])
