tmp0=!randint 1, 9

tmp=!translate ";': to $     $ in $(tmp0)*10+1

tmp=!lower $tmp
tmp1=!exec maxima fullratsimp($tmp);
val14=$(tmp1)
val7=$val7,$val14
tmp0=!randint 1, 9

tmp=!translate ";': to $     $ in $(tmp0)*10-1

tmp=!lower $tmp
