!set title=Puissance : calculer avec un exposant entier positif
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Ali, Elassaoui
email=elassaoui83@yahoo.fr
oefcss=<style type="text/css"> .question {text-align:center; background-color : #9CAAC1; padding : 10px; font-size: 20px; margin : 15px 15px; } </style>

ansorder=r
varcnt=6
prevarcnt=5
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 5

tmp=!nonempty items 1,-1

tmp1=!randitem $tmp
val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 2, 5

val7=$[rint($(tmp0))]
val8=$[rint(($val6)^$val7)]
!if $val6<0 
val6=($val6)
!else
val6=$val6
!endif
replytype1=numexp
replyname1=Votre rťponse
replygood1=$val8
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div class="question">	Dťterminer la valeur du nombre suivant :	  <div class="wimscenter">	    
!insmath  $val6^$val7
$() =  
!read oef/embed.phtml r1,3 
$()	  </div>	</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7
embedcnt=1
