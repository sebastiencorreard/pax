!set title=Calculs astucieux
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=A., Lebrun
language=fr

ansorder=r,r,r,r,r,r,r,r,r,r
varcnt=25
prevarcnt=24
postvarcnt=0
