val7=
val8=
val9=
val10=
val11=0.5,0.25,0.75
!for val12 =1 to 10 
tmp0=!randint 2, 11

tmp1=!randint 2, 11

tmp=!translate ";': to $     $ in $(tmp0)+($(tmp1)/100)

tmp=!lower $tmp
tmp2=!exec maxima fullratsimp($tmp);
val13=$[$(tmp2)]
tmp0=!randint 2, 11

val14=$(tmp0)
tmp0=!shuffle $val11

val15=$(tmp0)
val16=$(val15[1])
val17=4
!if $val16=0.5 
tmp=!nonempty items 2,4

tmp0=!randitem $tmp
val17=$(tmp0)
!endif
tmp=!translate ";': to $     $ in $val13*$val14*$val16*$val17

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val15=$[$(tmp0)]
val6=$val6,$val13
val7=$val7,$val14
val8=$val8,$val16
val9=$val9,$val17
val10=$val10,$val15
!next
val6=$(val6[2 to -1])
val7=$(val7[2 to -1])
val8=$(val8[2 to -1])
val9=$(val9[2 to -1])
val10=$(val10[2 to -1])
