!set title=Puissance : exposant manquant
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Ali, Elassaoui
email=elassaoui83@yahoo.fr 
oefcss=<style type="text/css"> .question {text-align:center; background-color : #9CAAC1; padding : 10px; font-size: 20px; margin : 15px 15px; } </style>

ansorder=r
varcnt=5
prevarcnt=4
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 9

val6=$[rint($(tmp0))]
tmp0=!randint 2, 9

val7=$[rint($(tmp0))]
tmp0=!randint -9, 9

val8=$[rint($(tmp0))]
val9=$[rint($val8-$val7)]
replytype1=numexp
replyname1=Votre rťponse
replygood1=$val9
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="question">	 Dťterminer le nombre manquant :	 <div class="wimscenter">	  
!read oef/special.phtml mathmlinput [$val6^{$val7} \times $val6^{reply1} = $val6^{$val8}],3	reply1	 
$()	  </div>	</div>	
$()
!exit

