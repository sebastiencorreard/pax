!set title=Puissance et fraction simple d'un nombre
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Ali, Elassaoui
email=elassaoui83@yahoo.fr 
oefcss=<style type="text/css"> .question {text-align:center; background-color : #9CAAC1; padding : 10px; font-size: 20px; margin : 15px 15px; } </style>

ansorder=r,r
varcnt=19
prevarcnt=18
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 10

val6=$[rint($(tmp0))]
tmp0=!randitem 1,2,3,5

val7=$[rint($(tmp0))]
!if $val7=1 
val8=huitiŤme
val9=$[rint(2)]
val10=2
val11=$[rint($val6-3)]
!endif
!if $val7=2 
val8=quart
val9=$[rint(2)]
val10=2
val11=$[rint($val6-2)]
!endif
!if $val7=3 
val8=tiers
val9=$[rint(3)]
val10=3
val11=$[rint($val6-1)]
!endif
!if $val7=5 
val8=cinquiŤme
val9=$[rint(5)]
val10=5
val11=$[rint($val6-1)]
!endif
replytype1=numexp
replyname1=Votre rťponse
replygood1=$val10
replytype2=numexp
replyname2=Votre rťponse
replygood2=$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="question">	<p>Le <span style="color: red">$val8</span> de 
!insmath $val9^{$val6}
$():</p>	 Votre rťponse:  
!read oef/embed.phtml  r1,2 
$()<sup><sup> 
!read oef/embed.phtml r2,3 
$()</sup></sup>	</div>	<div class="wims_instruction">Important : Donner le rťsultat sous la forme 
!insmath a ^p
$(). </div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,8,9
embedcnt=2
