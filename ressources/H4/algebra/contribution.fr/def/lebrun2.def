val13=$(tmp0)
tmp0=!shuffle $val7

val14=$(tmp0)
val15=$(val13[1])
val8=$val8,$val15
val16=$(val14[1])
tmp=!translate ";': to $     $ in $val12/$val16

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val17=$[$(tmp0)]
val9=$val9,$val17
tmp=!translate ";': to $     $ in $val17*$val15

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val18=$[$(tmp0)]
val10=$val10,$val18
!next
