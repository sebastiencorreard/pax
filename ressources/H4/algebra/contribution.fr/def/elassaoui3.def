!set title=Ecrire avec une seule puissance
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Ali, Elassaoui
email=elassaoui83@yahoo.fr
oefcss=<style type="text/css"> .question {text-align:center; background-color : #9CAAC1; padding : 10px; font-size: 20px; margin : 15px 15px; } </style>

ansorder=r,r
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem -10,10,-8,8,-6

val6=$[rint($(tmp0))]
tmp0=!randitem 1,3,-5,-4,6

val7=$[rint($(tmp0))]
tmp0=!randitem -2,2,5,-7,7

val8=$[rint($(tmp0))]
val9=$[rint($val6 + $val7 + $val8)]
tmp0=!randint 1-$val9, 20-$val9

tmp1=!randitem -1,1

val10=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 2, 100

val11=$[rint($(tmp0))]
val12=$[rint($val6 + $val7 +$val8 + $val10 )]
replytype1=numexp
replyname1=Votre réponse
replygood1=$val11
replytype2=numexp
replyname2=Votre réponse
replygood2=$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="question">	Ecrire avec une seule puissance 
!insmath d
$()’un nombre relatif :	 <div class="wimscenter">	   
!read oef/special.phtml mathmlinput [$val11^{$val6} \times $val11^{$val7} \times $val11^{$val8}	  \times $val11^{$val10} = reply1^{reply2}],3,noanswer	reply1,2	reply2,3	 
$()	 </div>	</div>	<div class="wims_instruction">Important. Donner le résultat sous la forme	 <span class="tt"> a^p</span>.</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,10,11
embedcnt=1
