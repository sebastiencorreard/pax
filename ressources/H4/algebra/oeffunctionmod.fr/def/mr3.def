tmp0=!randint 3, 4

val6=$[$(tmp0)/100]
tmp0=!randint 35, 55

val7=$[$(tmp0)/100]
val8=!rawmath -$val6*x*x*x+$val7*x*x
tmp=!translate ;";': to $     $ in $val8,x

tmp=!lower $tmp
tmp0=!exec maxima diff($tmp);
