$()	<div class="encadre">	<div id="haut"><div class="wimscenter">	<img src="$val1/robbie-maddison.png" alt="Saut du canal de Corinthe" /></div>	</div>	<p class="problematique"> $val6</p>	<div class="wimscenter"><a class="bouton"  
