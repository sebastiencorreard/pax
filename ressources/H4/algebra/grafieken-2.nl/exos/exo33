    #ch=ch.replace('id=\"1\" label=\"y\" unitLabel=\"\" showNumbers=\"true\"','id=\"1\" label=\"$label_y\" unitLabel=\"$unit_y\" showNumbers=\"true\"'); \
    #ch=ch.replace('scale=\"45.0\" yscale=\"45.0\"','scale=\"10\" yscale=\"10\"'); \
    #document.getElementById('ggbApplet').setXML(ch);

    a=!randitem 1,2,3,4
    pm=!randitem 1,-1
    a=$[$pm*$a]
    c=!randitem 10,15,20
    b=!randitem 1,2,3,4
    b1=$[5*$b]
    b2=$[$b1+$c]
    b3=$[$b1+2*$c]
    functie=!texmath b=y-$a*x
    functie1=!texmath $b1=y-$a*x
    functie2=!texmath $b2=y-$a*x
    functie3=!texmath $b3=y-$a*x
    formula$n= \left[ \begin{array}{l} $functie \\ b = $b1, \ b = $b2, \ b = $b3 \end{array} \right.
    question$n=!record 83 of lang/remarks.$taal
    answer$n=$a,$b1,$a,$b2,$a,$b3
    texanswer$n= \left[ \begin{array}{l} $functie1 \\  $functie2 \\ $functie3 \end{array}\right.
    var1=3
 !exit
!endif
