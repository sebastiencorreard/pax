	c=$[$b+1]
	formula$n=x = \frac{$a y}{$b y + $c}
	applettext=!nospace  x =  ($a*y)/($b*y+$c)->
	# var2 moet vergelijking in x zijn  a+x=b+y -> y = a+x-b -> var2=a+x-b
	var2=!rawmath $c*x/($a-$b*x)
	
	answer$n=$c*x/($a-$b*x)
	texanswer$n=\left[ \begin{array}{l}  x \cdot ($b y+ $c)  =  $a y \rightarrow \\ x \cdot $b y+ x \cdot $c  =  $a y \rightarrow \\ x \cdot $c  =  $a y - $b \cdot x \cdot y\rightarrow \\ $a y - $b \cdot x \cdot y = $c x\rightarrow \\ y ($a  - $b x ) = $c x\rightarrow \\  y=\frac{$c x}{$a - $b x} \end{array} \right.
    !else
	b=!randint 2,9
	a=$[$b+1]
	c=!randitem 1,$[$b+2]
	formula$n=x = \frac{$b y + $c}{$a y}
	applettext=!nospace  x = ($b*y+$c)/($a*y)->
	# var2 moet vergelijking in x zijn  a+x=b+y -> y = a+x-b -> var2=a+x-b
	var2=!rawmath $c/($a*x-$b)
	!if $c=1
	    tussen=$a y= \frac{1}{x - \frac{$b}{$a}} \rightarrow \\ 
	!else
	    tussen=\frac{$a y}{$c} = \frac{1}{x - \frac{$b}{$a}} \rightarrow \\ \frac{$a}{$c}\cdot y = \frac{1}{x - \frac{$b}{$a}} \rightarrow \\ 
	!endif
	answer$n=$c/($a*x-$b)
	texanswer$n=\left[ \begin{array}{l} x = \frac{$b y}{$a y} + \frac{$c}{$a y} \rightarrow \\ x = \frac{$b}{$a} + \frac{$c}{$a y} \rightarrow \\ \frac{$c}{$a y} = x - \frac{$b}{$a} \rightarrow \\ $tussen y=\frac{$c}{$a x- $b} \end{array} \right.
    !endif
    !goto KLAAR
!endif

