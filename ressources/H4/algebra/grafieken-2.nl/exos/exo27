	texanswer$n=\left[ \begin{array}{l} $a^{y} = $b - x \rightarrow \\ y = ^{$a} \log ($b-x) \end{array} \right.
    !else
	a=!randint 2,9
	b=!randint 2,15
	c=!randint 2,9
	formula$n= $c x - $a ^{y}=  $b
	applettext=!nospace $c*x - $a^y = $b->
	# var2 moet vergelijking in x zijn  a+x=b+y -> y = a+x-b -> var2=a+x-b
	var2= log($c*x-$b)/log($a)
	
	answer$n=log($c*x-$b)/log($a)
	texanswer$n=\left[ \begin{array}{l} $a^{y} = $c x - $b \rightarrow \\ y = ^{$a} \log ($c x - $b) \end{array} \right.
