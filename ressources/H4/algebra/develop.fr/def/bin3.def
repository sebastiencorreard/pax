!set title=Dķveloppement d'un bin¶me de degrķ 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=David Doyen
email=david.doyen@u-pem.fr
language=fr
computeanswer=no
precision=10000
leftrange=-5.000000
rightrange=5.000000

ansorder=r
varcnt=7
prevarcnt=6
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!shuffle 1,2,3,4

val6=$(tmp0)
val7=$(val6[1])
val8=$(val6[2])
tmp=!nonempty items +,-

tmp0=!randitem $tmp
val9=$(tmp0)
val10=($val7*x $val9 $val8)^3
t_=!replace internal \( by ( in expand($val10)
tmp0=!exec maxima $t_

val11=$(tmp0)
replytype1=algexp
replyname1=
replygood1=$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div>Dķvelopper l'expression 
!insmath P(x)=$val10
$().</div></br>	<div>
!insmath P(x)=
$() 
!read oef/embed.phtml reply 1,30 
$()</div>	
$()
!exit

