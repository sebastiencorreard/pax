!set title=Dķveloppement d'expressions polyn¶miales 4
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=David Doyen
email=david.doyen@u-pem.fr
language=fr
computeanswer=no
precision=10000
leftrange=-5.000000
rightrange=5.000000

ansorder=r
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 3

val6=$(tmp0)
tmp0=!randint 1, 4

tmp=!nonempty items -1,1

tmp1=!randitem $tmp
val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!shuffle -4,-3,-2,-1,1,2,3,4

val8=$(tmp0)
val9=$[rint($(val8[1]))]
val10=$[rint($(val8[2]))]
tmp=!nonempty items ($val6*x+$val7)*(x+$val9)*(x+$val10),(x+$val9)*($val6*x+$val7)*(x+$val10),(x+$val9)*(x+$val10)*($val6*x+$val7)

tmp0=!randitem $tmp
val11=$(tmp0)
t_=!replace internal \( by ( in expand($val11)
tmp0=!exec maxima $t_

val12=$(tmp0)
replytype1=algexp
replyname1=
replygood1=$val12
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div>Dķvelopper l'expression 
!insmath P(x)=$val11
$().</div></br>	<div>
!insmath P(x) =
$() 
!read oef/embed.phtml reply 1,50 
$()</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=11
embedcnt=1
