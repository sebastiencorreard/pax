tmp0=!randint 1, 5

val6=$(tmp0)
tmp0=!randint 1, 5

tmp=!nonempty items -1,1

tmp1=!randitem $tmp
val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 5

val8=$(tmp0)
tmp0=!randint 1, 5

tmp=!nonempty items -1,1

tmp1=!randitem $tmp
val9=$[rint($(tmp0)*$(tmp1))]
