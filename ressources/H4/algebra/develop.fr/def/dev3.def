tmp0=!randint 1, 5

tmp=!nonempty items -1,1

tmp1=!randitem $tmp
val11=$[rint($(tmp0)*$(tmp1))]
tmp=!nonempty items ($val6*x+$val7)*($val8*x+$val9)+$val10*x^2+$val11,$val10*x^2+$val11+($val6*x+$val7)*($val8*x+$val9),($val6*x+$val7)*($val8*x+$val9)+$val10*x+$val11,$val10*x+$val11+($val6*x+$val7)*($val8*x+$val9)

tmp0=!randitem $tmp
val12=$(tmp0)
t_=!replace internal \( by ( in expand($val12)
tmp0=!exec maxima $t_

val13=$(tmp0)
replytype1=algexp
replyname1=
replygood1=$val13
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

