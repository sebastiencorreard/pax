\title{Dķveloppement d'expressions polyn¶miales 3}
\language{fr}
\author{David Doyen}
\email{david.doyen@u-pem.fr}
\computeanswer{no}


\text{a=randint(1..5)}
\integer{b=randint(1..5)*randitem(-1,1)}
\text{c=randint(1..5)}
\integer{d=randint(1..5)*randitem(-1,1)}
\integer{e=randint(1..5)*randitem(-1,1)}
\integer{f=randint(1..5)*randitem(-1,1)}

\text{\poly=randitem((\a*x+\b)*(\c*x+\d)+\e*x^2+\f,\e*x^2+\f+(\a*x+\b)*(\c*x+\d),(\a*x+\b)*(\c*x+\d)+\e*x+\f,\e*x+\f+(\a*x+\b)*(\c*x+\d))}
\text{\polydev=maxima(expand(\poly))}

\statement{<div>Dķvelopper l'expression \(P(x)=\poly\).</div></br>
<div>\(P(x) =\)\embed{reply 1,50}</div>
}

\answer{}{\polydev}{type=algexp}
