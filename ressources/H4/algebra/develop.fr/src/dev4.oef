\title{Dķveloppement d'expressions polyn¶miales 4}
\language{fr}
\author{David Doyen}
\email{david.doyen@u-pem.fr}
\computeanswer{no}
\precision{10000}
\range{-5..5}

\text{a=randint(2..3)}
\integer{b=randint(1..4)*randitem(-1,1)}
\text{l=shuffle(-4,-3,-2,-1,1,2,3,4)}
\integer{c=\l[1]}
\integer{d=\l[2]}

\text{\poly=randitem((\a*x+\b)*(x+\c)*(x+\d),(x+\c)*(\a*x+\b)*(x+\d),(x+\c)*(x+\d)*(\a*x+\b))}
\text{\polydev=maxima(expand(\poly))}

\statement{<div>Dķvelopper l'expression \(P(x)=\poly\).</div></br>
<div>\(P(x) =\)\embed{reply 1,50}</div>
}

\answer{}{\polydev}{type=algexp}