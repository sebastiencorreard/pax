\title{Dķveloppement d'un bin¶me de degrķ 3}
\language{fr}
\author{David Doyen}
\email{david.doyen@u-pem.fr}
\computeanswer{no}
\precision{10000}
\range{-5..5}

\text{l=shuffle(1,2,3,4)}
\text{a=\l[1]}
\text{b=\l[2]}
\text{s=randitem(+,-)}

\text{poly=(\a*x \s \b)^3}
\text{polydev=maxima(expand(\poly))}

\statement{<div>Dķvelopper l'expression \(P(x)=\poly\).</div></br>
<div>\(P(x)=\)\embed{reply 1,30}</div>
}

\answer{}{\polydev}{type=algexp}
