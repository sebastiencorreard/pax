\title{Dķveloppement d'expressions polyn¶miales 1}
\language{fr}
\author{David Doyen}
\email{david.doyen@u-pem.fr}

\text{a=randint(1..5)}
\integer{b=randint(1..3)*randitem(-1,1)}
\integer{c=randint(1..5)*randitem(-1,1)}
\integer{d=randint(1..5)}
\integer{e=randint(1..5)*randitem(-1,1)}

\text{\poly=(\a*x+\b)*(\d*x+\e)}
\text{\polydev=maxima(expand(\poly))}

\statement{<div>Dķvelopper l'expression \(P(x)=\poly\).</div></br>
<div>\(P(x) =\)\embed{reply 1,30}</div>
}

\answer{}{\polydev}{type=algexp}
