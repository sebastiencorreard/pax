!set title=Fct Cube comparaisons
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
language=fr
computeanswer=yes
precision=1000

ansorder=r,r,r
varcnt=4
prevarcnt=3
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 99

tmp1=!randint 200, 500

tmp=!nonempty items $(tmp0)/100,$(tmp1)/100

tmp2=!randitem $tmp
val6=$[$(tmp2)]

!ifval ($val6<1)
val7= $val6<sup>3</sup>,$val6<sup>2</sup>,$val6
!else
val7=$val6,$val6<sup>2</sup>,$val6<sup>3</sup>
!endif
val8=$val6,$val6<sup>2</sup>,$val6<sup>3</sup>
replytype1=dragfill
replyname1=
replygood1=$(val7[1]);
replytype2=dragfill
replyname2=
replygood2=$(val7[2]);
replytype3=dragfill
replyname3=
replygood3=$(val7[3]);
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Comparer les nombres rÈels $val6, $val6<sup>2</sup> et $val6<sup>3</sup> :	<div class="wimscenter ">	 
!read oef/embed.phtml r1,50x30 
$() <b> &#60; </b>  
!read oef/embed.phtml r2,50x30 
$() <b> &#60; </b>  
!read oef/embed.phtml r3,50x30 
$() </div>	<div class="wims_instruction">	Faire glisser les Èlements.</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$() 
!if $val6<1 
$()0 < $val6 < 1 donc $val6<sup>3</sup> < $val6<sup>2</sup> < $val6 
!else
$() $val6 > 1 donc $val6 < $val6<sup>2</sup> < $val6<sup>3</sup>. 
!endif
$()
$()
!exit

:latex
$()
$()
!exit

:feedback
!ifval $m_sc_reply1*$m_sc_reply2=0
 <div class='oef_feedbacks'>Attention, il faut comparer les nombres ‡ 1.
$()</div>
!endif

!exit

:test

!exit

:stat
vsavelist=6
embedcnt=3
