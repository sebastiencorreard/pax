val6=$[rint($(tmp0))]
val7=$[rint($val6^2)]

!ifval ($val6<0)
val7= aucune
!else
val7=$val7
!endif
replytype1=fset
replyname1=Solutions
replygood1=$val7
question=__EXECUTED_1692754_EXERCISE__
