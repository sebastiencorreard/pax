!set title=Fct Inverse inéquation 2: 1/x>a
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
keywords=inequations
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
language=fr
computeanswer=yes
precision=1000

ansorder=r
varcnt=15
prevarcnt=14
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items -5,-4,-2,-1,-0.5,0.5,1,2,4,5

tmp0=!randitem $tmp
val6=$[$(tmp0)]
tmp0=!randint 1, 4

val7=$[rint($(tmp0))]
val8=<,\leq,\geq,>
val9=$[1/$val6]
val10=&#123;,&#125;,0,$val6,&#93;,&#91;,U,&empty;
!if $val6<0 
tmp=!trim &#93;,$val9,&#59;,0,&#91;	&#91;,$val9,&#59;,0,&#91;	&#93;,-&infin;,&#59;,$val9,&#93;,U,&#93;,0,&#59;,+&infin;,&#91;	&#93;,-&infin;,&#59;,$val9,&#91;,U,&#93;,0,&#59;,+&infin;,&#91;
val11=!translate internal $	\
$ to ;; in $tmp
!endif
!if $val6>0 
tmp=!trim &#93;,-&infin;,&#59;,0,&#91;,U,&#93;,$val9,&#59;,+&infin;,&#91;	&#93;,-&infin;,&#59;,0,&#91;,U,&#91;,$val9,&#59;,+&infin;,&#91;	&#93;,0,&#59;,$val9,&#93;	&#93;,0,&#59;,$val9,&#91;
val11=!translate internal $	\
$ to ;; in $tmp
!endif
!if $val7<3 
!if $val6<=0 
val12=$val9,0,0,0
!else
val12=$val9,0,5,0
!endif
!else
!if $val6<=0 
val12=-5,0,$val9,0
!else
val12=0,0,$val9,0
!endif
!endif
!if $val6<0 and $val7>=3 
val13=0,0,5,0
!else
!if $val6>0 and $val7<=2 
val13=-5,0,0,0
!else
val13=-5,-11,5,-11
!endif
!endif
replytype1=dragfill
replyname1=Solutions
replygood1=$(val11[$val7;]);$val10
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Résoudre dans 
!insmath \,\RR^*
$() l'inéquation :	<div class="wimscenter wims_emph">	
!insmath \frac{1}{x} $(val8[$val7]) $val6
$()</div>	S= 
!read oef/embed.phtml r1,45x30 
$()	<div class="wims_instruction">	Faire glisser les élements afin de former l'ensemble des solutions.</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()<b> 0 est valeur interdite.</b>	<br> L'équation 
!insmath \frac{1}{x}=$val6
$() a une solution : 
!insmath x=\frac{1}{$val6}=$val9
$().	<br> D'aprčs la variation de la fonction inverse (elle est <b>strictement décroissante</b>	sur &#93;-&infin;;0&#91; et sur &#93;0;+&infin;&#91;) et son signe (elle est <b>strictement négative</b>	sur &#93;-&infin;;0&#91; et <b>strictement positive</b> sur &#93;0;+&infin;&#91;), on obtient 
!if $val6>0 or $val7>=3 
$()(en orange) 
!endif
$() l'ensemble des solutions.	<br>	<center>	 
!read oef/draw.phtml 300,300 \
	xrange -5,5	yrange -6,6	linewidth 2	segment -10,0,10,0, black	segment 0,-10,0,10, black	segment -10,$val6,10,$val6,green	text black,-0.4,5.5,medium,y	text black,4.8,-0.4,medium,x	text blue,7,9.5,medium,y=1/x	segment 1/$val6,$val6, 1/$val6,0,green	text black,-0.3,0.5,medium,0	text green,-0.5,$val6,medium,$val6	text orange,$val9,-0.5,medium,$val9	segment $(val12[1]),$(val12[2]),$(val12[3]),$(val12[4]),orange	segment $(val13[1]),$(val13[2]),$(val13[3]),$(val13[4]),orange	plot blue,1/x 
$()	<br>En bleu, la courbe de la fonction inverse.</center>
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,12,13
embedcnt=1
