!set title=Fct Inverse inťquation 1: 1/x>a, x>0
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
keywords=inequations
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
language=fr
computeanswer=yes
precision=1000

ansorder=r
varcnt=14
prevarcnt=13
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem -1,-2,-0.5

tmp=!nonempty items $(tmp0),0.5,1,2,4,5

tmp1=!randitem $tmp
val6=$[$(tmp1)]
tmp0=!randint 1, 4

val7=$[rint($(tmp0))]
val8=<,\leq,\geq,>
val9=$[1/$val6]
val10=&#123;,&#125;,0,$val6,&#93;,&#91;,U,&empty;
!if $val6<0 
tmp=!trim &empty;	&empty;	&#93;,0,&#59;,+&infin;,&#91;	&#93;,0,&#59;,+&infin;,&#91;
val11=!translate internal $	\
$ to ;; in $tmp
!endif
!if $val6>0 
tmp=!trim &#93;,$val9,&#59;,+&infin;,&#91;	&#91;,$val9,&#59;,+&infin;,&#91;	&#93;,0,&#59;,$val9,&#93;	&#93;,0,&#59;,$val9,&#91;
val11=!translate internal $	\
$ to ;; in $tmp
!endif
!if $val7<3 
!if $val6<=0 
val12=0,10,6,10
!else
val12=$val9,0,6,0
!endif
!else
!if $val6<=0 
val12=0,0,6,0
!else
val12=0,0,$val9,0
!endif
!endif
!if $val9>0 
val13=$val9
!else
val13=
!endif
replytype1=dragfill
replyname1=Solutions
replygood1=$(val11[$val7;]);$val10
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Rťsoudre dans &#93;0;+&infin;&#91; l'inťquation :	<div class="wimscenter wims_emph">	
!insmath \frac{1}{x} $(val8[$val7]) $val6
$()</div>	S= 
!read oef/embed.phtml r1,45x30 
$()	<div class="wims_instruction">	Faire glisser les ťlements afin de former l'ensemble des solutions.</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()<b>Attention les solutions sont demandťes sur &#93;0;+&infin;&#91;</b>	<br>0 est valeur interdite.	<br> L'ťquation 
!insmath \frac{1}{x}=$val6
$()	
!if $val6<0 
$()n'a pas de solution strictement positive 
!else
$() a une solution strictement positive : 
!insmath x=\frac{1}{$val6}=$val9
$() 
!endif
$().<br>	<br>
!if $val6<0 
$()D'aprŤs le signe de la fonction inverse sur &#93;0;+&infin;&#91; (elle est <b>strictement positive</b>) 
!else
$() D'aprŤs la variation de la fonction inverse sur &#93;0;+&infin;&#91; (elle est <b>strictement dťcroissante</b>) 
!endif
$(), on obtient 
!if $val6>0 or $val7>=3 
$()(en orange) 
!endif
$() l'ensemble des solutions.<br>	<center> 
!read oef/draw.phtml 300,300 \
	xrange -1,6	yrange -3,6	linewidth 2	segment -10,0,10,0, black	segment 0,-10,0,10, black	segment -10,$val6,10,$val6,green	text black,-0.5,0,medium,O	text blue,7,9.5,medium,y=1/x	segment 1/(sqrt($val6))^2,$val6, 1/$val6,0,green	text green,0.3,$val6,medium,$val6	text orange,$val9,-0.6,medium,$val13	segment $(val12[1]),$(val12[2]),$(val12[3]),$(val12[4]),orange	plot blue,1/(sqrt(x))^2 
$()	<br>En bleu, la courbe de la fonction inverse sur &#93;0;+&infin;&#91;.</center>	
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
