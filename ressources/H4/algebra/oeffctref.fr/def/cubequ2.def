!set title=Fct Cube ťquation 2: ax^3+b&#61;c
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
language=fr
computeanswer=yes
precision=1000
computeanswer=yes

ansorder=r
varcnt=8
prevarcnt=7
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 10

tmp1=!randitem -1,1

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 20

tmp1=!randitem -1,1

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -5, 5

val8=$[rint($(tmp0))]
val9=$[rint($val8^3)]
val10=$[rint($val9*$val6+$val7)]
val11=$[rint($val9*$val6)]
t_=!replace internal \( by ( in $val6*x^3+$val7
tmp0=!exec maxima $t_

val12=!rawmath $(tmp0)
replytype1=fset
replyname1=Solutions
replygood1=$val8
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Rťsoudre dans 
!insmath \,\RR
$() l'ťquation :	<div class="wimscenter wims_emph">
!insmath $val12 = $val10
$()</div>	S= 
