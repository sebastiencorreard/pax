$()
!exit

:help
$()
$()
!exit

:solution
$()
!insmath $val12=$val10
$()	<br>$m_Leftrightarrow $val6 
!insmath x^3= $val11
$()	<br>$m_Leftrightarrow 
!insmath x^3=$val9
$()	<br>$m_Leftrightarrow 
!insmath x=$val8
$().
$()
!exit

:latex
