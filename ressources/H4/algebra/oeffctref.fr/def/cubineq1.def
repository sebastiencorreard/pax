 !exit
!endif

tmp0=!randint -4, 4

val6=$[rint($(tmp0))]
val7=$[rint($val6^3)]
val8=$[rint(-$val6)]
tmp0=!randint 1, 4

val9=$[rint($(tmp0))]
val10=&lt;,&le;,&ge;,&gt
val11=&#123;,&#125;,$val7,$val8,&#93;,&#91;,U,&empty;,0,+&infin;,-&infin;
tmp=!trim &#93;,-&infin;,&#59;,$val6,&#91;	&#93;,-&infin;,&#59;,$val6,&#93;	&#91;,$val6,&#59;,+&infin;,&#91;	&#93;,$val6,&#59;,+&infin;,&#91;	
val12=!translate internal $	\
$ to ;; in $tmp
!if $val9<3 
val13=segment -6,0,$val6,0,orange
!else
val13=segment $val6,0,6,0,orange
!endif
replytype1=dragfill
replyname1=Solutions
replygood1=$(val12[$val9;]);$val11
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

