!! On pose les questions dans ce fichier. D'habitude, c'est par
!! des forms. Voici un exemple de conception de la forme de r閜onse.

!form reply
<input type=submit value="发送"> 
!if $reply_cnt=0
 你的答案:<br>
!else
 你订正好的答案:<br>
!endif
!for i=1 to $term
 !set c=!char $i of abcdefghijk
 $(m_$c)&nbsp;=&nbsp;<input size=5 name=num$i value="$(num$i)"> &nbsp; &nbsp;
!next i
</form>

