tmp0=!shuffle 2,3,4,5,6,7,8,9,0.2,1.4,2.5,3.7,0.05,4.5,1.25,7.75

val6=$(tmp0)
!if $val2=Z 
tmp0=!shuffle 2,-3,4,-5,-6,7,-8,9,0.2,-1.4,2.5,-3.7,0.05,-4.5,1.25,-7.75

val6=$(tmp0)
!endif
!if $val2=Q 
tmp0=!shuffle -1/2,1/3,-2/3,1/4,-3/4,1/5,-2/5,3/5,-4/5,1/6,-5/6,2,-3,4,-5,6

val6=$(tmp0)
!endif
val7=
val8=
val9=
val10=
val11=solution
val12=
val13=
val14=$[rint(2)]
!for val15 =1 to $val14 
val10=(l'inconnue est notÈe \(p)) 
t_=!rawmath $(val6[4*($val15-1)+1])
val16=!exec pari print($t_)
t_=!rawmath $(val6[4*($val15-1)+2])
val17=!exec pari print($t_)
t_=!rawmath $(val6[4*($val15-1)+3])
val18=!exec pari print($t_)
val19=p
val20=p

!ifval (- isin $val17 or / isin $val17) 
val17= ($val17) 
!else
val17= $val17 
!endif

!ifval (- isin $val18 or / isin $val18) 
val18= ($val18) 
!else
val18= $val18 
!endif
val21=$val16=$val17\times$val18+p
t_=!rawmath $val16-$val17*$val18
val22=!exec pari print($t_)
val23=$[round($val22*1000)/1000]
!if . isin $val22 

!ifval abs($val23-$val22)>10^(-20) 
val24= p \approx $val23 
!else
val24= p=$val22
!endif
!else
val24=p=$val22
!endif
val25=<table><tr><td>\(3=2\times 7+p)</td></tr><tr><td>\(\Leftrightarrow 3=14+p)</td></tr><tr><td>\(\Leftrightarrow 3-14=p)</td></tr><tr><td>\(\Leftrightarrow -11=p)</td></tr><tr><td>ou encore :\(p=-11)</td></tr></table>
!if $val2=Z 
val25=<table><tr><td>\(-3=2\times (-7)+p)</td></tr><tr><td>\(\Leftrightarrow -3=-14+p)</td></tr><tr><td>\(\Leftrightarrow -3+14=p)</td></tr><tr><td>\(\Leftrightarrow 11=p)</td></tr><tr><td>ou encore :\(p=11)</td></tr></table>
!endif
!if $val2=Q 
val25=<table><tr><td>\(3=(2/3) \times (7/5)+p)</td></tr><tr><td>\(\Leftrightarrow 3=(14/15)+p)</td></tr><tr><td>\(\Leftrightarrow 3-(14/15)=p)</td></tr><tr><td>\(\Leftrightarrow (45/15)-(14/15)=p)</td></tr><tr><td>\(\Leftrightarrow 31/15=p)</td></tr><tr><td>ou encore :\(p=31/15)</td></tr></table>
!endif
tmp0=!append item $val21 to $val7

val7=$(tmp0)
tmp0=!append item $val22 to $val9

val9=$(tmp0)
tmp0=!append item $val24 to $val8

val8=$(tmp0)
!next
replytype1=numeric
replyoption1=comma absolute 
replyname1=
replygood1=$[$(val9[1])]
replytype2=numeric
replyoption2=comma absolute 
replyname2=
replygood2=$[$(val9[2])]
