  texanswer$n=\left[ \begin{array}{l}  \textrm{$txt1} \\  $b x - $c = 0 \rightarrow $b x = $c \rightarrow x = $ftex \\ $b x - $c \ge 0 \: \textrm{$txt4} \: x \ge $ftex \\ $b x - $c < 0 \: \textrm{$txt4} \: x < $ftex \\ \textrm{$txt2} \\ f(x) = $a x - | $b x - $c | = $a x - ($b x - $c) = $e x + $c \rightarrow  \color{red} f(x) = $e x + $c \: \textrm{ $txt3 }  \: D_{f} : x \ge $ftex  \\ f(x) = $a x - | $b x - $c | = $a x - -1 \cdot ( $b x - $c) = $a x + ( $b x - $c) = $d x - $c \rightarrow  \color{red}  f(x) = $d x - $c \: \textrm{ $txt3 }  \: D_{f} :1 x < $ftex   \end{array} \right.
 !endif
!endif

