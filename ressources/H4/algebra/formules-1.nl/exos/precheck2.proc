n=$counter
errortext=$empty
!if ? isin $(reply$n)
 goback=0
 remark$n=$NOK
 maxscore=0
 !exit
!endif
# eerst check op letterlijk overtiepen
a=$(reply$n)
g=$(answer$n)
return=-1

!readproc exos/copy_of_question.proc
!if $return !=-1
    goback=$return
!else
    !readproc exos/checkfile3.proc
!endif
!exit
