    ans=$empty
  !else
   ans=\rightarrow y=$tussen
  !endif
  var2=$c/($a*x)
  texanswer$n=\left[ \begin{array}{l} $a \cdot y \cdot x = $b^{2}\rightarrow \\ y= \frac{$c}{$a x} $ans  \end{array} \right.
 !else
  d=!randint 2,15
  e=$[$b-$d]
  !if $e=0
    d=$[$d+5]
    e=$[$b-$d]
  !endif
  c=$[$e*$e]
  formula$n= $d + \sqrt{$a \cdot y \cdot x}=$b
  applettext=!nospace $d + sqrt($a*y*x)=$b   ->
  # var2 moet vergelijking in x zijn  a+x=b+y -> y = a+x-b -> var2=a+x-b
  tot=!exec pari A=$c/($a*x)\
  printtex(A)
  answer$n=!line 1 of $tot
  tex_ans=!line 2 of $tot
  var2=$c/($a*x)
  texanswer$n=\left[ \begin{array}{l} \sqrt{$a \cdot y \cdot x}=$b-$d=$e \rightarrow \\ $a \cdot y \cdot x = ($e)^{2}  \rightarrow \\ y= \frac{$c}{$a x}  \\ y = $tex_ans \end{array} \right.
