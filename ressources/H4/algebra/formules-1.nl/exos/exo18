 !if $keuze=0
  c=$[$b*$b]
  formula$n= \sqrt{$a \cdot y \cdot x}=$b
  applettext=!nospace sqrt($a*y*x)=$b   ->
  # var2 moet vergelijking in x zijn  a+x=b+y -> y = a+x-b -> var2=a+x-b
  tot=!exec pari A=$c/($a*x)\
  printtex(A)

  answer$n=!line 1 of $tot
