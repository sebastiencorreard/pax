!else
val22=$val14 $val21 $val15
val23=\($val14 $val21 $val15\) <br>	\(\Leftrightarrow $val17 $val21 $val16\) <br>	\(\Leftrightarrow $val18 $val21 $val6\) <br>
!endif
!else
tmp=!nonempty items 1,2

tmp0=!randitem $tmp
!if $(tmp0)=1 
val22=$val15 $val20 $val14
val23=\($val15 $val20 $val14\) <br>	\(\Leftrightarrow $val16 $val20 $val17\) <br>	\(\Leftrightarrow $val6 $val21 $val18\) <br>
!else
val22=$val14 $val21 $val15
val23=\($val14 $val21 $val15\) <br>	\(\Leftrightarrow $val17 $val21 $val16\) <br>	\(\Leftrightarrow $val18 $val20 $val6\) <br>
!endif
