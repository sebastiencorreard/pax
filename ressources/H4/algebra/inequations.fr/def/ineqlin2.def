tmp=!nonempty items -1,1

tmp0=!randitem $tmp
tmp1=!randint 1, 6

val14=$[rint($(tmp0)*$(tmp1))]
tmp=!nonempty items $val12*$val6+$val13,$val13+$val12*$val6

tmp0=!randitem $tmp
val15=$(tmp0)
tmp0=!texmath $val15

val15=$(tmp0)
tmp0=!texmath $val12*$val6

val16=$(tmp0)
val17=$[rint($val14-$val13)]
t_=!rawmath ($val14-$val13)/($val12)
val18=!exec pari print($t_)
val19=$val18
!if $val12>0 
val20=$(val7[$val11])
val21=$(val8[$val11])
!else
val20=$(val8[$val11])
val21=$(val7[$val11])
