!set title=Forme canonique d'un quotient (1)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=VÈronique Royer
email=royer.veronique@orange.fr

ansorder=r,r,r
varcnt=16
prevarcnt=15
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
tmp1=!randint 1, 4

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -12, 12

val8=$[rint($(tmp0))]
val9=$[rint(1)]
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
tmp1=!randint 1, 12

val10=$[rint($(tmp0)*$(tmp1))]
tmp=!translate ";': to $     $ in $val7*x+$val8

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val11=!rawmath $(tmp0)
tmp=!translate ";': to $     $ in $val9*x+$val10

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val12=!rawmath $(tmp0)
tmp0=!replace internal * by in $val11

val11=$(tmp0)
tmp0=!replace internal * by in $val12

val12=$(tmp0)
val13=\frac{$val11}{$val12}
t_=!rawmath -$val10/$val9
val14=!exec pari print($t_)
t_=!rawmath $val8-($val7*$val10)/$val9
val15=!exec pari print($t_)
t_=!rawmath $val7/$val9
val16=!exec pari print($t_)
tmp=!translate ";': to $     $ in a+ $val10*b

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val17=!rawmath $(tmp0)
tmp0=!replace internal * by in $val17

val17=$(tmp0)
oefsteps=reply1	reply2,reply3 
nextstep=!nosubst reply1	reply2,reply3 
!readproc oef/steps.proc
replytype1=rational

replyoption1=nonstop 
replyname1=Valeur interdite
replygood1=$val14
replytype2=rational

replyoption2=nonstop 
replyname2=Coefficient \(a\)
replygood2=$val15
replytype3=rational

replyoption3=nonstop 
replyname3=Coefficient \(b\)
replygood3=$val16
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Soit 
!insmath f
$() la fonction dÈfinie par 
!insmath  f(x) = $val13
$().	<!--- PremiËre Ètape -->	
!if $m_step==1 
$()	  <h2 class="small">Question 1.</h2>	  Quel est l'ensemble de dÈfinition de 
!insmath f
$() ?	  <div class="wimscenter">
!insmath  D_{f} = \RR \setminus \{\alpha\} 
$()	  avec <label for="reply1">
!insmath \,\alpha
$() =</label>  
!read oef/embed.phtml reply1,8 
$().</div>	   
!endif
$()	<!--- DeuxiËme Ètape-->	
!if $m_step==2 
$()	  <h2 class="small">Analyse de la question 1.</h2>	  
!if $m_reply1=$val14 
$()	    <p class="oef_indgood">Votre rÈponse est juste: 
!else
$()	     <p><span class="oef_indbad">Votre rÈponse est erronÈe.</span>	    
!insmath f(x)
$() n'est pas dÈfini lorsque 
!insmath $val12 = 0
$(), donc 
!endif
$()	    
!insmath D_{f} = \RR \setminus \{$val14\}
$().	    </p>	  <h2 class="small">Question 2.</h2>	  On peut Ècrire 
!insmath f
$() sous forme canonique, comme suit :	  <div class="wims_question">Pour tout rÈel 
!insmath x \neq $val14
$(),	  
!insmath f(x) = \frac{a}{$val12} + b
$()	  avec <label for="reply2">
!insmath a
$() =</label>  
!read oef/embed.phtml reply2,8 
$()	  et <label for="reply3">
!insmath b
$() =</label>  
!read oef/embed.phtml reply3,8 
$().	  </div>	   
!endif
$()	
$()
!exit

:hint
$()	  RÈduire au mÍme dÈnominateur l'expression 
!insmath \frac{a}{$val12} + b 
$().	  On <i>identifie</i> le numÈrateur du quotient obtenu avec celui de 
!insmath f(x)
$().	  C'est-ý-dire, on choisit 
!insmath a
$() et 
!insmath b
$() pour que les deux	  numÈrateurs respectifs de 
!insmath \frac{a}{$val12} + b
$() et de 
!insmath $val13
$()	  soient identiques.		</div>
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback
!ifval reply2!=$val15 or reply3!=$val16
 <div class='oef_feedbacks'>	  <h2 class="small">Solution.</h2>		  <div class="wimscenter">	  
!insmath \frac{a}{$val12} + b = \frac{a + b($val12)}{$val12} = \frac{ b x + $val17}{$val12} 
$().		  </div>		  On identifie avec le numÈrateur de 
!insmath f(x)
$() : 
!insmath b x + $val17 = $val7 x + $val8
$()	  (pour tout rÈel 
!insmath x
$() diffÈrent de 
!insmath $val14
$()).	  Il suffit de choisir : 
!insmath  b = $val7
$() et 
!insmath $val17 = $val8
$().		  <p>	  On obtient 
!insmath b = $val16
$() et 
!insmath  a = $val15
$().	  </p>	
$()</div>
!endif

!exit

:test

!exit

:stat
vsavelist=7,8,12,13,14,15,16,17
embedcnt=3
