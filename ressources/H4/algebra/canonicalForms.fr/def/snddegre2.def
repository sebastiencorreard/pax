postvarcnt=0
replycnt=4
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
tmp1=!randint 1, 12

val7=$[rint($(tmp0)*$(tmp1))]
tmp=!nonempty items 1,1,1,2,2,3

tmp0=!randitem $tmp
val8=$[rint($(tmp0))]
t_=!rawmath $val7/$val8
val9=!exec pari print($t_)
t_=!rawmath -($val9/2)
val10=!exec pari print($t_)
t_=!rawmath -($val9/2)^2
val11=!exec pari print($t_)
val12=!rawmath x^2 +$val9 x
tmp=!nonempty items -1,-2,-3,-4,1,2,3,4

tmp0=!randitem $tmp
val13=$[rint($(tmp0))]
val14=$val13

!ifval $val13==1
val14=
!endif

!ifval $val13==-1
val14=-
!endif
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
tmp1=!randint 1, 12

val15=$[rint($(tmp0)*$(tmp1))]
val12=!rawmath x^2 +$val9*x
tmp0=!replace internal * by in $val12

val16=$(tmp0)
t_=!replace internal \( by ( in $val13*($val12) +$val15
tmp0=!exec maxima $t_

val17=!rawmath $(tmp0)
t_=!rawmath $val15-$val13*($val9/2)^2
val18=!exec pari print($t_)
oefsteps=reply1, reply2	reply3, reply4 
nextstep=!nosubst reply1, reply2	reply3, reply4 
!readproc oef/steps.proc
replytype1=rational

replyoption1=nonstop 
replyname1=Coefficient \(\,\alpha\)
replygood1=$val10
replytype2=rational

replyoption2=nonstop 
replyname2=Coefficient \(\,\beta\)
replygood2=$val11
replytype3=rational

replyoption3=nonstop 
replyname3=Coefficient \(\,\alpha\)
replygood3=$val10
replytype4=rational

replyoption4=nonstop 
replyname4=Coefficient \(\,\gamma\)
replygood4=$val18
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<!--- PremiŤre ťtape -->	Soit 
!insmath u
$() la fonction dťfinie sur 
!insmath \R
$() par 
!insmath  u(x) = $val12
$().	
!if $m_step==1 
$()	  <h2 class="small">Question 1.</h2>	  Rťťcrire 
!insmath u(x)
$() sous forme canonique :	  <div class="wimscenter"> 
!insmath u(x) = (x - \alpha)^2 + \beta 
