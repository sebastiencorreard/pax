!set title=Forme canonique d'un quotient (2)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Véronique Royer
email=royer.veronique@orange.fr

ansorder=r,r,r
varcnt=25
prevarcnt=24
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
tmp1=!randint 1, 12

val7=$[rint($(tmp0)*$(tmp1))]
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
tmp1=!randint 1, 6

val8=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -12, 12

val9=$[rint($(tmp0))]
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
tmp1=!randint 1, 4

val10=$[rint($(tmp0)*$(tmp1))]
t_=!replace internal \( by ( in gcd($val8,$val9);
tmp0=!exec maxima $t_

val11=$[rint($(tmp0))]
t_=!replace internal \( by ( in gcd($val10,$val7);
tmp0=!exec maxima $t_

val12=$[rint($(tmp0))]
t_=!replace internal \( by ( in gcd($val11,$val12);
tmp0=!exec maxima $t_

val13=$[rint($(tmp0))]
!if $val13!=1 
val8=$[rint($val8/$val13)]
val9=$[rint($val9/$val13)]
val10=$[rint($val10/$val13)]
val7=$[rint($val7/$val13)]
!endif
tmp=!translate ";': to $     $ in $val8*x+$val9

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val14=!rawmath $(tmp0)
tmp=!translate ";': to $     $ in $val10*x+$val7

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val15=!rawmath $(tmp0)
tmp0=!replace internal * by in $val14

val14=$(tmp0)
tmp0=!replace internal * by in $val15

val15=$(tmp0)
val16=\frac{$val14}{$val15}
t_=!rawmath -$val7/$val10
val17=!exec pari print($t_)
t_=!rawmath $val9-($val8*$val7)/$val10
val18=!exec pari print($t_)
t_=!rawmath $val8/$val10
val19=!exec pari print($t_)
tmp=!translate ";': to $     $ in a+ $val7*b

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val20=!rawmath $(tmp0)
tmp0=!replace internal * by in $val20

val20=$(tmp0)
tmp=!translate ";': to $     $ in $val10*b

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
val21=!rawmath $(tmp0)
tmp0=!replace internal * by in $val21

val21=$(tmp0)
oefsteps=reply1	reply2,reply3 
nextstep=!nosubst reply1	reply2,reply3 
!readproc oef/steps.proc
replytype1=rational

replyoption1=nonstop 
replyname1=Valeur interdite
replygood1=$val17
replytype2=rational

replyoption2=nonstop 
replyname2=Coefficient \(a\)
replygood2=$val18
replytype3=rational

replyoption3=nonstop 
replyname3=Coefficient \(b\)
replygood3=$val19
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Soit 
!insmath f
$() la fonction définie par 
!insmath  f(x) = $val16
$().	<!--- Premičre étape -->	
!if $m_step==1 
$()	  <h2 class="small">Question 1.</h2>	  Quel est l'ensemble de définition de 
!insmath f
$() ?	  <div class="wimscenter">
!insmath  D_{f} = \RR \setminus \{\alpha\} 
$()	  avec <label for="reply1">
!insmath \,\alpha
$() =</label>  
!read oef/embed.phtml reply1,8 
$().</div>	   
!endif
$()	<!--- Deuxičme étape-->	
!if $m_step==2 
$()	  <h2 class="small">Analyse de la question 1.</h2>	  
!if $m_reply1=$val17 
$()	    <p class="oef_indgood">Votre réponse est juste: 
!else
$()	     <p><span class="oef_indbad">Votre réponse est erronée.</span>	    
!insmath f(x)
$() n'est pas défini lorsque 
!insmath $val15 = 0
$(), donc 
!endif
$()	    
!insmath D_{f} = \RR \setminus \{$val17\}
$().	    </p>	  <h2 class="small">Question 2.</h2>	  On peut écrire 
!insmath f
$() sous forme canonique, comme suit :	  <div class="wims_question">Pour tout réel 
!insmath x \neq $val17
$(),	  
!insmath f(x) = \frac{a}{$val15} + b
$()	  avec <label for="reply2">
!insmath a
$() =</label>  
!read oef/embed.phtml reply2,8 
$()	  et <label for="reply3">
!insmath b
$() =</label>  
!read oef/embed.phtml reply3,8 
$().	  </div>	   
!endif
$()	
$()
!exit

:hint
$()	  Réduire au męme dénominateur l'expression 
!insmath \frac{a}{$val15} + b 
$().	  On <i>identifie</i> le numérateur du quotient obtenu avec celui de 
!insmath f(x)
$().	  C'est-ŕ-dire, on choisit 
!insmath a
$() et 
!insmath b
$() pour que les deux	  numérateurs respectifs de 
!insmath \frac{a}{$val15} + b
$() et de 
!insmath $val16
$()	  soient identiques.		  Attention les solutions peuvent ętre rationnelles...		</div>
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback
!ifval reply2!=$val18 or reply3!=$val19
 <div class='oef_feedbacks'>	  <h2 class="small">Solution.</h2>		  Pour tout réel 
!insmath x
$() différent de 
!insmath $val17
$() :	  <div class="wimscenter">	  
!insmath \frac{a}{$val15} + b = \frac{a + b($val15)}{$val15} = \frac{ $val21 x + $val20}{$val15} 
$()		  </div>		  On identifie avec le numérateur de 
!insmath f(x)
$() : 
!insmath  $val21 x + $val20 = $val8 x + $val9
$().	  Il suffit de choisir : 
!insmath  $val21 = $val8
$() et 
!insmath $val20 = $val9
$().		  <p>	  On obtient 
!insmath b = $val19
$() et 
!insmath  a = $val18
$().	  </p>	
$()</div>
!endif

!exit

:test

!exit

:stat
vsavelist=8,9,15,16,17,18,19,20,21
embedcnt=3
