!set title=Variation d'une fonction homographique
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Véronique Royer
email=royer.veronique@orange.fr

ansorder=r,r,r,r,r,r
varcnt=30
prevarcnt=29
postvarcnt=0
replycnt=6
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oef/env lang 
tmp0=$slib_out
val6=$(tmp0)
val7=strictement croissante,strictement décroissante
val8=strictement croissante sur,strictement décroissante sur
val9=positives non nulles ,négatives non nulles
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
val10=$[rint($(tmp0))]
tmp0=!randint 2, 8

val11=$[rint($val10*$(tmp0))]
tmp0=!randint 1, 10

val12=$[rint($(tmp0))]
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
val13=$[rint($(tmp0)*$val12)]
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
val14=$[rint($(tmp0))]
tmp0=!randint 1, 8

val15=$[rint($val14*$(tmp0))]
tmp0=!randint -10, 10

val16=$[rint($(tmp0))]
t_=!replace internal \( by ( in $val15*x+$val16
tmp0=!exec maxima $t_

val17=!rawmath $(tmp0)
tmp0=!replace internal * by in $val17

val17=$(tmp0)
t_=!rawmath -$val16/$val15
val18=!exec pari print($t_)
tmp=!nonempty items -1,1

tmp0=!randitem $tmp
val19=$[rint($(tmp0))]
val20=&#8734;

!ifval $val19==1
val21=&#93; $val18 ; +$val20 &#91; 
!else
val21= &#93; -$val20 ; $val18 &#91;
!endif

!ifval $val14==1
val22=$[rint(1)]
!else
val22=$[rint(2)]
!endif

!ifval $val14*$val19==1
val23=$[rint(1)]
!else
val23=$[rint(2)]
!endif

!ifval $val23==1
val24=\(\RR^{*}+\)
!else
val24=\(\RR^{*}-\)
!endif

!ifval $val23==1
val25=$[rint(1)]
!else
val25=$[rint(2)]
!endif
t_=!replace internal \( by ( in $val11*t+$val13
tmp0=!exec maxima $t_

val26=!rawmath $(tmp0)
tmp0=!replace internal * by in $val26

val26=$(tmp0)

!ifval $val10==1
val27=$[rint(1)]
!else
val27=$[rint(2)]
!endif

!ifval $val13>0
val28= + $val12 
!else
val28= - $val12
!endif
val29=!rawmath \frac{$val11}{$val17} $val28

!ifval $val22==1
val30=$[rint(2)]
!else
val30=$[rint(1)]
!endif
val31=\(\RR \setminus\{$val18\}\)

!ifval $val30*$val27==2
val32=$[rint(2)]
!else
val32=$[rint(1)]
!endif
replytype1=menu
replyname1=Variation de u
replygood1=$val22;$val7
replytype2=menu
replyname2=
replygood2=$val23;$val9
replytype3=menu
replyoption3=shuffle 
replyname3=Variation des inverses
replygood3=$val25;$(val8[2]) &#93; 0 &#59; +$val20&#91;,$(val8[2]) &#93; -$val20 &#59; 0 &#91;,$(val8[1]) &#93; 0 &#59; +$val20&#91;,$(val8[1]) &#93; -$val20 &#59; 0 &#91;
replytype4=menu
replyname4=Variation de v
replygood4=$val27;$val7
replytype5=menu
replyname5=Variation de 1/u
replygood5=$val30;$val7
replytype6=menu
replyname6=Variation de f
replygood6=$val32;$val7
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	On considčre la fonction 
!insmath f
$() définie sur $val31 par 
!insmath f : x \mapsto $val29
$().	On étudie son sens de variation sur l'intervalle $val21.	<p>	Complétez le texte suivant, afin que l'étude de variation	soit correcte sur $val21.	</p>	<div class="wims_question">		La fonction 
!insmath f
$() s'obtient en enchaînant les fonctions suivantes,	  ŕ la suite l'un de l'autre :		<ol><li>	d'abord, la fonction affine 
!insmath u : x \mapsto $val17
$() qui est	   
!read oef/embed.phtml reply1 
$() sur 
!insmath \,\RR
$()	et qui prend des valeurs  
!read oef/embed.phtml reply2 
$() sur l'intervalle $val21.	</li><li>		ensuite, la fonction inverse 
!insmath i : X \mapsto 1/X
$() qui est  
!read oef/embed.phtml reply3 
$().		</li><li>	Enfin, la fonction affine 
!insmath v : t \mapsto $val26
$() qui est  
!read oef/embed.phtml reply4 
$() sur 
!insmath \,\RR
$().	</li></ol>	On en déduit que :	<ol><li>		Les deux premičres étapes produisent la fonction 
!insmath x \mapsto \frac{1}{$val17}
$(),	  qui est  
!read oef/embed.phtml reply5 
$() sur l'intervalle $val21.	</li><li>	En appliquant ensuite la fonction <b>
!insmath v
$()</b>, on conclut que la fonction	
!insmath f : x \mapsto $val29
$() est  
!read oef/embed.phtml reply6 
$() sur $val21.		</li></ol>	</div>	
$()
!exit

:hint
$()	  <ul><li>	  Si la fonction 
!insmath u
$() est strictement croissante sur 
!insmath I
$()	  et prend ses valeurs dans 
!insmath J
$(), et si la fonction 
!insmath v
$() est	  strictement croissante sur 
!insmath J
$(), alors la composée 
!insmath v \circ u
$()	  (soit 
!insmath u
$() suivie de 
!insmath v
$()) est strictement croissante sur 
!insmath I
$().	  </li><li>	  Si la fonction 
!insmath u
$() est strictement croissante sur 
!insmath I
$()	  et prend ses valeurs dans 
!insmath J
$(), et si la fonction 
!insmath v
$() est	  strictement décroissante sur 
!insmath J
$(), alors la composée	  
!insmath v \circ u
$() (soit 
!insmath u
$() suivie de 
!insmath v
$()) est strictement décroissante sur 
!insmath I
$().	  </li></ul>	  De façon générale :	  <ul><li>	  composer avec une fonction croissante revient ŕ <b>conserver</b> le sens de variation de la premičre fonction ;	  </li><li>	  composer avec une fonction décroissante revient ŕ <b>inverser</b> le sens de variation de la premičre fonction.	  </li></ul>	
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=17,21,26,29,31
embedcnt=6
