:question
$()	$val37		<table class="wimscenter wimsnoborder">	     
!for m_k=1 to $val19 
$()	    <tr>	      <td style="background-color:$(val17[(2*$m_k-1)%3+1]);text-align:left">	        <table>	   <tr>	     <td style="background-color:$val18">	        
!read oef/embed.phtml reply 1,$(val35[$m_k]) 
$()	     </td>	     <td style="text-align:center">	      $(val26[$m_k;])	     </td>	   </tr>	 </table>	      </td>	      <td style="background-color:$(val17[(2*$m_k)%3+1]);text-align:left">	        <table>	   <tr>	     <td style="background-color:$val18">	               
!read oef/embed.phtml reply 1,$(val36[$m_k]) 
$()	     </td>	     <td>	      $(val26[($m_k+$val19);])	     </td>	   </tr>	 </table>	      </td>	    </tr>	     
!next
$()	    
!if $val20<>0 
$()	    <tr>	      <td style="background-color:$(val17[$val28%3+1]) colspan="2">	        <table>	   <tr>	     <td style="background-color:steelblue">	        
!read oef/embed.phtml reply 1,$val28 
$()	     </td><td>	         $(val26[$val28;])	     </td>	   </tr>	 </table>	      </td>	    </tr>	     
!endif
$()	  </table>	
