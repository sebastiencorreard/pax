:feedback
!ifval $val25 notsametext $(val11[1;])
 <div class='oef_feedbacks'>$(val10[1;]) est un $(val12[2]), son écriture est $(val11[1;])
$()</div>
!endif
!ifval $m_step > 1 && $val26 notsametext $(val11[2;])
 <div class='oef_feedbacks'>$(val10[2;]) est un $(val12[3]),son écriture est $(val11[2;])
$()</div>
!endif
!ifval $m_step > 2 && $val27 notsametext $(val11[3;])
 <div class='oef_feedbacks'>$(val10[3;]) est un $(val12[4]),son écriture est $(val11[3;])
$()</div>
!endif
!ifval $m_step > 3 && $val28 notsametext $(val11[4;])
 <div class='oef_feedbacks'>$(val10[4;]) est un $(val12[5]),son écriture est $(val11[4;])
$()</div>
!endif
!ifval $m_step > 4 && $val29 notsametext $(val11[5;])
 <div class='oef_feedbacks'>$(val10[5;]) est un $(val12[6]),son écriture est $(val11[5;])
$()</div>
!endif
!ifval $m_step > 5 && $val30 notsametext $(val11[6;])
 <div class='oef_feedbacks'>$(val10[6;]) est un $(val12[7]),son écriture est $(val11[6;])
$()</div>
!endif
!ifval $m_step > 6 && $val31 notsametext $(val11[7;])
 <div class='oef_feedbacks'>$(val10[7;]) est un $(val12[8]),son écriture est $(val11[7;])
$()</div>
!endif
!ifval $m_step > 7 && $val32 notsametext $(val11[8;])
 <div class='oef_feedbacks'>$(val10[8;]) est un $(val12[9]),son écriture est $(val11[8;])
$()</div>
!endif
!ifval $m_step > 8 && $val33 notsametext $(val11[9;])
 <div class='oef_feedbacks'>$(val10[9;]) est un $(val12[10]),son écriture est $(val11[9;])
$()</div>
!endif
!ifval $m_step > 9 && $val34 notsametext $(val11[10;])
 <div class='oef_feedbacks'>$(val10[10;]) est un $(val12[11]),son écriture est $(val11[10;])
$()</div>
!endif

!exit

:test

condlist=$val24

!ifval $val25 issametext $(val11[1;])
