!endif
$() 
!endif
$() 
!endif
$() 
!endif
$()	</span>	 </p> 
!else
$()	   </p><ol>	    
!for m_s = 1 to $(val13[$m_h]) 
$()	   <li> 
!read oef/embed.phtml reply \h , \s  
$()</li>	    
!next
$()	   </ol>	   
