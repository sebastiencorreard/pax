!set title=Écriture décimale: questions enchainées
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r,r,r,r,r,r,r,r,r,r
varcnt=30
prevarcnt=29
postvarcnt=0
replycnt=10
choicecnt=0
conditioncnt=10
feedbackcnt=10
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=10
val7=dataecrdec
tmp0=!recordcnt $val7

val8=$[rint($(tmp0))]
tmp0=!shuffle $val6

val9=$(tmp0)
tmp=!trim 
val10=!translate internal $	\
$ to ;; in $tmp
tmp=!trim 
val11=!translate internal $	\
$ to ;; in $tmp
val12=
val13=
tmp=!trim 
val14=!translate internal $	\
$ to ;; in $tmp
!for val15  = 1 to $val6  
tmp0=!record $(val9[$val15]) of $val7

tmp=!trim $(tmp0)
val16=!translate internal $	\
$ to ;; in $tmp
tmp=!trim $val10	  $(val16[1;])
val10=!translate internal $	\
$ to ;; in $tmp
tmp=!trim $val11	  $(val16[2;])
val11=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val16

tmp0=!rowcnt $tmp
val17=$[rint($(tmp0)-3)]
val13=$val13,$val17
val18=
tmp0=!shuffle $val17

val19=$(tmp0)
!for val20  = 4 to $val17 + 3 
val21=$(val16[$val20;])
tmp=!trim $val18, $(val21[1;])
val18=!translate internal $	\
$ to ;; in $tmp
!next
tmp0=!nonempty items $val18

val18=$(tmp0)
val18=$(val18[$val19])
tmp=!trim $val14	     $val18
val14=!translate internal $	\
$ to ;; in $tmp
val22=$(val16[3;])
val12=$val12, $val22
!next
tmp0=!nonempty items $val13

val13=$(tmp0)
tmp0=!makelist r x for x = 1 to $val6

val23=$(tmp0)
tmp0=!replace internal , by ; in $val23

val23=$(tmp0)
tmp0=!makelist x for x = 1 to $val6

val24=$(tmp0)
oefsteps=$val23 
nextstep=!nosubst $val23 
!readproc oef/steps.proc
replytype1=radio
replyname1=
replygood1=?analyze 25;$(val14[1;])
replytype2=radio
replyname2=
replygood2=?analyze 26;$(val14[2;])
replytype3=radio
replyname3=
replygood3=?analyze 27;$(val14[3;])
replytype4=radio
replyname4=
replygood4=?analyze 28;$(val14[4;])
replytype5=radio
replyname5=
replygood5=?analyze 29;$(val14[5;])
replytype6=radio
replyname6=
replygood6=?analyze 30;$(val14[6;])
replytype7=radio
replyname7=
replygood7=?analyze 31;$(val14[7;])
replytype8=radio
replyname8=
replygood8=?analyze 32;$(val14[8;])
replytype9=radio
replyname9=
replygood9=?analyze 33;$(val14[9;])
replytype10=radio
replyname10=
replygood10=?analyze 34;$(val14[10;])
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()Répondre aux questions :	  
!for m_h = 1 to $m_step 
$()	  <p>	  Le nombre réel <span class="wims_emph">$(val10[$m_h;])</span> possčde	une écriture décimale:	  
!if $m_h < $m_step 
$()	    <span class="wims_emph">
!if $m_h == 1 
$()$val25 
!else
$() 	
!if $m_h == 2 
$()$val26 
!else
$() 	
!if $m_h == 3 
$()$val27 
!else
$() 	
!if $m_h == 4 
$()$val28 
!else
$() 	
!if $m_h == 5 
$()$val29 
!else
$() 	
!if $m_h == 6 
$()$val30 
!else
$() 	
