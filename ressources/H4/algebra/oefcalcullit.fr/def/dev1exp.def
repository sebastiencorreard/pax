val17=$(tmp0)
tmp0=!randitem x,y,z,m,n,t,k

val18=$(tmp0)
val19=$val10 ($val18 $val9 $val12)*($val18 $val8 $val14)
t_=!replace internal \( by ( in expand(($val19));
tmp0=!exec maxima $t_

val20=$(tmp0)
tmp0=!texmath $val20

val21=$(tmp0)
t_=!replace internal \( by ( in factor(($val20));
tmp0=!exec maxima $t_

val22=$(tmp0)
tmp0=!texmath $val22

val22=$(tmp0)
val23=$val10 ($val17 $val8 $val14)*($val17 $val9 $val13)
t_=!replace internal \( by ( in expand(($val23));
tmp0=!exec maxima $t_

val24=$(tmp0)
tmp0=!texmath $val24

val25=$(tmp0)
t_=!replace internal \( by ( in factor(($val24));
tmp0=!exec maxima $t_

val26=$(tmp0)
tmp0=!texmath $val26

val26=$(tmp0)
val27=$val24
t_=!replace internal \( by ( in $val27
tmp0=!exec pari $t_

val28=!rawmath $(tmp0)
replytype1=default
replyoption1=noanalyzeprint 
replyname1=$val7
replygood1=$val27
question=__EXECUTED_1692754_EXERCISE__

