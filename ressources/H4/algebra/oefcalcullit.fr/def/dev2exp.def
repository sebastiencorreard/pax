!set title=Développer deux expressions
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr
keywords=literal_calculation
author=Régine, Mangeard
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r,r,r
varcnt=25
prevarcnt=24
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=Développer l'expression suivante.
val7=La dernière expression sera réduite.
tmp0=!randint 1, 15

val8=$[rint($(tmp0))]
tmp0=!randint -15, 15

val9=$[rint($(tmp0))]
!if $val9=0 
val9=$[rint($val9+1)]
!endif
tmp0=!randint 1, 15

val10=$[rint($(tmp0))]
tmp0=!randint -15, 15

val11=$[rint($(tmp0))]
!if $val11=0 
val11=$[rint($val11+1)]
!endif
tmp0=!randint 1, 15

val12=$[rint($(tmp0))]
tmp0=!randint -15, 15

val13=$[rint($(tmp0))]
!if $val13=0 
val13=$[rint($val13+1)]
!endif
tmp0=!randint 1, 15

val14=$[rint($(tmp0))]
tmp0=!randint -15, 15

val15=$[rint($(tmp0))]
!if $val15=0 
val15=$[rint($val15+1)]
!endif
val16=+,-
tmp0=!shuffle $val16

val16=$(tmp0)
tmp0=!item 1 of $val16

val16=$(tmp0)
val17=($val8*x+$val9)*($val10*x+$val11)$val16($val12*x+$val13)*($val14*x+$val15)
val18=($val8*x+$val9)*($val10*x+$val11)
val19=($val12*x+$val13)*($val14*x+$val15)
tmp0=!texmath $val17

val20=$(tmp0)
t_=!replace internal \( by ( in expand($val17)
tmp0=!exec maxima $t_

val21=$(tmp0)
t_=!replace internal \( by ( in expand($val18)
tmp0=!exec maxima $t_

val22=$(tmp0)
t_=!replace internal \( by ( in expand($val19)
tmp0=!exec maxima $t_

val23=$(tmp0)
replytype1=function
replyname1=
replygood1=!rawmath $val22
replytype2=function
replyname2=
replygood2=!rawmath $val23
replytype3=algexp
replyname3=
replygood3=$val21
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<p>$val6:</p>	<ul class="wims_nopuce">	<li><label for="reply1">
!insmath $val20
$()</label>	</li>
!insmath {}={}
$() 
!read oef/embed.phtml reply1, 20 
$()
!insmath {}$val16({}
$() 
!read oef/embed.phtml reply2, 20 
$()
!insmath {}
$())</li>	</li><li>	<label for="reply3">
!insmath $val20
$()</label>= 
!read oef/embed.phtml reply3, 20 
$().	</li></ul>	<div class="wims_instruction">$val7</div>	
$()
!exit

