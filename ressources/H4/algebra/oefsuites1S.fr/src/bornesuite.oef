}
\text{question= \(u_n = \s\) }
\rational{delta=(4*(\b)*(\c)-(\d)^2)/(4*(\b))}
\if{\bd>0}
{ \rational{valb=\c}}
{ \rational{absom=-(\d)/(\b)/2}
  \integer{n1=floor(\absom)}
