{
\integer{k=random(1..2)}
\text{s=\c  + \frac{\b}{ n + \a}}
 \if{\nat==4}
 {\integer{d=\c*\a+(\b)}
 \text{s= \frac{\d + \c n}{n + \a}}
 }
\text{question= \(u_n = \s) }
\integer{indrep=\b<0?1:2}
\text{tf=wims(replace internal n by x in \s)}
\text{tfeed= \( u_n=f(n)) avec \(f(x)= \tf)<br>
La fonction \(f) est \variation[\indrep] sur \(\RR^+)<br>
la suite est donc \variation[\indrep]}

\integer{indrepM=1}
\integer{indrepm=1}
