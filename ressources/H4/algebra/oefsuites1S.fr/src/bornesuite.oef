  \integer{vn1= \b * \n1^2 + (\d) * \n1 + \c}
  \integer{vn2= \b * \n2^2 + (\d) * \n2 + \c}
  \if{\b>0}
    {\rational{valb=\vn1<\vn2?\vn1:\vn2}}
    {\rational{valb=\vn1>\vn2?\vn1:\vn2}}
}
