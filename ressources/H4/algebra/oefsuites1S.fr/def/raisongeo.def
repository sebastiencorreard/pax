val6=Pour une telle suite,	  donner une raison possible et le terme initial de rang 0 correspondant.
val7=Soit \( (u_n) \) la suite de terme gťnťral,	   Soit \( (u_n) \) une suite gťomťtrique vťrifiant
val8=et
val9=ou
val10=raison&nbsp;,terme initial de rang 0&nbsp;
val11=Il y a deux possibilitťs, La solution est
tmp0=!randint 1, 3

val12=$[rint($(tmp0))]
tmp0=!randint 1, 2

val13=$[rint($(tmp0))]
tmp0=!randint 2, 10

tmp1=!randitem -1,1

val14=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 2, 10

val15=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 2, 11

val16=$[rint($(tmp0))]
tmp0=!randint 2, 5

val17=$[rint($(tmp0))]
tmp0=!randint 2, 3

val18=$[rint($(tmp0))]
tmp0=!randitem -1,1

tmp1=!randitem 3,5,9,15

val19=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randitem 2,7,4,8,14

val20=$[rint($(tmp0)*$(tmp1))]
!if $val12 == 1 
!if $val13 == 1 
val21=$val14 \times($val15)^n
t_=!rawmath $val14
val22=!exec pari print($t_)
t_=!rawmath $val15
val23=!exec pari print($t_)
!else
val21=\frac{$val14}{$val17} \times (\frac{$val15}{$val18})^n
t_=!rawmath ($val14)/($val17)
val22=!exec pari print($t_)
t_=!rawmath ($val15)/($val18)
val23=!exec pari print($t_)
!endif
!endif
!if $val12 == 2 
tmp0=!randint 1, 2

val24=$[rint($(tmp0))]
val25=$[rint($val24+$val13)]
val26=u_{$val24}
val27=u_{$val25}
!if $val13 == 1 
val28=$val14*($val15)^n
t_=!rawmath $val14
val22=!exec pari print($t_)
t_=!rawmath $val15
val23=!exec pari print($t_)
!else
val28=($val14)/($val18)*(($val15)/($val16))^n
t_=!rawmath ($val14)/($val18)
val22=!exec pari print($t_)
t_=!rawmath ($val15)/($val16)
val23=!exec pari print($t_)

!ifval $val24=1
t_=!rawmath -$val22
val29=!exec pari print($t_)
!else
t_=!rawmath $val22
val29=!exec pari print($t_)
!endif
t_=!rawmath -$val23
val30=!exec pari print($t_)
!endif
evaltmp=$val28

evaltmp=!mathsubst n=($val24) in $evaltmp
tmp0=($evaltmp)
t_=!rawmath $(tmp0)
val31=!exec pari print($t_)
evaltmp=$val28

evaltmp=!mathsubst n=($val25) in $evaltmp
tmp0=($evaltmp)
t_=!rawmath $(tmp0)
val32=!exec pari print($t_)
val33=$val31
tmp0=!replace internal / by , in $val33

val33=$(tmp0)
tmp0=!itemcnt $val33


!ifval $(tmp0)=1
val33=$val33
!else
val33=\frac{$(val33[1])}{$(val33[2])}
!endif
val34=$val32
tmp0=!replace internal / by , in $val34

val34=$(tmp0)
tmp0=!itemcnt $val34


!ifval $(tmp0)=1
val34=$val34
!else
val34=\frac{$(val34[1])}{$(val34[2])}
!endif
!endif
!if $val12==3 
!if $val13 == 1 
val21=$val14 \times($val15)^{n+$val18}
t_=!rawmath ($val14)*($val15)^$val18
val22=!exec pari print($t_)
t_=!rawmath $val15
val23=!exec pari print($t_)
!else
val21=$val14\times ($val15)^{$val18 n}
t_=!rawmath ($val14)
val22=!exec pari print($t_)
t_=!rawmath ($val15)^$val18
val23=!exec pari print($t_)
!endif
!endif
replytype1=algexp
