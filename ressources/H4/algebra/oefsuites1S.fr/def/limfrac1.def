!set title=Calcul de limites de suites
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r,r,r
varcnt=28
prevarcnt=27
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 5

val6=$[rint($(tmp0))]
tmp0=!randint 0, 10

val7=$[rint($(tmp0))]
tmp0=!randint 1, 5

val8=$[rint($(tmp0))]
tmp0=!randint 0, 10

val9=$[rint($(tmp0))]
tmp0=!randint 1, 5

val10=$[rint($(tmp0))]
tmp0=!randint 0, 10

val11=$[rint($(tmp0))]
tmp0=!randint 1, 3

val12=$[rint($(tmp0))]

!ifval $val12=1
t_=!replace internal \( by ( in expand(($val6*x+$val7)*($val8*x+$val9))
tmp0=!exec maxima $t_

val13=!rawmath $(tmp0)
!else
t_=!replace internal \( by ( in expand(($val6*x+$val7)*($val8*x+$val9)*($val10*x+$val11))
tmp1=!exec maxima $t_

val13=!rawmath $(tmp1)
!endif
tmp0=!randint 1, 6

tmp1=!randitem 1,-1

val14=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -5, 5

val15=$[rint($(tmp0))]
tmp0=!randint -5, 5

val16=$[rint($(tmp0))]

!ifval $val12<3
t_=!replace internal \( by ( in expand(($val14*x^2+$val15*x+$val15)*($val10*x+$val11))
tmp0=!exec maxima $t_

val17=!rawmath $(tmp0)
!else
t_=!replace internal \( by ( in ($val14*x^2+$val15*x+$val15)
tmp1=!exec maxima $t_

val17=!rawmath $(tmp1)
!endif
val18=\(+ \infty)
val19=\(- \infty)
val20=$val18, $val19
t_=!replace internal \( by ( in limit(($val17)/($val13),x,INF)
tmp0=!exec maxima $t_

val21=$(tmp0)
!if inf isin \lim 
val22=+\infty
!endif
!if minf isin \lim 
val22=-\infty
!endif
!if inf notin \lim 
val22=\lim
!endif
tmp0=!replace internal x by n in $val17

val23=$(tmp0)
tmp0=!replace internal x by n in $val13

val24=$(tmp0)
val25=a une limite finie, a une limite infinie, n'a pas de limite

!ifval $val12=1
val26=2
!else
val26=1
!endif
!if $val12=1 
val27=r1	    r3
!if $val14>0 
val28=$val18
!else
val28=$val19
!endif
!else
val27=r1	      r2
!endif
oefsteps=$val27 
nextstep=!nosubst $val27 
!readproc oef/steps.proc
replytype1=menu
replyname1=type limite
replygood1=$val26;$val25
replytype2=numeric
replyname2=
replygood2=$[$val21]
replytype3=clickfill
replyname3=
replygood3=$val28;$val19,$val18
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()On considčre la suite 
!insmath u
$() définie par	<div class="wimscenter">
!insmath u_n = ($val23)/($val24)
$()</div>		
!if $m_step=1 
$()	Choisissez la bonne réponse:	<div class="wimscenter">	La suite 
!insmath u
$()  
!read oef/embed.phtml reply 1 
$()	</div>	 
!endif
$()	
!if $m_step=2 
$()	 
!if $val26=1 
$()	Quelle est la limite finie de 
!insmath u 
$()?:	<p class="wimscenter">	<label for="reply2">	
!insmath \displaystyle{\lim_{n \to +\infty}u_n = } 
$()</label>  
!read oef/embed.phtml reply 2 
$()	</p>	  
!else
$() 	Choisissez la bonne réponse:	<div class="wimscenter">	
!insmath \displaystyle{\lim_{n \to +\infty}u_n = } 
$()  
!read oef/embed.phtml reply 3 
$()	 </div>	  
!endif
$()	 
!endif
$()	
$()
!exit

