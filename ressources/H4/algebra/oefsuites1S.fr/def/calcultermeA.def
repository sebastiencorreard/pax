precision=10000

ansorder=r,r,r
varcnt=23
prevarcnt=22
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 10

val6=$[rint($(tmp0))]
tmp0=!randitem -1,1

tmp1=!randint 2, 10

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 2, 11

val8=$[rint($(tmp0))]
tmp0=!randitem -1,1

tmp1=!randint 2, 100

val9=$[rint($(tmp0)*$(tmp1))]
val9=$[$val9/10]
tmp0=!randint 2, 3

val10=$[rint($(tmp0))]
tmp0=!randitem -1,1

tmp1=!randitem 3,5,9,15

val11=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randitem 2,7,4,8,14

val12=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 2, 6

val13=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 3

val14=$[rint($(tmp0))]
tmp=!trim x-$val8,x+$val6,x-$val6,$val10+x,-$val10+x,x-($val11)/$val10,x+$val6/$val10	$val6 * x,$val7 * x,$val10 * x,$val11/$val10* x,1/$val10*x	-x-$val8,$val8/x, x^2+$val8, $val10 * x^2+$val6,-$val10* x^2,(x+$val10)*(x-1),(x+$val10)^2,(x-$val10)^2
val15=!translate internal $	\
$ to ;; in $tmp
tmp=!trim x-$val8,x+$val6,x-$val6,$val10+x,-$val10+x,x-\frac{$val11}{$val10},x+\frac{$val6}{$val10}	$val6 x,$val7 x,$val10 x,\frac{$val11}{$val10} x,\frac{1}{$val10} x	-x-$val8,\frac{$val8}{x}, x^2+$val8, $val10 x^2+$val6,-$val10 x^2,(x+$val10)(x-1),(x+$val10)^2,(x-$val10)^2
val16=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in $val16

tmp=!row $val14 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val17=$(tmp0)
tmp0=!itemcnt $val17

val18=$[rint($(tmp0))]
tmp0=!randint 1, $val18

val19=$[rint($(tmp0))]
tmp0=!item $val19 of $val17

val20=$(tmp0)
tmp=!translate internal $	$ to ; in $val15

tmp=!row $val14 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val17=$(tmp0)
tmp0=!item $val19 of $val17

val21=$(tmp0)
tmp0=!replace internal x by u_n in $val20

val22=$(tmp0)
evaltmp=$val21

evaltmp=!mathsubst x=($val13) in $evaltmp
tmp0=($evaltmp)
t_=!rawmath $(tmp0)
val23=!exec pari print($t_)
evaltmp=$val21

evaltmp=!mathsubst x=($val23) in $evaltmp
tmp0=($evaltmp)
t_=!rawmath $(tmp0)
val24=!exec pari print($t_)
evaltmp=$val21

evaltmp=!mathsubst x=($val24) in $evaltmp
tmp0=($evaltmp)
t_=!rawmath $(tmp0)
val25=!exec pari print($t_)
replytype1=numexp
replyname1=\(u_1\)
replygood1=$val23
replytype2=numexp
replyname2=\(u_2\)
replygood2=$val24
replytype3=numexp
replyname3=\(u_3\)
replygood3=$val25
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

