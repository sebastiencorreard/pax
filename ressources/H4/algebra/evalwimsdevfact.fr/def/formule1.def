!set title=Connaissance des formules 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=7
prevarcnt=6
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items +,-

tmp0=!randitem $tmp
val6=$(tmp0)
val7=k(a$val6 b)
val8=\(k a$val6 k b)
val9=\(a\), \(b\) et \(k\)
val10=\(k a$val6 b),\(k a b),\(a$val6 k b)
val11=150x30x1
replytype1=clickfill
replyname1=rÈponse
replygood1=$val8;$val10
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Parmi les expressions suivantes, laquelle est l'expression dÈveloppÈe Ègale ‡ 
!insmath $val7
$()	  pour toutes les valeurs possibles de $val9 ?	<p>	<b>Votre rÈponse :</b>	</p>	<div class="wimscenter">	
!insmath $val7 =
$()  
!read oef/embed.phtml r1,$val11 
$().	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,9,11
embedcnt=1
