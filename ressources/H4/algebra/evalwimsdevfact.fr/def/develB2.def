 !exit
!endif

tmp0=!values v for v=2 to 12

val6=$(tmp0)
tmp0=!shuffle $val6

val6=$(tmp0)
tmp0=!item 1 of $val6

val7=$[rint($(tmp0))]
tmp0=!item 2 of $val6

val8=$[rint($(tmp0))]
tmp0=!item 3 of $val6

val9=$[rint($(tmp0))]
tmp0=!item 4 of $val6

val10=$[rint($(tmp0))]
tmp=!nonempty items x,y,z,t,u,v

tmp0=!randitem $tmp
val11=$(tmp0)
tmp=!nonempty items A,B,C,D,V

tmp0=!randitem $tmp
val12=$(tmp0)
tmp=!nonempty items ($val7*$val11+$val8),($val8+$val7*$val11)

tmp0=!randitem $tmp
tmp=!nonempty items ($val9*$val11+$val10),($val10+$val9*$val11)

tmp1=!randitem $tmp
val13=$(tmp0)*$(tmp1)
tmp0=!texmath $val13

val14=$(tmp0)
tmp0=!rawmath $val13

val15=$(tmp0)
!readproc slib/commutesom $val15,$val11 
tmp0=$slib_out
val15=$(tmp0)
replytype1=litexp
replyname1=rťponse
replygood1=$val15
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

