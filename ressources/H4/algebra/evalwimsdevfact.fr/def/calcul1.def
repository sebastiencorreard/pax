!set title=Calcul rÈflÈchi 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Fabrice, Guerimand
email=fguerima@free.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=100

ansorder=r
varcnt=7
prevarcnt=6
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!nonempty items A,B,C,D,V

tmp0=!randitem $tmp
val6=$(tmp0)
tmp0=!randint 1, 6

val7=$[rint($(tmp0))]
val8=$[rint(10+$val7)]
val9=$val8^2
tmp0=!texmath $val9

val10=$(tmp0)
val11=$[rint($val9)]
replytype1=numexp
replyname1=rÈponse
replygood1=$val11
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	  Calculer l'expression suivante :	<div class="wimscenter">
!insmath $val6 = $val9
$()</div>	<div class="wims_instruction">Vous devez effectuer ce calcul sans calculette.</div>	<p>	<b>Votre rÈponse :</b>	</p>	<div class="wimscenter">	
!insmath $val6 =
$()  
!read oef/embed.phtml r1,20 
$().	</div>	
$()
!exit

