!set title=Parallèle à une droite par un point
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Frédéric, Pitoun; Véronique, Royer
email=royer.veronique@orange.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=yes
precision=10000

ansorder=r,r,r,r,r
varcnt=20
prevarcnt=19
postvarcnt=0
replycnt=5
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oefenv lang 
tmp0=$slib_out
val6=$(tmp0)
val7=Solution
val8=égaux,opposés,inverses,différents
val9=Nature de,Pente de,Valeur de,Natures des pentes
val10=non verticale,verticale
tmp0=!randitem -1,1

tmp1=!randint 0, 8

tmp2=!randitem 2,3

t_=!rawmath $(tmp0)*$(tmp1)/$(tmp2)
val11=!exec pari print($t_)
tmp0=!randint -10, 10

val12=$[rint($(tmp0))]
tmp0=!randitem -1,1

tmp1=!randint 0, 6

val13=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 0, 6

val14=$[rint($(tmp0)*$(tmp1))]
t_=!rawmath $val14-$val11*$val13
val15=!exec pari print($t_)
tmp=!translate ";': to $     $ in $val11*x+$val12

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!replace internal \( by ( in expand($(tmp0))
tmp1=!exec maxima $t_

val16=!rawmath $(tmp1)
tmp=!translate ";': to $     $ in $val11*x+$val15

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!replace internal \( by ( in expand($(tmp0))
tmp1=!exec maxima $t_

val17=!rawmath $(tmp1)
tmp0=!texmath $val16

val18=$(tmp0)
tmp0=!texmath $val17

val19=$(tmp0)
val20=$[rint(1)]
val21=$[rint(1)]
tmp0=!randitem 1,2

val22=$[rint($(tmp0))]
tmp0=!item $val22 of m,a

val23=$(tmp0)
tmp0=!item $val22 of p,b

val24=$(tmp0)
replytype1=menu
replyoption1=shuffle 
replyname1=$(val9[1]) \(D\)
replygood1=$val20;$val10
replytype2=default
replyname2=$(val9[2]) \(D\)
replygood2=$val11
replytype3=menu
replyoption3=shuffle 
replyname3=$(val9[4])
replygood3=$val21;$val8
replytype4=default
replyname4=$(val9[2])\(D'\)
replygood4=$val11
replytype5=default
replyname5=$(val9[3]) \(b\)
replygood5=$val15
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div style="background-color:#FFFF66">	<p>Dans un repère 
!insmath (O,\vec{i},\vec{j})
$() du plan, on considère la droite	
!insmath D
$() d'équation réduite 
!insmath y = $val18
$().	<br>	On se propose de déterminer l'équation réduite de la droite 
!insmath \Delta
$()	parallèle à la droite 
!insmath D
$() et passant par le point	
!insmath A\left( $val13 ; $val14 \right) 
$().	</p>	<ul><li>	On cherche l'équation de 
!insmath \Delta
$() sous la forme : 
!insmath  y = $val23 x + $val24
$()	parce qu'il s'agit d'une droite  
!read oef/embed.phtml reply1, 10 
$().	</li><li>	<label for="reply2">La pente de la droite 
!insmath D
$() vaut</label>  
!read oef/embed.phtml reply2, 5 
$().	</li><li>	Comme les droites 
!insmath D
$() et 
!insmath \Delta
$() sont parallèles, alors elles	ont des coefficients directeurs  
!read oef/embed.phtml reply3, 10 
$(). Donc	<label for="reply4">
!insmath $val23
$() vaut</label>	 
!read oef/embed.phtml reply4, 5 
$().	</li><li>	On écrit que 
!insmath A
$() appartient à 
!insmath \Delta
$() pour calculer la valeur de	
!insmath $val24
$(). On obtient alors :	<div class="wimscenter"><label for="reply5">
!insmath $val24
$() = </label>	 
!read oef/embed.phtml reply5, 5 
$()</div></li>	</ul>	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()L'équation réduite de la droite 
!insmath \Delta
$() est 
!insmath y = $val17
$().	Les droites 
!insmath \Delta
$() et 
!insmath D
$() ont le même coefficient directeur, mais des ordonnées à l'origine	différentes. Voir dessin (
!insmath \Delta
$() est représentée en vert, et 
!insmath D
$() en bleu).	<div class="wimscenter">	 
!read oef/draw.phtml 400,400 \
xrange -20,20	yrange -20,20	parallel -20,-20,-20,20,1,0,40,grey	parallel -20,-20,20,-20,0,1,40,grey	hline 0,0,black	vline 0,0,black	linewidth 2	arrow 0,0,0,1,5,black	arrow 0,0,1,0,5,black	plot blue,$val16	plot green,$val17	text green,$val13+1,$val14,large,"A"	text blue,1,$val12,large,"D"	linewidth 6	point $val13,$val14,green 
$()	</div>	
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=12,13,14,16,17,18,23,24
embedcnt=5
