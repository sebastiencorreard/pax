!set title=Alignement ou non de trois points
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Véronique, Royer
email=royer.veronique@orange.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=yes
precision=10000

ansorder=r,r,r,r,r,r,r
varcnt=22
prevarcnt=21
postvarcnt=0
replycnt=7
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oefenv lang 
tmp0=$slib_out
val6=$(tmp0)
val7=Solution
val8=n'est pas, est
val9=vérifient,ne vérifient pas
val10=sont alignés,ne sont pas alignés
val11=Pente,Coefficient,Valeur de,Ordonnée de,Coordonnées de
val12=Question
tmp0=!randitem -1,1

tmp1=!randint 0, 8

val13=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 0, 8

val14=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 0, 8

val15=$[rint($(tmp0)*$(tmp1))]

!ifval $val15==$val13
tmp0=!randitem -3,-4,3,4,-5,5

val15=$[rint($val13+$(tmp0))]
!endif
tmp0=!randitem -1,1

tmp1=!randint 0, 8

val16=$[rint($(tmp0)*$(tmp1))]
t_=!rawmath ($val16-$val14)/($val15-$val13)
val17=!exec pari print($t_)
t_=!rawmath $val14-$val17*$val13
val18=!exec pari print($t_)
tmp0=!randitem -1,1

tmp1=!randint 10, 50

tmp2=!randint 1, 5

val19=$[rint($(tmp0)*$(tmp1)/$(tmp2))]
tmp0=!randitem 0,1

val20=$[rint($(tmp0))]

!ifval $val20==1
t_=!rawmath $val17*$val19+$val18
val21=!exec pari print($t_)
!else
tmp0=!randitem -1,1

tmp1=!randint 10, 50

tmp2=!randitem 1,2,3,5

t_=!rawmath $(tmp0)*$(tmp1)/$(tmp2)
val21=!exec pari print($t_)
!endif
tmp=!translate ";': to $     $ in $val17*x+$val18

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!replace internal \( by ( in expand($(tmp0))
tmp1=!exec maxima $t_

val22=!rawmath $(tmp1)
tmp0=!texmath $val22

val23=$(tmp0)
t_=!rawmath $val17*$val19+$val18
val24=!exec pari print($t_)

!ifval $val24==$val21
val25=$[rint(1)]
!else
val25=$[rint(2)]
!endif
oefsteps=reply1,reply2,reply3	reply4,reply5,reply6,reply7 
nextstep=!nosubst reply1,reply2,reply3	reply4,reply5,reply6,reply7 
!readproc oef/steps.proc
replytype1=menu
replyoption1=shuffle 
replyname1=
replygood1=1;$val8
replytype2=default
replyoption2=nonstop 
replyname2=$(val11[1]) m
replygood2=$val17
replytype3=default
replyoption3=nonstop 
replyname3=$(val11[2]) p
replygood3=$val18
replytype4=default
replyoption4=nonstop 
replyname4=$(val11[3]) m x_C+p
replygood4=$val24
replytype5=default
replyoption5=nonstop 
replyname5=$(val11[4]) C
replygood5=$val21
replytype6=menu
replyoption6=shuffle 
replyoption6=nonstop 
replyname6=$(val11[5]) C
replygood6=$val25;$val9
replytype7=menu
replyoption7=shuffle 
replyoption7=nonstop 
replyname7=C
replygood7=$val25;$val10
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div style="background-color:#FFFF66">	Dans un repčre 
!insmath (O,\vec{i},\vec{j})
$() du plan, on considčre les trois points	suivants :	<div class="wimscenter">
!insmath A\left( $val13 ; $val14 \right) 
$() ; 
!insmath B\left( $val15 ; $val16 \right) 
$() ; 
!insmath C\left( $val19 ; $val21 \right) 
$(). </div>	<b>On se propose de déterminer si ces trois points sont	alignés ou non.</b>	Dans ce but, on examine si le point 
!insmath C
$() appartient ŕ la droite 
!insmath (A B)
$().	
!if $m_step=1 
$()	<h2 class="small">$val12 1.</h2>	La droite 
!insmath (A B)
$()  
!read oef/embed.phtml reply1, 10 
$() parallčle ŕ l'axe des ordonnées.	<br>	Elle a donc une équation de la forme 
!insmath y = m x+p
$() avec	 <label for="reply2">
!insmath m
$() = </label> 
!read oef/embed.phtml reply2, 10 
$() et	 <label for="reply3">
!insmath p
$() =</label>  
!read oef/embed.phtml reply3, 10 
$().	 
!endif
$()	
!if $m_step=2 
$()	<h2 class="small">$val12 1.</h2>	
!if $m_reply2=$val17 and $m_reply3=$val18 
$()<span class="oef_indgood">Bonne réponse !</span> 
!else
$()	   < <span class="oef_indbad">Mauvaise réponse...</span> 
!endif
$()	La droite 
!insmath (A B)
$() admet comme équation : 
!insmath y = $val23
$().	<h2 class="small">$val12 2.</h2>	Pour 
!insmath x = $val19
$(), on a : <label for="reply4">
!insmath $val23
$() =</label>  
!read oef/embed.phtml reply4, 5 
$().	<div>L'ordonnée du point 
!insmath C
$() est :	<label for="reply5">
!insmath y_C
$() =</label>  
!read oef/embed.phtml reply5, 5 
$().	</div><div>	Donc les coordonnées du point 
!insmath C
$()  
!read oef/embed.phtml reply6 
$()	l'équation de 
!insmath (A B)
$().	</div><div>On conclut que les points 
!insmath A
$(), 
!insmath B
$() et 
!insmath C
$()	 
!read oef/embed.phtml reply7 
$().	</div>	 
!endif
$()	</div>	
$()
!exit

