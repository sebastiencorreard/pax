!set title=Perpendiculaire à une droite
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Véronique, Royer
email=royer.veronique@orange.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=yes
precision=10000

ansorder=r,r,r,r
varcnt=17
prevarcnt=16
postvarcnt=0
replycnt=4
choicecnt=0
conditioncnt=0
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!readproc slib/oefenv lang 
tmp0=$slib_out
val6=$(tmp0)
val7=Solution
val8=Nature de,Pente de,Valeur de
val9=non verticale,verticale
val10=Dans un repère orthonormal du plan&#44;	  la pente d'une droite est son coefficient directeur.
tmp0=!randitem -1,1

tmp1=!randint 1, 8

tmp2=!randitem 2,3

t_=!rawmath $(tmp0)*$(tmp1)/$(tmp2)
val11=!exec pari print($t_)
t_=!rawmath -1/($val11)
val12=!exec pari print($t_)
tmp0=!randint -10, 10

val13=$[rint($(tmp0))]
tmp0=!randitem -1,1

tmp1=!randint 2, 10

val14=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 2, 10

val15=$[rint($(tmp0)*$(tmp1))]
t_=!rawmath $val15-$val12*$val14
val16=!exec pari print($t_)
tmp=!translate ";': to $     $ in $val11*x+$val13

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!replace internal \( by ( in expand($(tmp0))
tmp1=!exec maxima $t_

val17=!rawmath $(tmp1)
tmp=!translate ";': to $     $ in $val12*x+$val16

tmp=!lower $tmp
tmp0=!exec maxima fullratsimp($tmp);
t_=!replace internal \( by ( in expand($(tmp0))
tmp1=!exec maxima $t_

val18=!rawmath $(tmp1)
tmp0=!texmath $val17

val19=$(tmp0)
tmp0=!texmath $val18

val20=$(tmp0)
val21=$[rint(1)]
replytype1=menu
replyoption1=shuffle 
replyname1=$(val8[1]) \(D\)
replygood1=$val21;$val9
replytype2=default
replyname2=$(val8[2]) \(D\)
replygood2=$val11
replytype3=default
replyname3=$(val8[2]) \(D'\)
replygood3=$val12
replytype4=default
replyname4=$(val8[3]) \(p'\)
replygood4=$val16
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div style="background-color:#FFFF66">	Dans un repère orthonormal 
!insmath (O,\vec{i},\vec{j})
$() du plan,	on considère la droite 
!insmath D
$() d'équation réduite 
!insmath y = $val19
$().	<p>On se propose de déterminer l'équation réduite de la droite 
!insmath \Delta
$()	perpendiculaire à la droite 
!insmath D
$() et passant par le point	
!insmath A\left( $val14 ; $val15 \right) 
$().	</p>	<ul><li>	On cherche l'équation de 
!insmath \Delta
$() sous la forme : 
!insmath  y = m' x + p'
$()	parce qu'il s'agit nécessairement d'une droite  
!read oef/embed.phtml reply1, 10 
$().	</li><li>	La  
!read oef/special.phtml tooltip pente,,$val10 
$()	 de la droite 
!insmath D
$() vaut <label for="reply2">
!insmath m
$() = </label> 
!read oef/embed.phtml reply2, 5 
$().	</li><li>	Les droites 
!insmath D
$() et 
!insmath \Delta
$() étant perpendiculaires, leurs pentes respectives 
!insmath m
$() et 
!insmath m'
$()	vérifient 
!insmath m\times m'= -1
$() (<i>résultat admis</i>).	<br> Alors on obtient : <label for="reply3">
!insmath m'
$() =</label>  
!read oef/embed.phtml reply3, 5 
$().	</li><li>	On écrit que 
!insmath A
$() appartient à 
!insmath \Delta
$() pour calculer la valeur	de l'ordonnée à l'origine	
!insmath p'
$(). <br> On obtient alors : <label for="reply4">
!insmath p'
$() =</label>  
!read oef/embed.phtml reply4, 5 
$()</li>	</ul>	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback
!ifval 0==0
 <div class='oef_feedbacks'>	<h2 class="small">$val7.</h2>	De l'égalité 
!insmath m\times m'=-1
$() on tire : 
!insmath m' = -\frac{1}{m} = $val12
$().	<br/>	Le point 
!insmath A
$() doit vérifier l'équation 
!insmath y = m' x + p'
$() avec 
!insmath m' = $val12
$(), donc	on obtient : 
!insmath p' = y_A - m'x_A = $val16
$().<br>	D'où l'équation réduite de la droite 
!insmath \Delta
$() : 
!insmath y = $val20
$().	<br>	 
!insmath \Delta
$() est représentée en vert ci-dessous.	<div class="wimscenter">	 
!read oef/draw.phtml 400,400 \
xrange -15,15	yrange -15,15	parallel -15,-15,-15,15,1,0,30,grey	parallel -15,-15,15,-15,0,1,30,grey	hline 0,0,black	vline 0,0,black	linewidth 2	arrow 0,0,0,1,5,black	arrow 0,0,1,0,5,black	plot blue,$val17	plot green,$val18	text green,$val14+1,$val15,large,"A"	text blue,1,$val13,large,"D"	linewidth 6	point $val14,$val15,green 
$()	</div>	
$()</div>
!endif

!exit

:test

!exit

:stat
vsavelist=7,10,12,13,14,15,16,17,18,19,20
embedcnt=5
