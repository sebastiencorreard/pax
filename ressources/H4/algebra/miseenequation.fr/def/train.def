!set title=Train
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=9
prevarcnt=8
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 60, 80

val6=$[rint($(tmp0)*10)]
tmp0=!randint 20, 50

val7=$[rint($(tmp0)*10)]
val8=$[rint($val6-$val7)]
tmp0=!randint 20, 40

val9=$[rint($(tmp0)*10)]
tmp0=!randint 30, 40

val10=$[rint($(tmp0))]
tmp0=!randint 15, 25

val11=$[rint($(tmp0))]
tmp0=!randint 5, 10

val12=$[rint($val11+$val10-$(tmp0))]
val13=$[rint($val12*$val7+$val10*$val8+$val11*$val9)]
replytype1=default
replyname1=
replygood1=$val8
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	Le TGV Paris-Marseille ne fait qu'un arrêt à Lyon.	Le prix d'un billet Paris-Lyon est de $val10 euros, celui d'un billet Lyon-Marseille	est de $val11 euros et celui	d'un billet Paris-Marseille est de $val12 euros.	<p>	$val6 voyageurs sont montés à Paris et $val9 sont montés à Lyon.	</p><p>	La recette totale étant de $val13 euros,	quel est le nombre de voyageurs descendus à Lyon?	</p>	<div class="wimscenter">	<label for="reply1">Nombre de voyageurs descendus à Lyon :</label>  
!read oef/embed.phtml r1,3 
$()</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()Soit 
!insmath x
$() le nombre de voyageurs Paris-Marseille	et 
!insmath y
$() le nombre de voyageurs Paris-Lyon.	<p>	Nous avons le système suivant	</p>	<div class="wimscenter">	
!insmath 	\begin{cases}	 x + y &= $val6 \\	 $val12 x + $val10 y + $val11 \times $val9 &= $val13	\end{cases}	
$()	</div>	Et la solution de ce système est 
!insmath x = $val7
$(), 
!insmath y = $val8
$().	
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,10,11,12,13
embedcnt=1
