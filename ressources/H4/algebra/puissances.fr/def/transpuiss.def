!set title=Transformation d'expressions avec des puissances
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=David Doyen
email=david.doyen@u-pem.fr
language=fr
computeanswer=no

ansorder=r
varcnt=30
prevarcnt=29
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

!if $val2= 
val6=1
!else
tmp=!nonempty items $val2,$val2

tmp0=!randitem $tmp
val6=$(tmp0)
!endif
val7=x
tmp=!nonempty items -4,-3,-2,-1,2,3,4,5,6

tmp0=!randitem $tmp
val8=$(tmp0)
tmp=!nonempty items -4,-3,-2,-1,2,3,4,5,6

tmp0=!randitem $tmp
val9=$(tmp0)
tmp=!nonempty items -4,-3,-2,-1,2,3,4,5,6

tmp0=!randitem $tmp
val10=$(tmp0)
tmp=!nonempty items -4,-3,-2,-1,2,3,4,5,6

tmp0=!randitem $tmp
val11=$(tmp0)
!if $val6=1 
val12=$val7^{$val8}  $val7^{$val9}
val13=$[rint($val8+$val9)]
!endif
!if $val6=2 
val12=\frac{$val7^{$val8}}{$val7^{$val9}}
val13=$[rint($val8-$val9)]
!endif
!if $val6=3 
val12=($val7^{$val8})^{$val9}
val13=$[rint($val8*$val9)]
!endif
!if $val6=4 
tmp=!nonempty items $val7 $val7^{$val8},$val7^{$val8} $val7

tmp0=!randitem $tmp
val12=$(tmp0)
val13=$[rint($val8+1)]
!endif
!if $val6=5 
tmp=!nonempty items 1,2

tmp0=!randitem $tmp
!if $(tmp0)=1 
val12=\frac{$val7^{$val8}}{$val7}
val13=$[rint($val8-1)]
!else
val12=\frac{$val7}{$val7^{$val8}}
val13=$[rint(1-$val8)]
!endif
!endif
!if $val6=7 
tmp=!nonempty items ($val7^{$val8})^{$val10} $val7^{$val9},$val7^{$val9}($val7^{$val8})^{$val10}

tmp0=!randitem $tmp
val12=$(tmp0)
val13=$[rint($val8*$val10+$val9)]
!endif
!if $val6=8 
tmp=!nonempty items 1,2

tmp0=!randitem $tmp
!if $(tmp0)=1 
val12=\frac{($val7^{$val8})^{$val10}}{$val7^{$val9}}
val13=$[rint($val8*$val10-$val9)]
!else
val12=\frac{$val7^{$val8}}{($val7^{$val9})^{$val11}}
val13=$[rint($val8-$val9*$val11)]
!endif
!endif
!if $val6=10 
val12=($val7^{$val8})^{$val10} ($val7^{$val9})^{$val11}
val13=$[rint($val8*$val10+$val9*$val11)]
!endif
!if $val6=11 
val12=\frac{($val7^{$val8})^{$val10}}{($val7^{$val9})^{$val11}}
val13=$[rint($val8*$val10-$val9*$val11)]
!endif
replytype1=numeric
replyname1=
replygood1=$[$val13]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div>Soit 
!insmath $val7
$() un réel strictement positif. Simplifier l'expression 
!insmath $val12
$() en l'écrivant sous la forme 
!insmath $val7^n
$(), oů 
!insmath n
$() est un entier.</div>		<div>
!insmath $val12 =$val7^n
$() avec 
!insmath n=
$() 
!read oef/embed.phtml reply1,3 
$()</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=7,12
embedcnt=1
