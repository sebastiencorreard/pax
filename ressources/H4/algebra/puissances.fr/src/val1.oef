\title{Puissance d'un entier}
\language{fr}
\author{David Doyen}
\email{david.doyen@u-pem.fr}
\computeanswer{no}

\text{a=randitem(1,2,3,4,5)}
\text{b=randitem(-1,-2,-3)}
\text{c=randitem(2,3,4)}

\text{expr=randitem(-\a^\b,-\a^\c,(-\a)^\b,(-\a)^\c,-(-\a)^\b,-(-\a)^\c,\a^\b)}
\text{rep=simplify(\expr)}

\statement{Calculer l'expression suivante.<br class="spacer">
\(\expr =\) \embed{reply1,5}<br class="spacer">
<div class=wims_instruction>Le résultat doit ętre sous la forme d'un entier ou d'une fraction irréductible.</div>
}
\answer{}{\rep}{type=numexp}
