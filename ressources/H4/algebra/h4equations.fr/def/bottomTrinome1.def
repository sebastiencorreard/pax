!set title=Cocher les valeurs interdites
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
author=YAMEOGO Joachim
email=yameogo@math.unice.fr

ansorder=r
varcnt=35
prevarcnt=34
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 11

val6=$[rint($(tmp0))]
tmp0=!randint 1, 11

val7=$[rint($(tmp0))]
tmp0=!randint 1, 11

val8=$[rint($(tmp0))]
tmp0=!randint 1, 11

val9=$[rint($(tmp0))]
tmp0=!randitem -1,1

tmp1=!randint 1, 20

val10=$[rint($(tmp0)*$(tmp1))]
val11=!rawmath $val6*x+$val7+($val10/(x*($val8*x+$val9)))
val12=!rawmath $val6*x+$val7+($val10/((x-$val8)^2-($val9)^2))
val13=!rawmath ($val6*x)/($val8*x^2-$val9)
val14=!rawmath ($val6*x)/(($val8*x+$val9)^2+($val10)*($val8*x+$val9))
val15=$val11,$val12,$val13,$val14
val16=0,(-$val9)/$val8;	$val8-$val9,$val8+$val9;	-sqrt(($val9)/($val8)),sqrt(($val9)/($val8));	(-$val9)/$val8,(-$val9-($val10))/($val8);	
tmp0=!randint 1, 4

val17=$[rint($(tmp0))]
tmp0=!texmath $(val15[$val17])

val18=$(tmp0)
t_=!replace internal \( by ( in $(val16[$val17;1]);
tmp0=!exec maxima $t_

val19=$(tmp0)
t_=!replace internal \( by ( in $(val16[$val17;2]);
tmp0=!exec maxima $t_

val20=$(tmp0)
val21=$[rint(floor(abs($(val16[$val17;2])-($(val16[$val17;1]))))+1)]
tmp0=!shuffle -5,-4,-3,-2,-1,1,2,3,4,5

val22=$(tmp0)
val23=
!for val24 =1 to 4 
!if $(val22[$val24])<0 
t_=!replace internal \( by ( in $(val22[$val24])-$val21+(($val19+$val20)/2);
tmp0=!exec maxima $t_

val25=$(tmp0)
tmp0=!texmath $val25

val25=$(tmp0)
tmp0=!append item $val25 to $val23

val23=$(tmp0)
!else
t_=!replace internal \( by ( in $(val22[$val24])+$val21+(($val19+$val20)/2);
tmp0=!exec maxima $t_

val25=$(tmp0)
tmp0=!texmath $val25

val25=$(tmp0)
tmp0=!append item $val25 to $val23

val23=$(tmp0)
!endif
!next
tmp0=!texmath $val19

val19=$(tmp0)
tmp0=!texmath $val20

val20=$(tmp0)
tmp0=!append item $val19 to $val23

val23=$(tmp0)
tmp0=!append item $val20 to $val23

val23=$(tmp0)
val26=Les valeurs interdites ŕ <b>f</b> sont:
tmp0=!shuffle 6

val27=$(tmp0)
tmp0=!positionof item 5 in $val27

val28=$[rint($(tmp0))]
tmp0=!positionof item 6 in $val27

val29=$[rint($(tmp0))]
val30=$val28,$val29
replytype1=checkbox
replyname1=$val26
replygood1=$val30;1,2,3,4,5,6
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

