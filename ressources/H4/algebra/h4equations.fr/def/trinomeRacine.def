!set title=Un trin&ocirc;me, une racine
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
author=YAMEOGO Joachim
email=yameogo@math.unice.fr

ansorder=r
varcnt=13
prevarcnt=12
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!shuffle 9

val6=$(tmp0)
val7=
!for val8 =1 to 8 
tmp0=!randitem -1,1

val9=$[rint($(tmp0)*$(val6[$val8]))]
tmp0=!append item $val9 to $val7

val7=$(tmp0)
!next
t_=!replace internal \( by ( in expand((x-$(val7[1]))*(x-$(val7[5])));
tmp0=!exec maxima $t_

val10=!rawmath $(tmp0)
t_=!replace internal \( by ( in expand((x-$(val7[2]))*(x-$(val7[6])));
tmp0=!exec maxima $t_

val11=!rawmath $(tmp0)
t_=!replace internal \( by ( in expand((x-$(val7[3]))*(x-$(val7[7])));
tmp0=!exec maxima $t_

val12=!rawmath $(tmp0)
t_=!replace internal \( by ( in expand((x-$(val7[4]))*(x-$(val7[8])));
tmp0=!exec maxima $t_

val13=!rawmath $(tmp0)
tmp0=!texmath $val10

tmp1=!texmath $val11

tmp2=!texmath $val12

tmp3=!texmath $val13

val14=\($(tmp0)),	\($(tmp1)),	\($(tmp2)),	\($(tmp3))	
val15=$(val7[1]),$(val7[2]),$(val7[3]),$(val7[4])
tmp0=!randitem qu'il annule,dont il est une racine

val16=$(tmp0)
replytype1=correspond
replyname1=Correspondance Trin&ocirc;me/racine
replygood1=$val14;$val15
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<center>	<table width=75%>	  <tr>	    <td align=center>	      <p  style="background-color:lightblue">	      Dans la liste ci-dessous, mettre en correspondance chaque nombre 	      avec un trin&ocirc;me $val16. 	      <br>	      <br>	       
!read oef/embed.phtml reply 1,40x120x40 
$()	      </p>	    </td>	  </tr>	</table>	</center>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=16
embedcnt=1
