!set title=Donner la valeur interdite
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
language=fr
computeanswer=yes
author=YAMEOGO Joachim
email=yameogo@math.unice.fr

ansorder=r
varcnt=11
prevarcnt=10
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem -1,1

tmp1=!randint 1, 20

val6=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 1, 20

val7=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 1, 20

val8=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem -1,1

tmp1=!randint 1, 20

val9=$[rint($(tmp0)*$(tmp1))]
val10=$[rint(($val6*$val8-$val9))]
val11=!rawmath ($val6*x+($val10/$val7))/($val7*x+$val8)
val12=!rawmath $val6+($val9/($val7*x+$val8))
tmp0=!randitem $val11,$val12

tmp1=!texmath $(tmp0)

val13=$(tmp1)
t_=!replace internal \( by ( in -($val8)/($val7);
tmp0=!exec maxima $t_

val14=$(tmp0)
val15=La valeur interdite de <b>f</b> est:
replyname1=
replygood1=$val14
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<center>	<table>	  <tr>	    <td>	      <p style="background-color:lightblue">	      On considŤre la fonction rťelle <b><em>f</em></b> dťfinie par 	      
!insmath f(x)=$val13
$(). 	      <br>	      Donner la valeur interdite 	      pour <b><em>f</em></b>. 	      </p>	      <p style="background-color:aquamarine"> 	        $val15 &nbsp;  
!read oef/embed.phtml reply 1, 10 
$()  	      </p>	    </td>	  </tr>	</table>	</center>	<br>	
$()
!exit

