!set title=Compléter des équations du premier degré
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr
precision=1000
computeanswer=no
leftrange=-5.000000
rightrange=5.000000

ansorder=r,r,r,r,r,r,r,r,r
varcnt=20
prevarcnt=17
postvarcnt=2
replycnt=9
choicecnt=0
conditioncnt=3
feedbackcnt=5
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=\(\emptyset)
val7=\(\RR)
tmp0=!randint 2, 9

tmp1=!randitem 1,-1

val8=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 9

val9=$[rint($(tmp0))]
tmp0=!randint 2, 9

tmp1=!randitem 1,-1

val10=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 9

val11=$[rint($(tmp0))]
tmp0=!randint -9, 9

val12=$[rint($(tmp0))]
tmp0=!randint 2, 9

tmp1=!randitem 1,-1

val13=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 9

val14=$[rint($(tmp0))]
tmp0=!randint 2, 9

tmp1=!randitem 1,-1

val15=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 9

val16=$[rint($(tmp0))]
tmp0=!randint -9, 9

val17=$[rint($(tmp0))]
tmp0=!randint 2, 9

tmp1=!randitem 1,-1

val18=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 9

val19=$[rint($(tmp0))]
tmp0=!randint 2, 9

tmp1=!randitem 1,-1

val20=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 9

val21=$[rint($(tmp0))]
tmp0=!randint -9, 9

val22=$[rint($(tmp0))]
replytype1=numeric
replyname1=v1 équation 1
replygood1=?analyze 23
replytype2=numeric
replyname2=v2 équation 1
replygood2=?analyze 24
replytype3=numeric
replyname3=v3 équation 1
replygood3=?analyze 25
