!set title=ComplÈter des Èquations carrÈ ou produit
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=RÈgine, Mangeard
email=regine@mangeard.fr
precision=1000
computeanswer=no
leftrange=-5.000000
rightrange=5.000000

ansorder=r,r,r,r,r,r,r,r,r
varcnt=23
prevarcnt=22
postvarcnt=0
replycnt=9
choicecnt=0
conditioncnt=2
feedbackcnt=6
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=\(\emptyset)
val7=\(\RR)
tmp0=!randint 2, 9

tmp1=!randitem 1,-1

val8=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint -9, 9

val9=$[rint($(tmp0))]
val10=$[rint(-$val8*$val9)]
tmp0=!randint 2, 9

tmp1=!randitem 1,-1

val11=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 2, 9

tmp1=!randitem 1,-1

val12=$[rint($(tmp0)*$(tmp1))]
tmp0=!randitem 0,1

val13=$[rint($(tmp0))]
tmp0=!randint -4, 4

val14=$[rint($(tmp0)*2+$val13)]
tmp0=!randint -4, 4

val15=$[rint($(tmp0)*2+$val13)]

!ifval $val14=$val15
val15=$[rint($val15+2)]
!endif
val16=$[rint(-$val12*($val15+$val14)/2)]
val17=$[rint(($val12*$val14+$val16)^2)]
tmp0=!randint 2, 9

tmp1=!randitem 1,-1

val18=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 2, 9

val19=$[rint($(tmp0))]
tmp0=!randint 2, 9

tmp1=!randitem 1,-1

val20=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 9

tmp1=!randitem 1,-1

val21=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 9

tmp1=!randitem 1,-1

val22=$[rint($(tmp0)*$(tmp1))]
val23=$[rint(-$val18*$val21)]
t_=!rawmath (-$val19+1)/$val22
val24=!exec pari print($t_)
tmp0=!texmath ($val18*x + $val23)*($val24*x+$val19)=$val18*x+$val23

val25=$(tmp0)
tmp0=!texmath ($val18*x + $val23)*($val24*x+$val19-1)=0

val26=$(tmp0)
replytype1=numeric
replyname1=v1 Èquation 1
replygood1=$[$val10]
replytype2=numeric
replyname2=v2 Èquation 1
replygood2=$[0]
replytype3=numeric
replyname3=v1 Èquation 2
replygood3=?analyze 27
replytype4=numeric
replyname4=v2 Èquation 2
replygood4=?analyze 28
replytype5=numeric
replyname5=v1 Èquation 3
replygood5=$[$val16]
replytype6=numeric
replyname6=v2 Èquation 3
replygood6=$[$val17]
replytype7=numeric
replyname7=v1 Èquation 4
replygood7=?analyze 29
replytype8=numeric
replyname8=v2 Èquation 4
replygood8=?analyze 30
replytype9=numeric
replyname9=v3 Èquation 4
replygood9=?analyze 31
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<b>ComplÈter les Èquations suivantes pour obtenir les ensembles de solutions indiquÈs</b>:<br>	<table class="wimsnoborder">	<tr><td style="min-width:300px"> 
!insmath S=\{ $val9 \}
$() pour l'Èquation </td><td>	 ($val8 x+ 
!read oef/embed.phtml reply1,2 
$())<sup>2</sup>= 
!read oef/embed.phtml reply2,2 
$()</td></tr>	<tr><td> 
!insmath S=\emptyset
$() pour l'Èquation </td><td>	 ($val11 x+ 
!read oef/embed.phtml reply3,2 
$())<sup>2</sup>= 
!read oef/embed.phtml reply4,2 
$()</td></tr>	<tr><td> 
!insmath S=\{ $val14 ; $val15 \}
$() pour l'Èquation </td><td>	 ($val12 x+ 
!read oef/embed.phtml reply5,2 
$())<sup>2</sup>= 
!read oef/embed.phtml reply6,2 
$()</td></tr>	<tr><td> 
!insmath S=\{ $val21 ; $val22 \}
$() pour l'Èquation </td><td>	 ($val18 x+ 
!read oef/embed.phtml reply7,2 
$())( 
!read oef/embed.phtml reply8,2 
$() x+$val19)=$val18 x+ 
!read oef/embed.phtml reply9,2 
$()</td></tr>	</table>			
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback
!ifval $m_reply2<>0
 <div class='oef_feedbacks'>Pour qu'une Èquation carrÈ n'est qu'une seule solution, il faut que le membre de droite soit nul.
$()</div>
!endif
!ifval $m_reply2=0 and $val8*$val9+$m_reply1<>0
 <div class='oef_feedbacks'>Pour que l'unique solution de l'Èquation 1 soit $val9, il faut que le membre de gauche soit nul quand on remplace 
!insmath x
$() par $val9.<br>	Or 
!insmath $val8 \times $val9+$m_reply1 \neq 0
$().
$()</div>
!endif
!ifval $m_reply4>=0
 <div class='oef_feedbacks'>Pour qu'une Èquation carrÈ n'est aucune solution, il faut que le membre de droite soit nÈgatif.
$()</div>
!endif
!ifval ($val18*$val21+$m_reply7)*($m_reply8*$val21+$val19)<>$val18*$val21+$m_reply9
 <div class='oef_feedbacks'>$val21 n'est pas solution de l'Èquation 4
$()</div>
!endif
!ifval ($val18*$val22+$m_reply7)*($m_reply8*$val22+$val19)<>$val18*$val22+$m_reply9
 <div class='oef_feedbacks'>$val22 n'est pas solution de l'Èquation 4
$()</div>
!endif
!ifval  ($val18*$val21+$m_reply7)*($m_reply8*$val21+$val19)<>$val18*$val21+$m_reply9 or ($val18*$val22+$m_reply7)*($m_reply8*$val22+$val19)<>$val18*$val22+$m_reply9
 <div class='oef_feedbacks'>L'Èquation 4 pouvait Ítre:<br>	
!insmath $val25 \Leftrightarrow $val26
$()
$()</div>
!endif

!exit

:test

!ifval $m_reply4<0
 condtest1=1
!else
 condtest1=0
!endif
condname1=Aucune solution pour l'Èquation 2

!ifval ($val18*$val21+$m_reply7)*($m_reply8*$val21+$val19)=$val18*$val21+$m_reply9 and ($val18*$val22+$m_reply7)*($m_reply8*$val22+$val19)=$val18*$val22+$m_reply9
 condtest2=1
!else
 condtest2=0
!endif
condname2=Deux solutions pour l'Èquation 4

!exit

:stat
vsavelist=8,9,11,12,14,15,18,19,21,22,25,26,27,28,29,30,31
