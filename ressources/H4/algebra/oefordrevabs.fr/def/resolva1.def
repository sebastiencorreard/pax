!set title=RÈsolution avec une valeur absolue
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=RÈgine, Mangeard
email=regine@mangeard.fr
oefobservation=L'objet de l'exercice est de rÈsoudre un abs(x-a) = b par l'appartenance ‡ un intervalle
language=fr
computeanswer=yes
precision=1000
oefcss=<style> .rm { font-size:large} .hint { padding:20px;} .solution { padding:20px;} .flex_box{ justify-content:flex-start; } </style>

ansorder=r,r
varcnt=15
prevarcnt=14
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=Votre rÈponse&nbsp;
val7=ou
val8=RÈsoudre&nbsp;
val9=Indiquer en premier la plus petite des deux solutions.
val10=$[rint(20)]
val11=$[rint(10)]
tmp0=!randint 1, $val11

tmp1=!randitem 1,-1

val12=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, $val10

val13=$[rint($(tmp0))]
tmp0=!texmath x-($val12)

val14=\(abs($(tmp0))) = $val13 
tmp0=!texmath x-($val12)

val15=$(tmp0)
val16=$[rint($val13+($val12))]
val17=$[rint(-($val13)+($val12))]

!ifval $val17<$val16
val18=$[rint($val16)]
!else
val18=$[rint($val17)]
!endif

!ifval $val17<$val16
val19=$[rint($val17)]
!else
val19=$[rint($val16)]
!endif
replytype1=numeric
replyname1=
replygood1=$[$val19]
replytype2=numeric
replyname2=
replygood2=$[$val18]
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="rm">	  $val8:	  <div class="wimscenter">	   $val14.	  </div>	  <div class="wims_instruction">	  $val9	  </div>	  <p>$val6:</p>	  <div class="wimscenter">	  S= &#123;  
!read oef/embed.phtml reply1,3 
$() ;  
!read oef/embed.phtml reply2,3 
$()&#125;.	  </div>	</div>	
$()
!exit

:hint
$() <div class="hint">	
!insmath abs(a)
$() = 
!insmath b
$() 
!insmath \Leftrightarrow 
$() 
!insmath a
$() = 
!insmath b
$() $val7 
!insmath a
$() = -
!insmath b
$()	</div>
$()
!exit

:help
$()
$()
!exit

:solution
$()	<div class="solution">	$val14 
!insmath \Leftrightarrow 
$() $val15 = $val13 $val7 $val15 = -($val13)<br>	
!insmath \Leftrightarrow
$() x = $val13 + ($val12) $val7 x = -($val13)+($val12)	</div>
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,12,13,14,15
embedcnt=2
