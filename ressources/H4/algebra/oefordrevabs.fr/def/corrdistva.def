 !exit
!endif

val6=Votre rťponse&nbsp;
val7=Soit \(\mathrm{M}\) le point d'abscisse \(x\)	  sur la droite graduťe d'origine
val8=Associer les valeurs absolues aux distances	  auxquelles elles correspondent.
val9=45x100x100
!readproc slib/draw/repere 800,30,10,-12,12,-1,0,1,0,black,white 
tmp0=$slib_out
val10=$(tmp0)
tmp=!translate internal $	$ to ; in $val10

tmp=!row 1 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val11=$(tmp0)
tmp0=!item 1 of $val11

val12=$[rint($(tmp0))]
tmp0=!item 2 of $val11

val13=$[rint($(tmp0))]
tmp=!translate internal $	$ to ; in $val10

tmp=!row 2 of $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val11=$(tmp0)
tmp0=!item 1 of $val11

val14=$[rint($(tmp0))]
tmp0=!item 2 of $val11

val15=$[rint($(tmp0))]
val12=$[rint(0)]
val14=$[rint(1)]
val16=xrange -16,16	  yrange -3,3	  hline 0,0,red	  arrow 15,0,16,0,15,red	  parallel -15,-0.2,-15,0.2,1,0,5,blue	  parallel -10,-0.4,-10,0.4,5,0,5,blue	  parallel -9,-0.2,-9,0.2,1,0,4,blue	  parallel -4,-0.2,-4,0.2,1,0,4,blue	  parallel 1,-0.2,1,0.2,1,0,4,blue	  parallel 6,-0.2,6,0.2,1,0,4,blue	  parallel 11,-0.2,11,0.2,1,0,5,blue	  text red,-0.1,1.5,medium,O	
val17=$[rint(-15)]
val18=$[rint(4)]
val19=A,B,C,D,E,F
tmp0=!itemcnt $val19

val20=$[rint($(tmp0))]
val21=$[rint($val13)]
val22=
val23=
val24=
val25=
tmp0=!shuffle $val20

val26=$(tmp0)
!for val27 =1 to $val20/2 
tmp0=!randint $val17+($val27-1)*$val18 ,  $val17+$val27*$val18-1

val28=$[rint($(tmp0))]
val29=$[rint(-1*($val28))]
val30=$[rint($val12+$val28*$val14)]
val31=$[rint($val12+$val29*$val14)]
val16=$val16	 text red,$val30-0.1,1.5,medium,$(val19[$(val26[$val27])])	 text red,$val30-0.1,-1,medium,$val28	 segment $val30,-0.2,$val30,0.2,red	 text red,$val31-0.1,1.5,medium,$(val19[$(val26[$val27+$val20/2])])	 text red,$val31-0.1,-1,medium,$val29	 segment $val31,-0.2,$val31,0.2,red	
tmp0=!append item $val28 to $val22

val22=$(tmp0)
tmp0=!append item $val30 to $val23

val23=$(tmp0)
tmp0=!texmath abs(x-($val28))

tmp1=!texmath abs(($val28)-x)

tmp2=!texmath abs(-x+($val28))

tmp3=!texmath abs(-($val28)+x)

val32=\($(tmp0)),\($(tmp1)),\($(tmp2)),\($(tmp3))
tmp=!nonempty items $val32

tmp0=!randitem $tmp
val33=$(tmp0)
tmp0=!append item $val33 to $val24

val24=$(tmp0)
val34=M$(val19[$(val26[$val27])]),$(val19[$(val26[$val27])])M
tmp=!nonempty items $val34

tmp0=!randitem $tmp
tmp1=!append item $(tmp0) to $val25

val25=$(tmp1)
tmp0=!append item $val29 to $val22

val22=$(tmp0)
tmp0=!append item $val31 to $val23

val23=$(tmp0)
tmp0=!texmath abs(x-($val29))

tmp1=!texmath abs(($val29)-x)

tmp2=!texmath abs(-x+($val29))

tmp3=!texmath abs(-($val29)+x)

val32=\($(tmp0)),\($(tmp1)),\($(tmp2)),\($(tmp3))
tmp=!nonempty items $val32

tmp0=!randitem $tmp
val33=$(tmp0)
tmp0=!append item $val33 to $val24

val24=$(tmp0)
val34=M$(val19[$(val26[$val27+$val20/2])]),$(val19[$(val26[$val27+$val20/2])])M
tmp=!nonempty items $val34

tmp0=!randitem $tmp
tmp1=!append item $(tmp0) to $val25

val25=$(tmp1)
!next

!ifval $val2=1 
val35= 
!else
val35=x-large
!endif
