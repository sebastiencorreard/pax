!set title=Équation avec deux valeurs absolues
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr
oefobservation= L'objet de l'exercice est de résoudre un abs(a x- c) = abs( b x-d) par l'appartenance ŕ un intervalle
language=fr
computeanswer=yes
precision=1000
oefcss=<style> .rm { font-size:large} .hint { padding:20px;} .solution { padding:20px;} .flex_box{ justify-content:flex-start; } </style>

ansorder=r,r
varcnt=24
prevarcnt=23
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=Votre réponse&nbsp;
val7=ou
val8=Résoudre&nbsp;
val9=Indiquer en premier la plus petite des deux solutions.
val10=Résoudre cette équation ŕ valeurs	  absolues revient ŕ résoudre deux équations du premier degré.
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val11=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 3

tmp1=!randitem 1,-1

val12=$[rint($val11+$(tmp0)*$(tmp1))]
!if $val12=$val11 or $val12=-$val11 
val12=$[rint(2*$val11)]
!endif
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val13=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 10

tmp1=!randitem 1,-1

val14=$[rint($(tmp0)*$(tmp1))]
tmp0=!texmath $val11 * x-($val13)

tmp1=!texmath $val12 * x-($val14)

val15=\(abs($(tmp0))) = \(abs($(tmp1))) 
tmp0=!texmath $val11 * x-($val13)

val16=$(tmp0)
tmp0=!texmath $val12 * x-($val14)

val17=$(tmp0)
tmp0=!texmath -($val12) * x+($val14)

val18=$(tmp0)
val19=$[rint($val13 - ($val14))]
val20=$[rint($val11 - ($val12))]
t_=!rawmath $val19 /($val20)
val21=!exec pari print($t_)
val22=$[rint($val13 + ($val14))]
val23=$[rint($val11 + ($val12))]
t_=!rawmath $val22 /($val23)
val24=!exec pari print($t_)

!ifval $val21<$val24
t_=!rawmath $val21
val25=!exec pari print($t_)
!else
t_=!rawmath $val24
val25=!exec pari print($t_)
!endif

!ifval $val21<$val24
t_=!rawmath $val24
val26=!exec pari print($t_)
!else
t_=!rawmath $val21
val26=!exec pari print($t_)
!endif

!ifval $val2=1 
val27= 
!else
val27=x-large
!endif
replytype1=numeric
replyname1=
replygood1=$[$val25]
replytype2=numeric
replyname2=
replygood2=$[$val26]
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="rm">	  $val8	  <div class="wimscenter">	    $val15.	  </div>	  <div class="wims_instruction">	  $val9	  </div>	  <p>$val6:</p>	  <div class="wimscenter">	     S= &#123;  
!read oef/embed.phtml reply1,3 
$() ;  
!read oef/embed.phtml reply2,3 
$() &#125;.	  </div>	</div>	
$()
!exit

:hint
$() <div class="hint">	&#124; a &#124; = &#124; b &#124; 
!insmath \Leftrightarrow
$() a = b $val7 a = -b<br>	$val10	</div>
$()
!exit

:help
$()
$()
!exit

:solution
$()<div class="solution">	 $val15 
!insmath  \Leftrightarrow
$() $val16 = $val17 $val7 $val16 = $val18<br>	
!insmath \Leftrightarrow
$() $val20 x = $val19 $val7 $val23 x = $val22 
!insmath \Leftrightarrow
$() x = 
!insmath \frac{$val19}{$val20}
$() $val7 x = 
!insmath \frac{$val22}{$val23}
$()	</div>	
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,10,15,16,17,18,19,20,22,23
