!set title=Résolution avec deux valeurs absolues
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr
oefobservation=L'objet de l'exercice est de résoudre un abs(x-a) = abs(x-b) par l'appartenance ŕ un intervalle
language=fr
computeanswer=yes
precision=1000
oefcss=<style> .rm { font-size:large} .hint { padding:20px;} .solution { padding:20px;} .flex_box{ justify-content:flex-start; } </style>

ansorder=r
varcnt=12
prevarcnt=11
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=Votre réponse&nbsp;
val7=Résoudre&nbsp;
val8=représente la distance de \(x\) ŕ \(a\).
val9=$[rint(20)]
val10=$[rint(10)]
tmp0=!randint 1, $val10

tmp1=!randitem 1,-1

val11=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, $val9

val12=$[rint($(tmp0))]
tmp0=!texmath x-($val11)

tmp1=!texmath x-($val12)

val13=\(abs($(tmp0))) = \(abs($(tmp1))) 
tmp0=!texmath x-($val11)

val14=$(tmp0)
t_=!rawmath ($val12+($val11))/2
val15=!exec pari print($t_)

!ifval $val2=1 
val16= 
!else
val16=x-large
!endif
replytype1=numeric
replyname1=
replygood1=$[$val15]
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="rm">	  $val7:	  <div class="wimscenter">	   $val13.	  </div>	<p>$val6:</p>	 <div class="wimscenter">	    S= &#123; 
!read oef/embed.phtml reply1,3 
$()&#125;.	 </div>	</div>	
$()
!exit

:hint
$() <div class="hint">
!insmath abs(x - a)
$() $val8 </div>
$()
!exit

:help
$()
$()
!exit

:solution
$()	<div class="solution">	 $val13 équivaut ŕ <span class="nowrap">
!insmath d(x,$val11) = d(x,$val12)
$().</span><br>	 Sur une droite graduée, considérons les points 
!insmath \mathrm{M}
$() d'abscisse <span class="nowrap">
!insmath x
$(),</span>	 
!insmath \mathrm{A}
$() d'abscisse 
!insmath $val11
$() et 
!insmath \mathrm{B}
$() d'abscisse <span class="nowrap">
!insmath $val12
$().</span><br>	Ainsi $val13 équivaut ŕ <span class="nowrap">
!insmath \mathrm{ M A} = \mathrm{ M B}
$().</span><br>	Le point 
!insmath \mathrm{M}
$(), aligné avec 
!insmath \mathrm{A}
$() et <span class="nowrap">
!insmath \mathrm{B}
$(),</span> est ŕ égale distance	de 
!insmath \mathrm{A}
$() et de <span class="nowrap">
!insmath \mathrm{B}
$(),</span>	il est donc au milieu du segment 
!insmath [\mathrm{A B}]
$()&nbsp;:<br>	
!insmath x = \frac{$val11+$val12}{2}
$()<br>	
!insmath x = $val15
$()	</div>	
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,11,12,13,15
embedcnt=1
