!set title=Transformation d'inégalité
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Régine, Mangeard
email=regine@mangeard.fr
oefobservation=L'objet de l'exercice est d'obtenir une inégalité concernant f(x) ŕ partir d'une inégalité sur x
language=fr
computeanswer=yes
precision=1000
oefcss=<style> .rm { font-size:large} .hint { padding:20px;} .solution { padding:20px;} .flex_box{ justify-content:flex-start; } </style>

ansorder=r,r
varcnt=33
prevarcnt=32
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif


!ifval \b>0
val6=positif
!else
val6=négatif
!endif

!ifval \b>0
val7=on conserve le sens de l'inégalité
!else
val7= on inverse le sens de l'inégalité
!endif
val8=Votre réponse&nbsp;
val9=Si \(x\) vérifie l'inégalité,	  que pouvez-vous dire de l'expression 
val10=positif,négatif
val11=on conserve le sens de l'inégalité, on inverse le sens de l'inégalité
val12=40x40
val13=>
val14=\(\ge )
val15=<
val16=\(\le )
val17=$val13,$val15,$val14,$val16
val18=>,<,\ge,\le
val19=2,1,4,3
tmp0=!randint 1, 10

tmp1=!randitem -1,1

val20=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 4

val21=$[rint($(tmp0))]
val22=\(x) $(val17[$val21]) $val20
val23=x $(val18[$val21]) $val20
tmp0=!randint 1, 10

tmp1=!randitem -1,1

val24=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 1, 10

tmp1=!randitem -1,1

val25=$[rint($(tmp0)*$(tmp1))]
tmp0=!texmath ($val25)*x +($val24)

val26=$(tmp0)

!ifval $val25>0
val27=$[rint($val21)]
!else
val27=$[rint($(val19[$val21]))]
!endif
val28=$[rint(($val25)*($val20)+($val24))]
val29=$[rint(($val25)*($val20))]
val30=$val25 \(\times) \(x) $(val17[$val27]) $val25 \(\times) ($val20)
val30=$val25 \times x $(val18[$val27]) $val25 \times $val20
val31=$val25 \(\times) \(x) $(val17[$val27]) $val29
val31=$val25 \times x $(val18[$val27]) $val29

!ifval $val25>0
val6=$(val10[1])
!else
val6=$(val10[2])
!endif

!ifval $val25>0
val7=$(val11[1])
!else
val7=$(val11[2])
!endif
val32=$val13,$val14,$val15,$val16	
val33=$(val17[$val27])
replytype1=clickfill
replyname1=
replygood1=$val33;$val32
replytype2=numeric
replyname2=
replygood2=$[$val28]
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="rm">	  $(val9[1]) $val22,	  $(val9[2]) 
!insmath $val26
$() ?	  <p>$val8:</p>	  <div class="wimscenter">	      
!insmath $val26
$()  
!read oef/embed.phtml reply1,$val12 
$()  
!read oef/embed.phtml reply2,5 
$()	  </div>	</div>	
$()
!exit

:hint
$()	<div class="rm hint">	  Servez-vous de théorčmes sur les inégalités	<ul>	<li> On peut ajouter un męme nombre aux deux membres d'une inégalité:<br>	 a < b 
!insmath \Leftrightarrow
$() a+c < b+c pour tout réel c	</li><li> On peut multiplier par un męme réel strictement positif les deux membres d'une inégalité:<br>	 a < b 
!insmath \Leftrightarrow
$() a 
!insmath \times
$() c < b 
!insmath \times
$() c pour tout c > 0	</li><li> On peut multiplier par un męme réel strictement négatif les deux membres	 d'une inégalité <span style="color:red"> en changeant le symbole de l'inégalité:</span><br>	 a < b 
!insmath \Leftrightarrow
$() a 
!insmath \times
$() c > b 
!insmath \times
$() c pour tout c < 0	</li><li> les nombres positifs sont rangés dans le męme ordre que leurs carrés: <br>	 0 < a < b 
!insmath \Leftrightarrow
$() 
!insmath a^2
$() < 
!insmath b^2
$()	</li><li> les nombres positifs sont rangés dans <span style="color:red">l'ordre inverse</span> de leurs inverses: <br>	 0 < a < b 
!insmath \Leftrightarrow
$() 
!insmath \frac{1}{a}
$() > 
!insmath \frac{1}{b}
$()	</li></ul>	</div>	
$()
!exit

:help
$()
$()
!exit

:solution
$()<div class="rm solution">	  Voici un <b>exemple de rédaction</b> de la solution:	  <br>	en multipliant les 2 termes de l'inégalité par $val25 $val6, $val7 :	<br>	 
!insmath \begin{split}	 $val23 &\Leftrightarrow $val30 \   &\Leftrightarrow $val31 \  & \Leftrightarrow $val26 $(val18[$val27]) $val28		\end{split}
$()	</div>
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,8,9,12,18,22,23,25,26,27,28,30,31
