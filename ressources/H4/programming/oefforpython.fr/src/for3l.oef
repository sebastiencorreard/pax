\integer{debut=randint(5..10)}
\integer{fin=\debut+randint(20..30)}
\integer{pas=randint(2..4)}
\integer{nbe=ceil((\fin-\debut)/\pas)}
\text{rrr=2,12,3}
\text{lrrr=\debut,\fin,\pas}

\text{enonfor=}
\text{enonran1=La fonction <code>range</code> permet la création d'une séquence
  de nombres entiers.}

\text{enonran2= Lorsque trois arguments sont utilisés dans la fonction range,
