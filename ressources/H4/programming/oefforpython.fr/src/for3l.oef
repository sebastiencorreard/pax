<ul><li>le premier est la valeur de <strong>départ incluse</strong>;</li>
<li>le second est la valeur de <strong>fin exclue</strong>;</li>
<li>le troisičme se nomme le <strong>pas</strong>: on ajoute cette valeur pour passer
 d'une valeur ŕ la suivante.</li>
</ul>}
\text{exemplefor=}
\text{exempleran=<code>print(list(range(\rrr)))</code> renvoie la liste : [2,5,8,11]}

\text{instruction_code=}
\text{DD=pari(l=vector(\nbe);
for(x=1,\nbe,l[x]=\debut+\pas*(x-1));)}
\text{lp=pari(print(l);)}
