\title{Boucle for avec 2 arguments pour lister par compréhension en lecture de script}

\integer{debut=randint(5..10)}
\integer{fin=\debut+randint(5..10)}
\integer{nbe=\fin-\debut}
\integer{pas=1}
\text{rrr=3,7}
\text{lrrr=\debut,\fin}
\text{enonfor=}
\text{enonran1=La fonction <code>range</code> permet la création d'une séquence de nombres entiers.}

\text{enonran2= Lorsque deux arguments sont utilisés dans la fonction range,
 la séquence créée part de la valeur du premier argument inclus et se termine ŕ la valeur
 du dernier argument <b>exclue</b> en ajoutant 1 ŕ chaque étape.}
\text{exemplefor=}
\text{exempleran=<code>print(list(range(\rrr)))</code> renvoie la liste : [3,4,5,6]}


\text{exempleran=<code>print([i for i in range(\rrr)])</code> renvoie la liste : [3,4,5,6]}

\text{enonfor=La compréhension de liste utilise une ou des boucles <code>for</code>
 de maničre concise.
 Elle construit une liste en utilisant l'expression du motif en partant du
 premier élément jusqu'au dernier. On sort de la boucle lorsque le dernier
 élément de la séquence a été lu.}

\text{instruction_code=}
\text{DD=pari(l=vector(\nbe);
for(x=1,\nbe,l[x]=\debut+\pas*(x-1));)}
\text{lp=pari(print(l);)}
\text{alist=[\lp]}
\text{lr=[\lp]:}

\text{code=print([i for i in range(\rrr)])}

\text{variable=[print,\lr]}
\text{enonce=\enonfor
\enonran1
\enonran2
<br>
<b><u>Exemple :</u></b>
<br>
\exempleran
\exemplefor
}

