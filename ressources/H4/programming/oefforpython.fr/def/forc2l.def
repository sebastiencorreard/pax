!ifval ($val2==)
val6=$[rint(1)]
!else
val6=$[rint($val2)]
!endif
tmp=!trim ambiance,neat;rubyblue,eclipse;the-matrix,3024-day
val7=!translate internal $	\
$ to ;; in $tmp
val8=[]
tmp0=!char 1 of $val8

val9=$(tmp0)
tmp0=!randint 5, 10

val10=$[rint($(tmp0))]
tmp0=!randint 5, 10

val11=$[rint($val10+$(tmp0))]
val12=$[rint($val11-$val10)]
val13=$[rint(1)]
val14=3,7
val15=$val10,$val11
val16=
val17=La fonction <code>range</code> permet la création d'une séquence de nombres entiers.
val18=Lorsque deux arguments sont utilisés dans la fonction range,	 la séquence créée part de la valeur du premier argument inclus et se termine ŕ la valeur	 du dernier argument <b>exclue</b> en ajoutant 1 ŕ chaque étape.
val19=
val20=<code>print(list(range($val14)))</code> renvoie la liste : [3,4,5,6]
val20=<code>print([i for i in range($val14)])</code> renvoie la liste : [3,4,5,6]
val16=La compréhension de liste utilise une ou des boucles <code>for</code>	 de maničre concise.	 Elle construit une liste en utilisant l'expression du motif en partant du	 premier élément jusqu'au dernier. On sort de la boucle lorsque le dernier	 élément de la séquence a été lu.
val21=
t_=!replace internal \( by ( in l=vector($val12);	for(x=1,$val12,l[x]=$val10+$val13*(x-1));
tmp0=!exec pari $t_

val22=$(tmp0)
t_=!replace internal \( by ( in print(l);
tmp0=!exec pari $t_

val23=$(tmp0)
val24=[$val23]
val25=[$val23]:
val26=print([i for i in range($val14)])
val27=[print,$val25]
val28=$val16	$val17	$val18	<br>	<b><u>Exemple :</u></b>	<br>	$val20	$val19	
val29=<li>Cliquer sur le bouton : "Jouer le code".</li>
val30=<li>Modifier le code afin d'obtenir l'affichage des éléments suivants :	<pre>$val24</pre>	</li>
val31=<li>Jouer le code et envoyer la réponse.</li>
replytype1=vector
replyoption1=vector_left_=\(\lbrack\) vector_right_=\(\rbrack\) 
replyname1=
