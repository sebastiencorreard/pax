!set title=Fonction range avec 1 argument en modifiant le script
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Julien, Lyotard
email=Julien.Lyotard@ac-dijon.fr
keywords=python,loops,for,range
language=fr

ansorder=r
varcnt=28
prevarcnt=27
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif


!ifval ($val2==)
val6=$[rint(1)]
!else
val6=$[rint($val2)]
!endif
tmp=!trim ambiance,neat;rubyblue,eclipse;the-matrix,3024-day
val7=!translate internal $	\
$ to ;; in $tmp
val8=[]
tmp0=!char 1 of $val8

val9=$(tmp0)
val10=$[rint(0)]
tmp0=!randint 5, 10

val11=$[rint($val10+$(tmp0))]
val12=$[rint($val11)]
val13=$[rint(1)]
val14=3
val15=$val11
val16=
val17=La fonction <code>range</code> permet la création d'une	  séquence de nombres entiers.
val18=Lorsqu'un seul argument est utilisé dans la fonction range,	 la séquence créée part de l'élément 0 et se termine ŕ la valeur de l'argument	 <b>exclue</b> en ajoutant 1 ŕ chaque étape.
val19=
val20=<code>print(list(range($val14)))</code> renvoie la liste : [0,1,2]
val21=
t_=!replace internal \( by ( in l=vector($val12);	for(x=1,$val12,l[x]=$val10+$val13*(x-1));
tmp0=!exec pari $t_

val22=$(tmp0)
t_=!replace internal \( by ( in print(l);
tmp0=!exec pari $t_

val23=$(tmp0)
val24=[$val23]
val25=[$val23]:
val26=print(list(range($val14)))
val27=[print,$val25]
val28=$val16	$val17	$val18	<br>	<b><u>Exemple :</u></b>	<br>	$val20	$val19	
val28=$val28	<div class="wims_instruction"> Pour éviter toutes erreurs de syntaxe, l'instruction proposée fonctionne et	 vous devez juste la modifier.</div>
val29=<li>Cliquer sur le bouton : "Jouer le code".</li>
val30=<li>Modifier le code afin d'obtenir l'affichage des éléments suivants :	<pre>$val24</pre>	</li>
val31=<li>Jouer le code et envoyer la réponse.</li>
replytype1=runcode

replyoption1=precision=100 
replyname1=
replygood1=$val27
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()<div class="encadre">	<p class="problematique">$m_prob</p>	<div id="boited">	<img src="$val1/python.png" alt="Logo de Python">	</div>	<div class="enonce">	$val28	<div class="question">		<ul>	$val29	$val30	$val31	</ul>	<div>	 
!read oef/embed.phtml reply 1,[python,[$val26]];[id1,init fullscreen theme=[$(val7[$val6;])] $val21,Jouer le code !] 
$()	</div>		</div></div></div>
$()
