!readproc slib/geo2D/jsxgraph jsxbox2,600 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=true;	JXG.Options.point.highlight=false;	JXG.Options.point.name = "";	JXG.Options.point.face = "+";	JXG.Options.point.size = 2;	JXG.Options.point.withLabel=true;	const bard = JXG.JSXGraph.initBoard('jsxbox2', {axis:true, boundingbox: [-1,0.6,10,-0.3],	shownavigation:false,showCopyright : false,	showZoom : true,keepaspectratio : false,	  zoom: {factorX: 1.25,factorY: 1.25,wheel: true,needShift: false,eps: 0.001},	  pan: {needShift: false,enabled: true,needTwoFingers: true,pinchHorizontal: true, pinchVertical: true,pinchSensitivity: 7}});	var p11=bard.create('point',[1,0],{name:'a', strokeColor:'black',fixed:true,label: {Color:'blue',offset:[-15,10]}});	var p22=bard.create('point',[8,0],{name:'b', strokeColor:'black',fixed:true,label: {Color:'blue'}});	bard.create('line',[p11,p22],{straightFirst:false, straightLast:false});	var nn2 = bard.create('slider',[[1,-0.2],[5,-0.2],[2,4,10]],{face:"[]",name:'nombre de sous-intervalles',snapWidth:1,fixed:false});	f=function (x){return 1/(1 +x);};	bard.create('functiongraph', [f, 1, 8], { strokeWidth: 2 });	var dynObj = [];	var pol = null;	var pold = null;	var lastNN = -1;	function clearAll() {	  if (pol) { bard.removeObject(pol); pol = null; }	  if (pold) { bard.removeObject(pold); pold = null; }	  for (var i = 0; i < dynObj.length; i++) {bard.removeObject(dynObj[i]);}	  dynObj = [];	}	function intt() {	  var nzz = Math.round(nn2.Value());	  if (nzz === lastNN) return;	  lastNN = nzz;	  var azz = p11.X();	  var bzz = p22.X();	  var hzz = (bzz - azz) / nzz;	  bard.suspendUpdate();	  clearAll();	  for (var i = 0; i <= nzz; i++) {	    var xi = azz + hzz * i;	    var ptAxe = bard.create('point', [xi, 0], {name: 'x_{' + i + '}', strokeColor: 'green', face: '+', size: 10,fixed: true, showInfobox: false, label: { offset: [0, -15] }});	    dynObj.push(ptAxe);	    var ptCourbe = bard.create('point', [xi, f(xi)], {strokeColor: 'red', fillColor: 'red', size: 3,face: 'o', fixed: true, name: '', showInfobox: true });	    dynObj.push(ptCourbe);	    dynObj.push(bard.create('segment', [ptAxe, ptCourbe], {strokeColor: '#666', strokeWidth: 1}));	    if (i < nzz) {	      dynObj.push(bard.create('text', [xi + hzz / 2, -0.08, 'h'], {anchorX: 'middle', fixed: true}));	      var xi1 = xi + hzz;	      var pg1 = bard.create('point', [xi, 0], { visible: false });	      var pg2 = bard.create('point', [xi, f(xi)], { visible: false });	      var pg3 = bard.create('point', [xi1, f(xi)], { visible: false });	      var pg4 = bard.create('point', [xi1, 0], { visible: false });	      dynObj.push(pg1, pg2, pg3, pg4);	      dynObj.push(bard.create('polygon', [pg1, pg2, pg3, pg4], {borders: { strokeColor: 'green', strokeWidth: 1 },fillColor: 'green', fillOpacity: 0.15, vertices: { visible: false }}));	      var pd1 = bard.create('point', [xi, 0], { visible: false });	      var pd2 = bard.create('point', [xi, f(xi1)], { visible: false });	      var pd3 = bard.create('point', [xi1, f(xi1)], { visible: false });	      var pd4 = bard.create('point', [xi1, 0], { visible: false });	      dynObj.push(pd1, pd2, pd3, pd4);	      dynObj.push(bard.create('polygon', [pd1, pd2, pd3, pd4], {borders: { strokeColor: 'red', strokeWidth: 1 },fillColor: 'red', fillOpacity: 0.15, vertices: { visible: false }}));	      }	    }	  dynObj.push(bard.create('line', [[azz, -0.02], [bzz, -0.02]], {straightFirst: false, straightLast: false, strokeColor: 'green', fixed: true}));	  bard.unsuspendUpdate();	}	intt();	nn2.on('drag', function() { intt(); });	 
