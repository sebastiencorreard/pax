val41=Mťthode de balayage classique pour rťsoudre une ťquation de la forme \(f(x)=$val35\)
t_=!replace internal \( by ( in default(format, "f.8");	vd=$val29;	xxli=[];	yyli=[];	mli=[];	vfilp=[];	vfalp=[];	vdd=[];	vff=[];	for(p=1,4,	xli=[];	yli=[];	if(p==1,vf=vd+1.0*10^(-p+1);,vf=vd+1.0*10^(-p+1)-10^(-p););	forstep(x=vd,vf,1.0*10^(-p),xli=concat(xli,x*1.00);	yli=concat(yli,f(x)*1.0);	if(f(x) $val17 $val35,vd=x;);	);	xxli=concat(xxli,[xli]);	yyli=concat(yyli,[yli]);	vfilp=concat(vfilp,f(vd));	vfalp=concat(vfalp,f(vd+10^(-p)));	vdd=concat(vdd,vd);	vff=concat(vff,vd+10^(-p));	);	
tmp0=!exec pari $t_

