val43=\#Initialisation des listes#	x_list=[]	y_list=[]	\#Dťfinition d'une fonction#	def f(x):	  return $val24	\#Initialisation des listes#	def balayage(f,k,a,b,n):	  fa,fb=f(a),f(b)	  for i in range(1,n+1):	    h=10**(-i)	    x=a	    \# Cas oý f est strictement croissante sur l'intervalle.	    if fa<fb:	      while f(x)<k:	        x_list.append(x)	        y_list.append(f(x))	        x=x+h	    else:	      \# Cas oý f est strictement dťcroissante sur l'intervalle.	      while f(x)>k:	        x_list.append(x)	        y_list.append(f(x))	        x=x+h	    a=x-h	  return (print(round(x-h,n),round(x,n),f(round(x,n))))	\#Appel de la fonction balayage oý les valeurs k, a, b et n sont ŗ indiquer.	balayage(f,$val44,??,??,??)	\#Affichage des listes#	print(x_list)	print(y_list)	
