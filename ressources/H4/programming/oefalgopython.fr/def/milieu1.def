create('text', [xi + h / 2, 0.5, 'h'], {anchorX: 'middle', fontSize: 12, fixed: true});	        dynamicObjects.push(txt);	      }	  }	var topSeg = board.create('segment', [[a, 0.25], [b, 0.25]], { strokeColor: 'green', strokeWidth: 2, fixed: true});	dynamicObjects.push(topSeg);	glider_xi = board.create('glider', [a, 0, xxaxis], { name: 'x_i',	  showInfobox: false,	  fillColor: 'white', strokeColor: 'red',	  face: 'o', size: 12,	  attractors: subdivPoints,	  attractorDistance: h / 2,	  snatchDistance: h / 2,	  label: { color: 'red', offset: [0, 25], fontSize: 12 }	});	var label_xi = board.create('text', [0, -1, function() {	      var k = Math.round((glider_xi.X() - p1.X()) / h);	      if (k === 0) return 'x_i = a';	      if (k === 1) return 'x_i = a+h';	      return 'x_i = a+' + k + 'h';	    }], { anchorX: 'middle', fontSize: 14, color: 'red', fixed: true });	dynamicObjects.push(label_xi);	board.unsuspendUpdate();	}	rebuild();	nn.on('drag', function() {rebuild();});	 
