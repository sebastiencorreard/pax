tmp0=!exec pari $t_

val55=$(tmp0)
t_=!replace internal \( by ( in print(llo);
tmp0=!exec pari $t_

val56=$(tmp0)
t_=!replace internal \( by ( in print(lcra);
tmp0=!exec pari $t_

val57=$(tmp0)
