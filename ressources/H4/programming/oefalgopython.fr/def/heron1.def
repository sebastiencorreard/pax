tmp0=!randint 3, 4

val49=$[rint($(tmp0))]
tmp0=!randint 1, 2

val50=$[rint($val49-$(tmp0))]
val51=<div class="bold">&#1645;Chercher ŕ approcher la valeur de	\(\sqrt{A}= \sqrt{$val48}\)</div>	On utilise la méthode de Héron, donc on cherche ŕ construire un rectangle	dont l'aire est de $val48 avec une largeur de $val49. Effectuer cette construction sur le schéma	 ci-dessous en déplaçant le point.
t_=!replace internal \( by ( in f(t,e)=(t+e/t)*0.5
tmp0=!exec pari $t_

val52=$(tmp0);
t_=!replace internal \( by ( in default(format, "f.6");	na=0;	u=$val49;	lo=$val48/$val49;	uu=f(u,$val48);	ul=[];	llo=[];	lla=[];	lcra=[];	while(abs(uu-u)>10^(-3),	na=na+1;	cra=uu^2;	lcra=concat(lcra,cra);	ul=concat(ul,uu);	if(u>lo,lla=concat(lla,lo);llo=concat(llo,u);,lla=concat(lla,u);llo=concat(llo,lo););	u=uu;	uu=f(u,$val48);	lo=$val48/u;);	
tmp0=!exec pari $t_

val53=$(tmp0)
t_=!replace internal \( by ( in print(ul);
tmp0=!exec pari $t_

val54=$(tmp0)
