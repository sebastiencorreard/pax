val41=Méthode de balayage avec seuil pour résoudre une équation de la forme \(f(x)=$val35\)
t_=!replace internal \( by ( in default(format, "f.8");	vd=$val29;	xxli=[];	yyli=[];	vfilp=[];	vfalp=[];	vdd=[];	vff=[];	x=vd;	for(p=1,4,	xli=[];	yli=[];	while(f(x) $val17 $val35 ,	xli=concat(xli,x*1.00);	yli=concat(yli,f(x)*1.0);	x=x+10^(-p););	xxli=concat(xxli,[xli]);	yyli=concat(yyli,[yli]);	vfilp=concat(vfilp,f(x-10^(-p))*1.0);	vfalp=concat(vfalp,f(x)*1.0);	vdd=concat(vdd,(x-10^(-p))*1.0);	vff=concat(vff,x*1.0);	x=x-10^(-p););	
tmp0=!exec pari $t_

