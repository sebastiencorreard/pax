t_=!replace internal \( by ( in default(format, "f.8");	vd=$val24;	va=$val25;	pn=$val7;	ph=(va-vd)/pn;	xxli=[];	yyli=[];	mmli=[];	ppli=[];	forstep(x=vd,va,ph,xxli=concat(xxli,x*1.00);	yyli=concat(yyli,f(x)*1.0);	ctt=(f(x+ph)-f(x))/ph*1.00;	mmli=concat(mmli,ctt);	ppli=concat(ppli,f(x)*1.0-ctt*x);	);	
