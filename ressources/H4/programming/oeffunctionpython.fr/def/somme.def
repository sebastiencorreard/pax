val23=des \(N+1\) premiers nombres entiers de 0 à \(N\)
val24=0+1+2+3+4=\displaystyle \sum_{i=0}^{N=4} i=10
tmp0=!randint 100, 1000

val25=$[rint($(tmp0))]
val26=$[rint($val25*($val25+1)/2)]
val27=somme
val28=Modifier la fonction afin qu'elle calcule la somme $val23
val29=Le programme Python ci-dessous permet d'afficher une liste contenant les nombres de 0 à \(N\).	 Il utilise une fonction intitulée "somme" avec un argument \(N\).
val30=print($val27(4))
val31=Modifier la fonction Python intitulée "$val27" de paramètre \(N\) afin	 qu'elle réalise la somme $val23.	 <br>	 <strong> Exemples :</strong> &emsp; \($val24\)	
val32=def $val27(N):	  S=[]	  for i in range(N+1):	    S.append(i)	  return S	\#Test#	$val30	
val33='@@@@'+'$val12'+'=$val27($val25)'
val34=[$val12,[$val26]]
val35=Tester votre fonction à l'aide de ce type	  d'instruction <code>$val30</code> pour vérifier qu'elle	 fonctionne dans chacun des cas.
