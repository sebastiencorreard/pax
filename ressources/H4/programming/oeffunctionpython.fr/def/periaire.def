val25=circonference,aire,volume
val26=d'une sphčre de rayon \(R\)
val27=la circonférence $val26,l'aire $val26,le volume $val26
val28=km,km^2,km^3
val29=Écrire une fonction afin de s'approprier son fonctionnement.
val30=La circonférence d'une sphčre est donnée par la relation : \(P=2  \pi  R \).	<br>	L'aire d'une sphčre est donnée par la relation : \(A= 4\pi R^2 \).	<br>	Le volume d'une sphčre est donnée par la relation : \(V= \frac{4}{3}\pi  R^3 \)
val31=print($(val25[$val24])(5))

!ifval ($val24==1)
val32=$[2*pi*$val23]
!endif

!ifval ($val24==2)
val32=$[4*pi*R^2]
!endif

!ifval ($val24==3)
val32=$[4/3*pi*$val23^3]
!endif
tmp0=!randint 1, 8

val33=$(tmp0)
tmp=!trim de Mercure,2400,Mercure.jpg	de Vénus,6100,Venus.jpg	de la Terre,6400,Terre.jpg	de Mars,3400,Mars.jpg	de Jupiter,71500,Jupiter.jpg	de Saturne,60300,Saturne.jpg	d'Uranus,25600,Uranus.png	de Neptune,26800,Neptune.jpg
val34=!translate internal $	\
$ to ;; in $tmp

!ifval ($val24==1)
val35=$[rint(2*pi*$(val34[$val33;2]))]
!endif

!ifval ($val24==2)
val35=$[rint(4*pi*($(val34[$val33;2]))^2)]
!endif

!ifval ($val24==3)
