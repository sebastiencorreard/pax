val35=[vi,1],[vf,$val14],[nt,$val17]
val36=<li>Déterminer les conditions ŕ remplir pour compter le nombre	d'apparitions de chacune des faces.</li>
val37=<script>	var tp=[];	var ch;	function graph(){if (ch) { brd.removeObject(ch); ch = null; };	if (liii) { brd.removeObject(liii); liii = null; };	if (tp.length) {for (var i = 0; i < tp.length; i++) {brd.removeObject(tp[i]);}tp = [];};	f1=Sk.ffi.remapToJs(Sk.globals["f1"]);	f2=Sk.ffi.remapToJs(Sk.globals["f2"]);	f3=Sk.ffi.remapToJs(Sk.globals["f3"]);	f4=Sk.ffi.remapToJs(Sk.globals["f4"]);	f5=Sk.ffi.remapToJs(Sk.globals["f5"]);	f6=Sk.ffi.remapToJs(Sk.globals["f6"]);	nn=[f1,f2,f3,f4,f5,f6];	const xlen=nn.length;	var liii=brd.create('line',[[0,1/6],[1,1/6]],{Color:'red'});	brd.suspendUpdate();	ch = brd.create('chart', [nn], {	         chartStyle:'bar',	         width:0.5,	         /*labels:nn,*/	         colors: color_liste,	         shadow:true	});	for(var jj = 0; jj < xlen; jj=jj+1) {	var tt=nn[jj].toFixed(3);	tp[jj]=brd.create('point', [jj+1,nn[jj]],{name:tt,label:{offset:[-10, 10]},color:color_liste[jj]});}	brd.unsuspendUpdate();	}	execidtest2.addEventListener('click',graph);	</script>
