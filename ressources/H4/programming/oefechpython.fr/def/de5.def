val31=<li>Déterminer les formules permettant de calculer la fréquence	 pour l'ensemble des faces. La formule qui calcule la fréquence pour la face 1	 est donnée dans le code.</li>
val32=La simulation donne les résultats en fréquence d'apparition d'une face.	 Serait-il plus pertinent de déterminer le nombre d'apparitions d'une face ?
val33=jsxbox,600 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.highlight=false;	JXG.Options.point.showInfobox=false;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.withLabel=true;	color_liste=['red','yellow','blue','green','orange','purple'];	JXG.Options.point.size =2;	var brd = JXG.JSXGraph.initBoard('jsxbox', {axis:false, boundingbox: [-1,0.5,7,-0.1],	shownavigation:false,showCopyright : false,	showZoom : true,keepaspectratio : false,showFullscreen: true});	xaxis = brd.create('axis', [[0,0], [1,0]],	      {name:'Issues possibles',	      withLabel: true,	      label: {position: 'rt',/* possible values are 'lft', 'rt', 'top', 'bot'*/	      offset: [-60, 30] /*(in pixels)*/},Color:'red'});	      yaxis = brd.create('axis', [[0, 0], [0,1]],	      {name:'Fréquence d\'apparition d\'une face',withLabel: true,	      label: {position: 'rt', /*possible values are 'lft', 'rt', 'top', 'bot'*/	      offset: [10, 0] /*(in pixels)*/},Color:'red'});
