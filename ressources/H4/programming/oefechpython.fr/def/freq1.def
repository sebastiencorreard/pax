tmp0=!char 2 of $val9

val11=$(tmp0)
val12=Pour étudier une pičce de monnaie, on lance cette pičce de monnaie un	  grand nombre de fois et on dénombre le nombre de "pile" et de "face". Ce travail étant fastidieux	  et répétitif, on utilise la programmation pour arriver aux résultats. La simulation est réalisée	 en Python et la méthode <code>$val8.$val8()</code> permet de générer un nombre ŕ virgule aléatoire	 compris entre 0 inclus et 1 non inclus.
val13=Jouer le code et envoyer la réponse.
tmp0=!randint 0, 10

val14=$[rint($(tmp0))]
val15=$[rint(1000+100*$val14)]
val16=\#Importation des librairies\#	from random import $val8	\#Entrer les variables\#
val17=Étude d'une pičce de monnaie
tmp0=!randint 20, 100

val15=$[rint($(tmp0))]
val16=$val16	nt=??	\#initialisation des listes\#	y_list = []	\#################	for i in range(nt):	  issue = $val8()	  y_list.append(issue)	\#Affichage des 5 premiers termes des listes#	print(y_list[\:5])
val18=var liii=brd.create('line',[[0,0.5],[1,0.5]],{Color:'red'});
val19=reply1,[python,[$val16]];[idtest2,theme=$val6 canvas init \instruction_code,Jouer le code !]
val20=[nt,$val15]
val21=jsxbox,600 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.highlight=false;	JXG.Options.point.showInfobox=false;	JXG.Options.point.name = "";	JXG.Options.point.face = "+";	JXG.Options.point.withLabel=true;	color_liste=['red','yellow','blue','green','orange','purple'];	JXG.Options.point.size =1;	var brd = JXG.JSXGraph.initBoard('jsxbox', {axis:false, boundingbox: [-$val15*0.2,1,$val15*1.2,-1],	shownavigation:false,showCopyright : false,	showZoom : true,keepaspectratio : false,showFullscreen: true});	xaxis = brd.create('axis', [[0,0], [1,0]],	      {name:'Nombre de tirages',	      withLabel: true,	      label: {position: 'rt',/* possible values are 'lft', 'rt', 'top', 'bot'*/	      offset: [-60, 30] /*(in pixels)*/},Color:'red'});	yaxis = brd.create('axis', [[0, 0], [0,1]],	      {name:'Probabilités',withLabel: true,	      label: {position: 'rt',/* possible values are 'lft', 'rt', 'top', 'bot'*/	      offset: [10, 0] /*(in pixels)*/},Color:'red'});
!readproc slib/geo2D/jsxgraph $val21 
tmp0=$slib_out
