val35=<li>Déterminer les conditions ŕ remplir pour compter le nombre	d'apparitions de chacune des faces.</li>
val36=<script>	var tp=[];	var ch;	function graph(){brd.removeObject(ch);	brd.removeObject(tp);	n1=Sk.ffi.remapToJs(Sk.globals["n1"]);	n2=Sk.ffi.remapToJs(Sk.globals["n2"]);	n3=Sk.ffi.remapToJs(Sk.globals["n3"]);	n4=Sk.ffi.remapToJs(Sk.globals["n4"]);	n5=Sk.ffi.remapToJs(Sk.globals["n5"]);	n6=Sk.ffi.remapToJs(Sk.globals["n6"]);	nn=[n1,n2,n3,n4,n5,n6];	const xlen=nn.length;	var liii=brd.create('line',[[0,$val17/6],[1,$val17/6]],{Color:'red'});	brd.suspendUpdate();	ch = brd.create('chart', [nn], {	         chartStyle:'bar',	         width:0.5,	         labels:nn,	         colors: color_liste,	         shadow:true	});	for(var jj = 0; jj < xlen; jj=jj+1) {	tp[jj]=brd.create('point', [jj+1,nn[jj]],{name:nn[jj],label:{offset:[-10, 10]},color:color_liste[jj]});}	brd.unsuspendUpdate();	}	execidtest2.addEventListener('click',graph);	</script>
