val6=$val3
!endif
val7=Étude d'un dé avec Python
val8=int
val9=random
val10=Jouer le code et envoyer la réponse.
tmp0=!randint 1, 10

val11=$[rint($(tmp0))]
tmp0=!randint 1, 3

val12=$[rint($(tmp0))]
val13=3,4,6,8,10,12,16,20,24,30
val14=$[rint($(val13[$val11]))]
val15=$[rint($(val13[$val12]))]
tmp0=!randint 1, $val14

val16=$[rint($(tmp0))]
tmp0=!randint 5, 30

val17=$[rint($(tmp0))]
tmp0=!makelist x for x=1 to $val14

val18=$(tmp0)
tmp0=!makelist x for x=1 to $val15

val19=$(tmp0)
val20=\#Importation des méthodes\#	from random import rand$val8
val20=$val20	\#Entrer les variables\#	vi=??	vf=??	nt=??	\#################	for i in range(nt):	  issue = rand$val8(vi,vf)	  print(issue)	
val21=[vi,1],[vf,$val14],[nt,$val17]
val22=<ul><li>Initialiser les variables \(\text{vi}\)	  et \(\text{vf}\) afin que le programme simule un dé équilibré dont les issues sont \( \{ $val18 \}\).</li>
val23=<li>Compléter la boucle for pour simuler $val17 tirages en initialisant	 la valeur \(\text{nt}\).</li>
val24=Pour étudier un dé, on lance ce dé un grand nombre de fois	et on étudie les données. Ce travail étant fastidieux et répétitif, on utilise	 la programmation pour arriver aux résultats. La simulation est réalisée	 en Python et la méthode <code>$val9.rand$val8(3,9)</code> permet de tirer	 un entier compris entre 3 et 9 inclus.
replytype1=runcode

replyoption1=precision=100 
replyname1=
replygood1=$val21
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

