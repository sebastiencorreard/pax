$()<div class="encadre">	<p class="problematique">$val7</p>	<div id="boiteg">	<img src="$val1/des.jpg" alt="Dés">	</div>	<div id="boited">	<img src="$val1/python.png" alt="Logo de Python">	</div>	<div class="enonce">	$val24	<div class="question">	$val22	$val23	$m_instruction3	$m_instruction4	<li>$val10</li>	</ul>	<div>	 
