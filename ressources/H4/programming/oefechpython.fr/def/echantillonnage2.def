$()	<script>	function graph(){	x_liste=Sk.ffi.remapToJs(Sk.globals["x_list"]);	y_liste=Sk.ffi.remapToJs(Sk.globals["y_list"]);	pr=Sk.ffi.remapToJs(Sk.globals["pr"]);	color_liste=Sk.ffi.remapToJs(Sk.globals["color_list"]);	N=Sk.ffi.remapToJs(Sk.globals["ne"]);	p=Sk.ffi.remapToJs(Sk.globals["p"]);	te=Sk.ffi.remapToJs(Sk.globals["te"]);	pp=p.toFixed(2);	NN=N/5;	$m_javalc	const xlen=x_liste.length;	function findMinMax(arr,ar) {let xmin = arr[0], xmax = arr[0],ymin = ar[0], ymax = ar[0];	  for (let i = 1, len=arr.length; i < len; i++){	    let v = arr[i];	    let vv = ar[i];	    xmin = (v < xmin && Math.abs(v)>0.0001) ? v : xmin;	    xmax = (v > xmax && Math.abs(v)>0.0001) ? v : xmax;	    ymin = (vv < ymin && Math.abs(v)>0.0001) ? vv : ymin;	    ymax = (vv > ymax && Math.abs(v)>0.0001) ? vv : ymax;}	  return [Math.round(xmin)-NN,Math.round(xmax)+NN,ymin-$val43,ymax+$val43];}	xyminmax=findMinMax(x_liste,y_liste);	JXG.Options.point.size =2;	var brd = JXG.JSXGraph.initBoard('jsxbox', {axis:false, boundingbox: [xyminmax[0],xyminmax[3],xyminmax[1],xyminmax[2]],	shownavigation:false,showCopyright : false,	showZoom : true,keepaspectratio : false,showFullscreen: true});	xaxis = brd.create('axis', [[0,pp ], [1,pp]],	      {name:'Nombre d\'ťchantillon',	      withLabel: true,	      label: {position: 'rt',/* possible values are 'lft', 'rt', 'top', 'bot'*/	      offset: [-60, 30] /*(in pixels)*/},Color:'red'});	yaxis = brd.create('axis', [[0, 0], [0,1]],	      {name:'Probabilitť d\'un ťchantillon',withLabel: true,	      label: {position: 'rt',/* possible values are 'lft', 'rt', 'top', 'bot'*/	      offset: [10, 0] /*(in pixels)*/}}	      );	var liii=brd.create('line',[[0,p],[1,p]],{Color:'red'});	brd.suspendUpdate();	for(var jj = 0; jj < xlen; jj=jj+1) {	brd.create('point', [x_liste[jj],y_liste[jj]],{color:color_liste[jj]});}	brd.unsuspendUpdate();}	execidtest2.addEventListener('click',graph);	</script>	 
