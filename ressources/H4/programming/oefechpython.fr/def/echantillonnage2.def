val44=\ \'un
val45=\#Importation des librairies\#	from math import *	from random import random	\#Entrer les variables\#	p= float(input('Entrer la proportion thťorique : '))	print(str(p))	te= $val8(input('Entrer la taille d un ťchantillon : '))	print(str(te))	ne= $val8(input('Entrer le nombre d ťchantillons : '))	print(str(ne))	\#initialisation de la probabilitť des ťchantillons	pr=0	\#initialisation des listes	x_list = []	y_list = []	color_list =[]	def echantillon(t,ft):	  f=0	  for i in range(t):	    a=$val8($val9()+ft)	    f=f+a/t	  return f	for i in range(ne):	  x_list.append(i)	  y=echantillon(te,p)	  y_list.append(y)	  if (y<=p+1/sqrt(te)) and (y>=p-1/sqrt(te)):	    pr=pr+1/ne	    color_list.append('black')	  else :	    color_list.append('red')	print('Probabilitť sur l ensemble des ťchantillons : '+str(pr))
