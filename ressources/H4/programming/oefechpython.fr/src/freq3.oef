nt=??
pt=??
NPN_ysup1=NPN_yinf1=NPB_y1=NPB_y0=0
\#initialisation des listes\#
y_list=[]
y_list_arrondi=[]
\#################
for i in range(nt):
  issue=\ppp()+pt
  issue_arrondi=\pp(issue)
  y_list.append(issue)
  y_list_arrondi.append(issue_arrondi)
  if issue >=1 :
    NPN_ysup1=NPN_ysup1+1
  else :
    NPN_yinf1=NPN_yinf1+1
  if issue_arrondi==1 :
    NPB_y1=NPB_y1+1
  else :
