\observation{Dans cet exercice, l'élève doit remarquer que a ou b est divisible par un certain nombre
 (par exemple 5) qui apparaît dans les instructions python disponibles. 
<br>Ensuite, il doit coder un programme du type "tant que a est positif, on lui soustrait 5 et on soustrait également 5 à b".}

\integer{result=(\alea==1)?\a-\b:\b-\a}

\text{tc=(\alea==1)?a-b:b-a}
\text{num=(\alea==1)?a=\a,b=\b:b=\b,a=\a}

\text{pr=soustractions,différence entre \(\num[1]\) et \(\num[2]\),\tc}

\text{instruction_code=instruction=[a=\a,b=\b,while a>0:,while b>0:,a=a+\d,a=a-\d,b=b-\d,b=b+\d,print(a),print(b),print(-a),print(-b),&#32;&#32;]}
