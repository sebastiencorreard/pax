!set title=Extraire une racine carrée entičre
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
oefobservation=Dans cet exercice, il est demandé d'extraire la racine carrée d'un nombre. <br>L'élčve doit coder un programme du type "tant que a est supérieur ŕ 0, on lui retire un nombre impair".

ansorder=r
varcnt=23
prevarcnt=22
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=\#Initialisation des variables#				\#Boucle#					\#Fin Boucle#	\#Affichage du résultat#			\#Fin Affichage#

!ifval ($val2==)
val7=$[rint(1)]
!else
val7=$[rint($val2)]
!endif
tmp=!trim ambiance,neat;rubyblue,eclipse;the-matrix,3024-day
val8=!translate internal $	\
$ to ;; in $tmp
val9=Ŕ l'aide des différentes instructions, réaliser le programme suivant écrit en langage Python.
val10=Placer le curseur de la souris dans la zone du programme et cliquer sur les	 différentes instructions sous forme de boutons. Le dernier bouton permet l'indentation du	 texte si nécessaire.	 <br>N'oublier pas de cliquer sur "jouer le code" avant de valider.	 On ne peut pas effacer ligne par ligne, mais on peut tout ré-initialiser...
tmp0=!randint 1, 2

val11=$[rint($(tmp0))]
val12=le résultat
val13=2,3,5
tmp=!nonempty items $val13

tmp0=!randitem $tmp
val14=$[rint($(tmp0))]

!ifval ($val11==1)
tmp0=!randint 100, 200

val15=$[rint($val14*$(tmp0))]
!else
tmp1=!randint 100, 200

val15=$[rint($val14*$(tmp1)+1)]
!endif

!ifval ($val11==1)
tmp0=!randint 100, 200

val16=$[rint($val14*$(tmp0)+1)]
!else
tmp1=!randint 100, 200

val16=$[rint($val14*$(tmp1))]
!endif
val17=Maîtriser la construction des \pr[1]
val18=Écrire un script qui permet d'afficher $val12 de la \pr[2].	 On attend la valeur entičre du résultat de l'opération : \(\pr[3]\).
val17=Utiliser une propriété mathématique pour écrire un script
val18=On cherche ŕ extraire la racine carrée entičre d'un nombre entier lorsqu'elle	 existe. Pour écrire le script, on utilise la propriété mathématique sur	 la somme des nombres impairs de 1 ŕ \(N\) dont le résultat est toujours un carré.	<br> <strong>Exemples :</strong>	<ul><li>\(1+3=4=2^2\)</li>	<li>\(1+3+5=9=3^2\)</li>	<li>\(1+3+5+7=16=4^2\)</li>	<li>\(1+3+5+7+9=25=5^2\)</li>	<li>...</li>	<li>\(1+3+5+...+(2n-1)={\displaystyle \sum_{i=0}^{n-1} (2i+1)}=n^2\)</li>	</ul>	Cette propriété s'illustre grâce ŕ la figure proposée :	<div class="wimscenter">	<img src="$val1/rc.jpg" alt="Figure illustrant la propriété">	<figcaption>	<cite><a href="http://villemin.gerard.free.fr/aNombre/FIGURE/Carre.htm#impair" target="_blank">Gérard Villemin</a></cite>	</figcaption>	</div>	On va donc soustraire les différents nombres impairs au nombre de départ. Le nombre de	 soustractions correspond ŕ la valeur de la racine carrée.	<br> <strong>Exemples et contre-exemples :</strong>	<ul><li>\(4\underset{\text{2 soustractions }}\underbrace{-1-3}=0 \Longrightarrow \text{2 soustractions} \Longrightarrow \sqrt{4}={2}\)</li>	<li>\(9\underset{\text{3 soustractions }}\underbrace{-1-3-5}=0 \Longrightarrow \text{3 soustractions} \Longrightarrow \sqrt{9}={3}\)</li>	<li>\(16\underset{\text{4 soustractions }}\underbrace{-1-3-5-7}=0 \Longrightarrow \text{4 soustractions} \Longrightarrow \sqrt{16}={4}\)</li>	<li>\(25\underset{\text{5 soustractions }}\underbrace{-1-3-5-7-9}=0 \Longrightarrow \text{5 soustractions} \Longrightarrow \sqrt{25}={5}\)</li>	<li>...</li>	<li>\(n^2\underset{\text{n soustractions }}\underbrace{-1-3-5-...-(2n-1)}=0 \Longrightarrow \text{n soustractions} \Longrightarrow \sqrt{n^2}={n}\)</li>	<li>\(17\underset{\text{5 soustractions }}\underbrace{-1-3-5-7-9}=-8 \Longrightarrow \sqrt{17}\) n'admet pas de racine carrée entičre</li>	<li>\(31\underset{\text{6 soustractions }}\underbrace{-1-3-5-7-9-11}=-5 \Longrightarrow \sqrt{31}\) n'admet pas de racine carrée entičre</li>	</ul>	 Le programme devra afficher la racine carrée du nombre \(a\).
tmp0=!makelist x for x = 0 to \nbrech-1

val19=$(tmp0)
tmp0=!makelist x^2 for x=19 to 100

val20=$(tmp0)
tmp=!nonempty items $val20

tmp0=!randitem $tmp
val15=$[rint($(tmp0)*1)]
val21=$[rint(sqrt($val15))]
val22=$val21
val9=Ŕ l'aide des différentes instructions, réaliser le programme suivant écrit en langage	 Python.
val23=instruction=[a=$val15,n=0,n_imp=0,n=1,n_imp=1,while a>0:,while n>0:,while n_imp>0:,a=a+1,n=n+1,a=a-1,n_imp=2*n-1,n_imp=2*n,n_imp=2*n+1,n_imp=n_imp+2,n_imp=n_imp-2,a=a-n_imp,a=a+n_imp,a=a-2*n+1,a=a-2*n,a=a-2*n-1,print(n),print(n_imp),print(a),&#32;&#32;]
replytype1=runcode

replyoption1=precision=1000 $val23 
replyname1=
replygood1=[print,[$val22:]]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

