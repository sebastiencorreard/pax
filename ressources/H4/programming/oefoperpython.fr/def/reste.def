!set title=Reste de la Division euclidienne de 2 nombres
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
oefobservation=Dans cet exercice, l'élève doit coder un programme du type "tant que a est supérieur à b, on lui retire b et on ajoute 1 à une variable m si on besoin du quotient".

ansorder=r
varcnt=27
prevarcnt=26
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=\#Initialisation des variables#				\#Boucle#					\#Fin Boucle#	\#Affichage du résultat#			\#Fin Affichage#

!ifval ($val2==)
val7=$[rint(1)]
!else
val7=$[rint($val2)]
!endif
tmp=!trim ambiance,neat;rubyblue,eclipse;the-matrix,3024-day
val8=!translate internal $	\
$ to ;; in $tmp
val9=À l'aide des différentes instructions, réaliser le programme suivant écrit en langage Python.
val10=Placer le curseur de la souris dans la zone du programme et cliquer sur les	 différentes instructions sous forme de boutons. Le dernier bouton permet l'indentation du	 texte si nécessaire.	 <br>N'oublier pas de cliquer sur "jouer le code" avant de valider.	 On ne peut pas effacer ligne par ligne, mais on peut tout ré-initialiser...
tmp0=!randint 1, 2

val11=$[rint($(tmp0))]
val12=$[rint(2)]

!ifval ($val11==1)
tmp0=!randint 100, 200

val13=$[rint($(tmp0))]
!else
tmp1=!randint 400, 1000

val13=$[rint($(tmp1))]
!endif
tmp0=!randint 11, 50

val14=$[rint($(tmp0))]
tmp0=!randint 51, 90

val15=$[rint($(tmp0))]
tmp0=!randint 91, 200

val16=$[rint($(tmp0))]

!ifval ($val11==1)
val17=$[rint($val16*$val14+$val15)]
!else
val17=$[rint($val16)]
!endif

!ifval ($val11==1)
val13=$[rint($val16)]
!else
val13=$[rint($val16*$val14+$val15)]
!endif

!ifval ($val12==1)
val18=le quotient
!else
val18=le reste
!endif
!if $val12==1 
t_=!replace internal \( by ( in floor($val17 \ $val13)
tmp0=!exec pari $t_

val19=$[rint($(tmp0))]
t_=!replace internal \( by ( in floor($val13 \ $val17)
tmp0=!exec pari $t_

val20=$[rint($(tmp0))]

!ifval ($val11==1)
val21=\frac{a}{b}
!else
val21=\frac{b}{a}
!endif
!else
val19=$[rint($val17%$val13)]
val20=$[rint($val13%$val17)]

!ifval ($val11==1)
val21=a\%b
!else
val21=b\%a
!endif
!endif

!ifval ($val11==1)
val22=$[rint($val19)]
!else
val22=$[rint($val20)]
!endif

!ifval ($val11==1)
val16=a=$val17,b=$val13
!else
val16=b=$val13,a=$val17
!endif
val23=divisions,division euclidienne de \($(val16[1])\) par \($(val16[2])\),$val21
val24=instruction=[a=$val17,b=$val13,m=0,while a>b:,while b>a:,a=a-b,b=b-a,m=m+1,m=m-1,print(a),print(b),print(m),&#32;&#32;]
val25=Maîtriser la construction des $(val23[1])
val26=Écrire un script qui permet d'afficher $val18 de la $(val23[2]).	 On attend la valeur entière du résultat de l'opération : \($(val23[3])\).
replytype1=runcode

replyoption1=precision=1000 $val24 
replyname1=
replygood1=[print,[$val22:]]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="encadre">	<p class="problematique">$val25</p>	<div id="boited">	<img src="$val1/python.png" alt="Logo de Python">	</div>	<div class="enonce">	$val9	<div class="question">	$val26	</div>	<div class="wims_instruction">$val10</div>	</div>	<div>	 
!read oef/embed.phtml reply1,[python,[$val6]];[id1,canvas init readonly fullscreen theme=[$(val8[$val7;])] $val24,Jouer le code !] 
$()	</div>	</div>	
$()
!exit

