!else
val21=liste[1]=tmp
!endif
t_=!replace internal \( by ( in liste=[$val18];	nn=matsize(liste);	$val19;	$val20;	$val21;
tmp0=!exec pari $t_

val22=$(tmp0)
t_=!replace internal \( by ( in print(liste);
tmp0=!exec pari $t_

val23=[$(tmp0)]
val8=\#Initialisation des variables#	liste=[$val18]	\###	\#Permutation des variables#	\###	\###	\###	\###	\#Fin de la permutation des variables#	\#Affichage du rťsultat#	$val6	\#Fin Affichage#
val24=Permutation circulaire d'une liste

!ifval ($val12==1)
val25=\longleftarrow
!else
val25=\longrightarrow
!endif
val26=\(\left \|	\begin{array}{c c c}	 tmp & $val25 & list[0] \\ list[0] & $val25 & list[1] \\ list[1] & $val25 & list[2] \\ \vdots & $val25 & \vdots \\ list[i-1] & $val25 & list[i] \\ \vdots & $val25 & \vdots \\ list[n] & $val25 & tmp	\end{array}	\right.	\)

!ifval ($val12==1)
val27=a->i->b->e->h->f->g->c->d->a
!else
val27=a->d->c->g->f->h->e->b->i->a
!endif
val28=layout="circo";	bgcolor= grey90	  a [color=black,shape=box,style=rounded,label="list[0]"];	  b [color=black,shape=box,style=rounded,label="list[n]"];	  c [color=black,shape=box,style=rounded,label="list[2]"];	  d [color=black,shape=box,style=rounded,label="list[1]"];	  e [color=black,shape=box,style=rounded,label="..."];	  f [color=black,shape=box,style=rounded,label="list[i-1]"];	  g [color=black,shape=box,style=rounded,label="..."];	  h [color=black,shape=box,style=rounded,label="list[i]"];	  i [color=black,shape=box,style=rounded,label="tmp"];	  $val27 [color=black, arrowsize=2];
