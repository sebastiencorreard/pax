val6=print(a)	print(b)
val7=
val6=print(liste)
val7=Le dernier bouton permet l'indentation du texte si nťcessaire.
val8=\#Initialisation des variables#	\###	\###	\###	\###	\#Permutation des variables#	\###	\###	\###	\###	\###	\#Fin de la permutation des variables#	\#Affichage du rťsultat#	$val6	\#Fin Affichage#
tmp=!trim ambiance,neat;3024-night,3024-day
val9=!translate internal $	\
$ to ;; in $tmp
val10=ņ l'aide des diffťrentes instructions, construire le programme suivant ťcrit en langage Python.
val11=Sťlectionner les 3 symboles diŤses (#) et cliquer sur les	 diffťrentes instructions sous forme de boutons. $val7	<br>N'oublier pas de cliquer sur "jouer le code" avant de valider.
tmp0=!randint 1, 2

val12=$[rint($(tmp0))]
val13=2,3,5
tmp=!nonempty items $val13

tmp0=!randitem $tmp
val14=$[rint($(tmp0))]

!ifval ($val12==1)
tmp0=!randint 100, 200

val15=$[rint($val14*$(tmp0))]
!else
tmp1=!randint 100, 200

val15=$[rint($val14*$(tmp1)+1)]
!endif

!ifval ($val12==1)
tmp0=!randint 100, 200

val16=$[rint($val14*$(tmp0)+1)]
!else
tmp1=!randint 100, 200

val16=$[rint($val14*$(tmp1))]
!endif
tmp0=!randint 20, 30

val17=$[rint($(tmp0))]
tmp0=!shuffle $val17

val18=$(tmp0)

!ifval ($val12==1)
val19=tmp=liste[1]
!else
val19=tmp=liste[nn[2]]
!endif

!ifval ($val12==1)
val20=for(x=1,nn[2]-1,liste[x]=liste[x+1])
!else
