!set title=Soustraction de 2 nombres
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
oefobservation=Dans cet exercice, l'élčve doit remarquer que a ou b est divisible par un certain nombre (par exemple 5) qui apparaît dans les instructions python disponibles. <br>Ensuite, il doit coder un programme du type "tant que a est positif, on lui soustrait 5 et on soustrait également 5 ŕ b".

ansorder=r
varcnt=19
prevarcnt=18
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

val6=\#Initialisation des variables#				\#Boucle#					\#Fin Boucle#	\#Affichage du résultat#			\#Fin Affichage#

!ifval ($val2==)
val7=$[rint(1)]
!else
val7=$[rint($val2)]
!endif
tmp=!trim ambiance,neat;rubyblue,eclipse;the-matrix,3024-day
val8=!translate internal $	\
$ to ;; in $tmp
val9=Ŕ l'aide des différentes instructions, réaliser le programme suivant écrit en langage Python.
val10=Placer le curseur de la souris dans la zone du programme et cliquer sur les	 différentes instructions sous forme de boutons. Le dernier bouton permet l'indentation du	 texte si nécessaire.	 <br>N'oublier pas de cliquer sur "jouer le code" avant de valider.	 On ne peut pas effacer ligne par ligne, mais on peut tout ré-initialiser...
tmp0=!randint 1, 2

val11=$[rint($(tmp0))]
val12=le résultat
val13=2,3,5
tmp=!nonempty items $val13

tmp0=!randitem $tmp
val14=$[rint($(tmp0))]

!ifval ($val11==1)
tmp0=!randint 100, 200

val15=$[rint($val14*$(tmp0))]
!else
tmp1=!randint 100, 200

val15=$[rint($val14*$(tmp1)+1)]
!endif

!ifval ($val11==1)
tmp0=!randint 100, 200

val16=$[rint($val14*$(tmp0)+1)]
!else
tmp1=!randint 100, 200

val16=$[rint($val14*$(tmp1))]
!endif

!ifval ($val11==1)
val17=$[rint($val15-$val16)]
!else
val17=$[rint($val16-$val15)]
!endif

!ifval ($val11==1)
val18=a-b
!else
val18=b-a
!endif

!ifval ($val11==1)
val19=a=$val15,b=$val16
!else
val19=b=$val16,a=$val15
!endif
val20=soustractions,différence entre \($(val19[1])\) et \($(val19[2])\),$val18
val21=instruction=[a=$val15,b=$val16,while a>0:,while b>0:,a=a+$val14,a=a-$val14,b=b-$val14,b=b+$val14,print(a),print(b),print(-a),print(-b),&#32;&#32;]
val22=Maîtriser la construction des $(val20[1])
val23=Écrire un script qui permet d'afficher $val12 de la $(val20[2]).	 On attend la valeur entičre du résultat de l'opération : \($(val20[3])\).
replytype1=runcode

replyoption1=precision=1000 $val21 
replyname1=
replygood1=[print,[$val17:]]
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="encadre">	<p class="problematique">$val22</p>	<div id="boited">	<img src="$val1/python.png" alt="Logo de Python">	</div>	<div class="enonce">	$val9	<div class="question">	$val23	</div>	<div class="wims_instruction">$val10</div>	</div>	<div>	 
!read oef/embed.phtml reply1,[python,[$val6]];[id1,canvas init readonly fullscreen theme=[$(val8[$val7;])] $val21,Jouer le code !] 
$()	</div>	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=1,6,7,8,9,10,21,22,23
embedcnt=1
