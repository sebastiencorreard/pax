\matrix{encopy=\DDD}
\text{encop=}
\for{kkk=1 to \nc}{
\text{encop=wims(append item [\encopy[;\kkk]] to \encop)}}
\text{encop=[\encop]}
\text{mjsx=}
\for{kk=1 to \nc}{
\for{kj=1 to \nc}{
\integer{s=\kk+\nc*(\kj-1)}
\if{\enco[\aleafig;\s]==0}{
\text{mjsx=wims(append line board.create('point', [\kk-0.5,\kj-0.5],{color:'black'}); to \mjsx)}
}}}
