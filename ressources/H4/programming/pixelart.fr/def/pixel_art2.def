val7=ambiance
!else
val7=$val2
!endif
val8=Pixel Art et Python
val9=morpion.jpg
val10=Tic-tac-toe ou Morpion
val11=En 1950, le premier jeu connu Bertie the Brain est dťveloppť par Josef	 Kates dans le cadre de l'exposition nationale canadienne. La machine permet au public	 de jouer au morpion "Tic-tac-toe" face ŗ une intelligence artificielle, avec diffťrents	 niveaux de difficultť.	 <a href="https://fr.wikipedia.org/wiki/Tic-tac-toe" target="_blank">Source Wikipedia</a>
tmp0=!randint 10, 20

val12=$[rint($(tmp0))]
val13=??
val14=??
val15=[[1] * nombre_colonne for _ in range(nombre_ligne)]
val16=for
t_=!replace internal \( by ( in m=matrix(1,$val12,i,j,0);
tmp0=!exec pari $t_

val17=$(tmp0)
t_=!replace internal \( by ( in print(m);
tmp0=!exec pari $t_

val17=$(tmp0)
tmp0=!replace internal ; by , in $val17 

val17=$(tmp0)
val18=
!for val19 =1 to $val12 
tmp0=!append line board.create('point', [$val19-0.5,0.5],{color:'black'}); to $val18

val18=$(tmp0)
!next
val20=Modifier cet algorithme pour qu'il effectue <b>sans erreur</b> la reprťsentation donnťe ŗ droite ou ci-dessous.
val21=$[0.1*$val12]
val22=$[1.1*$val12]
val23=$[150/$val12]
val24=#################	##Initialisation#	#################	nombre_ligne=$val13	nombre_colonne=$val14	mat=$val15	########################	##Boucle sur la matrice#	########################	for i in range(nombre_ligne):	  for j in range(nombre_colonne):	      mat[i][j]=??	###########################	##Affichage de la matrice##	###########################	for i in range(nombre_ligne):	  print(mat[i])	
!readproc slib/geo2D/jsxgraph jsxbox1,400 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=false;	JXG.Options.point.highlight=true;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.size = $val23;	JXG.Options.point.withLabel=true;	var board = JXG.JSXGraph.initBoard('jsxbox1', {axis:false, boundingbox: [-$val21,-$val21,$val22,$val22],	shownavigation:false,showCopyright:false,showFullscreen: true});	xaxis = board.create('axis', [[0, 0], [1,0]],	      {name:'nombre de colonnes',	      withLabel: true,	      label: {position: 'lrt',offset: [-100, 25]},	      });	xaxis.removeAllTicks();	board.create('ticks', [xaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [5, 10]},	  minorTicks:0,	  drawZero:true});	yaxis = board.create('axis', [[0, 0], [0,1]],	      {name:'nombre de lignes',	      withLabel: true,	      label: {position: 'lrt',offset: [10, 0]}	      ,ticks:{scale: 1}}	      );	yaxis.removeAllTicks();	board.create('ticks', [yaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [-15, -10]},	  minorTicks:0,	  drawZero:true});	$val18	 
tmp0=$slib_out
val25=$(tmp0)
!readproc slib/geo2D/jsxgraph jsxbox,400 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=false;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.withLabel=true; 
tmp0=$slib_out
val26=$(tmp0)
