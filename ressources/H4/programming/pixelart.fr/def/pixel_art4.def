val6=Les premiŤres consoles de jeux ne disposent pas de beaucoup de mťmoire donc les programmeurs	 sont obligťs de coder les images en binaire, c'est-ŗ-dire par une suite de 0 et de 1.	 Le zťro correspond ŗ la couleur noire.

!ifval ($val2==)
val7=ambiance
!else
val7=$val2
!endif
val8=Pixel Art et Python
val9=Tennis_for_Two_Machine_at_CAX_2010.jpg
val10=Jeux de Tennis
val11=Tennis for Two est un jeu vidťo de tennis conÁu en 1958 par William Higinbotham	 et dťveloppť par Robert Dvorak, souvent considťrť comme le premier jeu vidťo de l'histoire.	 <a href="https://fr.wikipedia.org/wiki/Tennis_for_Two" target="_blank">Source Wikipedia</a>
tmp0=!randint 10, 20

val12=$[rint($(tmp0))]
val13=1
val14=$val12
val15=[[1] * nombre_colonne for _ in range(nombre_ligne)]
val16=for&if
val17=instruction=[if k%2==0 :]
tmp0=!randint 1, 2

val18=$[rint($(tmp0))]

!ifval ($val18==1)
val19=j
!else
val19=(j+1)
!endif

!ifval ($val18==1)
val20=0
!else
val20=1
!endif
t_=!replace internal \( by ( in m=matrix(1,$val12,i,j,if($val19%2==0,0,1));
tmp0=!exec pari $t_

val21=$(tmp0)
t_=!replace internal \( by ( in print(m);
tmp0=!exec pari $t_

val21=$(tmp0)
tmp0=!replace internal ; by , in $val21 

val21=$(tmp0)
val22=
!for val23 =1 to $val12 
val24=$[rint(($val23+$val20)%2)]
!if $val24==0 
tmp0=!append line board.create('point', [$val23-0.5,0.5],{color:'black'}); to $val22

val22=$(tmp0)
!endif
!next
val25=Modifier cet algorithme avec l'instruction conditionnelle <code>if k%2==0 :</code>	 pour qu'il effectue <b>sans erreur</b> la reprťsentation donnťe ŗ droite ou ci-dessous.
val26=$[0.1*$val12]
val27=$[1.1*$val12]
val28=$[150/$val12]
val29=#################	##Initialisation#	#################	nombre_ligne=$val13	nombre_colonne=$val14	mat=$val15	########################	##Boucle sur la matrice#	########################	for i in range(nombre_ligne):	  for j in range(nombre_colonne):	      mat[i][j]=??	###########################	##Affichage de la matrice##	###########################	for i in range(nombre_ligne):	  print(mat[i])	
!readproc slib/geo2D/jsxgraph jsxbox1,400 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=false;	JXG.Options.point.highlight=true;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.size = $val28;	JXG.Options.point.withLabel=true;	var board = JXG.JSXGraph.initBoard('jsxbox1', {axis:false, boundingbox: [-$val26,-$val26,$val27,$val27],	shownavigation:false,showCopyright:false,showFullscreen: true});	xaxis = board.create('axis', [[0, 0], [1,0]],	      {name:'nombre de colonnes',	      withLabel: true,	      label: {position: 'lrt',offset: [-100, 25]},	      });	xaxis.removeAllTicks();	board.create('ticks', [xaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [5, 10]},	  minorTicks:0,	  drawZero:true});	yaxis = board.create('axis', [[0, 0], [0,1]],	      {name:'nombre de lignes',	      withLabel: true,	      label: {position: 'lrt',offset: [10, 0]}	      ,ticks:{scale: 1}}	      );	yaxis.removeAllTicks();	board.create('ticks', [yaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [-15, -10]},	  minorTicks:0,	  drawZero:true});	$val22	 
tmp0=$slib_out
val30=$(tmp0)
!readproc slib/geo2D/jsxgraph jsxbox,400 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=false;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.withLabel=true; 
tmp0=$slib_out
val31=$(tmp0)
