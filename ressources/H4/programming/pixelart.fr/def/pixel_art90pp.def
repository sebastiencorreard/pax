val7=ambiance
!else
val7=$val2
!endif
val8=Pixel Art et Python
val9=Avcs2600_set.jpg
val10=Console Atari
val11=En 1977, Atari lance sa console Video Computer System, renommée par la	 suite Atari 2600. En 1979, la société Activision est créée par un groupe de	 programmeurs d'Atari mécontents. Il s'agit du premier développeur tiers de jeux vidéo.	 <a href="https://fr.wikipedia.org/wiki/Atari_2600" target="_blank" >Source Wikipedia</a>
tmp0=!randint 10, 20

val12=$[rint($(tmp0))]
val13=$val12
val14=$val12
val15=[[1] * nombre_colonne for _ in range(nombre_ligne)]
val16=for&if&or
val17=instruction=[if, k%3==??,i<=j+?? ,j<=i+??,and,or ]
tmp0=!randint 0, 3

val18=$[rint($(tmp0))]
tmp0=!randint 0, 1

val19=$[rint($(tmp0))]
tmp0=!randint 0, 2

val20=$[rint($(tmp0))]
tmp=!nonempty items j%2==$val19,j%3==$val20,true

tmp0=!randitem $tmp
val21=$(tmp0)
tmp=!nonempty items i<=j+$val18,j<=i+$val18

tmp0=!randitem $tmp
val22=$(tmp0)
t_=!replace internal \( by ( in m=matrix($val12,$val12,i,j,if(($val21) && ($val22),0,1));
tmp0=!exec pari $t_

val23=$(tmp0)
t_=!replace internal \( by ( in print(m);
tmp0=!exec pari $t_

val24=$(tmp0)
tmp0=!replace internal ; by , in $val24 

val23=$(tmp0)
val25=
!for val26 =1 to $val12 
!for val27 =1 to $val12 
val28=$[rint($(val24[$val27;$val26]))]
!if ($val28==0) 
tmp0=!append line board.create('point', [$val26-0.5,$val27-0.5],{color:'black'}); to $val25

val25=$(tmp0)
!endif
!next
!next
val29=Modifier cet algorithme en ecrivant des inégalités entre les variables couplées éventuellement avec	 les opérateurs and et modulo qui donne le reste de la division euclidienne afin d'écrire une instruction de la forme :	<code>if i%2==0 and j<=i+2 :</code>.	 La représentation donnée ŕ droite ou ci-dessous est ŕ effectuer.
val30=$[0.1*$val12]
val31=$[1.1*$val12]
val32=$[150/$val12]
val33=#################	##Initialisation#	#################	nombre_ligne=$val13	nombre_colonne=$val14	mat=$val15	########################	##Boucle sur la matrice#	########################	for i in range(nombre_ligne):	  for j in range(nombre_colonne):	      mat[i][j]=??	###########################	##Affichage de la matrice##	###########################	for i in range(nombre_ligne):	  print(mat[i])	
!readproc slib/geo2D/jsxgraph jsxbox1,400 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=false;	JXG.Options.point.highlight=true;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.size = $val32;	JXG.Options.point.withLabel=true;	var board = JXG.JSXGraph.initBoard('jsxbox1', {axis:false, boundingbox: [-$val30,-$val30,$val31,$val31],	shownavigation:false,showCopyright:false,showFullscreen: true});	xaxis = board.create('axis', [[0, 0], [1,0]],	      {name:'nombre de colonnes',	      withLabel: true,	      label: {position: 'lrt',offset: [-100, 25]},	      });	xaxis.removeAllTicks();	board.create('ticks', [xaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [5, 10]},	  minorTicks:0,	  drawZero:true});	yaxis = board.create('axis', [[0, 0], [0,1]],	      {name:'nombre de lignes',	      withLabel: true,	      label: {position: 'lrt',offset: [10, 0]}	      ,ticks:{scale: 1}}	      );	yaxis.removeAllTicks();	board.create('ticks', [yaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [-15, -10]},	  minorTicks:0,	  drawZero:true});	$val25	 
tmp0=$slib_out
val34=$(tmp0)
!readproc slib/geo2D/jsxgraph jsxbox,400 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=false;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.withLabel=true; 
tmp0=$slib_out
val35=$(tmp0)
