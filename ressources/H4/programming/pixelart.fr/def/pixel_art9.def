val8=Pixel Art et Python
val9=Pong.png
val10=PONG !
val11=Pong (stylisť PONG) est un des premiers jeux vidťo d'arcade et le premier	 jeu vidťo d'arcade de sport. Il a ťtť imaginť par l'Amťricain Nolan Bushnell et	 dťveloppť par Allan Alcorn, et la sociťtť Atari le commercialise ŗ partir de novembre	 1972. Bien que d'autres jeux vidťo aient ťtť inventťs prťcťdemment, comme	 Computer Space, Pong est le premier ŗ devenir populaire.	   <a href="https://fr.wikipedia.org/wiki/Pong" target="_blank" >Source Wikipedia</a>
tmp0=!randint 10, 20

val12=$[rint($(tmp0))]
val13=$val12
val14=$val12
val15=[[1] * nombre_colonne for _ in range(nombre_ligne)]
val16=for&if
val17=instruction=[if k%2==0 :]
tmp0=!randint 1, 2

val18=$[rint($(tmp0))]

!ifval ($val18==1 or $val18==2)
val19=0
!else
val19=1
!endif
tmp0=!randint 1, 2

val20=$[rint($(tmp0))]

!ifval ($val20==2)
val21=i
!else
val21=j
!endif
t_=!replace internal \( by ( in m=matrix($val12,$val12,i,j,if($val21%2==$val19,0,1));
tmp0=!exec pari $t_

val22=$(tmp0)
t_=!replace internal \( by ( in print(m);
tmp0=!exec pari $t_

val22=$(tmp0)
tmp0=!replace internal ; by , in $val22 

val22=$(tmp0)
val23=
!for val24 =1 to $val12 
!for val25 =1 to $val12 
val26=$[rint(($val25)%2)]
val27=$[rint(($val24)%2)]
!if ($val20==1 and ($val27==$val19)) or ($val20==2 and ($val26==$val19)) 
tmp0=!append line board.create('point', [$val24-0.5,$val25-0.5],{color:'black'}); to $val23

val23=$(tmp0)
!endif
!next
!next
val28=Modifier cet algorithme avec l'instruction conditionnelle <code>if k%2==0 :</code>.	 La reprťsentation donnťe ŗ droite ou ci-dessous est ŗ rťaliser.
val29=$[0.1*$val12]
val30=$[1.1*$val12]
val31=$[150/$val12]
val32=#################	##Initialisation#	#################	nombre_ligne=$val13	nombre_colonne=$val14	mat=$val15	########################	##Boucle sur la matrice#	########################	for i in range(nombre_ligne):	  for j in range(nombre_colonne):	      mat[i][j]=??	###########################	##Affichage de la matrice##	###########################	for i in range(nombre_ligne):	  print(mat[i])	
!readproc slib/geo2D/jsxgraph jsxbox1,400 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=false;	JXG.Options.point.highlight=true;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.size = $val31;	JXG.Options.point.withLabel=true;	var board = JXG.JSXGraph.initBoard('jsxbox1', {axis:false, boundingbox: [-$val29,-$val29,$val30,$val30],	shownavigation:false,showCopyright:false,showFullscreen: true});	xaxis = board.create('axis', [[0, 0], [1,0]],	      {name:'nombre de colonnes',	      withLabel: true,	      label: {position: 'lrt',offset: [-100, 25]},	      });	xaxis.removeAllTicks();	board.create('ticks', [xaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [5, 10]},	  minorTicks:0,	  drawZero:true});	yaxis = board.create('axis', [[0, 0], [0,1]],	      {name:'nombre de lignes',	      withLabel: true,	      label: {position: 'lrt',offset: [10, 0]}	      ,ticks:{scale: 1}}	      );	yaxis.removeAllTicks();	board.create('ticks', [yaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [-15, -10]},	  minorTicks:0,	  drawZero:true});	$val23	 
tmp0=$slib_out
val33=$(tmp0)
!readproc slib/geo2D/jsxgraph jsxbox,400 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=false;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.withLabel=true; 
