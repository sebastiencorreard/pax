val6=Les premiŤres consoles de jeux ne disposent pas de beaucoup de mťmoire donc les programmeurs	 sont obligťs de coder les images en binaire, c'est-ŗ-dire par une suite de 0 et de 1.	 Le zťro correspond ŗ la couleur noire.

!ifval ($val2==)
val7=ambiance
!else
val7=$val2
!endif
val8=Pixel Art et Python
val9=Avcs2600_set.jpg
val10=Console Atari
val11=En 1977, Atari lance sa console Video Computer System, renommťe par la	 suite Atari 2600. En 1979, la sociťtť Activision est crťťe par un groupe de	 programmeurs d'Atari mťcontents. Il s'agit du premier dťveloppeur tiers de jeux vidťo.	 <a href="https://fr.wikipedia.org/wiki/Atari_2600" target="_blank" >Source Wikipedia</a>
tmp0=!randint 10, 20

val12=$[rint($(tmp0))]
val13=$val12
val14=$val12
val15=[[1] * nombre_colonne for _ in range(nombre_ligne)]
val16=for&if
val17=instruction=[if k%2==0 ,or ,and ]
tmp0=!randint 1, 4

val18=$[rint($(tmp0))]

!ifval ($val18==1 or $val18==2)
val19=0
!else
val19=1
!endif

!ifval ($val18==2 or $val18==4)
val20=1
!else
val20=0
!endif
tmp0=!randint 1, 2

val21=$[rint($(tmp0))]

!ifval ($val21==2)
val22=&&
!else
val22=||
!endif
t_=!replace internal \( by ( in m=matrix($val12,$val12,i,j,if(j%2==$val19 $val22 i%2==$val20,0,1));
tmp0=!exec pari $t_

val23=$(tmp0)
t_=!replace internal \( by ( in print(m);
tmp0=!exec pari $t_

val23=$(tmp0)
tmp0=!replace internal ; by , in $val23 

val23=$(tmp0)
val24=
!for val25 =1 to $val12 
!for val26 =1 to $val12 
val27=$[rint(($val26)%2)]
val28=$[rint(($val25)%2)]
!if ($val21==1 and ($val27==$val20 or $val28==$val19)) or ($val21==2 and ($val27==$val20 and $val28==$val19)) 
tmp0=!append line board.create('point', [$val25-0.5,$val26-0.5],{color:'black'}); to $val24

val24=$(tmp0)
!endif
!next
!next
val29=Modifier cet algorithme avec l'instruction <code>if k%2==0</code> couplťe avec	 les opťrateurs and et or afin d'ťcrire une instruction de la forme :	<code>if i%2==0 and j%2==0 :</code>.	 La reprťsentation donnťe ŗ droite ou ci-dessous est ŗ effectuer.
val30=$[0.1*$val12]
val31=$[1.1*$val12]
val32=$[150/$val12]
val33=#################	##Initialisation#	#################	nombre_ligne=$val13	nombre_colonne=$val14	mat=$val15	########################	##Boucle sur la matrice#	########################	for i in range(nombre_ligne):	  for j in range(nombre_colonne):	      mat[i][j]=??	###########################	##Affichage de la matrice##	###########################	for i in range(nombre_ligne):	  print(mat[i])	
!readproc slib/geo2D/jsxgraph jsxbox1,400 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=false;	JXG.Options.point.highlight=true;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.size = $val32;	JXG.Options.point.withLabel=true;	var board = JXG.JSXGraph.initBoard('jsxbox1', {axis:false, boundingbox: [-$val30,-$val30,$val31,$val31],	shownavigation:false,showCopyright:false,showFullscreen: true});	xaxis = board.create('axis', [[0, 0], [1,0]],	      {name:'nombre de colonnes',	      withLabel: true,	      label: {position: 'lrt',offset: [-100, 25]},	      });	xaxis.removeAllTicks();	board.create('ticks', [xaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [5, 10]},	  minorTicks:0,	  drawZero:true});	yaxis = board.create('axis', [[0, 0], [0,1]],	      {name:'nombre de lignes',	      withLabel: true,	      label: {position: 'lrt',offset: [10, 0]}	      ,ticks:{scale: 1}}	      );	yaxis.removeAllTicks();	board.create('ticks', [yaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [-15, -10]},	  minorTicks:0,	  drawZero:true});	$val24	 
tmp0=$slib_out
val34=$(tmp0)
!readproc slib/geo2D/jsxgraph jsxbox,400 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=false;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.withLabel=true; 
tmp0=$slib_out
val35=$(tmp0)
