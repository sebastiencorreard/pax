val6=Les premičres consoles de jeux ne disposent pas de beaucoup de mémoire donc les programmeurs	 sont obligés de coder les images en binaire, c'est-ŕ-dire par une suite de 0 et de 1.	 Le zéro correspond ŕ la couleur noire.

!ifval ($val2==)
val7=ambiance
!else
val7=$val2
!endif
val8=Pixel Art et Python
val9=Avcs2600_set.jpg
val10=Console Atari
val11=En 1977, Atari lance sa console Video Computer System, renommée par la	 suite Atari 2600. En 1979, la société Activision est créée par un groupe de	 programmeurs d'Atari mécontents. Il s'agit du premier développeur tiers de jeux vidéo.	 <a href="https://fr.wikipedia.org/wiki/Atari_2600" target="_blank" >Source Wikipedia</a>
tmp0=!randint 10, 20

val12=$[rint($(tmp0))]
val13=$val12
val14=$val12
val15=[[1] * nombre_colonne for _ in range(nombre_ligne)]
val16=for&if&or
val17=instruction=[i+j==?? ,i-j==??,or ,and ]
tmp0=!randint -4, 4

val18=$[rint($(tmp0))]
tmp0=!randint -4, 4

val19=$[rint($(tmp0))]
t_=!replace internal \( by ( in m=matrix($val12,$val12,i,j,if((i-j==$val18) || (i+j==$val12+$val19),0,1));
tmp0=!exec pari $t_

val20=$(tmp0)
t_=!replace internal \( by ( in print(m);
tmp0=!exec pari $t_

val20=$(tmp0)
tmp0=!replace internal ; by , in $val20 

val20=$(tmp0)
val21=
!for val22 =1 to $val12 
!for val23 =1 to $val12 
val24=$[rint(-$val22+$val23)]
val25=$[rint($val22+$val23)]
val26=$[rint($val12+$val19)]
!if ($val24==$val18) or ($val25==$val26) 
tmp0=!append line board.create('point', [$val22-0.5,$val23-0.5],{color:'black'}); to $val21

val21=$(tmp0)
!endif
!next
!next
val27=Modifier cet algorithme en ecrivant des égalités entre les variables couplées avec	 les opérateurs and et or afin d'écrire une instruction de la forme :	<code>if i+j==0 and i-j==0 :</code>.	 La représentation donnée ŕ droite ou ci-dessous est ŕ effectuer.
val28=$[0.1*$val12]
val29=$[1.1*$val12]
val30=$[150/$val12]
val31=#################	##Initialisation#	#################	nombre_ligne=$val13	nombre_colonne=$val14	mat=$val15	########################	##Boucle sur la matrice#	########################	for i in range(nombre_ligne):	  for j in range(nombre_colonne):	      mat[i][j]=??	###########################	##Affichage de la matrice##	###########################	for i in range(nombre_ligne):	  print(mat[i])	
!readproc slib/geo2D/jsxgraph jsxbox1,400 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=false;	JXG.Options.point.highlight=true;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.size = $val30;	JXG.Options.point.withLabel=true;	var board = JXG.JSXGraph.initBoard('jsxbox1', {axis:false, boundingbox: [-$val28,-$val28,$val29,$val29],	shownavigation:false,showCopyright:false,showFullscreen: true});	xaxis = board.create('axis', [[0, 0], [1,0]],	      {name:'nombre de colonnes',	      withLabel: true,	      label: {position: 'lrt',offset: [-100, 25]},	      });	xaxis.removeAllTicks();	board.create('ticks', [xaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [5, 10]},	  minorTicks:0,	  drawZero:true});	yaxis = board.create('axis', [[0, 0], [0,1]],	      {name:'nombre de lignes',	      withLabel: true,	      label: {position: 'lrt',offset: [10, 0]}	      ,ticks:{scale: 1}}	      );	yaxis.removeAllTicks();	board.create('ticks', [yaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [-15, -10]},	  minorTicks:0,	  drawZero:true});	$val21	 
tmp0=$slib_out
val32=$(tmp0)
!readproc slib/geo2D/jsxgraph jsxbox,400 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=false;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.withLabel=true; 
tmp0=$slib_out
val33=$(tmp0)
