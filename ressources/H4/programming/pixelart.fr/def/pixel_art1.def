val7=ambiance
!else
val7=$val2
!endif
val8=$[rint(4)]
val9=Pixel Art et Python
val10=Bombe-rebuild.jpg
val11=Rťplique de la Bombe
val12=Pendant la seconde Guerre mondiale, les premiers ordinateurs analogiques	 font leur apparition afin de contribuer ŗ l'effort de guerre. Selon plusieurs historiens,	 le travail du mathťmaticien Alan Turing pour dťchiffrer le code des transmissions allemandes	  permet de raccourcir la Seconde Guerre mondiale de deux ans.	 <a href="https://fr.wikipedia.org/wiki/Alan_Turing" target="_blank" >Source Wikipedia</a>
tmp0=!randint 10, 20

val13=$[rint($(tmp0))]
val14=1
val15=$val13
val16=[[1] * nombre_colonne for _ in range(nombre_ligne)]
val17=for
t_=!replace internal \( by ( in m=matrix(1,$val13,i,j,0);
tmp0=!exec pari $t_

val18=$(tmp0)
t_=!replace internal \( by ( in print(m);
tmp0=!exec pari $t_

val18=$(tmp0)
tmp0=!replace internal ; by , in $val18 

val18=$(tmp0)
val19=
!for val20 =1 to $val13 
tmp0=!append line board.create('point', [$val20-0.5,0.5],{color:'black'}); to $val19

val19=$(tmp0)
!next
val21=Modifier cet algorithme pour qu'il effectue <b>sans erreur</b> la reprťsentation donnťe ŗ droite ou ci-dessous.
val22=$[0.1*$val13]
val23=$[1.1*$val13]
val24=$[150/$val13]
val25=#################	##Initialisation#	#################	nombre_ligne=$val14	nombre_colonne=$val15	mat=$val16	########################	##Boucle sur la matrice#	########################	for i in range(nombre_ligne):	  for j in range(nombre_colonne):	      mat[i][j]=??	###########################	##Affichage de la matrice##	###########################	for i in range(nombre_ligne):	  print(mat[i])	
!readproc slib/geo2D/jsxgraph jsxbox1,400 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=false;	JXG.Options.point.highlight=true;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.size = $val24;	JXG.Options.point.withLabel=true;	var board = JXG.JSXGraph.initBoard('jsxbox1', {axis:false, boundingbox: [-$val22,-$val22,$val23,$val23],	shownavigation:false,showCopyright:false,showFullscreen: true});	xaxis = board.create('axis', [[0, 0], [1,0]],	      {name:'nombre de colonnes',	      withLabel: true,	      label: {position: 'lrt',offset: [-100, 25]},	      });	xaxis.removeAllTicks();	board.create('ticks', [xaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [5, 10]},	  minorTicks:0,	  drawZero:true});	yaxis = board.create('axis', [[0, 0], [0,1]],	      {name:'nombre de lignes',	      withLabel: true,	      label: {position: 'lrt',offset: [10, 0]}	      ,ticks:{scale: 1}}	      );	yaxis.removeAllTicks();	board.create('ticks', [yaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [-15, -10]},	  minorTicks:0,	  drawZero:true});	$val19	 
tmp0=$slib_out
val26=$(tmp0)
!readproc slib/geo2D/jsxgraph jsxbox,400 x 400,JXG.Options.point.fixed = true;	JXG.Options.point.showInfobox=false;	JXG.Options.point.name = "";	JXG.Options.point.face = "[]";	JXG.Options.point.withLabel=true; 
tmp0=$slib_out
val27=$(tmp0)
