$()	</div>	$val21	<br/>	<div class="wimscenter wimsborder box">	$val27	</div>	<div class="wimscenter wimsborder box">	$val26	</div>	</div>	<script>	function graph(){	mat=Sk.ffi.remapToJs(Sk.globals["mat"]);	let matligne=mat.length;	let matcolonne=mat[0].length;	let max=Math.max(matligne,matcolonne);	let gg=1.1*max;	let ggm=0.1*max;	JXG.Options.point.size = 150/max;	var brd = JXG.JSXGraph.initBoard('jsxbox', {axis:false, boundingbox: [-ggm,-ggm,gg,gg],	shownavigation:false,showCopyright:false,showFullscreen: true});	xxaxis = brd.create('axis', [[0, 0], [1,0]],	      {name:'nombre de colonnes',	      withLabel: true,	      label: {position: 'lrt',offset: [-100, 25]},	      });	xxaxis.removeAllTicks();	brd.create('ticks', [xxaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [5, 10]},	  minorTicks:0,	  drawZero:true});	yyaxis = brd.create('axis', [[0, 0], [0,1]],	      {name:'nombre de lignes',	      withLabel: true,	      label: {position: 'lrt',offset: [10, 0]}	      ,ticks:{scale: 1}}	      );	yyaxis.removeAllTicks();	brd.create('ticks', [yyaxis, 1],{	  strokeColor:'#ccc',	  majorHeight:-1,	  drawLabels:true,	  label: { offset: [-15, -10]},	  minorTicks:0,	  drawZero:true});	brd.suspendUpdate();	for(var jj = 0; jj < matligne; jj=jj+1) {	for(var ii = 0; ii < matcolonne; ii=ii+1) {	/*name:aaa[ss][jj][ii]*/	if(mat[jj][ii]==0){	brd.create('point', [ii+0.5,jj+0.5],{color:'black'});}}}	brd.unsuspendUpdate();}	execidtest2.addEventListener('click',graph);	</script>	
