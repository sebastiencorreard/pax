!set title=Affectation avec deux variables et 4 instructions avec des calculs
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Julien, Lyotard
email=Julien.Lyotard@ac-dijon.fr
language=fr

ansorder=r,r
varcnt=36
prevarcnt=34
postvarcnt=1
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!trim ambiance,neat;3024-night,3024-day
val6=!translate internal $	\
$ to ;; in $tmp
val7=a,b,c,d,f,g,h,l,m,n,o,p,q,r,s,t,u,v,x,y,z
tmp=!nonempty items $val7

tmp0=!randitem $tmp
val8=$(tmp0)
tmp0=!randint 3, 9

val9=$[rint($(tmp0))]
tmp=!nonempty items +1,-1

tmp0=!randitem $tmp
tmp1=!randint 2, $val9-1

val10=$[rint($(tmp0)*$(tmp1))]
val11=Aprčs avoir lu les instructions, déterminer la valeur finale de la variable	 \($val8\).
val12=
tmp=!trim r1
val13=!translate internal $	\
$ to ;; in $tmp
val14=
val15=$[rint(1)]
val16=$[rint(2)]
val17=$[rint(4)]
tmp=!trim r1,r2
val13=!translate internal $	\
$ to ;; in $tmp
tmp0=!listcomplement $val8 in $val7

val18=$(tmp0)
tmp=!nonempty items $val18

tmp0=!randitem $tmp
val19=$(tmp0)
val11=Aprčs avoir lu les instructions, déterminer la valeur finale des variables	 \($val8\) et \($val19\).
val20=$val9
val21=$val10
val22=$val8*$val19
val23=$val8+$val19
tmp0=!randint 1, 2

val24=$[rint($(tmp0))]

!ifval ($val24==1)
val25=$val8=$val22
!else
val25=$val19=$val23
!endif

!ifval ($val24==1)
val26=$val19=$val23
!else
val26=$val8=$val22
!endif
val27=$val8=$val22	$val19=$val23
val28=$val8=$val20	$val19=$val21	$val25	$val26
!if $val24==2 
val29=$val8
val8=$val19
val19=$val29
!endif

!ifval ($val24==1)
val30=$[rint($val9*$val10)]
!else
val30=$[rint($val9+$val10)]
!endif

!ifval ($val24==1)
val31=$[rint($val30+$val10)]
!else
val31=$[rint($val30*$val9)]
!endif
val32=Affectation des variables
val33=Instruction
tmp=!trim $val13
val34=!translate internal $	\
$ to ;; in $tmp
!readproc slib/coding/editor [python,[$val28]],1,readonly fullscreen theme=[zenburn,neat] bystep=[$val14] 
tmp0=$slib_out
val35=$(tmp0)
dynsteps=yes
oefsteps=$val34 
nextstep=!nosubst $val34 
!readproc oef/steps.proc
replytype1=numexp
replyname1=
replygood1=$val30
replytype2=numexp
replyname2=
replygood2=$val31
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="encadre">	<p class="problematique">$val32</p>	<div id="boited">	<img src="$val1/python.png" alt="Logo de Python">	</div>	<div class="enonce">	$val11	$val12	<div class="question">	$val35	<div>La valeur finale de 
!insmath $val8
$() est :  
!read oef/embed.phtml reply$val15,4 
$()</div>	<div>La valeur finale de 
!insmath $val19
$() est :  
!read oef/embed.phtml reply$val16,4 
$()</div>	</div>	</div>	</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:postdef

!ifval ($m_step=2)
val34=
!endif

!exit

:feedback

