!set title=Affectation avec une variable et 4 instructions en mode pas ą pas
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Julien, Lyotard
email=Julien.Lyotard@ac-dijon.fr
oefcss=<style> .tabb {visibility:hidden;display:inline-block;min-width:70px;} .jxgbox {display:inline-block;} </style>
language=fr

ansorder=r,r,r,r,r
varcnt=41
prevarcnt=39
postvarcnt=1
replycnt=5
choicecnt=0
conditioncnt=0
feedbackcnt=1
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!trim ambiance,neat;3024-night,3024-day
val6=!translate internal $	\
$ to ;; in $tmp
val7=a,b,c,d,f,g,h,l,m,n,o,p,q,r,s,t,u,v,x,y,z
tmp=!nonempty items $val7

tmp0=!randitem $tmp
val8=$(tmp0)
tmp0=!randint 3, 9

val9=$[rint($(tmp0))]
tmp=!nonempty items +1,-1

tmp0=!randitem $tmp
tmp1=!randint 2, $val9-1

val10=$[rint($(tmp0)*$(tmp1))]
val11=Aprčs avoir lu les instructions, déterminer la valeur finale de la variable	 \($val8\).
val12=
tmp=!trim r1
val13=!translate internal $	\
$ to ;; in $tmp
val14=
val15=$[rint(1)]
val16=$[rint(4)]
tmp=!nonempty items +1,-1

tmp0=!randitem $tmp
tmp1=!randint 2, 5

val10=$[rint($(tmp0)*$(tmp1))]
tmp0=!randint 2, 9

val9=$[rint($val10*$(tmp0))]
tmp=!nonempty items +1,-1

tmp0=!randitem $tmp
tmp1=!randint 2, 9

val17=$[rint($(tmp0)*$(tmp1))]
tmp=!nonempty items +1,-1

tmp0=!randitem $tmp
tmp1=!randint 2, 4

val18=$[rint($(tmp0)*$(tmp1))]
val19=$val8=$val9
t_=!replace internal \( by ( in $val8/$val10
tmp0=!exec pari $t_

val20=$(tmp0)
t_=!replace internal \( by ( in $val8+$val17
tmp0=!exec pari $t_

val21=$(tmp0)
val22=$val18*$val8
val23=$val19	$val8=$val20	$val8=$val21	$val8=$val22
val24=$[rint(($val9/$val10+$val17)*$val18)]
val12=<div class="wims_instruction">Cliquer sur le bouton intitulé "Mode pas ą pas"	 puis compléter le tableau.</div>
tmp0=!makelist r x for x = 1 to $val16+1

val13=$(tmp0)
val15=$[rint($val16+1)]
val14=1,1,1,4;2,1,2,6
val25=$val19,$val20,$val21,$val22
val26=
!for val27 =1 to $val16 
tmp0=!charcnt $(val25[$val27])

val28=$[rint($(tmp0)+3)]
tmp0=!append item $val28 to $val26

val26=$(tmp0)
!next
val14=1,1,1,$(val26[1]);2,1,2,$(val26[2]);3,1,3,$(val26[3]);4,1,4,$(val26[4])
val29=$[rint($val9)]
val30=$[rint($val9/$val10)]
val31=$[rint($val30+$val17)]
val32=$[rint($val24)]
val33=Affectation des variables
val34=Instruction
tmp=!trim $val13
val35=!translate internal $	\
$ to ;; in $tmp
!readproc slib/coding/editor [python,[$val23]],1,readonly fullscreen theme=[zenburn,neat] bystep=[$val14] 
tmp0=$slib_out
val36=$(tmp0)
dynsteps=yes
oefsteps=$val35 
nextstep=!nosubst $val35 
!readproc oef/steps.proc
replytype1=numexp
replyname1=
replygood1=$val29
replytype2=numexp
replyname2=
replygood2=$val30
replytype3=numexp
replyname3=
replygood3=$val31
replytype4=numexp
replyname4=
replygood4=$val32
replytype5=numexp
replyname5=
replygood5=$val24
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="encadre">	<p class="problematique">$val33</p>	<div id="boited">	<img src="$val1/python.png" alt="Logo de Python">	</div>	<div class="enonce">	$val11	$val12	<div class="question">	$val36	<div class="spacer"></div>	<table class="wimsborder">	<tr><th>ligne n°</th> 
!for m_k=1 to $val16 
$()<td><span id="td1$m_k">$m_k</span></td> 
!next
$()</tr>	<tr><th>Valeur de $val8</th> 
!for m_jj=1 to $val16 
$()<td><span id="td2$m_jj" class="tabb"> 
!read oef/embed.phtml reply\jj,3 
$()</span></td> 
!next
$()</tr>	</table>	<div>La valeur finale de 
!insmath $val8
$() est :  
!read oef/embed.phtml reply$val15,4 
$()</div>	</div>	</div>	</div>	<script>	    var mode_pasapas = document.getElementById('bystep1');	    var i_modepasapas=1;	    function aff() {var atab=document.getElementsByClassName('tabb');	    for (var i = 0; i < atab.length; i++) {atab[i].style.visibility='visible';}}	    function test() {	        var ele=document.getElementById('td2'+i_modepasapas);	        ele.style.visibility='visible';	        ele.style.backgroundColor='white';	        ele.style.padding='0 0.2em 0 0.2em';	        document.querySelector('#td2'+i_modepasapas+' input').focus();	        i_modepasapas=i_modepasapas+1;	        if(i_modepasapas==$val16+1){mode_pasapas.style.visibility='hidden';};	    }	    mode_pasapas.addEventListener('click',test);	  </script>
$()
!exit

