!set title=Affectation avec une variable et 2 instructions
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Julien, Lyotard
email=Julien.Lyotard@ac-dijon.fr
language=fr

ansorder=r
varcnt=20
prevarcnt=18
postvarcnt=1
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp=!trim ambiance,neat;3024-night,3024-day
val6=!translate internal $	\
$ to ;; in $tmp
val7=a,b,c,d,f,g,h,l,m,n,o,p,q,r,s,t,u,v,x,y,z
tmp=!nonempty items $val7

tmp0=!randitem $tmp
val8=$(tmp0)
tmp0=!randint 3, 9

val9=$[rint($(tmp0))]
tmp=!nonempty items +1,-1

tmp0=!randitem $tmp
tmp1=!randint 2, $val9-1

val10=$[rint($(tmp0)*$(tmp1))]
val11=AprĶs avoir lu les instructions, dķterminer la valeur finale de la variable	 \($val8\).
val12=
tmp=!trim r1
val13=!translate internal $	\
$ to ;; in $tmp
val14=
val15=$[rint(1)]
val16=$[rint(2)]
t_=!replace internal \( by ( in $val8+$val10
tmp0=!exec pari $t_

val17=$(tmp0)
val18=$val8=$val9	$val8=$val17
val19=$[rint($val9+$val10)]
val20=Affectation des variables
val21=Instruction
tmp=!trim $val13
val22=!translate internal $	\
$ to ;; in $tmp
!readproc slib/coding/editor [python,[$val18]],1,readonly fullscreen theme=[zenburn,neat] bystep=[$val14] 
tmp0=$slib_out
val23=$(tmp0)
dynsteps=yes
oefsteps=$val22 
nextstep=!nosubst $val22 
!readproc oef/steps.proc
replytype1=numexp
replyname1=
replygood1=$val19
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<div class="encadre">	<p class="problematique">$val20</p>	<div id="boited">	<img src="$val1/python.png" alt="Logo de Python">	</div>	<div class="enonce">	$val11	$val12	<div class="question">	$val23	<div>La valeur finale de 
!insmath $val8
$() est :  
!read oef/embed.phtml reply$val15,4 
$()</div>	</div>	</div>	</div>	
$()
!exit

