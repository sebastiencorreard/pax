$()
$()
!exit

:help
$()
$()
!exit

:solution
$()
$()
!exit

:latex
$()
$()
!exit

:postdef

!ifval ($m_step=2)
val25=
!endif

!exit

:feedback
!ifval 1==1
 <div class='oef_feedbacks'><script>window.onload = aff;	</script>
$()</div>
!endif

!exit

:test

