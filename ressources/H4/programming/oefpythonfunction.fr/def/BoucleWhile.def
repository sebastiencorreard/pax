!read oef/embed.phtml reply\jj+20,3 
$()</span></td> 
!next
$()</tr>	</table>	</div>	</div>	<script>	    var mode_pasapas = document.getElementById('bystepid');	    var i_modepasapas=1;	    var j_modepasapas=1;	    var nalg=$val20;	    if(nalg==2){var lalgo=["1","3","2"];}else{var lalgo=["1","2","3"];}	    var str_modepasapas=""+lalgo[i_modepasapas-1]+""+j_modepasapas;	    var coord=[$val25];	    function aff() {var atab=document.getElementsByClassName('tabb');	    for (var i = 0; i < atab.length; i++) {atab[i].style.visibility='visible';}}	    function test() {	        var ele=document.getElementById('td'+str_modepasapas+'');	        ele.style.visibility='visible';	        ele.style.backgroundColor='white';	        ele.style.padding='0 0.2em 0 0.2em';	        document.querySelector('#td'+str_modepasapas+' input').focus();	        if(i_modepasapas==1 & j_modepasapas==1){aa.setAttribute({fixed: true,visible: true});taa.setAttribute({fixed: true,visible: true});}	        if(i_modepasapas%3==0){j_modepasapas=j_modepasapas+1;i_modepasapas=0;}	        if(i_modepasapas==1 && j_modepasapas>1){aa.moveTo([coord[j_modepasapas-1],0],100);}	        i_modepasapas=i_modepasapas+1;	        if(i_modepasapas==2 && j_modepasapas==1 && nalg==2){i_modepasapas=3;}	        str_modepasapas=""+lalgo[i_modepasapas-1]+""+j_modepasapas;	        if(j_modepasapas==$val28+$val29+1){mode_pasapas.style.visibility='hidden';}	    }	    mode_pasapas.addEventListener('click',test);	  </script>	</div>
