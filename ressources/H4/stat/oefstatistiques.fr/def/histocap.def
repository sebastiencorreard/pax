!next
$()	</tr> 
!next
$()	</table>	<br><br>	<table class="wimscenter">	<tr><th>Temps de réaction</th>	<th>Nombre de tests <br> n<sub>i</sub></th>	<th>Centre de classe<br> x<sub>i</sub></th>	<th>Produit<br> n<sub>i</sub>
!insmath \times
$() x<sub>i</sub></th>	</tr>	 
!for m_jj=1 to 20 
$()	<tr>	<td>&#91; $(val17[$m_jj]);$(val17[$m_jj+1]) &#91;</td>	<td>
!if $(val51[$m_jj])=$(val20[$m_jj]) 
$()<span style="color:#0dff00;font-weight:bold">$(val20[$m_jj])</span> 
!else
$() <span style="color:red;font-weight:bold;text-decoration:line-through">$(val51[$m_jj])</span>&nbsp;<span style="color:#0dff00;font-weight:bold">$(val20[$m_jj])</span> 
!endif
$()</td>	<td>
!if $(val54[$m_jj])=$(val18[$m_jj]) 
$()<span style="color:#0dff00;font-weight:bold">$(val54[$m_jj])</span> 
!else
$() <span style="color:red;font-weight:bold;text-decoration:line-through">$(val54[$m_jj])</span>&nbsp;<span style="color:#0dff00;font-weight:bold">
!insmath \frac{($(val17[$m_jj])+$(val17[$m_jj+1]))}{2}
$()=$(val18[$m_jj])</span> 
!endif
$()</td>	<td>
!if $(val134[$m_jj])=$(val55[$m_jj;1]) 
$()<span style="color:#0dff00;font-weight:bold">$(val134[$m_jj])</span> 
!else
$() <span style="color:red;font-weight:bold;text-decoration:line-through">$(val134[$m_jj])</span>&nbsp;<span style="color:#0dff00;font-weight:bold">$(val20[$m_jj])*$(val18[$m_jj])= $(val55[$m_jj;1])</span> 
!endif
$()</td>	</tr> 
!next
$()	<tr>	<td><b>Total = 
!insmath \sum{}
$()</b></td><td>
!if $m_reply72=$val7 
$()<span style="color:#0dff00;;font-weight:bold">$val7</span> 
!else
$() <span style="color:red; text-decoration:line-through; font-weight:bold">$m_reply72</span><span style="color:#0dff00;font-weight:bold">$val7</span> 
!endif
$()</td>	<td></td><td>
!if $m_reply73=$val133 
$()<span style="color:#0dff00;;font-weight:bold">$val133</span> 
!else
$() <span style="color:red; text-decoration:line-through; font-weight:bold">$m_reply73</span>&nbsp;<span style="color:#0dff00;font-weight:bold">$val133</span> 
!endif
$()</td>	</tr>	</table>	</div>
$()</div>
!endif

!exit

