:feedback
!ifval 1=1
 <div class='oef_feedbacks'><div class="solution">	Vos temps de rÈaction <b>triÈs</b> sont donnÈs dans le tableau suivant :	<br>	<br>	<table class="wimscenter wimsborder">	 
!for m_jj=1 to $val9 
$()	<tr>	 
!for m_jjj=1 to $val8 
$()<td>$(val20[($m_jj-1)*$val8+$m_jjj])</td> 
!next
$()	</tr> 
!next
$()	</table>	<br><br>	<table class="wimscenter">	<tr><th>Temps de rÈaction</th>	<th>Nombre de tests <br> n<sub>i</sub></th>	<th>Effectifs cumulÈs <br>croissants en %</th>	<th>Centre de classe<br> x<sub>i</sub></th>	<th>Produit<br> n<sub>i</sub>
!insmath \times
$() x<sub>i</sub></th>	</tr>	 
!for m_jj=1 to $val17 
$()	<tr>	<td>&#91; $(val18[$m_jj]);$(val18[$m_jj+1]) &#91;</td>	<td>
!if $(val42[$m_jj])=$(val21[$m_jj]) 
$()<span style="color:#0dff00;font-weight:bold">$(val21[$m_jj])</span> 
!else
$() <span style="color:red;font-weight:bold;text-decoration:line-through">$(val42[$m_jj])</span>&nbsp;<span style="color:#0dff00;font-weight:bold">$(val21[$m_jj])</span> 
!endif
$()</td>	<td>
!if $(val44[$m_jj])=$(val43[$m_jj;1]) 
$()<span style="color:#0dff00;font-weight:bold">$(val43[$m_jj;1])</span> 
!else
$() <span style="color:red;font-weight:bold;text-decoration:line-through">$(val44[$m_jj])</span>&nbsp;<span style="color:#0dff00;font-weight:bold">$(val43[$m_jj;1])</span> 
!endif
$()</td>	<td>
!if $(val45[$m_jj])=$(val19[$m_jj]) 
$()<span style="color:#0dff00;font-weight:bold">$(val45[$m_jj])</span> 
!else
$() <span style="color:red;font-weight:bold;text-decoration:line-through">$(val45[$m_jj])</span>&nbsp;<span style="color:#0dff00;font-weight:bold">
!insmath \frac{($(val18[$m_jj])+$(val18[$m_jj+1]))}{2}
$()=$(val19[$m_jj])</span> 
!endif
$()</td>	<td>
!if $(val118[$m_jj])=$(val46[$m_jj;1]) 
$()<span style="color:#0dff00;font-weight:bold">$(val118[$m_jj])</span> 
!else
$() <span style="color:red;font-weight:bold;text-decoration:line-through">$(val118[$m_jj])</span>&nbsp;<span style="color:#0dff00;font-weight:bold">$(val21[$m_jj])*$(val19[$m_jj])= $(val46[$m_jj;1])</span> 
!endif
$()</td>	</tr> 
!next
$()	<tr>	<td><b>Total = 
!insmath \sum
$()</b></td><td>
!if $m_reply52=$val7 
$()<span style="color:#0dff00;;font-weight:bold">$val7</span> 
!else
$() <span style="color:red; text-decoration:line-through; font-weight:bold">$m_reply52</span><span style="color:#0dff00;font-weight:bold">$val7</span> 
!endif
$()</td>	<td></td><td></td><td>
!if $m_reply53=$val116 
$()<span style="color:#0dff00;;font-weight:bold">$val116</span> 
!else
$() <span style="color:red; text-decoration:line-through; font-weight:bold">$m_reply53</span>&nbsp;<span style="color:#0dff00;font-weight:bold">$val116</span> 
!endif
$()</td>	</tr>	</table>	</div>
$()</div>
!endif

!exit

