\real{rsp=\nbrinter1*50+\nbrinter2*150+\nbrinter3*250+\nbrinter4*350+\nbrinter5*450+\nbrinter6*550+\nbrinter7*550+\nbrinter8*750+\nbrinter9*850+\nbrinter10*950}
\answer{}{\sp}{type=numeric}{option=nonstop noanalyzeprint}
\condition{La somme des produits est de }{\sp=\rsp}{option=hide}

\integer{oi=1}
\integer{me=50}
\real{eccmed=\nbrinter1/\nbrtest*100}
\while{\eccmed<=50}{\integer{oi=\oi+1}
\real{eccmed=\eccmed+(\nbrinter[\oi]/\nbrtest*100)}
\integer{me=50+100*(\oi-1)}}

