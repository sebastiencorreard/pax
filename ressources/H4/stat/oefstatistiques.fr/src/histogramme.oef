\title{Temps de réaction}
\language{fr}
\range{-5..5}
\author{Julien, Lyotard}
\email{Julien.Lyotard@ac-dijon.fr}

\computeanswer{no}
\format{html}
\precision{100000}

\text{flash=slib(media/video [mp4="https://tube-sciences-technologies.apps.education.fr/download/videos/2f2c3de3-7dd5-4e16-8c57-c2c5eb3cade0-768.mp4"])}

Attention 100/\nbrtest doit ętre un entier
\text{nbrtest=(\confparm1==)?10:\confparm1}
\text{nbrcol=10}
\integer{nbrli=ceil(\nbrtest/\nbrcol)}
\integer{delad=(\confparm2==)?1:\confparm2}
\integer{temaxxx=1000}
\integer{delamax=(\confparm3==)?1:\confparm3}

\text{listegraph=<img src="\imagedir/tempsreactiongood.png" alt="Temps de réaction">,<img src="\imagedir/tempsreactionbat.png" alt="Temps de réaction">,<img src="\imagedir/tempsreactioncir.png" alt="Temps de réaction">,<img src="\imagedir/tempsreactioncir1.png" alt="Temps de réaction">}
\text{li=shuffle(4)}
\text{listegraphmixe=\listegraph[\li[1]],\listegraph[\li[2]],\listegraph[\li[3]],\listegraph[\li[4]]}
\integer{rep=position(1,\li)}

\integer{ncla=10}
\text{inte=wims(values x*100 for x = 0 to \ncla)}
\text{ccc=wims(values x*100+50 for x = 0 to \ncla)}

\text{listetrie=}
\matrix{nbrinter=}
\integer{nbrinter1=0}
\integer{nbrinter1=0}
\integer{nbrinter1=0}
\integer{nbrinter2=0}
\integer{nbrinter3=0}
\integer{nbrinter4=0}
\integer{nbrinter5=0}
\integer{nbrinter6=0}
\integer{nbrinter7=0}
\integer{nbrinter8=0}
\integer{nbrinter9=0}
\integer{nbrinter10=0}

\integer{vmin=0}
\integer{vmax=1000}
\integer{cmmin=0}
\integer{cmmax=50}
\integer{ver=0}

\text{A=}

\real{moyy=}
\integer{eten=}
\integer{me=}
\real{eccmed=}

\matrix{nbrinter=}
\matrix{rnbr=}
\matrix{ecc=}
