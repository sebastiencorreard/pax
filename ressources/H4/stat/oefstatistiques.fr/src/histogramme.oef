\answer{}{\min}{type=numeric}{option=nonstop noanalyzeprint hide}
\condition{Valeur minimum \vmin }{\min=\vmin}
\answer{}{\max}{type=numeric}{option=nonstop noanalyzeprint hide}
\condition{Valeur maximum \vmax}{\max=\vmax}
