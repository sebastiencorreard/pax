\title{Médicament et Placebo(bug)}
\language{fr}
\range{-5..5}
\author{Moďse, Muller}
\email{Julien.Lyotard@ac-dijon.fr}

debug
\moyB <br>
maxiB=\maxiB;
miniB=\miniB;medianB=\medianB;sigmaB=\sigmaB;sigmaB[3;1]=\sigmaB[3;1];Q1B=\Q1B;Q3B=\Q3B;Q1G=\Q1G;Q3G=\Q3G

\computeanswer{no}
\format{html}
\precision{10000000}

\text{listequestion= wims(makelist r x for x = 1 to 6)}
\text{listequestion2= wims(makelist r x for x = 7 to 16)}
\matrix{STEP= \listequestion
\listequestion2}
\steps{\STEP}

\matrix{At=slib(stat/normal 50,1.569,0.086)}
\matrix{B=}
\for{gg=1 to 50}{
\integer{zz=\At[1;\gg]*100}
\real{z=\zz/100}
\matrix{B=wims(append item \z to \B)}}
\matrix{Ba=wims(replace internal , by ; in \B)}
\matrix{Ba=wims(replace internal . by , in \Ba)}
\real{moyB=item(1,slib(stat/arithmean \B))}
\text{listeB=wims(sort  numeric item \B)}
\text{maxiB=wims(item -1 of  \listeB)}
\text{miniB=wims(item 1 of  \listeB)}
\real{medianB=slib(stat/median [\B])}
\matrix{sigmaB=slib(stat/covariance [\B])}
\integer{sigmB=sqrt(\sigmaB[3;1])*10000}
\real{sigmB=\sigmB/10000}
\real{Q1B=(\listeB[ceil(50/4)]+1/4*(\listeB[ceil(50/4+1)]-\listeB[ceil(50/4)]))}
\real{Q3B=\listeB[ceil(3*50/4)]-1/4*(\listeB[ceil(3*50/4)]-\listeB[ceil(3*50/4-1)])}
\integer{miniiB=\miniB*100}
\real{miniiiB=\miniiB/100}
\integer{mediannB=\medianB*100}
\real{mediannnB=\mediannB/100}
\integer{Q33B=\Q3B*100}
\real{Q333B=\Q33B/100}
randint(1..2)

\integer{eff=2}
\integer{vaeff=2}
\real{nono=(\eff=1)?1.25:1.482}
\real{vanono=(\vaeff=1)?0.02:0.1689}
\integer{repeff=((\eff=1) or (\vaeff=1))?1:2}
\text{justeff=(\eff=1)?1,2}
\text{justeff=(\vaeff=1)?3,4}
\text{justeff=((\eff=1) and (\vaeff=1))?1,2,3,4}
\text{justeff=((\eff=2) and (\vaeff=2))?7,8,9}

\matrix{G1=slib(stat/normal 25,\nono,\vanono)}
\matrix{G=}
\for{gg=1 to 25}{
\integer{zz=\G1[1;\gg]*100}
\real{z=\zz/100}
\matrix{G=wims(append item \z to \G)}}
\matrix{Ga=wims(replace internal , by ; in \G)}
\matrix{Ga=wims(replace internal . by , in \Ga)}
\real{moyG=item(1,slib(stat/arithmean \G))}
\text{listeG=wims(sort  numeric item \G)}
\text{maxiG=wims(item -1 of  \listeG)}
\text{miniG=wims(item 1 of  \listeG)}
\matrix{medianG=slib(stat/median [\G])}
\matrix{sigmaG=slib(stat/covariance [\G])}
\integer{sigmG=sqrt(\sigmaG[3;1])*10000}
\real{sigmG=\sigmG/10000}
\real{Q1G=(\listeG[ceil(25/4)])}
\real{Q3G=(\listeG[ceil(3*25/4)])}
\integer{moyyG=\moyG*10000}
\real{moyyyG=\moyyG/10000}
\integer{miniiG=\miniG*100}
\real{miniiiG=\miniiG/100}
\integer{Q11G=\Q1G*100}
\real{Q111G=\Q11G/100}
\integer{mediannG=\medianG*100}
\real{mediannnG=\mediannG/100}
\integer{Q33G=\Q3G*100}
\real{Q333G=\Q33G/100}
\integer{maxiiG=\maxiG*100}
\real{maxiiiG=\maxiiG/100}


\matrix{G2=slib(stat/normal 25,1.482,0.1689)}
\matrix{GG=}
\for{gg=1 to 25}{
\integer{zz=\G2[1;\gg]*100}
\real{z=\zz/100}
\matrix{GG=wims(append item \z to \GG)}}
\matrix{GGa=wims(replace internal , by ; in \GG)}
\matrix{GGa=wims(replace internal . by , in \GGa)}
\real{moyGG=item(1,slib(stat/arithmean \GG))}
\text{listeGG=wims(sort  numeric item \GG)}
\text{maxiGG=wims(item -1 of  \listeGG)}
\text{miniGG=wims(item 1 of  \listeGG)}
\real{medianGG=slib(stat/median [\GG])}
\matrix{sigmaGG=slib(stat/covariance [\GG])}
\integer{sigmGG=sqrt(\sigmaGG[3;1])*10000}
\real{sigmGG=\sigmGG/10000}
\real{Q1GG=(\listeGG[ceil(25/4)])}
\real{Q3GG=(\listeGG[ceil(3*25/4)])}

\matrix{pbm=14,9,4}
\text{script= var brd = JXG.JSXGraph.initBoard('jxgbox', {
axis:false,boundingbox: [0.8, 20, 2, -2], grid:true, shownavigation:false});
 xaxis = brd.create('axis', [[0, 0], [1, 0]], { 
 ticks: { ticksDistance: 0.1,  insertTicks: false}});
yaxis = brd.create('axis', [[-1000, 0], [-1000, 1]],{
 ticks: { ticksDistance:1,  insertTicks: false}});
brd.create('text',[1.2,18,"Diagramme en boîte ŕ moustaches" ],{fontSize:30});
brd.create('text',[0.8,\pbm[2],"Placebo"],{fontSize:20});
jxgbox_rep1 = brd.create('point',jxgbox_var1, {face:'o', name:'Déplace moi', size:2, showInfobox: true});
jxgbox_rep2 = brd.create('point',jxgbox_var2, {face:'o', name:'', size:2, showInfobox: true});
jxgbox_rep3 = brd.create('point',jxgbox_var3, {face:'o', name:'', size:2, showInfobox: true});
jxgbox_rep4 = brd.create('point',jxgbox_var4, {face:'o', name:'', size:2, showInfobox: true});
jxgbox_rep5 = brd.create('point',jxgbox_var5, {face:'o', name:'', size:2, showInfobox: true});
brd.on('move', function(){
jxgbox_rep1.moveTo([ Math.min(jxgbox_rep1.X(),jxgbox_rep2.X()), \pbm[2]]);
jxgbox_rep2.moveTo([Math.min(jxgbox_rep2.X(),jxgbox_rep3.X()), \pbm[2]]);
jxgbox_rep3.moveTo([Math.min(jxgbox_rep3.X(),jxgbox_rep4.X()), \pbm[2]]);
jxgbox_rep4.moveTo([Math.min(jxgbox_rep4.X(),jxgbox_rep5.X()), \pbm[2]]);
jxgbox_rep5.moveTo([Math.max(jxgbox_rep4.X(),jxgbox_rep5.X()), \pbm[2]]);
});
jxgbox_rep11 = brd.create('point',[function(){return jxgbox_rep1.X()},\pbm[2]+1], {face:'o', name:'', size:2, showInfobox: true,visible:false});
jxgbox_rep111 = brd.create('point',[function(){return jxgbox_rep1.X()},\pbm[2]-1], {face:'o', name:'', size:2, showInfobox: true,visible:false});
jxgbox_rep55 = brd.create('point',[function(){return jxgbox_rep5.X()},\pbm[2]+1], {face:'o', name:'', size:2, showInfobox: true,visible:false});
jxgbox_rep555 = brd.create('point',[function(){return jxgbox_rep5.X()},\pbm[2]-1], {face:'o', name:'', size:2, showInfobox: true,visible:false});
jxgbox_rep22 = brd.create('point',[function(){return jxgbox_rep2.X()},\pbm[2]+2], {face:'o', name:'', size:2, showInfobox: true,visible:false});
jxgbox_rep222 = brd.create('point',[function(){return jxgbox_rep2.X()},\pbm[2]-2], {face:'o', name:'', size:2, showInfobox: true,visible:false});
jxgbox_rep33 = brd.create('point',[function(){return jxgbox_rep3.X()},\pbm[2]+2], {face:'o', name:'', size:2, showInfobox: true,visible:false});
jxgbox_rep333 = brd.create('point',[function(){return jxgbox_rep3.X()},\pbm[2]-2], {face:'o', name:'', size:2, showInfobox: true,visible:false});
jxgbox_rep44 = brd.create('point',[function(){return jxgbox_rep4.X()},\pbm[2]+2], {face:'o', name:'', size:2, showInfobox: true,visible:false});
jxgbox_rep444 = brd.create('point',[function(){return jxgbox_rep4.X()},\pbm[2]-2], {face:'o', name:'', size:2, showInfobox: true,visible:false});
brd.create('line',[jxgbox_rep1,jxgbox_rep2],{straightFirst:false, straightLast:false});
brd.create('line',[jxgbox_rep4,jxgbox_rep5],{straightFirst:false, straightLast:false});
brd.create('line',[jxgbox_rep11,jxgbox_rep111],{straightFirst:false, straightLast:false});
brd.create('line',[jxgbox_rep55,jxgbox_rep555],{straightFirst:false, straightLast:false});
brd.create('line',[jxgbox_rep22,jxgbox_rep222],{straightFirst:false, straightLast:false});
brd.create('line',[jxgbox_rep33,jxgbox_rep333],{straightFirst:false, straightLast:false});
brd.create('line',[jxgbox_rep44,jxgbox_rep444],{straightFirst:false, straightLast:false});
brd.create('line',[jxgbox_rep22,jxgbox_rep44],{straightFirst:false, straightLast:false});
brd.create('line',[jxgbox_rep222,jxgbox_rep444],{straightFirst:false, straightLast:false})
brd.create('text',[0.8,\pbm[1],"Avant traitement"],{fontSize:20});
miniB = brd.create('point',[\miniB,\pbm[1]], {face:'+', name:'', size:4, showInfobox: true,fixed:true});
miniBh = brd.create('point',[\miniB,\pbm[1]+1], {name:'',visible:false});
miniBb = brd.create('point',[\miniB,\pbm[1]-1], {name:'',visible:false});
brd.create('line',[miniBh,miniBb],{straightFirst:false, straightLast:false});
Q1B = brd.create('point',[\Q1B,\pbm[1]], {face:'+', name:'', size:4, showInfobox: true,fixed:true});
Q1Bh = brd.create('point',[\Q1B,\pbm[1]+2], {name:'', visible:false});
Q1Bb = brd.create('point',[\Q1B,\pbm[1]-2], {name:'', visible:false});
brd.create('line',[Q1Bh,Q1Bb],{straightFirst:false, straightLast:false});
brd.create('line',[Q1B,miniB],{straightFirst:false, straightLast:false});
medianB = brd.create('point',[\medianB,\pbm[1]], {face:'+', name:'', size:4, showInfobox: true,fixed:true});
medianBh = brd.create('point',[\medianB,\pbm[1]+2], {name:'', visible:false});
medianBb = brd.create('point',[\medianB,\pbm[1]-2], {name:'', visible:false});
brd.create('line',[medianBh,medianBb],{straightFirst:false, straightLast:false});
Q3B = brd.create('point',[\Q3B,\pbm[1]], {face:'+', name:'', size:4, showInfobox: true,fixed:true});
Q3Bh = brd.create('point',[\Q3B,\pbm[1]+2], {name:'', visible:false});
Q3Bb = brd.create('point',[\Q3B,\pbm[1]-2], {name:'', visible:false});
brd.create('line',[Q3Bh,Q3Bb],{straightFirst:false, straightLast:false});
brd.create('line',[Q3Bh,Q1Bh],{straightFirst:false, straightLast:false});
brd.create('line',[Q3Bb,Q1Bb],{straightFirst:false, straightLast:false});
maxiB = brd.create('point',[\maxiB,\pbm[1]], {face:'+', name:'', size:4, showInfobox: true,fixed:true});
brd.create('line',[Q3B,maxiB],{straightFirst:false, straightLast:false});
maxiBh = brd.create('point',[\maxiB,\pbm[1]+1], {name:'',visible:false});
maxiBb = brd.create('point',[\maxiB,\pbm[1]-1], {name:'',visible:false});
brd.create('line',[maxiBh,maxiBb],{straightFirst:false, straightLast:false});
}

