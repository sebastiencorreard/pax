!set title=Urne double 1
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Jean-Luc, Donadoni
email=jluc.donadoni@laposte.net
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=38
prevarcnt=37
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!shuffle 5

val6=$(tmp0)
val7=<span style="color:#0000FF"> (B)</span>,<span style="color:#FFFF00"> (J)</span>,<span style="color:#000000"> (N)</span>,<span style="color:#00FF00"> (V)</span>,<span style="color:#FF0000"> (R)</span>
val8=bleues (B),jaunes (J),noires (N),vertes (V),rouges (R)
val9=bleue (B),jaune (J),noire (N),verte (V),rouge (R)
val10=(A),(B),(C),(D),(E),(F),(G),(H),(I),(J),(K),(L),(M),(N)
tmp0=!randint 5, 14

val11=$[rint($(tmp0))]
tmp0=!item 1 to $val11 of $val10

val10=$(tmp0)
tmp0=!shuffle $val10

val12=$(tmp0)
tmp0=!randint 8, 16

val13=$[rint($(tmp0))]
tmp0=!randint 1, $val13-3

val14=$[rint($(tmp0))]
tmp0=!randint 1, $val13-$val14

val15=$[rint($(tmp0))]
val16=$[rint($val13-$val14-$val15)]
!if $val16<>0 
tmp0=!randint 1, $val13-$val14-$val15

val16=$[rint($(tmp0))]
!endif
val17=$[rint($val13-$val14-$val15-$val16)]
val18=$val14,$val15,$val16,$val17
!if $val16=0 
val19=$[rint(2)]
!else
!if $val17=0 
val19=$[rint(3)]
!else
val19=$[rint(4)]
!endif
!endif
val20=
val21=$(val7[$(val6[1])])
!for val22 =2 to $val14 
val21=$val21,$(val7[$(val6[1])])
!next
!for val22 =1 to $val15 
val21=$val21,$(val7[$(val6[2])])
!next
!if $val16<>0 
!for val22 =1 to $val16 
val21=$val21,$(val7[$(val6[3])])
!next
!endif
!if $val17<>0 
!for val22 =1 to $val17 
val21=$val21,$(val7[$(val6[4])])
!next
!endif
tmp0=!shuffle $val21

val21=$(tmp0)
!for val23 =1 to $val19-1 
!if $(val18[$val23])=1 
val20=$val20 $(val18[$val23]) boule $(val9[$(val6[$val23])]),
!else
val20=$val20 $(val18[$val23]) boules $(val8[$(val6[$val23])]),
!endif
!next
!if $(val18[$val19])=1 
val20=$val20 et $(val18[$val19]) boule $(val9[$(val6[$val19])])
!else
val20=$val20 et $(val18[$val19]) boules $(val8[$(val6[$val19])])
!endif
t_=!replace internal \( by ( in ($val14)/($val13)
tmp0=!exec maxima $t_

val24=$(tmp0)
t_=!replace internal \( by ( in 1/($val11)
tmp0=!exec maxima $t_

val25=$(tmp0)
t_=!replace internal \( by ( in $val24*$val25
tmp0=!exec maxima $t_

val26=$(tmp0)
replytype1=numexp
replyoption1=noreduction 
replyname1=
replygood1=$val26
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<table class="wimscenter" border="5" style="width:320px; height:120px">	<tr><td><strong>$val21 </strong></td>	<td></td>	<td><strong>$val12 </strong></td>	</tr></table>	<ul><li>	Dans une premičre urne, nous avons $val20, indiscernables au toucher.	</li><li> Dans une deuxičme urne, nous avons $val11 boules marquées avec les lettres de (A) ŕ $(val10[$val11]), indiscernables au toucher.	</li><li> Nous tirons une boule dans la premičre urne et une boule dans la deuxičme urne.	</li></ul>	<div class="spacer">	<label for="reply1">La probabilité de tirer une boule $(val9[$(val6[1])]) et une boule avec la lettre	$(val12[3]) =</label>  
!read oef/embed.phtml r1,5 
$()</div>	<div class="wims_instruction">	Vous donnerez les résultats sous la forme de fractions.	</div>	
$()
