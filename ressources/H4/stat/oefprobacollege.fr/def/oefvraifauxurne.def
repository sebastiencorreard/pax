val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!shuffle 5

val6=$(tmp0)
val7=<span style="color:#0000FF"> (B)</span>,<span style="color:#FFFF00"> (J)</span>,<span style="color:#000000"> (N)</span>,<span style="color:#00FF00"> (V)</span>,<span style="color:#FF0000"> (R)</span>
val8=bleues (B),jaunes (J),noires (N),vertes (V),rouges (R)
val9=bleue (B),jaune (J),noire (N),verte (V),rouge (R)
tmp0=!randint 8, 16

val10=$[rint($(tmp0))]
tmp0=!randint 1, $val10/2

val11=$[rint($(tmp0))]
val12=$[rint($val10-$val11)]
val13=$val11,$val12
val14=
val15=$(val7[$(val6[1])])
!for val16 =2 to $val11 
val15=$val15,$(val7[$(val6[1])])
!next
!for val16 =1 to $val12 
val15=$val15,$(val7[$(val6[2])])
!next
tmp0=!shuffle $val15

val15=$(tmp0)
val17=$[rint(2)]
!for val18 =1 to $val17-1 
!if $(val13[$val18])=1 
val14=$val14 $(val13[$val18]) boule $(val9[$(val6[$val18])]),
!else
val14=$val14 $(val13[$val18]) boules $(val8[$(val6[$val18])]),
!endif
!next
!if $(val13[$val17])=1 
val14=$val14 et $(val13[$val17]) boule $(val9[$(val6[$val17])])
!else
val14=$val14 et $(val13[$val17]) boules $(val8[$(val6[$val17])])
!endif
val19=vrai,faux,je ne sais pas
!if $val11=$val12 
val20=$[rint(1)]
!else
val20=$[rint(2)]
!endif
val21=$[rint($val11/$val10*100)]
val22=$[rint($val12/$val10*100)]
!if $val11<$val12 
val23=$[rint($val11/$val12*100)]
!else
val23=$[rint($val12/$val11*100)]
!endif
val24=$val21,$val22,$val23
tmp0=!randint 1, 3

val25=$[rint($(tmp0))]
!if $val25=1 
val26=$[rint(1)]
!else
val26=$[rint(2)]
!endif
!if $val21=$val22 
val26=$[rint(1)]
!endif
!if $val25=3 
val26=$[rint(2)]
!endif
val24=$(val24[$val25])
replytype1=radio
replyname1=
replygood1=$val20;$val19
replytype2=radio
replyname2=
replygood2=1;$val19
replytype3=radio
replyname3=
replygood3=$val26;$val19
replytype4=radio
replyname4=
replygood4=2;$val19
question=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

