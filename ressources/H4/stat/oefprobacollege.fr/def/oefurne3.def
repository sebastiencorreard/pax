!set title=Urne 3
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Jean-Luc, Donadoni
email=jluc.donadoni@laposte.net
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=no
precision=10000

ansorder=r
varcnt=34
prevarcnt=32
postvarcnt=1
replycnt=1
choicecnt=0
conditioncnt=1
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!shuffle 5

val6=$(tmp0)
val7=<span style="color:#0000FF"> (B)</span>,<span style="color:#FFFF00"> (J)</span>,<span style="color:#000000"> (N)</span>,<span style="color:#00FF00"> (V)</span>,<span style="color:#FF0000"> (R)</span>
val8=bleues (B),jaunes (J),noires (N),vertes (V),rouges (R)
val9=bleue (B),jaune (J),noire (N),verte (V),rouge (R)
tmp0=!randint 8, 16

val10=$[rint($(tmp0))]
tmp0=!randint 1, $val10-3

val11=$[rint($(tmp0))]
tmp0=!randint 1, $val10-$val11

val12=$[rint($(tmp0))]
val13=$[rint($val10-$val11-$val12)]
!if $val13<>0 
tmp0=!randint 1, $val10-$val11-$val12

val13=$[rint($(tmp0))]
!endif
val14=$[rint($val10-$val11-$val12-$val13)]
val15=$val11,$val12,$val13,$val14
!if $val13=0 
val16=$[rint(2)]
!else
!if $val14=0 
val16=$[rint(3)]
!else
val16=$[rint(4)]
!endif
!endif
val17=
val18=$(val7[$(val6[1])])
!for val19 =2 to $val11 
val18=$val18,$(val7[$(val6[1])])
!next
!for val19 =1 to $val12 
val18=$val18,$(val7[$(val6[2])])
!next
!if $val13<>0 
!for val19 =1 to $val13 
val18=$val18,$(val7[$(val6[3])])
!next
!endif
!if $val14<>0 
!for val19 =1 to $val14 
val18=$val18,$(val7[$(val6[4])])
!next
!endif
tmp0=!shuffle $val18

val18=$(tmp0)
!for val20 =1 to $val16-1 
!if $(val15[$val20])=1 
val17=$val17 $(val15[$val20]) boule $(val9[$(val6[$val20])]),
!else
val17=$val17 $(val15[$val20]) boules $(val8[$(val6[$val20])]),
!endif
!next
!if $(val15[$val16])=1 
val17=$val17 et $(val15[$val16]) boule $(val9[$(val6[$val16])])
!else
val17=$val17 et $(val15[$val16]) boules $(val8[$(val6[$val16])])
!endif
val21=$[rint($val11/$val10*1000)]
val21=$[$val21/1000]
replytype1=raw
replyname1=reponse
replygood1=?analyze 22
question=__EXECUTED_1692754_EXERCISE__
solution=!nosubst La bonne réponse est $val21


!goto stat

!exit

:question
$()	<table class="wimscenter" border="5" style="width:140px; height:120px">	<tr><td><strong>$val18 </strong></td></tr>	</table>	<p> Dans une urne, nous avons $val17, indiscernables au toucher.</p>	<p>Quelle est la probabilité de tirer une boule $(val9[$(val6[1])])?</p>	<div class="spacer">	<label for="reply1">	La probabilité (sous forme d'un nombre décimal arrondi au milličme) =	</label> 
!read oef/embed.phtml r1,6 
$() </div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()La bonne réponse est $val21
$()
!exit

:latex
$()
$()
!exit

:postdef
tmp0=!translate , to . in $val22

val22=$(tmp0)

!exit

:feedback

!exit

:test

!ifval $val22=$val21
 condtest1=1
!else
 condtest1=0
!endif
condname1=Votre réponse

!exit

:stat
vsavelist=6,9,17,18,21,22
embedcnt=1
