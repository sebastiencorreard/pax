maximaal=!recordcnt lang/questions.$taal
num=!randint 1,$maximaal
vragen=!record $num of lang/questions.$taal
#vraagjes=!record 1 of nivo/vragen
question=!item 1 of $vragen
answers=!item 2 to -1 of $vragen
answers=!shuffle $answers

!for p=1 to 4
    image$p=!item $p of $answers
    !if @ isin $(image$p)
	myvar12=$p
	image$p=!replace internal @ by $empty in $(image$p)
    !endif
!next p    

