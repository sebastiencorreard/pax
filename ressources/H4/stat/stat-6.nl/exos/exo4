# CHECKFILE AANPASSEN : DECIMALE GETALLEN MET EEN KOMMA CORRIGEREN !!!
math=0
mathview=0
# spreadsheet gemiddelde van een kolom
n=$counter
tsv_file=som_$counter.tsv
datum=!date +%d-%m-%Y
data=$datum\
$wims_firstname $wims_lastname\
$module_title\
\
"cijfer"	"aantal leerlingen"\


sum=0
rnd=!randitem 1,2
rounding=$[10^$rnd]
leerling=0
!for d1=1 to 10
 d2=!randint 1,4
 sum=$[$sum + $d1*$d2]
 leerling=$[$leerling + $d2]
 data=!append line $d1	$d2 to $data
!next p

answer$n=$[(round($rounding*$sum/$leerling))/$rounding]

!filewrite getfile/$tsv_file $data

helptext=Als je met Windows EXCEL werkt en deze niet automatisch een \'tsv\' bestand wil openen...via OPENEN MET...zoeken naar  EXCEL.EXE in \'Program Files ... Microsoft Office ... Office16 ... EXCEL.EXE\' <hr />werk je met Apple of een vrije Unix variant...zal OPEN OFFICE het \'tsv\' bestand vermoedelijk automatisch openen...

mousetxt=Bewaar het bestand \'$tsv_file\' als een \'tsv\' bestandstype.<br />bijvoorbeeld \'$tsv_file\' of \'wims.tsv\'<br />Of open dit bestand direkt in je spreadsheet programma<br />bijvoorbeeld \'MS Excel\', \'OpenOffice Calc\' of een online-spreadsheet  als je een <a target=\'new\' href=\'https://docs.google.com/spreadsheets\'> Google account</a> hebt.<br />Bij gebruik van \'MS Excel\' zie <img src=$gifdir/tip.png />

ss=We gaan nu mbv een spreadsheet het <b>gewogen</b> gemiddelde berekenen van de behaalde cijfers in een klas.<br />\
In kolom A staan de cijfers...in kolom B staan de aantallen leerlingen die het betreffende cijfer hebben behaald.<br /><br />\
Open <a href="$wims_ref_name?session=$session&cmd=getfile&special_parm=$tsv_file" download="$tsv_file"><b>deze data</b></a> in 'tsv' formaat met je spreadsheet programma.<br />\
<em>Let op dat je het spreadsheet in schrijfmode opent en niet in read-only</em><br /><br />\
Bereken het gewogen gemiddelde van de getallen in kolom A.<br />Rond dit antwoord af op $rnd decimalen.<br />\
Stuur dit antwoord op naar WIMS als antwoord.
 



textanswer$n=<ul>\
<li>open het bestand </li>\
<li>ga met je muis in <b>B17</b> staan</li>\
<li>bereken de som van kolom B...in formulebalk : = SOM(B7:B16) [ENTER] <br />(dit is het totaal aantal leerlingen in die klas)</li>\
<li>ga met je muis in C7 staan...in formulebalk : = A7*B7  [ENTER]</li>\
<li>ga met je muis rechts onderin C7 staan...je muis wordt een kruis<br />en scroll naar C16 </li>\
<li>ga met je muis in C17 staan...in formulebalk : = SOM(C7:C16) [ENTER]</li>\
<li>ga met je muis bijv. in C18 staan...in formulebalk : = C17/B17 [ENTER]</li>\
<li>rond dit getal af op $rnd decimalen<br />\
Dit kan ook mbv van de spreadsheet...in formulebalk : <b>= AFRONDEN(SOM(C7:C16)/B17;$rnd)</b> [ENTER] </li>\
<li>Let op: als je Engels als taal hebt : <b>= ROUND(SUM(C7:C16)/B17;$rnd)</b> [ENTER]</li>\
</ul>

checkfile=$checkdir/number.proc
var1=yes
inputs=1.1
cols=5
rows=10
make_tr=1
description=Gewogen gemiddelde cijfer :
ex1=$empty 
question$n=<a onmouseover="return escape('$mousetxt')">$ss</a>

!exit

