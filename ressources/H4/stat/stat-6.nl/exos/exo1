math=0
mathview=0
questiontype=7
javascript=js/spreadsheet.phtml
inputs=yes
cols=5
rows=10

# spreadsheet en optellen van kolommen
n=$counter
tsv_file=som_$counter.tsv

datum=!date +%d-%m-%Y
data=$datum\
$wims_firstname $wims_lastname\
spreadsheet en optellen van kolommen\
\
"kolom 1"	"kolom 2"\


var8=1
var7=kolom A,kolom B,kolom C
var5=$empty
sum=$empty
calc_data=$empty
var6=!randint 8,10
tabel_ans=<table class="demospecial"><tr><th>kolom A</th><th>kolom B</th><th>kolom C</th></tr>
!for p=1 to $var6
 d1=!randint 1,99
 d2=!randint 1,99
 d3=$[$d1 + $d2]
 sum=!append item $d3 to $sum
 data=!append line $d1	$d2 to $data
 var5=!append word $d1,$d2 to $var5
 tabel_ans=!append word <tr><td>$d1</td><td>$d2</td><td>$d3</td></tr> to $tabel_ans
!next p
tabel_ans=!append word </table> to $tabel_ans
answer$n=$sum
!filewrite getfile/$tsv_file $data

