#:10 Spreadsheet &amp; frequentietabel [woorden]
# var6 = max1,max2,max3... (aantal cellen in een kolom)
# var5 = A1,B1 A2,B2 ... Amax,Bmax
# var7 = head Kolom A,Kolom B ,Kolom C
# var8 = aantal invoer kolommen.
var1=yes
questiontype=7
javascript=js/spreadsheet.phtml
inputs=yes
cols=5
math=0
mathview=0

# Spreadsheet &amp; berekenen van de standaardafwijking
n=$counter
k=!randitem 1,2
!if $k=1
 type=autos 
 autos=!shuffle Mercedes,Citroen,Volvo,VW,BMW,Chrysler,Honda,Suzuki,Zastava,Daihatsu,Lada,Skoda,Fiat,Seat,Buick,MG,Landrover,Jaguar,Peugeot,Ford,Toyota,Mazda,Subaru
!else
 type=motorfietsen
 autos=!shuffle Ducati,MotoGuzzi,Benelli,Laverda,BiMota,Honda,Suzuki,Kawasaki,Yamaha,Voxan,Bultaco,UralDnepr,Voskod,Montesa,Ossa,Malagutti,MotoMorini,BMW,MZ,BSA,NORTON,Triumph,Cagiva
!endif

nums=!randint 5,8
tsv_file=som_$counter.$wims_nowseconds.tsv
datum=!date +%d-%m-%Y

data=$datum\
$wims_firstname $wims_lastname\
spreadsheet en frequentietabel\
\
"$type"	"  merken   "	"frequentie"\

rounding=0
freq=$empty
var5=$empty
showans=<table class="demospecial"><tr><th>$type</th><th>freq</th></tr>
lijst=$empty
num=0
!for a=1 to $nums
 aantal=!randint 1,10
 merk=!item $a of $autos
 freq=!append item $aantal to $freq
 showans=!append word $ <tr><th>$merk</th><th>$aantal</th></tr> $ to $showans
 var5=!append word $ $merk $ to $var5
 !for i=1 to $aantal
  lijst=!append item $merk to $lijst 
  !increase num
 !next i
!next a
showans=!append word $ </table> $ to $showans
lijst=!shuffle $lijst

!if $wims_user=supervisor
 !for p=1 to $num
  !if $p<= $nums
   data=!append line "$(lijst[$p])"	"$(autos[$p])"	$(freq[$p]) to $data
  !else
   data=!append line "$(lijst[$p])"		$(freq[$p]) to $data  
  !endif
 !next p
!else
 !for p=1 to $num
  !if $p <= $nums
   data=!append line "$(lijst[$p])"	"$(autos[$p])" to $data
  !else
   data=!append line "$(lijst[$p])"  to $data  
  !endif
 !next p
!endif
answer$n=$freq
var7=merk,frequentie
var6=$nums
var8=1
!filewrite getfile/$tsv_file $data

