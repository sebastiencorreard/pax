 begin=$[0.01*$ph1]
 klasse= $begin &minus; $[0.01*$ph1+0.4]
 # [ 5.5-5.9 ]
 k1=$[$begin-0.05]
 k2=$[$begin-0.05+0.5]
 k3=$[$begin-0.05+1]
 k4=$[$begin-0.05+1.5]
 k5=$[$begin-0.05+2]
 k6=$[$begin-0.05+2.5]
 k7=$[$begin-0.05+3]
 k8=$[$begin-0.05+3.5]
 k9=$[$begin-0.05+4]
 kk=9
!endif
t=!randint 2,8
r=!randint 20,50
dump_start=$[round($num/$t)]
dump_end=$[$dump_start+$r]
datum=!date %d-%m-%Y

data=Meetgegevens station 21\
datum $datum\
begin 0:00\
eind 23:59\
bewerkt door: $wims_firstname $wims_lastname\
\
"meting"	"ph-waarde"\




calc_data=$empty
ph_min=10
ph_max=0
!for p=1 to $num
 ph=!randint $ph1,$ph2
 !if $p>=$dump_start
  !if $p<= $dump_end
   ph=!randint $lozing1,$lozing2
  !endif
 !endif
 ph=$[0.01*$ph]
 !if $ph > $ph_max
  ph_max=$ph
 !endif
 !if $ph < $ph_min
  ph_min=$ph
 !endif
 PH=!replace internal . by , in $ph
 data=!append line "meting $p"	$PH to $data
 calc_data=!append item $ph to $calc_data
!next p

!filewrite getfile/$tsv_file $data

sortdata=!sort numeric item $calc_data
!for p=1 to $kk
 klasse$p=0
!next p
!for p=1 to $num
 d=!item $p of $sortdata
 !for k=1 to $kk
  s=$(k$k)
  !if $d >= $s and $d < $[$s+0.5] 
   !increase klasse$k
  !endif
 !next k
!next p

ymax=0
staaf=$empty
body=$empty
textansw=$empty
answer$n=$empty
var5=$empty
!for p=1 to $kk
 answer$n=!append item $(klasse$p) to $(answer$n)
 !if $(klasse$p)>$ymax
  ymax=$(klasse$p)
 !endif
 s=$(k$p)
 # kl=linker grens kr=rechter grens
 kl=$[$s+0.05]
 kr=$[$s+0.45]
 staaf=!append item $kl,$(klasse$p),$kr,0 to $staaf
 body=!append word <tr id="mytr$[$p-1]"><td>$kl &minus $kr</td><td><input class="schaersvoorde_input" size="4" id="myinput$[$p-1]" value=""></td></tr>  to $body
 var5=!append word $ $kl&minus;$kr $ to $var5
 textans=!append word <tr id="mytr$[$p-1]"><td>$kl &minus; $kr</td><td>$(klasse$p)</td></tr>  to $textans
!next p

