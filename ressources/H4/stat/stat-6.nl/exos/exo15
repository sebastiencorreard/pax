dag=!randint 2,4
min=!randitem 10,15,20,30
num=$[$dag*24*60/$min]
k=!randint 0,1
ph1=550
ph2=750
!if $k=1
 lozing1=250
 lozing2=550
 begin=$[0.01*$lozing1]
 klasse=$begin &minus; $[0.01*$lozing1+0.4]
 # [ 2.5-2.9 ]
 k1=$[$begin-0.05]
 k2=$[$begin-0.05+0.5]
 k3=$[$begin-0.05+1]
 k4=$[$begin-0.05+1.5]
 k5=$[$begin-0.05+2]
 k6=$[$begin-0.05+2.5]
 k7=$[$begin-0.05+3]
 k8=$[$begin-0.05+3.5]
 k9=$[$begin-0.05+4]
 k10=$[$begin-0.05+4.5]
 k11=$[$begin-0.05+5]
 kk=11
!else
 lozing1=750
