#:10 Spreadsheet &amp; frequentietabel [getallen]
# var6 = max1,max2,max3... (aantal cellen in een kolom)
# var5 = A1,B1 A2,B2 ... Amax,Bmax
# var7 = head Kolom A,Kolom B ,Kolom C
# var8 = aantal invoer kolommen.
var1=yes
questiontype=7
javascript=js/spreadsheet.phtml
inputs=yes
cols=5
math=0
mathview=0

# Spreadsheet &amp; berekenen van de standaardafwijking
n=$counter

tsv_file=som_$counter.$wims_nowseconds.tsv
datum=!date +%d-%m-%Y

data=$datum\
$wims_firstname $wims_lastname\
spreadsheet en frequentietabel\
\
"lichaamslengte in cm"	"klassen"	"rechtergrens"	"frequentie"\

rounding=1
datalist=$empty
diff=10
klassen=$empty
grens=$empty
lengtes=$empty
freq=$empty
num1=0
num2=0
var5=$empty
showans=<table class="demospecial"><tr><th>klasse</th><th>freq</th></tr>
!for p=150 to 211 step $diff
 rt=!randint 1,10
 rg=$[$p+$diff-1]
 klassen=!append item $p-$rg to $klassen
 var5=!append word $ $p-$rg $ to $var5
 grens=!append item $rg to $grens
 freq=!append item $rt to $freq
 showans=!append word $ <tr><th>$p &minus; $rg</th><th>$rt</th></tr> $ to $showans
 !increase num2
 !for t=1 to $rt
  L=!randint $p,$rg
  lengtes=!append item $L to $lengtes
  !increase num1
 !next t
!next p
showans=!append word $ </table> $ to $showans
answer$n=$freq
lengtes=!shuffle $lengtes

var7=klassen,frequentie
var6=$num2
var8=1

!if $wims_user=supervisor
 !for p=1 to $num1
  !if $p <= $num2
   data=!append line $(lengtes[$p])	$(klassen[$p])	$(grens[$p])	$(freq[$p]) $ to $data
  !else
   data=!append line $(lengtes[$p])	$ to $data
  !endif
 !next p
!else
 !for p=1 to $num1
  !if $p <= $num2
   data=!append line $(lengtes[$p])	$(klassen[$p])	$(grens[$p])	$ to $data
  !else
   data=!append line $(lengtes[$p])	$ to $data
  !endif
 !next p
!endif
!filewrite getfile/$tsv_file $data

