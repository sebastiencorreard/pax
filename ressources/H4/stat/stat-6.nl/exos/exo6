data=$datum\
$wims_firstname $wims_lastname\
spreadsheet en optellen van kolommen\
\
"cijfer"\


sum=0
var8=4
max=!randint 10,15
var6=$max
rows=$max
mean=!mathmlmath \overline{x}
sqrt=!mathmlmath \sqrt{\overline{x}}
diff=!mathmlmath x - \overline{x}
kwadraat=!mathmlmath \left( x - \overline{x} \right)^{2}
vari=!mathmlmath \frac{ \left( x- \overline{x} \right)^{2}}{$max}
sigma=!mathmlmath \sigma=\sqrt{ \frac{ \left( x - \overline{x} \right)^{2}}{$max}}

var7=A<br />cijfers,B<br />$diff,C<br />$kwadraat,het gemiddelde van C<br />(de variantie)<br />$vari,de wortel uit variantie<br />(de standaardafwijking)<br />$sigma
rnd=!randitem 1,2,3
rounding=$[10^$rnd]
datalist=$empty
!for p=1 to $max
 d1=!randint 19,99
 d1=$[0.1*$d1]
 sum=$[$sum + $d1]
 datalist=!append item $d1 to $datalist
!next p

mean=$[$sum/$max]
datalist=!sort numeric item of $datalist
variantie=0

kolomB=$empty
kolomC=$empty
!for p=1 to $max
 a=!item $p of $datalist
 var5=!append word $a to $var5
 aa=!replace internal . by , in $a
 data=!append line $aa to $data
 tussen1=$[$a-$mean]
 tussen2=$[$tussen1*$tussen1]
 variantie=$[$variantie + $tussen2]
 kolomB=!append item $tussen1 to $kolomB
 kolomC=!append item $tussen2 to $kolomC
!next p

vari=$[$variantie/$max]
std=$[sqrt($vari)]
strd=$[(round($rounding*$std))/$rounding]
# var8=4=aantal invoer kolommen

answer$n=$kolomB\
$kolomC\
$vari\
$strd

