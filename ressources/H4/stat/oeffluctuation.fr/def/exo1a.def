!set title=Intervalle de fluctuation#
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Thomas, Charon
email=thomas.charon@ac-lyon.fr
language=fr
leftrange=-5.000000
rightrange=5.000000
computeanswer=yes
precision=10000

ansorder=r,r,r
varcnt=28
prevarcnt=27
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randitem 25,64,100,400,625,1600,2500

val6=$[rint($(tmp0))]
tmp0=!randint 26, 1000

val7=$[rint($(tmp0))]
tmp0=!randint 5, 24

val8=$[rint($(tmp0))]
tmp0=!randitem $val6,$val6,$val7,$val8

val9=$[rint($(tmp0))]
tmp0=!randint 5, 100

val9=$[rint($(tmp0))]
tmp0=!randint 1, 999

val10=$[rint($(tmp0))]
val11=$[$val10/1000]
!if $val2=2 
val12=$[$val11-1/sqrt($val9)]
val13=$[$val11+1/sqrt($val9)]
!else
!readproc slib/stat/binomialinv [0.025,0.975],$val9,$val11 
tmp0=$slib_out
val14=$(tmp0)
val12=$[$(val14[1])/$val9]
val13=$[$(val14[2])/$val9]
!endif
val15=$[floor(1000*$val12)/1000]
val16=$[ceil(1000*$val13)/1000]
!if $val2=2 

!ifval $val11<0.2
val17=$[rint( 0)]
!else
val17=$[rint(1)]
!endif

!ifval $val11>0.8
val18=$[rint( 0)]
!else
val18=$[rint(1)]
!endif

!ifval $val9<25
val19=$[rint( 0)]
!else
val19=$[rint(1)]
!endif
!else

!ifval $val11*$val9<5
val17=$[rint( 0)]
!else
val17=$[rint(1)]
!endif

!ifval (1-$val11)*$val9<5
val18=$[rint( 0)]
!else
val18=$[rint(1)]
!endif

!ifval $val9<30
val19=$[rint( 0)]
!else
val19=$[rint(1)]
!endif
!endif
val20=$[rint($val17*$val18*$val19)]
val21=$[rint($val20+1)]
val22=oui,non
val23=$[rint(-$val20+2)]
tmp=!trim reply 1
val24=!translate internal $	\
$ to ;; in $tmp
tmp=!trim reply 1	reply 2, reply 3
val25=!translate internal $	\
$ to ;; in $tmp

!ifval $val20=0
tmp=!trim  $val24 
val26=!translate internal $	\
$ to ;; in $tmp
!else
tmp=!trim  $val25
val26=!translate internal $	\
$ to ;; in $tmp
!endif
oefsteps=$val26 
nextstep=!nosubst $val26 
!readproc oef/steps.proc
replytype1=radio
replyname1=
replygood1=$val23;$val22
replytype2=default
replyname2=
replygood2=$val15
replytype3=default
replyname3=
replygood3=$val16
question=__EXECUTED_1692754_EXERCISE__
hint=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<p class="consigne">	
!if $val2=2 
$()Cet exercice est paramétré pour le <b>niveau seconde</b> 
!else
$() Cet exercice est paramétré pour le	<b>niveau premičre</b> : vous devez utiliser la loi binomiale ! 
!endif
$()	</p>	<div class="enonce">	On considčre un échantillon de taille 
!insmath n = $val9
$() issu d'une population pour laquelle	on étudie un caractčre qui apparaît avec une proportion 
!insmath p=$val11
$(). </div>		
!if $m_step=1 
$()<div class="question">	  Peut-on déterminer un intervalle de fluctuation au seuil de 95 % relatif	  aux paramčtres 
!insmath p=$val11
$()	  (proportion du caractčre étudié) et 
!insmath n =$val9
$() ?	  <div class="wimscenter"> 
!read oef/embed.phtml reply 1 
$()</div></div>	  
!endif
$()	 
!if $m_step=2 
$()<div class="enonce">	  A l'aide de la loi binomiale, calculer l'intervalle de fluctuation au seuil de 95 %	  relatif aux paramčtres 
!insmath p =$val11
$()	  et 
!insmath n=$val9
$().</div>	   <div class="question">L'intervalle de fluctuation demandé est	  <div class="wimscenter">[ 
!read oef/embed.phtml  reply 2,5  
$(); 
!read oef/embed.phtml  reply 3,5  
$()] (arrondir au milličme)	  </div></div>		  
!endif
$()			
$()
!exit

:hint
$()	 
!if $val2=2 
$()Si 
!insmath 0,2 \leq p \leq 0,8
$() et 
!insmath n \geq 25
$(), alors l'intervalle de	  fluctuation au seuil	  de 95 % relatif aux paramčtres	  
!insmath p
$() et 
!insmath n
$() est l'intervalle [
!insmath p-1/sqrt(n)
$() ; 
!insmath p+1/sqrt(n)
$()]	   
!else
$()		   On considčre que la situation revient ŕ répéter $val9 fois de suite	  un tirage au sort dans des conditions identiques et indépendantes :	  en cas de succčs (probabilité $val11), la personne	  concernée possčde le caractčre. En cas d'échec, elle ne l'a pas.	  On nomme X la variable aléatoire égale au nombre de succčs obtenus.	  X suit donc une loi binomiale de paramčtres 
!insmath n
$()=$val9 et 
!insmath p
$()=$val11.	  <br>Dans la loi de probabilité de X, on repčre la plus petite	  valeur 
!insmath a
$() pour laquelle 
!insmath P(X <= a) > 0.025
$().	  <br>On repčre également la plus petite valeur 
!insmath b
$() pour laquelle	  
!insmath P(X <= b) <= 0.975
$()...	   
!endif
$()	 
$()
!exit

:help
$()
$()
!exit

:solution
$()	 
!if $val2=2 
$()	 
!if $m_step=1 
$()
!if $val23=2 
$()On ne peut pas déterminer l'intervalle de fluctuation au seuil de 95 %	   car 
!insmath n
$() doit ętre supérieur ŕ 25 et 
!insmath p
$() compris entre 0,2 et 0,8 
!else
$()	    On peut déterminer l'intervalle de fluctuation au seuil de 95 % car 
!insmath n >= 25
$()	   et 
!insmath n \in [0,2 ; 0,8]
$() 
!endif
$()	   
!endif
$()	 
!if $m_step=2 
$()L'intervalle de fluctuation au seuil de 95 % est l'intervalle [
!insmath p-1/sqrt(n)
$();
!insmath p+1/sqrt(n)
$()] 
!endif
$()	  
!else
$()	  
!if $m_step=1 
$()
!if $val23=2 
$()On ne peut pas déterminer l'intervalle de fluctuation au seuil de 95 %	   car 
!insmath n
$() doit ętre supérieur ŕ 25 et 
!insmath np
$() et 
!insmath n(1-p)
$() supérieures ŕ 5 
!else
$()	    On peut déterminer l'intervalle de fluctuation au seuil de 95 % car 
!insmath n >= 25
$()	   et 
!insmath np
$() et 
!insmath n(1-p)
$() sont tous les deux supérieurs ŕ 5 
!endif
$()	   
!endif
$()	 
!if $m_step=2 
$()La plus petite valeur 
!insmath a
$() pour laquelle 
!insmath P(X <= a) > 0.025
$() est 
!insmath a
$()=$(val14[1]).	  La plus petite valeur 
!insmath b
$() pour laquelle 
!insmath P(X <= b) <= 0.975
$() est 
!insmath b
$()=$(val14[2]).	  donc, l'intervalle de confiance au seuil de 95 % est l'intervalle [
!insmath a/n
$();
!insmath b/n
$()]=[$val15;$val16]	   
!endif
$()	  
!endif
$()	 
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=2,9,11,14,15,16,23
embedcnt=3
