\computeanswer{no}
\format{html}
\precision{100000}

\integer{uu=randint(1..2)}
\text{photo= \uu=1 ? activites:loisirs}

\text{secteur=Télévision - hifi - vidéo, Informatique (y compris logiciels),DVD - CD - Disques - cassettes -
 pellicules photo,Presse - livres et papeterie,cinéma - spectacles vivants - musées - abonnements audiovisuels -
