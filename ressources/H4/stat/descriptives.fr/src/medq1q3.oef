  var URLimg='\image';
    var im=brd.create('image',[URLimg,[\rangex[1],\rangey[1]],[\wh[1],\wh[2]]],{fixed: true});
    var l=brd.create('line',[[-1,0],[-1,\rangey[2]]],{strokeColor:'black',fixed: true,visible:false});
    var sl1=brd.create('glider',[l],{strokeColor:'black',name:'',snapSizeY:0.5,snapToGrid:true});
