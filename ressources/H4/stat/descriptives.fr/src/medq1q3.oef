    var sl2=brd.create('glider',[\rangex[2]/10,0,l1],{strokeColor:'black',name:'',snapToGrid:true});
    var l2=brd.create('line',[sl2,[function(){return sl2.X()},0]],{strokeColor:'green'});
}



