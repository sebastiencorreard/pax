:solution
$()<p>Sachant le calcul ŗ produire pour la moyenne, il faut rťsoudre :	
!insmath ($(val11[1])*$(val12[1])+$(val11[2])*$(val12[2])+$(val11[3])*$(val12[3])+x*$(val12[4]))/($(val12[1])+$(val12[2])+$(val12[3])+$(val12[4]))=$val15
$().</p>	<p>
!insmath ($(val11[1])*$(val12[1])+$(val11[2])*$(val12[2])+$(val11[3])*$(val12[3])+x*$(val12[4]))/($(val12[1])+$(val12[2])+$(val12[3])+$(val12[4]))=$val15
$()	<br>&hArr; 
!insmath ($(val11[1])*$(val12[1])+$(val11[2])*$(val12[2])+$(val11[3])*$(val12[3])+x*$(val12[4]))/($val16)=$val15
$()	<br>&hArr; 
!insmath ($val17+$(val12[4])x)/$val16=$val15
$()	<br>&hArr; 
!insmath $val17+$(val12[4])x=$val15*$val16
$()	<br>&hArr; 
!insmath $val17+$(val12[4])x=$val18
$()	<br>&hArr;  
!insmath $(val12[4])x=$val19
$()	<br>&hArr; 
!insmath x=$(val11[4])
$().</p>	
$()
!exit

