!set title=Comparaisons avec indicateurs
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
precision=1000

ansorder=r,r
varcnt=11
prevarcnt=10
postvarcnt=0
replycnt=2
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 300, 950

val6=$[$(tmp0)/100]
tmp0=!randint 300, 950

val7=$[$(tmp0)/100]
tmp0=!randint 300, 950

val8=$[$(tmp0)/100]
tmp0=!randitem -1,1

tmp1=!randint 20, 280

val9=$[$val8+$(tmp0)*$(tmp1)/100]
tmp0=!randint 6, 15

val10=$[rint($(tmp0))]
tmp0=!randitem -1,1

tmp1=!randint 1, 5

val11=$[rint($val10+$(tmp0)*$(tmp1))]
tmp0=!randint 5, 15

val12=$[rint($(tmp0))]
tmp0=!randint 5, 15

val13=$[rint($(tmp0))]

!ifval ($val8<$val9)
val14=$[rint( 1)]
!else
val14=$[rint(2)]
!endif

!ifval ($val10<$val11)
val15=$[rint( 1)]
!else
val15=$[rint(2)]
!endif
replytype1=menu
replyname1=
replygood1=$val14;série 1,série 2, je ne sais pas
replytype2=menu
replyname2=
replygood2=$val15;série 3,série 4, je ne sais pas
question=__EXECUTED_1692754_EXERCISE__
solution=!nosubst  <ul><li>Plus l'écart-type est petit, plus les données sont homogènes, regroupées autour de la moyenne. </li><li>Plus l'écart interquartile est petit, plus les données sont homogènes, regroupées autour de la médiane. </li></ul>


!goto stat

!exit

:question
$()<p><b>Cas n° 1:</b>	La série 1 a une moyenne égale à $val6 et un écart-type égal à $val8.<br>	La série 2 a une moyenne égale à $val7 et un écart-type égal à $val9.</p>	<div class="wims_question">Quelle série est la plus homogène ?  
!read oef/embed.phtml r1 
$()</div>	<p><b>Cas n° 2:</b>	La série 3 a une médiane égale à $val12 et un écart interquartile égal à $val10.<br>La série 4 a une médiane égale à $val13 et un écart interquartile égal à $val11.	</p><div class="wims_question">Quelle série est la plus homogène ?  
!read oef/embed.phtml r2 
$()</div>	
$()
