!set title=Calcul d'écart-type (tableau)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
keywords=standard_deviation
oefcss=<style type="text/css">td.cel{width: 13%;}</style>

ansorder=r
varcnt=21
prevarcnt=20
postvarcnt=0
replycnt=1
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 1, 5

val6=$(tmp0)
tmp0=!randint 2, 8

val7=$(tmp0)
val8=$[rint($(val6[1]))]
val9=$[rint($(val7[1]))]
val10=$[rint($(val6[1])*$(val7[1]))]
!for val11 =2 to 6 
tmp0=!randint 1, 4

val12=$[rint($(val6[$val11-1])+$(tmp0))]
tmp0=!randint 2, 8

val13=$[rint($(tmp0))]
tmp0=!append item $val12 to $val6

val6=$(tmp0)
tmp0=!append item $val13 to $val7

val7=$(tmp0)
!next
val14=$[rint($(val7[1])+$(val7[2])+$(val7[3])+$(val7[4])+$(val7[5])+$(val7[6]))]
tmp0=!randint 1, 6

val15=$[rint($(tmp0))]
val16=$(val7[1]) \times $(val6[1])+$(val7[2]) \times $(val6[2])+$(val7[3]) \times $(val6[3])+$(val7[4]) \times $(val6[4])+$(val7[5]) \times $(val6[5])+$(val7[6]) \times $(val6[6])
val17=$[rint($(val7[1])*$(val6[1])+$(val7[2])*$(val6[2])+$(val7[3])*$(val6[3])+$(val7[4])*$(val6[4])+$(val7[5])*$(val6[5])+$(val7[6])*$(val6[6]))]
t_=!rawmath $val17/$val14
val12=!exec pari print($t_)
!readproc slib/stat/variance $val6;$val7 
tmp0=$slib_out
val18=$(tmp0)
t_=!replace internal \( by ( in sqrt($(val18[1]))
tmp0=!exec maxima $t_

val19=$[$(tmp0)]
t_=!replace internal \( by ( in mod(floor(1000*$val19),10)
tmp0=!exec maxima $t_

val20=$[rint($(tmp0))]
val19=$[floor(100*$val19)/100]

!ifval ($val20<5)
val21=$[ $val19]
!else
val21=$[$val19+0.01]
!endif
replytype1=range
replyname1=
replygood1=!rawmath $val19,$val19+0.01,$val21
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()On considère la série suivante :	<table class="wimscenter wimsborder" style="width: 40%;"><tbody>	<tr><th>Valeurs</th>	<td class="cel">$(val6[1])</td>	<td class="cel">$(val6[2])</td>	<td class="cel">$(val6[3])</td>	<td class="cel">$(val6[4])</td>	<td class="cel">$(val6[5])</td>	<td class="cel">$(val6[6])</td>	</tr>	<tr><th>Effectifs</th>	<td class="cel">$(val7[1])</td>	<td class="cel">$(val7[2])</td>	<td class="cel">$(val7[3])</td>	<td class="cel">$(val7[4])</td>	<td class="cel">$(val7[5])</td>	<td class="cel">$(val7[6])</td>	</tr>	</tbody></table>	<div class="wims_question"><label for "reply1">L'écart-type est égal à</label> :  
!read oef/embed.phtml r1,4 
$()  </div>	<div class=wims_instruction>On donnera une valeur approchée à 0.01 près. Le séparateur décimal est le point.</div>
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()<p> 
!read oef/special.phtml glossary mathematics/statistics/fr/standard_deviation,tooltip=[L'écart-type,300px]  
$() est la racine carré de la  
!read oef/special.phtml glossary mathematics/statistics/fr/variance,tooltip=[variance,300px]  
$().</p>	On a donc 
!insmath \sigma=\sqrt{\frac{\sum\limits_{i=1}^$val14 n_i(x_i-\bar x)^2}{n} }
$(), où :	<ul><li> 
!insmath n
$() est l'effectif total, ici : 
!insmath $val14
$()	</li><li> les 
!insmath x_i
$() sont les valeurs de la série statistique : 
!insmath x_1=$(val6[1])
$(), 
!insmath x_2=$(val6[2])
$() etc 
!insmath x_6=$(val6[6])
$().	</li><li> 
!insmath n_i
$() est l'effectif de 
!insmath x_i
$(), par exemple : 
!insmath n_$val15
$()=$(val7[$val15])	</li><li> 
!insmath \bar x
$() est la moyenne de la série : 
!insmath \frac{$val16}{$val14}=\frac{$val17}{$val14} 
$() .	      </li></ul>
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=6,7,14,15,16,17
embedcnt=3
