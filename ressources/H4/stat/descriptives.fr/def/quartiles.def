!set title=Calcul des quartiles (liste)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
author=Cyrille, Douriez
email=cyrille.douriez@ac-amiens.fr
keywords=quartile
precision=1000

ansorder=r,r,r,r,r
varcnt=18
prevarcnt=17
postvarcnt=0
replycnt=5
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 8, 20

val6=$[rint($(tmp0))]
val7=
!for val8 =1 to $val6 
tmp0=!randint 1, 8

val9=$[rint($(tmp0))]
tmp0=!append item $val9 to $val7

val7=$(tmp0)
!next
tmp0=!sort numeric list $val7

val10=$(tmp0)
val11=$[$val6/4]
!if floor($val11)<$val11 
val12=$[rint(floor($val11)+1)]
!else
val12=$[rint($val11)]
!endif
val13=$[3*$val6/4]
!if floor($val13)<$val13 
val14=$[rint(floor($val13)+1)]
!else
val14=$[rint(floor($val13))]
!endif
val15=$[rint($(val10[$val12]))]
val16=$[rint($(val10[$val14]))]
val17=$[rint($val16-$val15)]
tmp0=!replace internal , by  \(\,;\,) in $val7

val7=$(tmp0)
tmp0=!replace internal , by  \(\,;\,) in $val10

val10=$(tmp0)
replytype1=numeric
replyname1=
replygood1=$[$val12]
replytype2=numeric
replyname2=
replygood2=$[$val15]
replytype3=numeric
replyname3=
replygood3=$[$val14]
replytype4=numeric
replyname4=
replygood4=$[$val16]
replytype5=numeric
replyname5=
replygood5=$[$val17]
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

