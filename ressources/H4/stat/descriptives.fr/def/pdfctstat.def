!set title=Pičces défectueuses (Questions de statistiques)
!if $wims_read_parm!=$empty
 !goto $wims_read_parm
!endif
oef2wims_version=3.22
keywords=absolute_frequency, relative_frequency, percentage
author=Paul,Byache
email=paul@byache.fr
oefobservation=On peut donner les réponses en fractions ou en valeurs décimales. Une solution donne les bonnes réponses sous forme de fractions.
language=fr
computeanswer=yes
precision=200
oefcss=<style type="text/css"> .cadre {border-style:solid;text-align:center; border-width:0px;margin-left:auto; margin-right:auto; border: 1px; } .ctable {text-align:center;padding:4px;} .consigne {color:#000080;margin-bottom:6px;} .bonne {color:#008000;margin-bottom:6px;} .formatrep {font-style:italic;font-size:90%;} table.tableau, table.cadre {margin-left:auto; margin-right:auto; border-collapse: collapse; padding: 6px; margin-top: 10px; margin-bottom: 10px; } table.tableau th, table.cadre th { text-align:center; border: 1px solid #999; padding:6px; background-color:#D6EBEB; } table.tableau td, table.cadre td, table.tableau tr, table.cadre tr{ text-align:center; border: 1px solid #999; padding:6px; } table.tableau tr th:first-child { min-width:100px; } </style>

ansorder=r,r,r
varcnt=16
prevarcnt=15
postvarcnt=0
replycnt=3
choicecnt=0
conditioncnt=0
feedbackcnt=0
format=html

val1=$imagedir
val2=$confparm1
val3=$confparm2
val4=$confparm3
val5=$confparm4

!if $testcondition=yes
 !goto test
!endif
!if $status=waiting
 !exit
!endif

tmp0=!randint 2, 20

val6=$[rint($(tmp0)*1000)]
tmp0=!shuffle A,B,C,E,F,G,H

val7=$(tmp0)
val8=$(val7[1])
val9=$(val7[2])
val10=$(val7[3])
tmp0=!randint 2, 9

val11=$[rint($(tmp0))]
tmp0=!randint 2, 9

val12=$[rint($(tmp0))]
tmp0=!randint 2, 9

val13=$[rint($(tmp0))]
tmp0=!randint 1, 4

val14=$[rint($(tmp0)*10)]
tmp0=!randint 1, 4

val15=$[rint($(tmp0)*10)]
val16=$[rint(100-$val14-$val15)]
tmp=!translate internal $	$ to ; in Quelle est la fréquence des ampoules ayant un défaut parmi les ampoules produites par la machine $val8,f_$val8(D),\eAD/\eA	Quelle est la fréquence des ampoules ayant un défaut parmi les ampoules qui n'ont pas été produites par la machine $val8,f_\overline{$val8}(D),(\eD-\eAD)/($val6-\eA)	Quelle est la fréquence des ampoules ayant un défaut parmi les ampoules produites par la machine $val9,f_$val9(D),\eBD/\eB	Quelle est la fréquence des ampoules ayant un défaut parmi les ampoules qui n'ont pas été produites par la machine $val9,f_\overline{$val9}(D),(\eD-\eBD)/($val6-\eB)

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
tmp=!translate internal $	$ to ; in Quelle est la fréquence des ampoules produites par la machine $val8 parmi celles qui ont un défaut,f_D($val8),\eAD/\eD	Quelle est la fréquence des ampoules ne provenant pas de la machine $val8 parmi celles qui ont un défaut,f_D(\overline{$val8}),(\eD-\eAD)/\eD	Quelle est la fréquence des ampoules produites par la machine $val10 parmi celles qui ont un défaut,f_D($val10),\eCD/\eD	Quelle est la fréquence des ampoules ne provenant pas de la machine $val10 parmi celles qui ont un défaut,f_D(\overline{$val10}),(\eD-\eCD)/\eD

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp1=!translate internal $\
$ to ; in $tmp
tmp=!translate internal $	$ to ; in Quelle est la fréquence des ampoules ayant un défaut,f(D),\eD/$val6	Quelle est la fréquence des ampoules n'ayant pas de défaut,f(\overline{D}),\esD/$val6	Quelle est la fréquence des ampoules provenant de la machine $val8,f($val8),\eA/$val6	Quelle est la fréquence des ampoules ne provenant pas de la machine $val9,f(\overline{$val9}),($val6-\eB)/$val6	Quelle est la fréquence des ampoules ne provenant pas de la machine $val10,f(\overline{$val10}),($val6-\eC)/$val6

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp2=!translate internal $\
$ to ; in $tmp
tmp=!translate internal $	$ to ; in Quelle est la fréquence des ampoules n'ayant pas de défaut parmi les ampoules produites par la machine $val10,f_$val10(\overline{D}),\eCsD/\eC	Quelle est la fréquence des ampoules produites par la machine $val10 parmi celles qui n'ont pas de défaut,f_\overline{D}($val10),\eCsD/\esD	Quelle est la fréquence des ampoules n'ayant pas de défaut parmi les ampoules produites par la machine $val9,f_$val9(\overline{D}),\eBsD/\eB	Quelle est la fréquence des ampoules produites par la machine $val9 parmi celles qui n'ont pas de défaut,f_\overline{D}($val9),\eBsD/\esD

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp3=!translate internal $\
$ to ; in $tmp
tmp=!trim $(tmp0)	$(tmp1)	$(tmp2)	$(tmp3)
val17=!translate internal $	\
$ to ;; in $tmp
tmp0=!shuffle 1,2,4

tmp1=!shuffle 3,$(tmp0)

val18=$(tmp1)
tmp=!trim $(val17[$(val18[1]);])	$(val17[$(val18[2]);])	$(val17[$(val18[3]);])	$(val17[$(val18[4]);])
val19=!translate internal $	\
$ to ;; in $tmp
tmp=!translate internal $	$ to ; in La machine $val8 produit $val14 % de la production, la machine $val9 produit $val15 % de la production et la machine $val10 fournit le reste.	La machine $val9 produit $val15 % de la production, la machine $val10 produit $val16 % de la production et la machine $val8 fournit le reste.	La machine $val8 produit $val14 % de la production, la machine $val10 produit $val16 % de la production et la machine $val9 fournit le reste.

tmp=!nonempty rows $tmp
tmp=!randrow $tmp
tmp0=!translate internal $\
$ to ; in $tmp
val20=$(tmp0)
replytype1=numeric
replyname1=question 1
replygood1=$[$(val19[1;3])]
replytype2=numeric
replyname2=question 2
replygood2=$[$(val19[2;3])]
replytype3=numeric
replyname3=question 3
replygood3=$[$(val19[3;3])]
question=__EXECUTED_1692754_EXERCISE__
solution=__EXECUTED_1692754_EXERCISE__

!goto stat

!exit

:question
$()	<p>$(val19[1;1]) ?  
!read oef/embed.phtml r1,10 
$()</p>	<p>$(val19[2;1]) ?  
!read oef/embed.phtml r2,10 
$()</p>	<p>$(val19[3;1]) ?  
!read oef/embed.phtml r3,10 
$()</p>	<div class="wims_instruction">Donnez vos réponses sous forme décimale ou sous forme de fraction. Par exemple, si une réponse est 20%,	vous pouvez répondre 0.2 ou 20/100 ou encore 1/5.</div>	
$()
!exit

:hint
$()
$()
!exit

:help
$()
$()
!exit

:solution
$()Voici les bonnes réponses, données sous forme de fractions :	<p>$(val19[1;1]) ? <span class="oef_indgood">Réponse : 
!insmath \f1
$()</span></p>	<p>$(val19[2;1]) ? <span class="oef_indgood">Réponse : 
!insmath \f2
$()</span></p>	<p>$(val19[3;1]) ? <span class="oef_indgood">Réponse : 
!insmath \f3
$()</span></p>
$()
!exit

:latex
$()
$()
!exit

:feedback

!exit

:test

!exit

:stat
vsavelist=19
embedcnt=3
