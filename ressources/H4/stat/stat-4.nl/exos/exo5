        factor2=$[(factorial(52 - 13))/((factorial($num - $p))*(factorial((52 - 13) - $num + $p)))]
	factor3=$[(factorial(52))/((factorial($num))*(factorial(52 - $num)))]
	kans=$[$factor1*$factor2/$factor3]
	kansen=!append item $kans to $kansen
	gem=$[$gem+$p*$kans]
	freq=$[round($kans*$number_of_games)]
	frequenties=!append item $freq to $frequenties
	head1=!append word <th>$p</th> to $head1
	head2=!append word <th>$freq</th> to $head2
    !next p
    sigma=0
    !for p=0 to $num
    	k=!item $[$p+1] of $kansen
	sigma=$[$sigma+$k*($p - $gem)^2]
    !next p
    sigma=$[sqrt($sigma)]
    
    tabel=!subst <table class=\'grid_table\'><tr>$head1</tr><tr>$head2</tr></table>
    
