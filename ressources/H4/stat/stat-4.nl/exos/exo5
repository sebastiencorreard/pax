    d=$[$zoveel+1]
    frequentie=$(frequenties[$d])
    
    P=$[$frequentie/$number_of_games]
    f=$[factorial($number)/((factorial($keer))*(factorial($number - $keer)))]
    answer2=$[$f*($P^($keer))*((1-$P)^($number - $keer))]
    ans2=$[(round($rounding*$answer2))/$rounding]
    
