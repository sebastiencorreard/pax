# Production .env template. Copy to .env and fill all values.
# This file is consumed by docker-compose.prod.yml (variable substitution).

POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme
POSTGRES_DB=changeme

# REQUIRED. Generate with: openssl rand -hex 32
# Must be ≥32 chars and not start with a known placeholder
# (changeme/dev-only/secret/test/your-). The backend refuses to start
# otherwise.
SECRET_KEY=changeme

CORS_ORIGINS=["https://your-frontend-domain.com"]
NUXT_PUBLIC_API_BASE=https://host.changeme
NUXT_PUBLIC_DEBUG_OEF=false
