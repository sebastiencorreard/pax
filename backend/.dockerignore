# Local virtualenv — image installs deps fresh from requirements.txt.
.venv/
venv/
env/

# Python bytecode and caches
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# Test caches, coverage, snapshots — none of this is needed at runtime.
tests/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Secrets / local config
.env
.env.*
!.env.example

# Logs
*.log
logs/

# OS / editor noise
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# Build artifacts
build/
dist/
*.egg-info/
.tox/

# Git metadata (in case the build context ever includes the repo root)
.git/
.gitignore
