# Copier ce fichier en .env et remplir les valeurs

# Base de données
DATABASE_URL=postgresql+asyncpg://pax:pax@localhost:5432/pax

# Redis
REDIS_URL=redis://localhost:6379/0

# Sécurité
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Keycloak (optionnel au départ)
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=pax
KEYCLOAK_CLIENT_ID=pax-backend

# WIMS (pour le wrapper oef2wims phase 1)
WIMS_HOME=/var/lib/wims
OEF2WIMS_BIN=/var/lib/wims-svn/wims/bin/oef2wims

# CAS
MAXIMA_BIN=/usr/bin/maxima
CAS_TIMEOUT_SECONDS=3
