# Re-installed in the image
node_modules/

# Generated by Nuxt — built fresh in the `builder` stage
.nuxt/
.output/

# Tests + reports — not needed in any image stage
e2e/
playwright-report/
playwright.config.ts
test-results/

# Local secrets / config
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS / editor noise
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# Git metadata (in case the build context ever includes the repo root)
.git/
.gitignore
